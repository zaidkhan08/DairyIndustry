@model DairyIndustry.Models.Finance.StaffPaymentModel
@{
    ViewData["Title"] = $"Staff Payment SP-{Model.PaymentId:D4}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string role = ViewBag.Role as string ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --blue: #2563eb;
        --blue-bg: #eff6ff;
        --green: #059669;
        --green-bg: #ecfdf5;
        --amber: #d97706;
        --amber-bg: #fffbeb;
        --red: #e11d48;
        --red-bg: #fff1f2;
        --slate: #64748b;
        --slate-bg: #f8fafc;
        --ink: #0f172a;
        --muted: #64748b;
        --border: rgba(226,232,240,.8);
        --shadow: 0 10px 40px rgba(15,23,42,.07);
        --radius: 24px;
        --pill: 999px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: radial-gradient(circle at top left,rgba(37,99,235,.07),transparent 30%), linear-gradient(to bottom,#f8f9ff,#f5f7fc);
    }

    .spd-root {
        font-family: 'Figtree',sans-serif;
        color: var(--ink);
        padding: 32px;
        max-width: 820px;
        margin: 0 auto;
    }

    /* header strip */
    .spd-header {
        background: rgba(255,255,255,.75);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,.7);
        border-radius: 28px;
        padding: 24px 32px;
        margin-bottom: 20px;
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .spd-header-id {
        font-size: 22px;
        font-weight: 800;
        color: var(--ink);
    }

    .spd-header-sub {
        font-size: 13px;
        color: var(--muted);
        margin-top: 3px;
    }

    .spd-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 8px 16px;
        background: #fff;
        transition: all .15s;
    }

        .spd-back:hover {
            color: var(--blue);
            border-color: var(--blue);
        }

    /* status banner */
    .spd-status {
        border-radius: 18px;
        padding: 16px 24px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 15px;
        font-weight: 700;
    }

        .spd-status.Processed {
            background: var(--green-bg);
            color: var(--green);
            border: 1px solid rgba(5,150,105,.2);
        }

        .spd-status.Pending {
            background: var(--amber-bg);
            color: var(--amber);
            border: 1px solid rgba(217,119,6,.2);
        }

        .spd-status.Failed {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(225,29,72,.2);
        }

        .spd-status.Cancelled {
            background: var(--slate-bg);
            color: var(--slate);
            border: 1px solid rgba(100,116,139,.2);
        }

    .spd-status-icon {
        font-size: 22px;
    }

    /* grid of cards */
    .spd-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
    }

        .spd-grid.full {
            grid-template-columns: 1fr;
        }

    .spd-card {
        background: rgba(255,255,255,.88);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        box-shadow: var(--shadow);
    }

    .spd-card-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: var(--muted);
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .spd-kv {
        margin-bottom: 12px;
    }

        .spd-kv:last-child {
            margin-bottom: 0;
        }

    .spd-kv-label {
        font-size: 11px;
        color: var(--muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 3px;
    }

    .spd-kv-val {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
    }

        .spd-kv-val.mono {
            font-family: 'DM Mono',monospace;
        }

        .spd-kv-val.big {
            font-size: 28px;
            font-weight: 800;
            color: var(--green);
        }

    /* pill */
    .spd-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: var(--pill);
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

        .spd-pill::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

    .sp-pill-processed {
        background: var(--green-bg);
        color: var(--green);
        border: 1px solid rgba(5,150,105,.2);
    }

        .sp-pill-processed::before {
            background: var(--green);
        }

    .sp-pill-pending {
        background: var(--amber-bg);
        color: var(--amber);
        border: 1px solid rgba(217,119,6,.2);
    }

        .sp-pill-pending::before {
            background: var(--amber);
        }

    .sp-pill-failed {
        background: var(--red-bg);
        color: var(--red);
        border: 1px solid rgba(225,29,72,.2);
    }

        .sp-pill-failed::before {
            background: var(--red);
        }

    .sp-pill-cancelled {
        background: var(--slate-bg);
        color: var(--slate);
        border: 1px solid rgba(100,116,139,.2);
    }

        .sp-pill-cancelled::before {
            background: var(--slate);
        }

    /* action buttons */
    .spd-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .spd-btn {
        flex: 1;
        min-width: 160px;
        border: none;
        border-radius: 14px;
        padding: 14px 22px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        transition: transform .15s, box-shadow .15s;
    }

        .spd-btn.pay {
            background: linear-gradient(135deg,#2563eb,#7c3aed);
            color: #fff;
            box-shadow: 0 4px 20px rgba(37,99,235,.35);
        }

            .spd-btn.pay:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px rgba(37,99,235,.45);
            }

        .spd-btn.cancel {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(225,29,72,.2);
        }

            .spd-btn.cancel:hover {
                background: var(--red);
                color: #fff;
            }

        .spd-btn.back-list {
            background: #f1f5f9;
            color: var(--muted);
            border: 1px solid var(--border);
        }

            .spd-btn.back-list:hover {
                background: var(--blue-bg);
                color: var(--blue);
                border-color: var(--blue);
            }

    /* avatar */
    .spd-avatar {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 800;
        flex-shrink: 0;
    }

    /* toast */
    .spd-toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 16px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 8px 32px rgba(0,0,0,.14);
        animation: slideUp .3s ease;
        max-width: 380px;
    }

        .spd-toast.success {
            background: var(--green-bg);
            color: var(--green);
            border: 1px solid rgba(5,150,105,.2);
        }

        .spd-toast.error {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(225,29,72,.2);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    @@media(max-width:640px) {
        .spd-root {
            padding: 16px;
        }

        .spd-grid {
            grid-template-columns: 1fr;
        }

        .spd-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<!-- TOAST -->
@if (TempData["Success"] != null)
{
    <div class="spd-toast success" id="toast"><i class="bi bi-check-circle-fill"></i>@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="spd-toast error" id="toast"><i class="bi bi-exclamation-circle-fill"></i>@TempData["Error"]</div>
}

<div class="spd-root">

    <!-- HEADER -->
    <div class="spd-header">
        <div>
            <div class="spd-header-id">
                <i class="bi bi-receipt" style="color:var(--blue);margin-right:8px;"></i>
                Staff Payment SP-@Model.PaymentId.ToString("D4")
            </div>
            <div class="spd-header-sub">@Model.StaffName — @Model.CenterName — @Model.PlantName</div>
        </div>
        <a href="@Url.Action("StaffPayments", "Finance")" class="spd-back">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- STATUS BANNER -->
    <div class="spd-status @Model.PaymentStatus">
        @{
            string statusIcon = Model.PaymentStatus switch
            {
                "Processed" => "bi-check-circle-fill",
                "Pending" => "bi-clock-fill",
                "Failed" => "bi-x-circle-fill",
                _ => "bi-slash-circle"
            };
            string statusMsg = Model.PaymentStatus switch
            {
                "Processed" => "Payment successfully processed via Stripe.",
                "Pending" => "Payment is pending. Use the Pay via Stripe button below to complete.",
                "Failed" => "Payment failed. You can retry using the Pay via Stripe button.",
                _ => "This payment has been cancelled."
            };
        }
        <i class="bi @statusIcon spd-status-icon"></i>
        <div>
            <strong>@Model.PaymentStatus</strong> — @statusMsg
        </div>
    </div>

    <!-- MAIN GRID -->
    <div class="spd-grid">

        <!-- Staff Details -->
        <div class="spd-card">
            <div class="spd-card-title"><i class="bi bi-person-fill"></i> Staff Details</div>
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
                <div class="spd-avatar">
                    @string.Concat(Model.StaffName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0]))
                </div>
                <div>
                    <div style="font-size:17px;font-weight:800;">@Model.StaffName</div>
                    <div style="font-size:13px;color:var(--muted);margin-top:2px;">@Model.RoleName</div>
                </div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Center</div>
                <div class="spd-kv-val">@Model.CenterName</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Plant</div>
                <div class="spd-kv-val">@Model.PlantName</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Monthly Salary</div>
                <div class="spd-kv-val">@(Model.MonthlySalary.HasValue ? "₹" + Model.MonthlySalary.Value.ToString("N2") : "Not set")</div>
            </div>
        </div>

        <!-- Payment Details -->
        <div class="spd-card">
            <div class="spd-card-title"><i class="bi bi-wallet2"></i> Payment Details</div>
            <div class="spd-kv">
                <div class="spd-kv-label">Payment Period</div>
                <div class="spd-kv-val">@Model.FromDate.ToString("dd MMM yyyy") – @Model.ToDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Payment Date</div>
                <div class="spd-kv-val">@Model.PaymentDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Status</div>
                <div class="spd-kv-val">
                    <span class="spd-pill @Model.StatusBadgeClass">@Model.PaymentStatus</span>
                </div>
            </div>
            <div class="spd-kv" style="margin-top:14px;">
                <div class="spd-kv-label">Total Amount</div>
                <div class="spd-kv-val big">₹@Model.TotalAmount.ToString("N2")</div>
            </div>
        </div>

    </div>

    <!-- Bank & Transaction -->
    <div class="spd-grid">
        <div class="spd-card">
            <div class="spd-card-title"><i class="bi bi-bank2"></i> Bank Account</div>
            <div class="spd-kv">
                <div class="spd-kv-label">Bank Name</div>
                <div class="spd-kv-val">@(Model.BankName ?? "Not linked")</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Account No.</div>
                <div class="spd-kv-val mono">@(Model.AccountNumber ?? "—")</div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">IFSC Code</div>
                <div class="spd-kv-val mono">@(Model.IFSCCode ?? "—")</div>
            </div>
        </div>

        <div class="spd-card">
            <div class="spd-card-title"><i class="bi bi-arrow-left-right"></i> Transaction Details</div>
            <div class="spd-kv">
                <div class="spd-kv-label">Bank Status</div>
                <div class="spd-kv-val">
                    @if (Model.BankStatus != null)
                    {
                        <span style="color:@(Model.BankStatus == "Success" ? "var(--green)" : "var(--red)");font-weight:700;">
                            @Model.BankStatus
                        </span>
                    }
                    else
                    {

                        <span style="color:var(--muted);">Not yet processed</span>
                    }
                </div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Transaction Ref</div>
                <div class="spd-kv-val mono" style="font-size:11px;word-break:break-all;">
                    @(Model.TransactionReference ?? "—")
                </div>
            </div>
            <div class="spd-kv">
                <div class="spd-kv-label">Payment Method</div>
                <div class="spd-kv-val">Stripe</div>
            </div>
        </div>
    </div>

    <!-- ACTIONS -->
    @if (Model.PaymentStatus == "Pending" || Model.PaymentStatus == "Failed")
    {
        <div class="spd-card" style="margin-bottom:0;">
            <div class="spd-card-title"><i class="bi bi-lightning-fill"></i> Actions</div>
            <div class="spd-actions">
                <!-- Pay via Stripe -->
                <form method="post" action="@Url.Action("CreateStaffCheckoutSession","Finance")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="staffPaymentId" value="@Model.PaymentId" />
                    <input type="hidden" name="totalAmount" value="@Model.TotalAmount" />
                    <input type="hidden" name="staffName" value="@Model.StaffName" />
                    <button type="submit" class="spd-btn pay">
                        <i class="bi bi-credit-card-fill"></i>
                        Pay ₹@Model.TotalAmount.ToString("N2") via Stripe
                    </button>
                </form>

                <!-- Cancel -->
                <form method="post" action="@Url.Action("CancelStaffPayment","Finance")"
                      onsubmit="return confirm('Cancel this payment?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="paymentId" value="@Model.PaymentId" />
                    <button type="submit" class="spd-btn cancel">
                        <i class="bi bi-x-circle"></i> Cancel Payment
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="spd-actions">
            <a href="@Url.Action("StaffPayments", "Finance")" class="spd-btn back-list">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    }

</div>

<script>
    setTimeout(() => { const t = document.getElementById('toast'); if (t) t.style.display = 'none'; }, 5000);
</script>
