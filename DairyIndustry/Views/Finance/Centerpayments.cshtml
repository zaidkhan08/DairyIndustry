@model List<DairyIndustry.Models.Finance.CenterPaymentModel>
@{
    ViewData["Title"] = "Center Payments";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<style>

    .cp-root {
        font-family: 'DM Sans', sans-serif;
        --ink: #0f172a;
        --ink-muted: #64748b;
        --ink-faint: #94a3b8;
        --surface: #fff;
        --surface-2: #f8fafc;
        --surface-3: #f1f5f9;
        --border: #e2e8f0;
        --border-strong: #cbd5e1;
        --accent: #2563eb;
        --accent-light: #eff6ff;
        --accent-mid: #bfdbfe;
        --success: #16a34a;
        --success-light: #f0fdf4;
        --success-mid: #bbf7d0;
        --warning: #d97706;
        --warning-light: #fffbeb;
        --warning-mid: #fde68a;
        --danger: #dc2626;
        --danger-light: #fef2f2;
        --danger-mid: #fecaca;
        --cancelled: #64748b;
        --cancelled-light: #f1f5f9;
        --cancelled-mid: #cbd5e1;
        --r-sm: 6px;
        --r-md: 10px;
        --r-lg: 14px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
        --shadow-md: 0 4px 12px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
    }

    .cp-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .cp-page-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -.4px;
        margin: 0 0 2px;
    }

    .cp-page-sub {
        font-size: 13px;
        color: var(--ink-muted);
        margin: 0;
    }

    .cp-stats {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .cp-stat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 16px 18px;
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
    }

        .cp-stat::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--r-md) var(--r-md) 0 0;
        }

        .cp-stat.total::before {
            background: var(--accent);
        }

        .cp-stat.processed::before {
            background: var(--success);
        }

        .cp-stat.pending::before {
            background: var(--warning);
        }

        .cp-stat.cancelled::before {
            background: var(--cancelled);
        }

        .cp-stat.amount::before {
            background: #7c3aed;
        }

    .cp-stat-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: var(--ink-muted);
        margin-bottom: 6px;
    }

    .cp-stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -.5px;
        font-family: 'JetBrains Mono',monospace;
        line-height: 1;
    }

    .cp-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .cp-card-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        gap: 12px;
        flex-wrap: wrap;
    }

    .cp-toolbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cp-toolbar-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
    }

    .cp-count-badge {
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 600;
        color: var(--ink-muted);
        font-family: 'JetBrains Mono',monospace;
    }

    .cp-search {
        position: relative;
        width: 240px;
    }

        .cp-search input {
            width: 100%;
            height: 36px;
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            background: var(--surface-2);
            padding: 0 12px 0 34px;
            font-size: 13px;
            color: var(--ink);
            font-family: 'DM Sans',sans-serif;
            outline: none;
            transition: border-color .15s,box-shadow .15s;
        }

            .cp-search input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
                background: var(--surface);
            }

    .cp-search-icon {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--ink-faint);
        font-size: 14px;
        pointer-events: none;
    }

    .cp-btn-new {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 36px;
        padding: 0 16px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--r-sm);
        font-size: 13px;
        font-weight: 600;
        font-family: 'DM Sans',sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: background .15s,transform .1s,box-shadow .15s;
        box-shadow: 0 1px 4px rgba(37,99,235,.3);
        white-space: nowrap;
    }

        .cp-btn-new:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37,99,235,.35);
            color: #fff;
        }

    .cp-table-wrap {
        overflow-x: auto;
    }

    .cp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .cp-table thead tr {
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        .cp-table th {
            padding: 11px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .55px;
            color: var(--ink-muted);
            white-space: nowrap;
            user-select: none;
        }

            .cp-table th.r, .cp-table td.r {
                text-align: right;
            }

            .cp-table th.c, .cp-table td.c {
                text-align: center;
            }

        .cp-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .cp-table tbody tr:last-child {
                border-bottom: none;
            }

            .cp-table tbody tr:hover {
                background: var(--surface-2);
            }

            .cp-table tbody tr.row-cancelled {
                opacity: .5;
            }

        .cp-table td {
            padding: 13px 14px;
            color: var(--ink);
            vertical-align: middle;
            white-space: nowrap;
        }

    .cp-id {
        font-family: 'JetBrains Mono',monospace;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-muted);
    }

    .cp-transfer-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 3px 9px;
        font-size: 12px;
        font-family: 'JetBrains Mono',monospace;
        font-weight: 500;
        color: var(--ink);
    }

    .cp-center {
        font-weight: 600;
        color: var(--ink);
    }

    .cp-plant {
        font-size: 12px;
        color: var(--ink-muted);
    }

    .cp-num {
        font-family: 'JetBrains Mono',monospace;
        font-size: 12.5px;
        font-weight: 500;
    }

    .cp-amount {
        font-family: 'JetBrains Mono',monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--accent);
    }

    .cp-date {
        font-size: 12.5px;
        color: var(--ink-muted);
        font-family: 'JetBrains Mono',monospace;
    }

    .cp-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
        letter-spacing: .2px;
        white-space: nowrap;
    }

    .cp-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    .cp-pill-processed {
        background: var(--success-light);
        color: var(--success);
        border: 1px solid var(--success-mid);
    }

    .cp-pill-pending {
        background: var(--warning-light);
        color: var(--warning);
        border: 1px solid var(--warning-mid);
    }

    .cp-pill-failed {
        background: var(--danger-light);
        color: var(--danger);
        border: 1px solid var(--danger-mid);
    }

    .cp-pill-cancelled {
        background: var(--cancelled-light);
        color: var(--cancelled);
        border: 1px solid var(--cancelled-mid);
    }

    .cp-pill-secondary {
        background: var(--surface-3);
        color: var(--ink-muted);
        border: 1px solid var(--border);
    }

    .cp-bank-ok {
        color: var(--success);
        font-weight: 600;
        font-size: 12.5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .cp-bank-bad {
        color: var(--danger);
        font-weight: 600;
        font-size: 12.5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .cp-bank-nil {
        color: var(--ink-faint);
        font-size: 13px;
    }

    /* Action buttons */
    .cp-actions {
        display: flex;
        align-items: center;
        gap: 6px;
        justify-content: center;
    }

    .cp-btn-view {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border: 1px solid var(--border);
        border-radius: var(--r-sm);
        background: var(--surface);
        color: var(--ink-muted);
        font-size: 14px;
        text-decoration: none;
        transition: all .15s;
    }

        .cp-btn-view:hover {
            background: var(--accent-light);
            border-color: var(--accent-mid);
            color: var(--accent);
            transform: scale(1.08);
        }

    .cp-btn-cancel {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border: 1px solid var(--danger-mid);
        border-radius: var(--r-sm);
        background: var(--danger-light);
        color: var(--danger);
        font-size: 13px;
        cursor: pointer;
        transition: all .15s;
        outline: none;
    }

        .cp-btn-cancel:hover {
            background: var(--danger);
            color: #fff;
            border-color: var(--danger);
            transform: scale(1.08);
        }

    /* Confirm overlay */
    .cp-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.5);
        backdrop-filter: blur(4px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

        .cp-overlay.open {
            display: flex;
        }

    .cp-confirm-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        box-shadow: 0 24px 64px rgba(0,0,0,.18);
        padding: 28px;
        max-width: 380px;
        width: 90%;
        animation: cp-pop .18s ease;
    }

    @@keyframes cp-pop {
        from {
            opacity: 0;
            transform: scale(.93)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    .cp-confirm-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--danger-light);
        color: var(--danger);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 14px;
    }

    .cp-confirm-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 6px;
    }

    .cp-confirm-msg {
        font-size: 13px;
        color: var(--ink-muted);
        line-height: 1.55;
        margin-bottom: 22px;
    }

    .cp-confirm-btns {
        display: flex;
        gap: 10px;
    }

    .cp-btn-no {
        flex: 1;
        height: 38px;
        background: var(--surface);
        color: var(--ink-muted);
        border: 1px solid var(--border);
        border-radius: var(--r-sm);
        font-size: 13px;
        font-weight: 600;
        font-family: 'DM Sans',sans-serif;
        cursor: pointer;
        transition: border-color .15s, color .15s;
    }

        .cp-btn-no:hover {
            border-color: var(--border-strong);
            color: var(--ink);
        }

    .cp-btn-yes {
        flex: 1;
        height: 38px;
        background: var(--danger);
        color: #fff;
        border: none;
        border-radius: var(--r-sm);
        font-size: 13px;
        font-weight: 600;
        font-family: 'DM Sans',sans-serif;
        cursor: pointer;
        width: 100%;
        transition: background .15s;
    }

        .cp-btn-yes:hover {
            background: #b91c1c;
        }

    .cp-filter-pills {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .cp-filter-pill {
        height: 30px;
        padding: 0 12px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        font-size: 12px;
        font-weight: 600;
        color: var(--ink-muted);
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all .15s;
        white-space: nowrap;
    }

        .cp-filter-pill:hover,
        .cp-filter-pill.active {
            border-color: var(--accent);
            background: var(--accent-light);
            color: var(--accent);
        }

        .cp-filter-pill.active-processed {
            border-color: var(--success);
            background: var(--success-light);
            color: var(--success);
        }

        .cp-filter-pill.active-pending {
            border-color: var(--warning);
            background: var(--warning-light);
            color: var(--warning);
        }

        .cp-filter-pill.active-cancelled {
            border-color: var(--cancelled);
            background: var(--cancelled-light);
            color: var(--cancelled);
        }

        .cp-filter-pill.active-failed {
            border-color: var(--danger);
            background: var(--danger-light);
            color: var(--danger);
        }

    .cp-repay-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        height: 30px;
        padding: 0 10px;
        border-radius: var(--r-sm);
        border: 1px solid var(--accent-mid);
        background: var(--accent-light);
        color: var(--accent);
        font-size: 12px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        cursor: pointer;
        transition: all .15s;
        white-space: nowrap;
    }

        .cp-repay-btn:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }



    .cp-empty-icon {
        width: 52px;
        height: 52px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: var(--ink-faint);
        margin-bottom: 14px;
    }

    .cp-empty-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 6px;
    }

    .cp-empty-sub {
        font-size: 13px;
        color: var(--ink-muted);
    }

    .cp-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 13px 16px;
        border-radius: var(--r-md);
        font-size: 13.5px;
        font-weight: 500;
        margin-bottom: 18px;
        border: 1px solid;
        position: relative;
    }

    .cp-alert-success {
        background: var(--success-light);
        border-color: var(--success-mid);
        color: var(--success);
    }

    .cp-alert-danger {
        background: var(--danger-light);
        border-color: var(--danger-mid);
        color: var(--danger);
    }

    .cp-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        font-size: 16px;
        padding: 0;
        line-height: 1;
    }

        .cp-alert-close:hover {
            opacity: 1;
        }

    @@media(max-width:1100px) {
        .cp-stats {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:900px) {
        .cp-stats {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:600px) {
        .cp-stats {
            grid-template-columns: 1fr 1fr;
        }

        .cp-page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .cp-search {
            width: 100%;
        }
    }
</style>

<div class="cp-root">

    @if (TempData["Success"] != null)
    {
        <div class="cp-alert cp-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="cp-alert-close" onclick="this.closest('.cp-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="cp-alert cp-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="cp-alert-close" onclick="this.closest('.cp-alert').remove()">&times;</button>
        </div>
    }

    <div class="cp-page-header">
        <div>
            <h1 class="cp-page-title">Center Payments</h1>
            <p class="cp-page-sub">Milk transfer payments to collection centers</p>
        </div>
        <a asp-action="CreateCenterPayment" class="cp-btn-new">
            <i class="bi bi-plus-lg"></i> New Payment
        </a>
    </div>

    @{
        int total = Model.Count;
        int processed = Model.Count(p => p.PaymentStatus == "Processed");
        int pending = Model.Count(p => p.PaymentStatus == "Pending");
        int cancelled = Model.Count(p => p.PaymentStatus == "Cancelled");
        decimal totalAmt = Model.Where(p => p.PaymentStatus != "Cancelled").Sum(p => p.TotalAmount);
    }
    <div class="cp-stats">
        <div class="cp-stat total">
            <div class="cp-stat-label">Total Records</div>
            <div class="cp-stat-value">@total</div>
        </div>
        <div class="cp-stat processed">
            <div class="cp-stat-label">Processed</div>
            <div class="cp-stat-value">@processed</div>
        </div>
        <div class="cp-stat pending">
            <div class="cp-stat-label">Pending</div>
            <div class="cp-stat-value">@pending</div>
        </div>
        <div class="cp-stat cancelled">
            <div class="cp-stat-label">Cancelled</div>
            <div class="cp-stat-value">@cancelled</div>
        </div>
        <div class="cp-stat amount">
            <div class="cp-stat-label">Total Paid (₹)</div>
            <div class="cp-stat-value" style="font-size:17px;">@totalAmt.ToString("N0")</div>
        </div>
    </div>

    <div class="cp-card">
        <div class="cp-card-toolbar">
            <div class="cp-toolbar-left">
                <span class="cp-toolbar-title">All Payments</span>
                <span class="cp-count-badge" id="visibleCount">@Model.Count</span>
            </div>
            <div class="cp-filter-pills">
                <button class="cp-filter-pill active" onclick="filterStatus('all', this)">All</button>
                <button class="cp-filter-pill" onclick="filterStatus('Processed', this)">Processed</button>
                <button class="cp-filter-pill" onclick="filterStatus('Pending', this)">Pending</button>
                <button class="cp-filter-pill" onclick="filterStatus('Failed', this)">Failed</button>
                <button class="cp-filter-pill" onclick="filterStatus('Cancelled', this)">Cancelled</button>
            </div>
            <div class="cp-search">
                <i class="bi bi-search cp-search-icon"></i>
                <input type="text" id="cpSearch" placeholder="Search payments…" oninput="filterTable()">
            </div>
        </div>

        <div class="cp-table-wrap">
            <table class="cp-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Transfer</th>
                        <th>Center</th>
                        <th>Plant</th>
                        <th class="r">Qty (L)</th>
                        <th class="r">Rate/L (₹)</th>
                        <th class="r">Fat %</th>
                        <th class="r">CLR</th>
                        <th class="r">Total (₹)</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Bank</th>
                        <th class="c">Actions</th>
                    </tr>
                </thead>
                <tbody id="cpTbody">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="13">
                                <div class="cp-empty">
                                    <div class="cp-empty-icon"><i class="bi bi-receipt"></i></div>
                                    <div class="cp-empty-title">No payments yet</div>
                                    <div class="cp-empty-sub">Create your first center payment to get started.</div>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model)
                        {
                            string pillClass = p.PaymentStatus switch
                            {
                                "Processed" => "cp-pill-processed",
                                "Pending" => "cp-pill-pending",
                                "Failed" => "cp-pill-failed",
                                "Cancelled" => "cp-pill-cancelled",
                                _ => "cp-pill-secondary"
                            };
                            bool canCancel = p.PaymentStatus == "Pending" || p.PaymentStatus == "Failed";
                            bool canRepay = p.PaymentStatus == "Cancelled";
                            <tr class="@(p.PaymentStatus == "Cancelled" ? "row-cancelled" : "")" data-status="@p.PaymentStatus">
                                <td><span class="cp-id">CP-@p.CenterPaymentId.ToString("D4")</span></td>
                                <td><span class="cp-transfer-badge">@p.BatchRef</span></td>
                                <td><span class="cp-center">@p.CenterName</span></td>
                                <td><span class="cp-plant">@p.PlantName</span></td>
                                <td class="r"><span class="cp-num">@p.ReceivedQty.ToString("N2")</span></td>
                                <td class="r"><span class="cp-num">@p.RatePerLiter.ToString("N2")</span></td>
                                <td class="r"><span class="cp-num">@(p.TestedFat.HasValue? p.TestedFat.Value.ToString("N2") : "—")</span></td>
                                <td class="r"><span class="cp-num">@(p.TestedCLR.HasValue? p.TestedCLR.Value.ToString("N2") : "—")</span></td>
                                <td class="r"><span class="cp-amount">₹@p.TotalAmount.ToString("N2")</span></td>
                                <td><span class="cp-date">@p.PaymentDate.ToString("dd MMM yyyy")</span></td>
                                <td>
                                    <span class="cp-pill @pillClass">
                                        <span class="cp-pill-dot"></span>
                                        @p.PaymentStatus
                                    </span>
                                </td>
                                <td>
                                    @if (p.BankStatus == "Success")
                                    {
                                        <span class="cp-bank-ok"><i class="bi bi-check-circle-fill"></i> Success</span>
                                    }
                                    else if (p.BankStatus != null)
                                    {
                                        <span class="cp-bank-bad"><i class="bi bi-x-circle-fill"></i> @p.BankStatus</span>
                                    }
                                    else
                                    {
                                        <span class="cp-bank-nil">—</span>
                                    }
                                </td>
                                <td class="c">
                                    <div class="cp-actions">
                                        <a asp-action="CenterPaymentDetail" asp-route-id="@p.CenterPaymentId"
                                           class="cp-btn-view" title="View details">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                        @if (canRepay)
                                        {
                                            string repayUrl = p.OriginalTransferId.HasValue
                                            ? $"/Finance/CreateCenterPayment?preselect={p.OriginalTransferId}"
                                            : "/Finance/CreateCenterPayment";
                                            <a href="@repayUrl" class="cp-repay-btn" title="Create new payment for this transfer">
                                                <i class="bi bi-arrow-clockwise"></i> Re-pay
                                            </a>
                                        }
                                        @if (canCancel)
                                        {
                                            <button class="cp-btn-cancel" title="Cancel payment"
                                                    onclick="openCancel(@p.CenterPaymentId, 'CP-@p.CenterPaymentId.ToString("D4")', '@Html.Raw(p.CenterName.Replace("'", "\\'"))')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- ── Cancel Confirm Overlay ── -->
<div class="cp-overlay" id="cancelOverlay">
    <div class="cp-confirm-box">
        <div class="cp-confirm-icon"><i class="bi bi-x-octagon-fill"></i></div>
        <div class="cp-confirm-title">Cancel this payment?</div>
        <p class="cp-confirm-msg" id="confirmMsg"></p>
        <div class="cp-confirm-btns">
            <button class="cp-btn-no" onclick="closeCancel()">Keep It</button>
            <form id="cancelForm" asp-action="CancelCenterPayment" method="post" style="flex:1;display:flex;">
                <input type="hidden" name="centerPaymentId" id="cancelId" />
                <button type="submit" class="cp-btn-yes">Yes, Cancel</button>
            </form>
        </div>
    </div>
</div>

<script>
    let activeStatus = 'all';

    function filterTable() {
        const q = document.getElementById('cpSearch').value.toLowerCase();
        const rows = document.querySelectorAll('#cpTbody tr[data-status]');
        let visible = 0;
        rows.forEach(r => {
            const statusMatch = activeStatus === 'all' || r.dataset.status === activeStatus;
            const textMatch   = r.textContent.toLowerCase().includes(q);
            const show = statusMatch && textMatch;
            r.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('visibleCount').textContent = visible;
    }

    function filterStatus(status, btn) {
        activeStatus = status;
        // Update pill active classes
        document.querySelectorAll('.cp-filter-pill').forEach(p => {
            p.className = 'cp-filter-pill';
        });
        const classMap = {
            'all':       'active',
            'Processed': 'active-processed',
            'Pending':   'active-pending',
            'Failed':    'active-failed',
            'Cancelled': 'active-cancelled'
        };
        btn.classList.add(classMap[status] || 'active');
        filterTable();
    }

    function openCancel(id, ref, center) {
        document.getElementById('cancelId').value = id;
        document.getElementById('confirmMsg').textContent =
            `Cancel ${ref} for ${center}? This payment will be marked Cancelled. The transfer will become available again for a new payment.`;
        document.getElementById('cancelOverlay').classList.add('open');
    }

    function closeCancel() {
        document.getElementById('cancelOverlay').classList.remove('open');
    }

    document.getElementById('cancelOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeCancel();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCancel(); });
</script>
