@model List<DairyIndustry.Models.Finance.CenterPaymentModel>
@{
    ViewData["Title"] = "Center Payments";
    Layout = "~/Views/Shared/_FinanceLayout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0 fw-bold">
                        <i class="fas fa-building me-2 text-primary"></i>Center Payments
                    </h4>
                    <p class="text-muted mb-0">Milk transfer payments to collection centers</p>
                </div>
                <a asp-action="CreateCenterPayment" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-1"></i> New Center Payment
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="py-3">ID</th>
                            <th scope="col" class="py-3">Transfer</th>
                            <th scope="col" class="py-3">Center</th>
                            <th scope="col" class="py-3">Plant</th>
                            <th scope="col" class="py-3 text-end">Qty (L)</th>
                            <th scope="col" class="py-3 text-end">Rate/L (₹)</th>
                            <th scope="col" class="py-3 text-end">Fat %</th>
                            <th scope="col" class="py-3 text-end">CLR</th>
                            <th scope="col" class="py-3 text-end">Total (₹)</th>
                            <th scope="col" class="py-3">Payment Date</th>
                            <th scope="col" class="py-3">Status</th>
                            <th scope="col" class="py-3">Bank Status</th>
                            <th scope="col" class="py-3 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="13" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fas fa-inbox fa-2x mb-2"></i>
                                        <p class="mb-0">No center payments recorded yet.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td class="fw-medium">CP-@p.CenterPaymentId.ToString("D4")</td>
                                    <td>
                                        <span class="badge bg-light text-dark">@p.BatchRef</span>
                                    </td>
                                    <td class="fw-medium">@p.CenterName</td>
                                    <td>@p.PlantName</td>
                                    <td class="text-end">@p.ReceivedQty.ToString("N2")</td>
                                    <td class="text-end">@p.RatePerLiter.ToString("N2")</td>
                                    <td class="text-end">@(p.TestedFat.HasValue? p.TestedFat.Value.ToString("N2") : "—")</td>
                                    <td class="text-end">@(p.TestedCLR.HasValue? p.TestedCLR.Value.ToString("N2") : "—")</td>
                                    <td class="text-end fw-semibold text-primary">₹@p.TotalAmount.ToString("N2")</td>
                                    <td>@p.PaymentDate.ToString("dd-MMM-yyyy")</td>
                                    <td>
                                        @{
                                            string badgeClass = p.PaymentStatus switch
                                            {
                                                "Processed" => "bg-success",
                                                "Pending" => "bg-warning text-dark",
                                                "Failed" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@p.PaymentStatus</span>
                                    </td>
                                    <td>
                                        @if (p.BankStatus == "Success")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                                <i class="fas fa-check-circle me-1"></i>Success
                                            </span>
                                        }
                                        else if (p.BankStatus != null)
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle">@p.BankStatus</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="CenterPaymentDetail" asp-route-id="@p.CenterPaymentId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
