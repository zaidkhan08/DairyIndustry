@model List<DairyIndustry.Models.Finance.CenterPaymentModel>
@{
    ViewData["Title"] = "Center Payments";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int total = Model.Count;
    int processed = Model.Count(p => p.PaymentStatus == "Processed");
    int pending = Model.Count(p => p.PaymentStatus == "Pending");
    int cancelled = Model.Count(p => p.PaymentStatus == "Cancelled");
    int failed = Model.Count(p => p.PaymentStatus == "Failed");
    decimal totalAmt = Model
        .Where(p => p.PaymentStatus != "Cancelled")
        .Sum(p => p.TotalAmount);
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #F4F5F7;
        --surface: #FFFFFF;
        --surface-2: #F9FAFB;
        --border: #E4E7EC;
        --border-2: #D0D5DD;
        --text-1: #101828;
        --text-2: #344054;
        --text-3: #667085;
        --text-4: #98A2B3;
        --blue: #2563EB;
        --blue-bg: #EFF4FF;
        --blue-bd: #C7D7FD;
        --blue-text: #1E40AF;
        --green: #027A48;
        --green-bg: #ECFDF3;
        --green-bd: #ABEFC6;
        --amber: #B54708;
        --amber-bg: #FFFAEB;
        --amber-bd: #FEDF89;
        --red: #B42318;
        --red-bg: #FEF3F2;
        --red-bd: #FECDCA;
        --slate: #344054;
        --slate-bg: #F2F4F7;
        --slate-bd: #D0D5DD;
        --shadow: 0 1px 2px rgba(16,24,40,.06), 0 1px 3px rgba(16,24,40,.1);
        --radius: 10px;
        --radius-lg: 14px;
    }

    body {
        background: var(--bg);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-1);
        -webkit-font-smoothing: antialiased;
    }

    .cp-page {
        padding: 2rem 1.75rem 4rem;
    }

    /* ── Header ── */
    .cp-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cp-page-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-4);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 5px;
    }

    .cp-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: -.4px;
    }

    .cp-subtitle {
        font-size: 13px;
        color: var(--text-3);
        margin-top: 4px;
    }

    .cp-new-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: var(--radius);
        background: var(--text-1);
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: opacity .15s;
        white-space: nowrap;
    }

        .cp-new-btn:hover {
            opacity: .85;
            color: #fff;
        }

        .cp-new-btn svg {
            width: 15px;
            height: 15px;
            stroke: currentColor;
            stroke-width: 2.5;
            fill: none;
        }

    /* ── KPIs ── */
    .cp-kpis {
        display: grid;
        grid-template-columns: repeat(5, minmax(0,1fr));
        gap: .875rem;
        margin-bottom: 1.5rem;
    }

    .cp-kpi {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.2rem 1.4rem;
        box-shadow: var(--shadow);
    }

    .kpi-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-4);
        margin-bottom: 8px;
    }

    .kpi-val {
        font-size: 26px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: -.5px;
        line-height: 1;
    }

        .kpi-val.mono {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -.3px;
        }

    .kpi-hint {
        font-size: 12px;
        color: var(--text-3);
        margin-top: 5px;
    }

    .kpi-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        margin-right: 5px;
        vertical-align: 1px;
    }

    /* ── Panel ── */
    .cp-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    /* ── Toolbar ── */
    .cp-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
    }

    .cp-toolbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cp-panel-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-1);
    }

    .cp-count-badge {
        padding: 2px 9px;
        border-radius: 999px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        font-size: 12px;
        font-weight: 500;
        color: var(--text-3);
    }

    .cp-filters {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .cp-filter-btn {
        padding: 5px 13px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: transparent;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-3);
        cursor: pointer;
        transition: all .15s;
        font-family: inherit;
    }

        .cp-filter-btn:hover, .cp-filter-btn.active {
            background: var(--blue-bg);
            border-color: var(--blue-bd);
            color: var(--blue-text);
        }

    .cp-search {
        position: relative;
    }

        .cp-search svg {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 14px;
            height: 14px;
            stroke: var(--text-4);
            stroke-width: 2;
            fill: none;
            pointer-events: none;
        }

        .cp-search input {
            width: 210px;
            padding: 7px 12px 7px 32px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background: var(--surface-2);
            font-size: 13px;
            color: var(--text-1);
            font-family: inherit;
            outline: none;
            transition: border-color .15s;
        }

            .cp-search input:focus {
                border-color: var(--blue);
                background: var(--surface);
            }

            .cp-search input::placeholder {
                color: var(--text-4);
            }

    /* ── Table Head ── */
    .cp-thead {
        display: grid;
        grid-template-columns: 2.2fr 1fr 1fr 1.3fr 1fr 96px;
        gap: 12px;
        padding: 10px 18px;
        background: var(--surface-2);
        border-bottom: 1px solid var(--border);
    }

    .cp-th {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-4);
    }

        .cp-th.right {
            text-align: right;
        }

        .cp-th.center {
            text-align: center;
        }

    /* ── Rows ── */
    .cp-row {
        display: grid;
        grid-template-columns: 2.2fr 1fr 1fr 1.3fr 1fr 96px;
        gap: 12px;
        align-items: center;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        transition: background .12s;
    }

        .cp-row:last-child {
            border-bottom: none;
        }

        .cp-row:hover {
            background: var(--surface-2);
        }

    /* identity */
    .cp-row-id {
        font-size: 11px;
        color: var(--text-4);
        margin-bottom: 3px;
        font-variant-numeric: tabular-nums;
    }

    .cp-row-center {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-1);
        margin-bottom: 2px;
    }

    .cp-row-plant {
        font-size: 12px;
        color: var(--text-3);
    }

    .cp-row-batch {
        display: inline-flex;
        margin-top: 5px;
        padding: 2px 7px;
        border-radius: 5px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        font-size: 10px;
        color: var(--text-4);
    }

    /* numeric cells */
    .cp-cell-num {
        text-align: right;
    }

    .cp-cell-val {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-2);
        font-variant-numeric: tabular-nums;
    }

    .cp-cell-hint {
        font-size: 11px;
        color: var(--text-4);
        margin-top: 2px;
    }

    /* amount */
    .cp-row-amount {
        text-align: right;
    }

    .cp-amount-val {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-1);
        font-variant-numeric: tabular-nums;
    }

    .cp-amount-date {
        font-size: 11px;
        color: var(--text-4);
        margin-top: 2px;
    }

    /* status */
    .cp-row-status {
        display: flex;
        justify-content: center;
    }

    .cp-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 11px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
        border: 1px solid transparent;
    }

        .cp-status::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .cp-status.processed {
            background: var(--green-bg);
            color: var(--green);
            border-color: var(--green-bd);
        }

            .cp-status.processed::before {
                background: var(--green);
            }

        .cp-status.pending {
            background: var(--amber-bg);
            color: var(--amber);
            border-color: var(--amber-bd);
        }

            .cp-status.pending::before {
                background: var(--amber);
            }

        .cp-status.failed {
            background: var(--red-bg);
            color: var(--red);
            border-color: var(--red-bd);
        }

            .cp-status.failed::before {
                background: var(--red);
            }

        .cp-status.cancelled {
            background: var(--slate-bg);
            color: var(--slate);
            border-color: var(--slate-bd);
        }

            .cp-status.cancelled::before {
                background: var(--slate);
            }

    /* actions */
    .cp-row-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .cp-action-btn {
        width: 30px;
        height: 30px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all .15s;
        color: var(--text-3);
    }

        .cp-action-btn svg {
            width: 13px;
            height: 13px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
        }

        .cp-action-btn.view {
            color: var(--blue);
            border-color: var(--blue-bd);
            background: var(--blue-bg);
        }

            .cp-action-btn.view:hover {
                background: #dbeafe;
                border-color: #93c5fd;
            }

        .cp-action-btn.cancel {
            color: var(--red);
            border-color: var(--red-bd);
            background: var(--red-bg);
        }

            .cp-action-btn.cancel:hover {
                background: #fee2e2;
                border-color: #fca5a5;
            }

    /* empty */
    .cp-empty {
        padding: 56px 20px;
        text-align: center;
        color: var(--text-3);
        font-size: 14px;
    }

    /* ── Responsive ── */
    @@media (max-width: 1100px) {
        .cp-kpis {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media (max-width: 860px) {
        .cp-page {
            padding: 20px 16px;
        }

        .cp-kpis {
            grid-template-columns: repeat(2,1fr);
        }

        .cp-thead {
            display: none;
        }

        .cp-row {
            grid-template-columns: 1fr;
            gap: 8px;
            padding: 16px;
        }

        .cp-cell-num, .cp-row-amount, .cp-row-status, .cp-row-actions {
            text-align: left;
            justify-content: flex-start;
        }
    }
</style>

<div class="cp-page">

    <!-- Header -->
    <div class="cp-header">
        <div>
            <div class="cp-page-label">Finance · Payments</div>
            <h1 class="cp-title">Center Payments</h1>
            <p class="cp-subtitle">Milk transfer payments &amp; finance operations</p>
        </div>
        <a asp-action="CreateCenterPayment" class="cp-new-btn">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            New Payment
        </a>
    </div>

    <!-- KPIs -->
    <div class="cp-kpis">
        <div class="cp-kpi">
            <div class="kpi-label">Total Records</div>
            <div class="kpi-val">@total</div>
            <div class="kpi-hint">All payments</div>
        </div>
        <div class="cp-kpi">
            <div class="kpi-label">Processed</div>
            <div class="kpi-val"><span class="kpi-dot" style="background:#027A48"></span>@processed</div>
            <div class="kpi-hint">Successfully settled</div>
        </div>
        <div class="cp-kpi">
            <div class="kpi-label">Pending</div>
            <div class="kpi-val"><span class="kpi-dot" style="background:#B54708"></span>@pending</div>
            <div class="kpi-hint">Awaiting settlement</div>
        </div>
        <div class="cp-kpi">
            <div class="kpi-label">Cancelled</div>
            <div class="kpi-val"><span class="kpi-dot" style="background:#344054"></span>@cancelled</div>
            <div class="kpi-hint">Voided payments</div>
        </div>
        <div class="cp-kpi">
            <div class="kpi-label">Total Paid</div>
            <div class="kpi-val mono">₹@totalAmt.ToString("N0")</div>
            <div class="kpi-hint">Net transaction volume</div>
        </div>
    </div>

    <!-- Panel -->
    <div class="cp-panel">

        <!-- Toolbar -->
        <div class="cp-toolbar">
            <div class="cp-toolbar-left">
                <span class="cp-panel-title">Payment Activity</span>
                <span class="cp-count-badge" id="cp-visible-count">@Model.Count</span>
            </div>
            <div class="cp-filters">
                <button class="cp-filter-btn active" data-status="all">All</button>
                <button class="cp-filter-btn" data-status="processed">Processed</button>
                <button class="cp-filter-btn" data-status="pending">Pending</button>
                <button class="cp-filter-btn" data-status="failed">Failed</button>
                <button class="cp-filter-btn" data-status="cancelled">Cancelled</button>
            </div>
            <div class="cp-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" id="cp-search-input" placeholder="Search payments…" />
            </div>
        </div>

        <!-- Table Head -->
        <div class="cp-thead">
            <div class="cp-th">Payment</div>
            <div class="cp-th right">Quantity</div>
            <div class="cp-th right">Rate / L</div>
            <div class="cp-th right">Amount</div>
            <div class="cp-th center">Status</div>
            <div class="cp-th center">Actions</div>
        </div>

        <!-- Rows -->
        <div class="cp-tbody" id="cp-tbody">
            @if (!Model.Any())
            {
                <div class="cp-empty">No payment records found.</div>
            }
            else
            {
                foreach (var p in Model)
                {
                    string sc = p.PaymentStatus?.ToLower() ?? "pending";
                    bool canCancel = p.PaymentStatus == "Pending" || p.PaymentStatus == "Failed";

                    <div class="cp-row"
                         data-status="@sc"
                         data-search="@($"{p.CenterName} {p.PlantName} {p.BatchRef}".ToLower())">

                        <!-- Identity -->
                        <div>
                            <div class="cp-row-id">CP-@p.CenterPaymentId.ToString("D4")</div>
                            <div class="cp-row-center">@p.CenterName</div>
                            <div class="cp-row-plant">@p.PlantName</div>
                            <div class="cp-row-batch">@p.BatchRef</div>
                        </div>

                        <!-- Quantity -->
                        <div class="cp-cell-num">
                            <div class="cp-cell-val">@p.ReceivedQty.ToString("N2") L</div>
                            <div class="cp-cell-hint">Received</div>
                        </div>

                        <!-- Rate -->
                        <div class="cp-cell-num">
                            <div class="cp-cell-val">₹@p.RatePerLiter.ToString("N2")</div>
                            <div class="cp-cell-hint">Per litre</div>
                        </div>

                        <!-- Amount -->
                        <div class="cp-row-amount">
                            <div class="cp-amount-val">₹@p.TotalAmount.ToString("N2")</div>
                            <div class="cp-amount-date">@p.PaymentDate.ToString("dd MMM yyyy")</div>
                        </div>

                        <!-- Status -->
                        <div class="cp-row-status">
                            <span class="cp-status @sc">@p.PaymentStatus</span>
                        </div>

                        <!-- Actions -->
                        <div class="cp-row-actions">
                            <a asp-action="CenterPaymentDetail"
                               asp-route-id="@p.CenterPaymentId"
                               class="cp-action-btn view"
                               title="View details">
                                <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
                            </a>

                            @if (canCancel)
                            {
                                <button class="cp-action-btn cancel"
                                        title="Cancel payment"
                                        onclick="confirmCancel(@p.CenterPaymentId)">
                                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                </button>
                            }
                        </div>

                    </div>
                }
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        /* ── Filter + Search ── */
        (function () {
            const rows    = Array.from(document.querySelectorAll('.cp-row'));
            const filters = document.querySelectorAll('.cp-filter-btn');
            const search  = document.getElementById('cp-search-input');
            const badge   = document.getElementById('cp-visible-count');

            let activeStatus = 'all';
            let searchTerm   = '';

            function applyFilters() {
                let visible = 0;
                rows.forEach(function (row) {
                    const statusMatch = activeStatus === 'all' || row.dataset.status === activeStatus;
                    const searchMatch = searchTerm === '' || row.dataset.search.includes(searchTerm);
                    if (statusMatch && searchMatch) { row.style.display = ''; visible++; }
                    else { row.style.display = 'none'; }
                });
                badge.textContent = visible;
            }

            filters.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    filters.forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    activeStatus = btn.dataset.status;
                    applyFilters();
                });
            });

            search.addEventListener('input', function () {
                searchTerm = search.value.toLowerCase().trim();
                applyFilters();
            });
        })();

        /* ── Cancel via POST form (fixes [HttpPost] requirement) ── */
        function confirmCancel(id) {
            if (!confirm('Cancel payment CP-' + String(id).padStart(4, '0') + '?\nThis action cannot be undone.')) return;

            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Finance/CancelCenterPayment';

            // Include antiforgery token if present
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                var t = document.createElement('input');
                t.type  = 'hidden';
                t.name  = '__RequestVerificationToken';
                t.value = token.value;
                form.appendChild(t);
            }

            var input = document.createElement('input');
            input.type  = 'hidden';
            input.name  = 'centerPaymentId';   // matches controller param exactly
            input.value = id;
            form.appendChild(input);

            document.body.appendChild(form);
            form.submit();
        }
    </script>
}
