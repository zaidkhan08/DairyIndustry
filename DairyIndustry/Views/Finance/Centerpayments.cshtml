@model List<DairyIndustry.Models.Finance.CenterPaymentModel>
@{
    ViewData["Title"] = "Center Payments";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg: #f5f7ff;
        --surface: rgba(255,255,255,.85);
        --surface-solid: #fff;
        --border: rgba(226,232,240,.7);
        --ink: #0f172a;
        --muted: #64748b;
        --blue: #2563eb;
        --blue-bg: #eff6ff;
        --green: #059669;
        --green-bg: #ecfdf5;
        --amber: #d97706;
        --amber-bg: #fffbeb;
        --red: #e11d48;
        --red-bg: #fff1f2;
        --slate: #64748b;
        --slate-bg: #f8fafc;
        --violet: #7c3aed;
        --violet-bg: #f5f3ff;
        --shadow: 0 10px 40px rgba(15,23,42,.06), 0 2px 12px rgba(15,23,42,.03);
        --shadow-hover: 0 24px 60px rgba(15,23,42,.12), 0 6px 20px rgba(15,23,42,.06);
        --radius: 24px;
        --pill: 999px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: radial-gradient(circle at top left, rgba(37,99,235,.07), transparent 30%), radial-gradient(circle at bottom right, rgba(124,58,237,.06), transparent 35%), linear-gradient(to bottom,#f8f9ff,#f5f7fc);
    }

    .cp-root {
        font-family: 'Figtree',sans-serif;
        color: var(--ink);
        padding: 32px;
    }

    /* HERO */

    .cp-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        margin-bottom: 28px;
        background: rgba(255,255,255,.55);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,.6);
        border-radius: 32px;
        padding: 36px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

        .cp-hero::before {
            content: '';
            position: absolute;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle,rgba(37,99,235,.12),transparent 70%);
            right: -120px;
            top: -120px;
        }

    .cp-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        border-radius: 999px;
        background: var(--blue-bg);
        color: var(--blue);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

        .cp-badge::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--blue);
        }

    .cp-title {
        font-size: 42px;
        font-weight: 800;
        letter-spacing: -2px;
        margin-bottom: 10px;
    }

    .cp-sub {
        color: var(--muted);
        font-size: 15px;
    }

    .cp-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 24px;
        border-radius: 999px;
        background: linear-gradient(135deg,#2563eb,#4f46e5);
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(37,99,235,.28);
        transition: .25s;
    }

        .cp-btn:hover {
            transform: translateY(-2px);
            color: #fff;
        }

    /* KPI */

    .cp-kpis {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 18px;
        margin-bottom: 28px;
    }

    .cp-kpi {
        background: rgba(255,255,255,.7);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 24px;
        border: 1px solid rgba(255,255,255,.7);
        box-shadow: var(--shadow);
        transition: .25s;
        position: relative;
        overflow: hidden;
    }

        .cp-kpi:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
        }

        .cp-kpi::after {
            content: '';
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            right: -30px;
            bottom: -30px;
            opacity: .08;
        }

        .cp-kpi.blue::after {
            background: var(--blue);
        }

        .cp-kpi.green::after {
            background: var(--green);
        }

        .cp-kpi.amber::after {
            background: var(--amber);
        }

        .cp-kpi.red::after {
            background: var(--red);
        }

        .cp-kpi.violet::after {
            background: var(--violet);
        }

    .cp-kpi-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 12px;
    }

    .cp-kpi-value {
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -2px;
        line-height: 1;
    }

    .cp-kpi-sub {
        margin-top: 10px;
        color: #94a3b8;
        font-size: 12px;
    }

    /* PANEL */

    .cp-panel {
        background: rgba(255,255,255,.7);
        backdrop-filter: blur(18px);
        border-radius: 32px;
        border: 1px solid rgba(255,255,255,.8);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* TOOLBAR */

    .cp-toolbar {
        padding: 24px;
        border-bottom: 1px solid rgba(226,232,240,.55);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .cp-toolbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .cp-toolbar-title {
        font-size: 18px;
        font-weight: 700;
    }

    .cp-count {
        padding: 4px 12px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 12px;
        font-weight: 700;
    }

    /* FILTERS */

    .cp-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .cp-filter {
        height: 36px;
        padding: 0 16px;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        background: #fff;
        color: #64748b;
        font-weight: 600;
        transition: .2s;
    }

        .cp-filter:hover,
        .cp-filter.active {
            background: #eff6ff;
            color: #2563eb;
        }

    /* SEARCH */

    .cp-search {
        position: relative;
    }

        .cp-search input {
            width: 240px;
            height: 40px;
            border-radius: 999px;
            border: 1px solid rgba(226,232,240,.7);
            padding: 0 16px 0 42px;
            background: rgba(255,255,255,.7);
            font-family: 'Figtree',sans-serif;
        }

        .cp-search svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            color: #94a3b8;
        }

    /* TRANSACTION LIST */

    .cp-list {
        padding: 12px;
    }

    .cp-item {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr auto;
        gap: 18px;
        align-items: center;
        padding: 22px;
        border-radius: 24px;
        transition: .2s;
    }

        .cp-item:hover {
            background: rgba(37,99,235,.04);
        }

        .cp-item + .cp-item {
            margin-top: 8px;
        }

    .cp-id {
        font-size: 11px;
        color: #94a3b8;
        font-family: 'DM Mono',monospace;
        margin-bottom: 5px;
    }

    .cp-center {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .cp-plant {
        color: #64748b;
        font-size: 13px;
    }

    .cp-batch {
        display: inline-flex;
        margin-top: 8px;
        padding: 4px 10px;
        border-radius: 10px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 11px;
        font-family: 'DM Mono',monospace;
    }

    .cp-metric {
        text-align: right;
    }

    .cp-metric-value {
        font-weight: 700;
        font-family: 'DM Mono',monospace;
    }

    .cp-metric-label {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 3px;
    }

    .cp-amount {
        text-align: right;
    }

        .cp-amount strong {
            font-size: 18px;
            font-family: 'DM Mono',monospace;
        }

    .cp-date {
        color: #64748b;
        font-size: 12px;
        font-family: 'DM Mono',monospace;
    }

    /* STATUS */

    .cp-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
    }

        .cp-status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

        .cp-status.processed {
            background: var(--green-bg);
            color: var(--green);
        }

        .cp-status.pending {
            background: var(--amber-bg);
            color: var(--amber);
        }

        .cp-status.failed {
            background: var(--red-bg);
            color: var(--red);
        }

        .cp-status.cancelled {
            background: var(--slate-bg);
            color: var(--slate);
        }

    /* ACTIONS */

    .cp-actions {
        display: flex;
        gap: 8px;
    }

    .cp-icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        border: none;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .2s;
    }

        .cp-icon-btn:hover {
            transform: scale(1.08);
        }

    .cp-view {
        color: #2563eb;
        background: #eff6ff;
    }

    .cp-cancel {
        color: #e11d48;
        background: #fff1f2;
    }

    @@media(max-width:1200px) {
        .cp-kpis {
            grid-template-columns: repeat(2,1fr);
        }

        .cp-item {
            grid-template-columns: 1fr;
        }

        .cp-metric,
        .cp-amount {
            text-align: left;
        }
    }
</style>

<div class="cp-root">

    <div class="cp-hero">
        <div>
            <div class="cp-badge">
                Finance Intelligence
            </div>

            <h1 class="cp-title">
                Center Payments
            </h1>

            <p class="cp-sub">
                Milk transfer payments & finance operations dashboard
            </p>
        </div>

        <a asp-action="CreateCenterPayment" class="cp-btn">
            + New Payment
        </a>
    </div>

    @{
        int total = Model.Count;
        int processed = Model.Count(p => p.PaymentStatus == "Processed");
        int pending = Model.Count(p => p.PaymentStatus == "Pending");
        int cancelled = Model.Count(p => p.PaymentStatus == "Cancelled");
        decimal totalAmt = Model.Where(p => p.PaymentStatus != "Cancelled").Sum(p => p.TotalAmount);
    }

    <div class="cp-kpis">

        <div class="cp-kpi blue">
            <div class="cp-kpi-label">Total Records</div>
            <div class="cp-kpi-value">@total</div>
            <div class="cp-kpi-sub">All payments</div>
        </div>

        <div class="cp-kpi green">
            <div class="cp-kpi-label">Processed</div>
            <div class="cp-kpi-value">@processed</div>
            <div class="cp-kpi-sub">Successfully settled</div>
        </div>

        <div class="cp-kpi amber">
            <div class="cp-kpi-label">Pending</div>
            <div class="cp-kpi-value">@pending</div>
            <div class="cp-kpi-sub">Awaiting settlement</div>
        </div>

        <div class="cp-kpi red">
            <div class="cp-kpi-label">Cancelled</div>
            <div class="cp-kpi-value">@cancelled</div>
            <div class="cp-kpi-sub">Voided payments</div>
        </div>

        <div class="cp-kpi violet">
            <div class="cp-kpi-label">Total Paid</div>
            <div class="cp-kpi-value" style="font-size:28px">
                ₹@totalAmt.ToString("N0")
            </div>
            <div class="cp-kpi-sub">Net transaction volume</div>
        </div>

    </div>

    <div class="cp-panel">

        <div class="cp-toolbar">

            <div class="cp-toolbar-left">
                <div class="cp-toolbar-title">
                    Payment Activity
                </div>

                <div class="cp-count">
                    @Model.Count
                </div>
            </div>

            <div class="cp-filters">
                <button class="cp-filter active">All</button>
                <button class="cp-filter">Processed</button>
                <button class="cp-filter">Pending</button>
                <button class="cp-filter">Failed</button>
                <button class="cp-filter">Cancelled</button>
            </div>

            <div class="cp-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>

                <input type="text" placeholder="Search payments..." />
            </div>

        </div>

        <div class="cp-list">

            @foreach (var p in Model)
            {
                string statusClass = p.PaymentStatus.ToLower();

                <div class="cp-item">

                    <div>
                        <div class="cp-id">
                            CP-@p.CenterPaymentId.ToString("D4")
                        </div>

                        <div class="cp-center">
                            @p.CenterName
                        </div>

                        <div class="cp-plant">
                            @p.PlantName
                        </div>

                        <div class="cp-batch">
                            @p.BatchRef
                        </div>
                    </div>

                    <div class="cp-metric">
                        <div class="cp-metric-value">
                            @p.ReceivedQty.ToString("N2") L
                        </div>

                        <div class="cp-metric-label">
                            Quantity
                        </div>
                    </div>

                    <div class="cp-metric">
                        <div class="cp-metric-value">
                            ₹@p.RatePerLiter.ToString("N2")
                        </div>

                        <div class="cp-metric-label">
                            Rate/L
                        </div>
                    </div>

                    <div class="cp-amount">
                        <strong>
                            ₹@p.TotalAmount.ToString("N2")
                        </strong>

                        <div class="cp-date">
                            @p.PaymentDate.ToString("dd MMM yyyy")
                        </div>
                    </div>

                    <div class="cp-actions">

                        <span class="cp-status @statusClass">
                            @p.PaymentStatus
                        </span>

                        <a asp-action="CenterPaymentDetail"
                           asp-route-id="@p.CenterPaymentId"
                           class="cp-icon-btn cp-view">
                            →
                        </a>

                        @if (p.PaymentStatus == "Pending" || p.PaymentStatus == "Failed")
                        {
                            <button class="cp-icon-btn cp-cancel">
                                ×
                            </button>
                        }

                    </div>

                </div>
            }

        </div>

    </div>

</div>