@model DairyIndustry.Models.Finance.CenterWalletViewModel
@* Rendered as a partial — no Layout *@

@{
    decimal netBalance = Model.Summary.TotalReceived - Model.Summary.TotalStaffCost;
    decimal utilization = Model.Summary.TotalReceived > 0
        ? Math.Round((Model.Summary.TotalStaffCost / Model.Summary.TotalReceived) * 100, 1)
        : 0;
}

<style>
    .cw-root {
        font-family: 'DM Sans', sans-serif;
        --ink: #0f172a;
        --ink-muted: #64748b;
        --ink-faint: #94a3b8;
        --surface: #ffffff;
        --surface-2: #f8fafc;
        --surface-3: #f1f5f9;
        --border: #e2e8f0;
        --border-strong: #cbd5e1;
        --accent: #2563eb;
        --accent-light: #eff6ff;
        --accent-mid: #bfdbfe;
        --success: #16a34a;
        --success-light: #f0fdf4;
        --success-mid: #bbf7d0;
        --warning: #d97706;
        --warning-light: #fffbeb;
        --warning-mid: #fde68a;
        --danger: #dc2626;
        --danger-light: #fef2f2;
        --danger-mid: #fecaca;
        --purple: #7c3aed;
        --purple-light: #f5f3ff;
        --purple-mid: #ddd6fe;
        --teal: #0d9488;
        --teal-light: #f0fdfa;
        --teal-mid: #99f6e4;
        --r-sm: 6px;
        --r-md: 10px;
        --r-lg: 14px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
        --shadow-md: 0 4px 12px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
    }

    /* ── Header ── */
    .cw-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 24px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .cw-page-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -.4px;
        margin: 0 0 2px;
    }

    .cw-page-sub {
        font-size: 13px;
        color: var(--ink-muted);
        margin: 0;
    }

    /* ── Hero balance strip ── */
    .cw-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1d4ed8 100%);
        border-radius: var(--r-lg);
        padding: 28px 32px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: center;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }

        .cw-hero::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
        }

        .cw-hero::after {
            content: '';
            position: absolute;
            bottom: -60px;
            right: 120px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,.03);
        }

    .cw-hero-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: rgba(255,255,255,.55);
        margin-bottom: 8px;
    }

    .cw-hero-center {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
    }

    .cw-hero-balance {
        font-size: 38px;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
        color: #fff;
        letter-spacing: -1px;
        line-height: 1;
    }

        .cw-hero-balance.negative {
            color: #fca5a5;
        }

    .cw-hero-sub {
        font-size: 12px;
        color: rgba(255,255,255,.45);
        margin-top: 6px;
    }

    .cw-hero-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 12px;
    }

    .cw-hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 20px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,.85);
    }

    /* ── Stat cards ── */
    .cw-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    .cw-stat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 16px 18px;
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
    }

        .cw-stat::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--r-md) var(--r-md) 0 0;
        }

        .cw-stat.income::before {
            background: var(--success);
        }

        .cw-stat.pending::before {
            background: var(--warning);
        }

        .cw-stat.spent::before {
            background: var(--purple);
        }

        .cw-stat.net::before {
            background: var(--teal);
        }

    .cw-stat-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--r-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        margin-bottom: 10px;
    }

    .icon-income {
        background: var(--success-light);
        color: var(--success);
    }

    .icon-pending {
        background: var(--warning-light);
        color: var(--warning);
    }

    .icon-spent {
        background: var(--purple-light);
        color: var(--purple);
    }

    .icon-net {
        background: var(--teal-light);
        color: var(--teal);
    }

    .cw-stat-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: var(--ink-muted);
        margin-bottom: 5px;
    }

    .cw-stat-value {
        font-size: 20px;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
        color: var(--ink);
        letter-spacing: -.5px;
        line-height: 1;
    }

    .cw-stat-sub {
        font-size: 11px;
        color: var(--ink-faint);
        margin-top: 4px;
    }

    /* ── Utilization bar ── */
    .cw-util-bar-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 16px 20px;
        margin-bottom: 20px;
        box-shadow: var(--shadow-sm);
    }

    .cw-util-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .cw-util-title {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--ink-muted);
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .cw-util-pct {
        font-size: 13px;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
        color: var(--purple);
    }

    .cw-util-track {
        height: 8px;
        background: var(--surface-3);
        border-radius: 10px;
        overflow: hidden;
    }

    .cw-util-fill {
        height: 100%;
        border-radius: 10px;
        background: linear-gradient(90deg, var(--purple) 0%, #a855f7 100%);
        transition: width .6s ease;
    }

    .cw-util-legend {
        display: flex;
        gap: 16px;
        margin-top: 8px;
    }

    .cw-util-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--ink-muted);
    }

    .cw-util-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* ── Tables ── */
    .cw-section-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -.2px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .cw-section-badge {
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 600;
        color: var(--ink-muted);
        font-family: 'JetBrains Mono', monospace;
    }

    .cw-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-md);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .cw-card-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--surface-2);
        gap: 12px;
        flex-wrap: wrap;
    }

    .cw-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .cw-table thead tr {
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        .cw-table th {
            padding: 10px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .55px;
            color: var(--ink-muted);
            white-space: nowrap;
        }

            .cw-table th.r, .cw-table td.r {
                text-align: right;
            }

        .cw-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .cw-table tbody tr:last-child {
                border-bottom: none;
            }

            .cw-table tbody tr:hover {
                background: var(--surface-2);
            }

        .cw-table td {
            padding: 12px 14px;
            color: var(--ink);
            vertical-align: middle;
            white-space: nowrap;
        }

    /* ── Tally row ── */
    .cw-tally-row td {
        background: var(--surface-2) !important;
        font-weight: 700;
        border-top: 2px solid var(--border-strong);
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: var(--ink);
    }

    /* ── Cell styles ── */
    .cw-id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--ink-muted);
    }

    .cw-ref-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 3px 9px;
        font-size: 12px;
        font-family: 'JetBrains Mono', monospace;
        font-weight: 500;
    }

    .cw-amount-in {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--success);
    }

    .cw-amount-out {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--purple);
    }

    .cw-amount-neutral {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 600;
        color: var(--ink-muted);
    }

    .cw-date {
        font-size: 12.5px;
        color: var(--ink-muted);
        font-family: 'JetBrains Mono', monospace;
    }

    .cw-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
        white-space: nowrap;
    }

    .cw-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .pill-processed {
        background: var(--success-light);
        color: var(--success);
        border: 1px solid var(--success-mid);
    }

    .pill-pending {
        background: var(--warning-light);
        color: var(--warning);
        border: 1px solid var(--warning-mid);
    }

    .pill-failed {
        background: var(--danger-light);
        color: var(--danger);
        border: 1px solid var(--danger-mid);
    }

    .pill-cancelled {
        background: var(--surface-3);
        color: var(--ink-muted);
        border: 1px solid var(--border);
    }

    .cw-empty {
        padding: 40px;
        text-align: center;
        color: var(--ink-faint);
        font-size: 13px;
    }

    .cw-empty-icon {
        width: 48px;
        height: 48px;
        background: var(--surface-3);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 12px;
    }

    /* ── Alert ── */
    .cw-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 13px 16px;
        border-radius: var(--r-md);
        font-size: 13.5px;
        font-weight: 500;
        margin-bottom: 18px;
        border: 1px solid;
    }

    .cw-alert-success {
        background: var(--success-light);
        border-color: var(--success-mid);
        color: var(--success);
    }

    .cw-alert-danger {
        background: var(--danger-light);
        border-color: var(--danger-mid);
        color: var(--danger);
    }

    .cw-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        font-size: 16px;
        padding: 0;
    }

        .cw-alert-close:hover {
            opacity: 1;
        }

    @@media(max-width:1100px) {
        .cw-stats {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:600px) {
        .cw-stats {
            grid-template-columns: 1fr 1fr;
        }

        .cw-hero {
            grid-template-columns: 1fr;
        }

        .cw-hero-right {
            align-items: flex-start;
        }
    }
</style>

<div class="cw-root">

    @if (TempData["Success"] != null)
    {
        <div class="cw-alert cw-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="cw-alert-close" onclick="this.closest('.cw-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="cw-alert cw-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="cw-alert-close" onclick="this.closest('.cw-alert').remove()">&times;</button>
        </div>
    }

    <!-- Header -->
    <div class="cw-page-header">
        <div>
            <h1 class="cw-page-title">
                <i class="bi bi-wallet2" style="color:var(--accent);margin-right:8px;"></i>
                Center Wallet
            </h1>
            <p class="cw-page-sub">Financial overview — funds received from plants &amp; operational costs</p>
        </div>
    </div>

    <!-- Hero balance strip -->
    <div class="cw-hero">
        <div>
            <div class="cw-hero-label">Net Balance — @Model.Summary.CenterName</div>
            <div class="cw-hero-balance @(netBalance < 0 ? "negative" : "")">
                ₹@netBalance.ToString("N2")
            </div>
            <div class="cw-hero-sub">
                Total Received &nbsp;−&nbsp; Total Staff Cost
                &nbsp;=&nbsp; ₹@Model.Summary.TotalReceived.ToString("N2") − ₹@Model.Summary.TotalStaffCost.ToString("N2")
            </div>
        </div>
        <div class="cw-hero-right">
            <span class="cw-hero-pill">
                <i class="bi bi-receipt"></i>
                @Model.Summary.TotalTxns Total Transactions
            </span>
            <span class="cw-hero-pill">
                <i class="bi bi-people"></i>
                @Model.Summary.TotalStaffCount Staff Members
            </span>
        </div>
    </div>

    <!-- Stat cards -->
    <div class="cw-stats">
        <div class="cw-stat income">
            <div class="cw-stat-icon icon-income"><i class="bi bi-arrow-down-circle-fill"></i></div>
            <div class="cw-stat-label">Total Received (Plant)</div>
            <div class="cw-stat-value" style="color:var(--success);">₹@Model.Summary.TotalReceived.ToString("N0")</div>
            <div class="cw-stat-sub">Processed payments only</div>
        </div>
        <div class="cw-stat pending">
            <div class="cw-stat-icon icon-pending"><i class="bi bi-hourglass-split"></i></div>
            <div class="cw-stat-label">Pending Inflow</div>
            <div class="cw-stat-value" style="color:var(--warning);">₹@Model.Summary.TotalPending.ToString("N0")</div>
            <div class="cw-stat-sub">Awaiting payment from plant</div>
        </div>
        <div class="cw-stat spent">
            <div class="cw-stat-icon icon-spent"><i class="bi bi-arrow-up-circle-fill"></i></div>
            <div class="cw-stat-label">Staff Cost (Outflow)</div>
            <div class="cw-stat-value" style="color:var(--purple);">₹@Model.Summary.TotalStaffCost.ToString("N0")</div>
            <div class="cw-stat-sub">@Model.Summary.TotalStaffCount staff salaries paid</div>
        </div>
        <div class="cw-stat net">
            <div class="cw-stat-icon icon-net"><i class="bi bi-bar-chart-fill"></i></div>
            <div class="cw-stat-label">Net Available</div>
            <div class="cw-stat-value" style="color:var(--teal);">₹@netBalance.ToString("N0")</div>
            <div class="cw-stat-sub">After operational costs</div>
        </div>
    </div>

    <!-- Utilization bar -->
    <div class="cw-util-bar-wrap">
        <div class="cw-util-header">
            <span class="cw-util-title">Fund Utilization (Staff Cost vs Received)</span>
            <span class="cw-util-pct">@utilization%</span>
        </div>
        <div class="cw-util-track">
            <div class="cw-util-fill" style="width: @(Math.Min(utilization, 100))%;"></div>
        </div>
        <div class="cw-util-legend">
            <div class="cw-util-legend-item">
                <div class="cw-util-dot" style="background:var(--success);"></div>
                Received: ₹@Model.Summary.TotalReceived.ToString("N0")
            </div>
            <div class="cw-util-legend-item">
                <div class="cw-util-dot" style="background:var(--purple);"></div>
                Staff Cost: ₹@Model.Summary.TotalStaffCost.ToString("N0")
            </div>
            <div class="cw-util-legend-item">
                <div class="cw-util-dot" style="background:var(--teal);"></div>
                Remaining: ₹@netBalance.ToString("N0")
            </div>
        </div>
    </div>

    <!-- Inflow Table -->
    <div class="cw-section-title">
        <i class="bi bi-arrow-down-circle" style="color:var(--success);"></i>
        Inflow — Payments Received from Plants
        <span class="cw-section-badge">@Model.Transactions.Count</span>
    </div>

    <div class="cw-card">
        <div class="cw-card-toolbar">
            <span style="font-size:13px;font-weight:600;color:var(--ink);">All Center Payment Records</span>
            <div style="display:flex;gap:8px;align-items:center;">
                <span style="font-size:12px;color:var(--ink-muted);">
                    Total Received:
                    <strong style="color:var(--success);font-family:'JetBrains Mono',monospace;">
                        ₹@Model.Transactions.Where(t => t.PaymentStatus == "Processed").Sum(t => t.TotalAmount).ToString("N2")
                    </strong>
                </span>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table class="cw-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Transfer Ref</th>
                        <th>Plant</th>
                        <th class="r">Qty (L)</th>
                        <th class="r">Rate/L (₹)</th>
                        <th class="r">Amount (₹)</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Bank</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Transactions.Any())
                    {
                        <tr>
                            <td colspan="9">
                                <div class="cw-empty">
                                    <div class="cw-empty-icon"><i class="bi bi-inbox"></i></div>
                                    No payment records found.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in Model.Transactions)
                        {
                            string pillCss = t.PaymentStatus switch
                            {
                                "Processed" => "pill-processed",
                                "Pending" => "pill-pending",
                                "Failed" => "pill-failed",
                                _ => "pill-cancelled"
                            };
                            <tr>
                                <td><span class="cw-id">CP-@t.CenterPaymentId.ToString("D4")</span></td>
                                <td><span class="cw-ref-badge"><i class="bi bi-arrow-left-right" style="font-size:10px;"></i>@t.BatchRef</span></td>
                                <td style="font-size:13px;color:var(--ink-muted);">@t.PlantName</td>
                                <td class="r"><span class="cw-amount-neutral">@t.ReceivedQty.ToString("N2")</span></td>
                                <td class="r"><span class="cw-amount-neutral">@t.RatePerLiter.ToString("N2")</span></td>
                                <td class="r">
                                    <span class="@(t.PaymentStatus == "Processed" ? "cw-amount-in" : "cw-amount-neutral")">
                                        ₹@t.TotalAmount.ToString("N2")
                                    </span>
                                </td>
                                <td><span class="cw-date">@t.PaymentDate.ToString("dd MMM yyyy")</span></td>
                                <td>
                                    <span class="cw-pill @pillCss">
                                        <span class="cw-pill-dot"></span>
                                        @t.PaymentStatus
                                    </span>
                                </td>
                                <td>
                                    @if (t.BankStatus == "Success")
                                    {
                                        <span style="color:var(--success);font-weight:600;font-size:12.5px;">
                                            <i class="bi bi-check-circle-fill"></i> Success
                                        </span>
                                    }
                                    else if (t.BankStatus != null)
                                    {
                                        <span style="color:var(--danger);font-weight:600;font-size:12.5px;">
                                            <i class="bi bi-x-circle-fill"></i> @t.BankStatus
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--ink-faint);">—</span>
                                    }
                                </td>
                            </tr>
                        }

                        <!-- Tally row -->
                        <tr class="cw-tally-row">
                            <td colspan="5" style="text-align:right;padding-right:16px;color:var(--ink-muted);font-family:'DM Sans',sans-serif;font-size:12px;">
                                TOTAL RECEIVED (Processed only)
                            </td>
                            <td class="r" style="color:var(--success);">
                                ₹@Model.Transactions.Where(t => t.PaymentStatus == "Processed").Sum(t => t.TotalAmount).ToString("N2")
                            </td>
                            <td colspan="3"></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Outflow Table -->
    <div class="cw-section-title">
        <i class="bi bi-arrow-up-circle" style="color:var(--purple);"></i>
        Outflow — Staff Cost Breakdown
        <span class="cw-section-badge">@Model.StaffPayments.Count</span>
    </div>

    <div class="cw-card">
        <div class="cw-card-toolbar">
            <span style="font-size:13px;font-weight:600;color:var(--ink);">Staff Salary Records</span>
            <span style="font-size:12px;color:var(--ink-muted);">
                Total Cost:
                <strong style="color:var(--purple);font-family:'JetBrains Mono',monospace;">
                    ₹@Model.StaffPayments.Sum(s => s.TotalAmount).ToString("N2")
                </strong>
            </span>
        </div>
        <div style="overflow-x:auto;">
            <table class="cw-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Staff Name</th>
                        <th>Role</th>
                        <th>Period</th>
                        <th class="r">Salary/Mo (₹)</th>
                        <th class="r">Amount Paid (₹)</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.StaffPayments.Any())
                    {
                        <tr>
                            <td colspan="8">
                                <div class="cw-empty">
                                    <div class="cw-empty-icon"><i class="bi bi-people"></i></div>
                                    No staff payment records for this center.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var s in Model.StaffPayments)
                        {
                            string pillCss = s.PaymentStatus switch
                            {
                                "Processed" => "pill-processed",
                                "Pending" => "pill-pending",
                                _ => "pill-cancelled"
                            };
                            <tr>
                                <td><span class="cw-id">SP-@s.PaymentId.ToString("D4")</span></td>
                                <td style="font-weight:600;color:var(--ink);">@s.StaffName</td>
                                <td style="font-size:12.5px;color:var(--ink-muted);">@s.RoleName</td>
                                <td>
                                    <span class="cw-date">
                                        @s.FromDate.ToString("dd MMM") – @s.ToDate.ToString("dd MMM yyyy")
                                    </span>
                                </td>
                                <td class="r"><span class="cw-amount-neutral">@s.MonthlySalary.ToString("N2")</span></td>
                                <td class="r"><span class="cw-amount-out">₹@s.TotalAmount.ToString("N2")</span></td>
                                <td><span class="cw-date">@s.PaymentDate.ToString("dd MMM yyyy")</span></td>
                                <td>
                                    <span class="cw-pill @pillCss">
                                        <span class="cw-pill-dot"></span>
                                        @s.PaymentStatus
                                    </span>
                                </td>
                            </tr>
                        }

                        <!-- Tally row -->
                        <tr class="cw-tally-row">
                            <td colspan="5" style="text-align:right;padding-right:16px;color:var(--ink-muted);font-family:'DM Sans',sans-serif;font-size:12px;">
                                TOTAL STAFF COST
                            </td>
                            <td class="r" style="color:var(--purple);">
                                ₹@Model.StaffPayments.Sum(s => s.TotalAmount).ToString("N2")
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
