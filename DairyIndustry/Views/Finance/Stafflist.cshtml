@model DairyIndustry.Models.Finance.PlantStaffViewModel
@{
    ViewData["Title"] = "Staff List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string role = ViewBag.Role as string ?? "";
    string plantLabel = ViewBag.PlantName as string ?? "All Plants";
    bool isPlantManager = role == "Plant Manager";
}

<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg: #f5f7ff;
        --surface: rgba(255,255,255,.88);
        --surface-solid: #fff;
        --border: rgba(226,232,240,.7);
        --ink: #0f172a;
        --muted: #64748b;
        --blue: #2563eb;
        --blue-bg: #eff6ff;
        --green: #059669;
        --green-bg: #ecfdf5;
        --amber: #d97706;
        --amber-bg: #fffbeb;
        --red: #e11d48;
        --red-bg: #fff1f2;
        --slate: #64748b;
        --slate-bg: #f8fafc;
        --violet: #7c3aed;
        --violet-bg: #f5f3ff;
        --shadow: 0 10px 40px rgba(15,23,42,.06), 0 2px 12px rgba(15,23,42,.03);
        --shadow-hover: 0 24px 60px rgba(15,23,42,.12), 0 6px 20px rgba(15,23,42,.06);
        --radius: 24px;
        --pill: 999px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: radial-gradient(circle at top left,rgba(37,99,235,.07),transparent 30%), radial-gradient(circle at bottom right,rgba(124,58,237,.06),transparent 35%), linear-gradient(to bottom,#f8f9ff,#f5f7fc);
    }

    .sl-root {
        font-family: 'Figtree', sans-serif;
        color: var(--ink);
        padding: 32px;
    }

    /* ── HERO ──────────────────────────────────────────────────── */
    .sl-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        margin-bottom: 28px;
        background: rgba(255,255,255,.55);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,.6);
        border-radius: 32px;
        padding: 36px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

        .sl-hero::before {
            content: '';
            position: absolute;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle,rgba(37,99,235,.11),transparent 70%);
            right: -120px;
            top: -120px;
        }

    .sl-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        border-radius: 999px;
        background: var(--violet-bg);
        color: var(--violet);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

        .sl-badge::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--violet);
        }

    .sl-title {
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -1.8px;
        margin-bottom: 8px;
    }

    .sl-sub {
        color: var(--muted);
        font-size: 14px;
    }

    /* ── KPI CARDS ─────────────────────────────────────────────── */
    .sl-kpis {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 18px;
        margin-bottom: 28px;
    }

    .sl-kpi {
        background: rgba(255,255,255,.7);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 24px;
        border: 1px solid rgba(255,255,255,.7);
        box-shadow: var(--shadow);
        transition: .25s;
        position: relative;
        overflow: hidden;
    }

        .sl-kpi:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
        }

        .sl-kpi::after {
            content: '';
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            right: -30px;
            bottom: -30px;
            opacity: .08;
        }

        .sl-kpi.blue::after {
            background: var(--blue);
        }

        .sl-kpi.green::after {
            background: var(--green);
        }

        .sl-kpi.amber::after {
            background: var(--amber);
        }

        .sl-kpi.red::after {
            background: var(--red);
        }

        .sl-kpi.violet::after {
            background: var(--violet);
        }

    .sl-kpi-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 12px;
    }

    .sl-kpi-value {
        font-size: 36px;
        font-weight: 800;
        letter-spacing: -2px;
        line-height: 1;
    }

    .sl-kpi-sub {
        margin-top: 10px;
        color: #94a3b8;
        font-size: 12px;
    }

    /* ── MAIN PANEL ────────────────────────────────────────────── */
    .sl-panel {
        background: rgba(255,255,255,.7);
        backdrop-filter: blur(18px);
        border-radius: 32px;
        border: 1px solid rgba(255,255,255,.8);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* ── TOOLBAR ───────────────────────────────────────────────── */
    .sl-toolbar {
        padding: 24px;
        border-bottom: 1px solid rgba(226,232,240,.55);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .sl-toolbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sl-toolbar-title {
        font-size: 18px;
        font-weight: 700;
    }

    .sl-count {
        padding: 4px 12px;
        border-radius: 999px;
        background: var(--violet-bg);
        color: var(--violet);
        font-size: 12px;
        font-weight: 700;
    }

    /* ── FILTERS ───────────────────────────────────────────────── */
    .sl-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .sl-filter {
        height: 36px;
        padding: 0 16px;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        background: #fff;
        color: #64748b;
        font-weight: 600;
        font-family: 'Figtree', sans-serif;
        transition: .2s;
    }

        .sl-filter:hover, .sl-filter.active {
            background: var(--violet-bg);
            color: var(--violet);
        }

    /* ── SEARCH ────────────────────────────────────────────────── */
    .sl-search {
        position: relative;
    }

        .sl-search input {
            width: 240px;
            height: 40px;
            border-radius: 999px;
            border: 1px solid rgba(226,232,240,.7);
            padding: 0 16px 0 42px;
            background: rgba(255,255,255,.7);
            font-family: 'Figtree', sans-serif;
            font-size: 14px;
            outline: none;
        }

        .sl-search svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            color: #94a3b8;
        }

    /* ── STAFF TABLE ───────────────────────────────────────────── */
    .sl-table-wrap {
        overflow-x: auto;
    }

    .sl-table {
        width: 100%;
        border-collapse: collapse;
    }

        .sl-table thead tr {
            background: rgba(248,250,252,.9);
            border-bottom: 1px solid rgba(226,232,240,.6);
        }

        .sl-table th {
            padding: 14px 20px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: #94a3b8;
            white-space: nowrap;
        }

        .sl-table tbody tr {
            border-bottom: 1px solid rgba(226,232,240,.4);
            transition: background .15s;
        }

            .sl-table tbody tr:last-child {
                border-bottom: none;
            }

            .sl-table tbody tr:hover {
                background: rgba(37,99,235,.025);
            }

        .sl-table td {
            padding: 18px 20px;
            vertical-align: middle;
            font-size: 14px;
        }

    /* ── STAFF AVATAR ──────────────────────────────────────────── */
    .sl-avatar-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .sl-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--violet), #4f46e5);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: -.5px;
    }

    .sl-name {
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 2px;
    }

    .sl-role {
        font-size: 12px;
        color: var(--muted);
    }

    /* ── CENTER TAG ────────────────────────────────────────────── */
    .sl-center-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 999px;
        background: var(--blue-bg);
        color: var(--blue);
        font-size: 12px;
        font-weight: 600;
    }

    /* ── CONTACT INFO ──────────────────────────────────────────── */
    .sl-contact {
        font-size: 13px;
    }

        .sl-contact .contact-line {
            color: var(--muted);
            font-size: 12px;
            margin-top: 2px;
        }

    /* ── SALARY ────────────────────────────────────────────────── */
    .sl-salary {
        font-family: 'DM Mono', monospace;
        font-size: 14px;
        font-weight: 600;
        color: var(--green);
    }

    .sl-salary-na {
        color: #94a3b8;
        font-size: 13px;
    }

    /* ── JOIN DATE ─────────────────────────────────────────────── */
    .sl-date {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--muted);
    }

    /* ── STATUS PILLS ──────────────────────────────────────────── */
    .sl-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .3px;
    }

        .sl-pill::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

    .sl-pill-active {
        background: var(--green-bg);
        color: var(--green);
    }

    .sl-pill-inactive {
        background: var(--slate-bg);
        color: var(--slate);
    }

    .sl-pill-processed {
        background: var(--green-bg);
        color: var(--green);
    }

    .sl-pill-pending {
        background: var(--amber-bg);
        color: var(--amber);
    }

    .sl-pill-failed {
        background: var(--red-bg);
        color: var(--red);
    }

    .sl-pill-none {
        background: var(--slate-bg);
        color: #94a3b8;
    }

    /* ── EMPTY STATE ───────────────────────────────────────────── */
    .sl-empty {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

    .sl-empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
        opacity: .5;
    }

    .sl-empty-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .sl-empty-sub {
        font-size: 14px;
    }

    /* ── PLANT LABEL (admin grouped view) ──────────────────────── */
    .sl-group-header {
        padding: 10px 20px;
        background: linear-gradient(135deg, var(--violet-bg), rgba(255,255,255,.4));
        border-bottom: 1px solid rgba(226,232,240,.5);
        font-size: 12px;
        font-weight: 700;
        color: var(--violet);
        letter-spacing: .6px;
        text-transform: uppercase;
    }

    /* ── ALERTS ────────────────────────────────────────────────── */
    .sl-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 13px 16px;
        border-radius: 14px;
        font-size: 13.5px;
        font-weight: 500;
        margin-bottom: 18px;
        border: 1px solid;
    }

    .sl-alert-success {
        background: var(--green-bg);
        border-color: #bbf7d0;
        color: var(--green);
    }

    .sl-alert-danger {
        background: var(--red-bg);
        border-color: #fecaca;
        color: var(--red);
    }

    .sl-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        font-size: 16px;
        padding: 0;
    }

        .sl-alert-close:hover {
            opacity: 1;
        }

    @@media(max-width:1100px) {
        .sl-kpis {
            grid-template-columns: repeat(2,1fr);
        }

        .sl-title {
            font-size: 28px;
        }
    }

    @@media(max-width:700px) {
        .sl-root {
            padding: 16px;
        }

        .sl-hero {
            padding: 24px;
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="sl-root">

    @if (TempData["Success"] != null)
    {
        <div class="sl-alert sl-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="sl-alert-close" onclick="this.closest('.sl-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="sl-alert sl-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="sl-alert-close" onclick="this.closest('.sl-alert').remove()">&times;</button>
        </div>
    }

    <!-- ── HERO ── -->
    <div class="sl-hero">
        <div>
            <div class="sl-badge">HR Intelligence</div>
            <h1 class="sl-title">Staff List</h1>
            <p class="sl-sub">
                @if (isPlantManager)
                {
                    <span>Staff assigned to <strong>@plantLabel</strong> — plant session scoped view</span>
                }
                else
                {
                    <span>All staff across every plant &amp; center — admin overview</span>
                }
            </p>
        </div>
        <div style="flex-shrink:0;">
            <div style="font-size:11px;color:var(--muted);text-align:right;margin-bottom:6px;">Viewing as</div>
            <div style="font-size:14px;font-weight:700;color:var(--violet);">
                <i class="bi bi-person-badge"></i> @role
            </div>
            <div style="font-size:12px;color:var(--muted);margin-top:2px;">@plantLabel</div>
        </div>
    </div>

    <!-- ── KPI CARDS ── -->
    <div class="sl-kpis">

        <div class="sl-kpi blue">
            <div class="sl-kpi-label">Total Staff</div>
            <div class="sl-kpi-value">@Model.Summary.TotalStaff</div>
            <div class="sl-kpi-sub">Across @Model.Summary.TotalCenters center(s)</div>
        </div>

        <div class="sl-kpi green">
            <div class="sl-kpi-label">Active</div>
            <div class="sl-kpi-value">@Model.Summary.ActiveStaff</div>
            <div class="sl-kpi-sub">Currently working</div>
        </div>

        <div class="sl-kpi amber">
            <div class="sl-kpi-label">Inactive</div>
            <div class="sl-kpi-value">@Model.Summary.InactiveStaff</div>
            <div class="sl-kpi-sub">No longer active</div>
        </div>

        <div class="sl-kpi red">
            <div class="sl-kpi-label">Centers</div>
            <div class="sl-kpi-value">@Model.Summary.TotalCenters</div>
            <div class="sl-kpi-sub">Linked to @(isPlantManager? plantLabel : "all plants")</div>
        </div>

        <div class="sl-kpi violet">
            <div class="sl-kpi-label">Monthly Salary</div>
            <div class="sl-kpi-value" style="font-size:24px">
                ₹@Model.Summary.TotalMonthlySalary.ToString("N0")
            </div>
            <div class="sl-kpi-sub">Active staff total</div>
        </div>

    </div>

    <!-- ── PANEL ── -->
    <div class="sl-panel">

        <div class="sl-toolbar">

            <div class="sl-toolbar-left">
                <div class="sl-toolbar-title">Staff Directory</div>
                <div class="sl-count" id="visibleCount">@Model.Staff.Count</div>
            </div>

            <div class="sl-filters">
                <button class="sl-filter active" onclick="filterStaff('All', this)">All</button>
                <button class="sl-filter" onclick="filterStaff('Active', this)">Active</button>
                <button class="sl-filter" onclick="filterStaff('Inactive', this)">Inactive</button>
            </div>

            <div class="sl-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search name, role, center…"
                       oninput="searchStaff(this.value)" />
            </div>

        </div>

        @if (!Model.Staff.Any())
        {
            <div class="sl-empty">
                <div class="sl-empty-icon"><i class="bi bi-people"></i></div>
                <div class="sl-empty-title">No Staff Found</div>
                <div class="sl-empty-sub">
                    @if (isPlantManager)
                    {
                        <span>No staff members are linked to centers supplying <strong>@plantLabel</strong>.</span>
                    }
                    else
                    {
                        <span>No staff records found in the system.</span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="sl-table-wrap">
                <table class="sl-table" id="staffTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Staff Member</th>
                            <th>Center</th>
                            @if (!isPlantManager)
                            {
                                <th>Plant</th>
                            }
                            <th>Contact</th>
                            <th>Monthly Salary</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th>Last Payment</th>
                        </tr>
                    </thead>
                    <tbody id="staffBody">
                        @{
                            int rowNum = 0;
                            string lastPlant = "";
                        }
                        @foreach (var s in Model.Staff)
                        {
                            rowNum++;

                            // Show plant group header only in admin (all-plants) view
                            if (!isPlantManager && s.PlantName != lastPlant)
                            {
                                lastPlant = s.PlantName;
                                <tr class="sl-group-row" data-plant="@s.PlantName">
                                    <td colspan="9" class="sl-group-header">
                                        <i class="bi bi-building-gear"></i> @s.PlantName
                                    </td>
                                </tr>
                            }

                            string initials = string.Concat(s.FullName.Split(' ')
                            .Where(w => w.Length > 0)
                            .Take(2)
                            .Select(w => w[0]));

                            <tr class="sl-staff-row"
                                data-status="@(s.IsActive ? "Active" : "Inactive")"
                                data-plant="@s.PlantName"
                                data-search="@s.FullName.ToLower() @s.RoleName.ToLower() @s.CenterName.ToLower() @(s.Email?.ToLower()) @(s.Phone)">

                                <td>
                                    <span style="font-family:'DM Mono',monospace;font-size:12px;color:#94a3b8;">@rowNum</span>
                                </td>

                                <td>
                                    <div class="sl-avatar-wrap">
                                        <div class="sl-avatar">@initials</div>
                                        <div>
                                            <div class="sl-name">@s.FullName</div>
                                            <div class="sl-role">@(string.IsNullOrEmpty(s.RoleName) ? "—" : s.RoleName)</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="sl-center-tag">
                                        <i class="bi bi-geo-alt-fill" style="font-size:10px;"></i>
                                        @s.CenterName
                                    </span>
                                </td>

                                @if (!isPlantManager)
                                {
                                    <td>
                                        <span style="font-size:13px;color:var(--muted);">@s.PlantName</span>
                                    </td>
                                }

                                <td class="sl-contact">
                                    <div>@(string.IsNullOrEmpty(s.Email) ? "—" : s.Email)</div>
                                    <div class="contact-line">@(string.IsNullOrEmpty(s.Phone) ? "" : s.Phone)</div>
                                </td>

                                <td>
                                    @if (s.Salary.HasValue)
                                    {
                                        <span class="sl-salary">₹@s.Salary.Value.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="sl-salary-na">Not set</span>
                                    }
                                </td>

                                <td>
                                    <span class="sl-date">
                                        @(s.JoiningDate.HasValue? s.JoiningDate.Value.ToString("dd MMM yyyy") : "—")
                                    </span>
                                </td>

                                <td>
                                    <span class="sl-pill @s.StatusPillClass">
                                        @(s.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <td>
                                    @if (s.LastPaymentDate.HasValue)
                                    {
                                        <div>
                                            <span class="sl-pill @s.PaymentPillClass" style="margin-bottom:4px;display:inline-flex;">
                                                @s.LastPaymentStatus
                                            </span>
                                            <div class="sl-date" style="margin-top:4px;">
                                                @s.LastPaymentDate.Value.ToString("dd MMM yyyy")
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="sl-pill sl-pill-none">No payments</span>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>

</div>

<script>
    // ── Filter by status ─────────────────────────────────────────
    function filterStaff(status, btn) {
        document.querySelectorAll('.sl-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
    }

    // ── Search ───────────────────────────────────────────────────
    function searchStaff(query) {
        applyFilters();
    }

    // ── Combined apply ───────────────────────────────────────────
    function applyFilters() {
        const status = document.querySelector('.sl-filter.active')?.textContent?.trim() ?? 'All';
        const query  = (document.getElementById('searchInput')?.value ?? '').toLowerCase().trim();

        const rows   = document.querySelectorAll('.sl-staff-row');
        const groups = document.querySelectorAll('.sl-group-row');
        const visiblePlants = new Set();

        let visible = 0;

        rows.forEach(row => {
            const rowStatus  = row.dataset.status ?? '';
            const rowSearch  = row.dataset.search  ?? '';
            const rowPlant   = row.dataset.plant   ?? '';

            const statusMatch = status === 'All' || rowStatus === status;
            const searchMatch = !query || rowSearch.includes(query);

            if (statusMatch && searchMatch) {
                row.style.display = '';
                visible++;
                visiblePlants.add(rowPlant);
            } else {
                row.style.display = 'none';
            }
        });

        // Show group headers only if they have visible rows
        groups.forEach(g => {
            g.style.display = visiblePlants.has(g.dataset.plant) ? '' : 'none';
        });

        const countEl = document.getElementById('visibleCount');
        if (countEl) countEl.textContent = visible;
    }
</script>
