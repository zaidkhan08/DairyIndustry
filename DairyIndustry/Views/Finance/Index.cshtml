@model List<DairyIndustry.Models.Finance.FarmerPaymentModel>
@{
    ViewData["Title"] = "Farmer Payments";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #f6f9fc;
        --surface: #ffffff;
        --border: #e3e8ef;
        --border-s: #c8d0dc;
        --ink: #1a1f36;
        --ink-2: #3c4257;
        --ink-3: #697386;
        --ink-4: #a3acb9;
        --green: #09825d;
        --green-bg: #d7f7ee;
        --green-text: #0e6245;
        --amber: #9e6c00;
        --amber-bg: #fff8e1;
        --red: #a41c4e;
        --red-bg: #ffe4ed;
        --blue: #1a56db;
        --blue-bg: #e8f0fe;
        --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
        --shadow-lg: 0 8px 28px rgba(0,0,0,.12), 0 4px 12px rgba(0,0,0,.06);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    /* ════ MAIN ════ */
    .sp-main {
        padding: 24px 28px 60px;
        font-family: var(--font);
        font-size: 14px;
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
    }

    .sp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .sp-page-title {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--ink);
    }

    .sp-header-actions {
        display: flex;
        gap: 8px;
    }

    .btn-export {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 13px;
        border-radius: 5px;
        border: 1px solid var(--border-s);
        background: var(--surface);
        color: var(--ink-2);
        font-family: var(--font);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        box-shadow: var(--shadow-sm);
        transition: background .12s;
    }

        .btn-export:hover {
            background: #f8fafc;
        }

    .btn-create {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 13px;
        border-radius: 5px;
        border: 1px solid #1447c0;
        background: var(--blue);
        color: #fff;
        font-family: var(--font);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background .12s;
    }

        .btn-create:hover {
            background: #1447c0;
            color: #fff;
        }

    /* ── Alert ── */
    .sp-alert {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 14px;
        border: 1px solid transparent;
    }

        .sp-alert.success {
            background: var(--green-bg);
            color: var(--green-text);
            border-color: #a7f3d0;
        }

        .sp-alert.error {
            background: var(--red-bg);
            color: var(--red);
            border-color: #fca5a5;
        }

    .sp-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        font-size: 16px;
        padding: 0;
    }

    /* ── Tabs ── */
    .sp-tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
        margin-bottom: 14px;
    }

    .sp-tab {
        padding: 9px 16px;
        font-size: 13.5px;
        font-weight: 500;
        color: var(--ink-3);
        cursor: pointer;
        border: none;
        background: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color .12s;
        white-space: nowrap;
        font-family: var(--font);
    }

        .sp-tab:hover {
            color: var(--ink-2);
        }

        .sp-tab.active {
            color: var(--ink);
            font-weight: 600;
            border-bottom-color: var(--ink);
        }

    /* ── Filter bar ── */
    .sp-filterbar {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 12px;
        min-height: 30px;
    }

    .f-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        height: 26px;
        padding: 0 10px;
        border-radius: 100px;
        border: 1px solid var(--border-s);
        background: var(--surface);
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-2);
        box-shadow: var(--shadow-sm);
        white-space: nowrap;
    }

    .f-chip-x {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: rgba(0,0,0,.08);
        font-size: 9px;
        cursor: pointer;
        margin-left: 2px;
        border: none;
        color: inherit;
        font-family: var(--font);
        transition: background .1s;
    }

        .f-chip-x:hover {
            background: rgba(0,0,0,.18);
        }

    .f-add {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        height: 26px;
        padding: 0 10px;
        border-radius: 100px;
        border: 1px dashed var(--border-s);
        background: transparent;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-3);
        cursor: pointer;
        font-family: var(--font);
        transition: color .12s, border-color .12s;
    }

        .f-add:hover {
            color: var(--ink-2);
            border-color: var(--ink-3);
        }

    .f-clear {
        margin-left: auto;
        background: none;
        border: none;
        font-family: var(--font);
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-3);
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: color .12s, background .12s;
    }

        .f-clear:hover {
            color: var(--ink-2);
            background: var(--border);
        }

    /* ── Dropdown ── */
    .f-drop-wrap {
        position: relative;
    }

    .f-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        min-width: 210px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: var(--shadow-lg);
        z-index: 300;
        overflow: hidden;
        animation: dropIn .15s ease;
    }

    @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .f-dropdown.open {
        display: block;
    }

    .fd-head {
        padding: 10px 14px 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--ink-4);
        border-bottom: 1px solid var(--border);
    }

    .fd-list {
        padding: 4px 0;
    }

    .fd-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 14px;
        font-size: 13px;
        color: var(--ink-2);
        cursor: pointer;
        transition: background .1s;
        user-select: none;
    }

        .fd-item:hover {
            background: #f5f7fa;
        }

        .fd-item input[type="checkbox"] {
            width: 14px;
            height: 14px;
            accent-color: var(--blue);
            flex-shrink: 0;
            cursor: pointer;
        }

    .fd-apply {
        display: block;
        width: calc(100% - 16px);
        margin: 8px;
        padding: 8px;
        background: #0a2540;
        color: #fff;
        border: none;
        border-radius: 5px;
        font-family: var(--font);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: background .12s;
    }

        .fd-apply:hover {
            background: #0d3066;
        }

    /* ── Panel ── */
    .sp-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    /* ════ TABLE ════ */
    .sp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .sp-table thead tr {
            border-bottom: 1px solid var(--border);
        }

        .sp-table thead th {
            padding: 10px 16px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--ink-4);
            text-align: left;
            white-space: nowrap;
            background: #fafbfc;
        }

            .sp-table thead th.col-right {
                text-align: right;
            }

            .sp-table thead th:last-child {
                text-align: right;
            }

        .sp-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .1s;
        }

            .sp-table tbody tr:last-child {
                border-bottom: none;
            }

            .sp-table tbody tr:hover {
                background: #f9fafc;
            }

            .sp-table tbody tr.row-cancelled {
                opacity: .5;
            }

        .sp-table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            color: var(--ink-2);
        }

            .sp-table tbody td.col-right {
                text-align: right;
            }

            .sp-table tbody td:last-child {
                text-align: right;
            }

    .td-main {
        font-weight: 600;
        color: var(--ink);
        font-size: 13.5px;
    }

    .td-sub {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 3px;
        font-size: 11.5px;
        color: var(--ink-4);
    }

    .ref-tag {
        font-family: 'SF Mono', Consolas, monospace;
        font-size: 11px;
        font-weight: 500;
        background: #f3f4f6;
        color: var(--ink-3);
        padding: 1px 6px;
        border-radius: 3px;
    }

    .td-center-name {
        font-weight: 500;
        color: var(--ink-2);
        font-size: 13px;
    }

    .td-date {
        font-size: 12px;
        color: var(--ink-4);
        margin-top: 3px;
    }

    .td-num {
        font-variant-numeric: tabular-nums;
        font-weight: 600;
        color: var(--ink);
        font-size: 13.5px;
    }

    .td-unit {
        font-size: 11.5px;
        color: var(--ink-4);
        font-weight: 400;
        margin-left: 2px;
    }

    .td-dash {
        color: var(--ink-4);
    }

    .td-amount {
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        color: var(--ink);
        font-size: 13.5px;
    }

    .td-inr {
        font-size: 11.5px;
        color: var(--ink-4);
        font-weight: 400;
        margin-left: 2px;
    }

    /* ── Status badge ── */
    .sp-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

        .sp-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

    .badge-processed {
        background: var(--green-bg);
        color: var(--green-text);
    }

        .badge-processed::before {
            background: #1fad79;
        }

    .badge-pending {
        background: var(--amber-bg);
        color: var(--amber);
    }

        .badge-pending::before {
            background: #f59e0b;
        }

    .badge-failed {
        background: var(--red-bg);
        color: var(--red);
    }

        .badge-failed::before {
            background: #e5344a;
        }

    .badge-cancelled {
        background: #f3f4f6;
        color: var(--ink-3);
    }

        .badge-cancelled::before {
            background: #9ca3af;
        }

    /* ── 3-dot menu ── */
    .row-action-wrap {
        position: relative;
        display: flex;
        justify-content: flex-end;
    }

    .act-more {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 5px;
        border: 1px solid var(--border-s);
        background: var(--surface);
        color: var(--ink-3);
        cursor: pointer;
        font-size: 14px;
        font-weight: 700;
        font-family: var(--font);
        letter-spacing: 1px;
        transition: background .1s, border-color .1s;
        box-shadow: var(--shadow-sm);
    }

        .act-more:hover {
            background: #f3f4f6;
            color: var(--ink);
        }

    .act-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 5px);
        right: 0;
        min-width: 148px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 7px;
        box-shadow: var(--shadow-lg);
        z-index: 400;
        overflow: hidden;
        animation: dropIn .14s ease;
    }

        .act-dropdown.open {
            display: block;
        }

    .act-dd-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 13px;
        font-size: 13px;
        font-weight: 500;
        color: var(--ink-2);
        cursor: pointer;
        text-decoration: none;
        font-family: var(--font);
        background: none;
        border: none;
        width: 100%;
        text-align: left;
        transition: background .1s;
    }

        .act-dd-item:hover {
            background: #f5f7fa;
            color: var(--ink);
        }

        .act-dd-item.danger {
            color: var(--red);
        }

            .act-dd-item.danger:hover {
                background: var(--red-bg);
            }

    .act-dd-divider {
        height: 1px;
        background: var(--border);
        margin: 3px 0;
    }

    /* ── Empty ── */
    .sp-empty {
        padding: 56px 20px;
        text-align: center;
        color: var(--ink-3);
    }

    .sp-empty-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 18px;
        color: var(--ink-4);
    }

    .sp-empty strong {
        display: block;
        font-size: 14px;
        color: var(--ink-2);
        margin-bottom: 4px;
    }

    .sp-empty p {
        font-size: 12.5px;
        max-width: 240px;
        margin: 0 auto;
    }

    /* ── Table footer + pagination ── */
    .sp-tf {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-top: 1px solid var(--border);
        background: #fafbfc;
        font-size: 12.5px;
        color: var(--ink-3);
        flex-wrap: wrap;
        gap: 8px;
    }

    .sp-pager {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .pg-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 28px;
        min-width: 28px;
        padding: 0 9px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: var(--surface);
        font-family: var(--font);
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-3);
        cursor: pointer;
        text-decoration: none;
        transition: all .1s;
        box-shadow: var(--shadow-sm);
        user-select: none;
    }

        .pg-btn:hover:not(.disabled):not(.active) {
            background: #f3f4f6;
            color: var(--ink);
        }

        .pg-btn.active {
            background: var(--ink);
            border-color: var(--ink);
            color: #fff;
            cursor: default;
        }

        .pg-btn.disabled {
            opacity: .35;
            cursor: not-allowed;
            pointer-events: none;
        }

    .pg-ellipsis {
        padding: 0 4px;
        color: var(--ink-4);
        font-size: 12px;
        line-height: 28px;
    }

    /* ── Wallet loader ── */
    .cw-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 64px 20px;
        gap: 14px;
        color: var(--ink-3);
    }

    .cw-spinner {
        width: 32px;
        height: 32px;
        border: 3px solid var(--border);
        border-top-color: var(--blue);
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ── Modals ── */
    .sp-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(26,31,54,.4);
        backdrop-filter: blur(3px);
        z-index: 500;
        align-items: center;
        justify-content: center;
    }

        .sp-overlay.open {
            display: flex;
        }

    .sp-modal {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 22px;
        width: 100%;
        max-width: 370px;
        box-shadow: var(--shadow-lg);
        animation: modalIn .18s ease;
    }

    @@keyframes modalIn {
        from {
            opacity: 0;
            transform: translateY(8px) scale(.98);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .sp-modal-icon {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

        .sp-modal-icon.danger {
            background: var(--red-bg);
            color: var(--red);
        }

    .sp-modal-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 6px;
    }

    .sp-modal-body {
        font-size: 13px;
        color: var(--ink-3);
        line-height: 1.55;
        margin-bottom: 14px;
    }

        .sp-modal-body strong {
            color: var(--ink-2);
        }

    .sp-modal-warn {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 9px 12px;
        background: var(--amber-bg);
        border: 1px solid #fde68a;
        border-radius: 6px;
        font-size: 12px;
        color: var(--amber);
        font-weight: 500;
        margin-bottom: 16px;
        line-height: 1.5;
    }

    .sp-modal-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .sp-modal-cancel {
        padding: 7px 13px;
        background: var(--surface);
        border: 1px solid var(--border-s);
        border-radius: 5px;
        font-family: var(--font);
        font-size: 13px;
        font-weight: 500;
        color: var(--ink-2);
        cursor: pointer;
        transition: background .1s;
    }

        .sp-modal-cancel:hover {
            background: #f3f4f6;
        }

    .sp-modal-danger {
        padding: 7px 13px;
        background: #e5344a;
        border: 1px solid #c8263b;
        border-radius: 5px;
        font-family: var(--font);
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        transition: background .1s;
    }

        .sp-modal-danger:hover {
            background: #c8263b;
        }

    @@media (max-width: 860px) {
        .sp-main {
            padding: 16px 14px 40px;
        }
    }
</style>

@{
    var totalCount = Model.Count;
    var processedCount = Model.Count(x => x.PaymentStatus == "Processed");
    var pendingCount = Model.Count(x => x.PaymentStatus == "Pending");
    var failedCount = Model.Count(x => x.PaymentStatus == "Failed");
    var cancelledCount = Model.Count(x => x.PaymentStatus == "Cancelled");
}

<div class="sp-main">

    <!-- ── FARMER PAYMENTS SECTION ── -->
    <div id="section-farmer">

        <div class="sp-header">
            <h1 class="sp-page-title">Farmer Payments</h1>
            <div class="sp-header-actions">
                <button class="btn-export">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    Export
                </button>
                <a asp-action="Create" class="btn-create">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Create Payment
                </a>
            </div>
        </div>

        @if (TempData["Success"] != null || TempData["Error"] != null)
        {
            var isSuccess = TempData["Success"] != null;
            <div class="sp-alert @(isSuccess ? "success" : "error")">
                <i class="bi @(isSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                @((TempData["Success"] ?? TempData["Error"]).ToString())
                <button class="sp-alert-close" onclick="this.closest('.sp-alert').remove()">&#x2715;</button>
            </div>
        }

        <!-- Tabs -->
        <div class="sp-tabs">
            <button class="sp-tab active" onclick="setTab('', this)">
                All <span style="font-size:11px;color:var(--ink-4);margin-left:4px;">@totalCount</span>
            </button>
            <button class="sp-tab" onclick="setTab('Processed', this)">
                Succeeded <span style="font-size:11px;color:var(--ink-4);margin-left:4px;">@processedCount</span>
            </button>
            <button class="sp-tab" onclick="setTab('Pending', this)">
                Pending <span style="font-size:11px;color:var(--ink-4);margin-left:4px;">@pendingCount</span>
            </button>
            <button class="sp-tab" onclick="setTab('Failed', this)">
                Failed <span style="font-size:11px;color:var(--ink-4);margin-left:4px;">@failedCount</span>
            </button>
            <button class="sp-tab" onclick="setTab('Cancelled', this)">
                Cancelled <span style="font-size:11px;color:var(--ink-4);margin-left:4px;">@cancelledCount</span>
            </button>
        </div>

        <!-- Filter bar -->
        <div class="sp-filterbar" id="filterBar">
            <div class="f-drop-wrap">
                <button class="f-add" onclick="toggleDrop('statusDrop')">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Status
                </button>
                <div class="f-dropdown" id="statusDrop">
                    <div class="fd-head">Filter by status</div>
                    <div class="fd-list">
                        @foreach (var s in new[] { "Processed", "Pending", "Failed", "Cancelled" })
                        {
                            <label class="fd-item"><input type="checkbox" class="fd-s-cb" value="@s"> @s</label>
                        }
                    </div>
                    <button class="fd-apply" onclick="applyStatus()">Apply</button>
                </div>
            </div>
            <button class="f-clear" id="clearBtn" style="display:none;" onclick="clearAll()">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
                Clear filter
            </button>
        </div>

        <!-- Panel -->
        <div class="sp-panel">
            <div style="overflow-x:auto;">
                <table class="sp-table">
                    <thead>
                        <tr>
                            <th>Farmer / Ref</th>
                            <th>Center &amp; Period</th>
                            <th class="col-right">Qty (L)</th>
                            <th class="col-right">Amount</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="sp-empty">
                                        <div class="sp-empty-icon"><i class="bi bi-inbox"></i></div>
                                        <strong>No records found</strong>
                                        <p>No payment records match your current filters.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var p in Model)
                        {
                            var badgeClass = p.PaymentStatus?.ToLower() switch
                            {
                                "processed" => "badge-processed",
                                "pending" => "badge-pending",
                                "failed" => "badge-failed",
                                "cancelled" => "badge-cancelled",
                                _ => "badge-failed"
                            };

                            bool canCancel = p.PaymentStatus == "Pending" || p.PaymentStatus == "Failed";
                            bool canPrint = p.PaymentStatus == "Processed";

                            <tr class="@(p.PaymentStatus == "Cancelled" ? "row-cancelled" : "")"
                                data-status="@p.PaymentStatus">

                                <!-- Farmer / Ref -->
                                <td>
                                    <div class="td-main">@p.FarmerName</div>
                                    <div class="td-sub">
                                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="3" width="18" height="18" rx="2" />
                                            <path d="M3 9h18" />
                                        </svg>
                                        <span class="ref-tag">FP-@p.PaymentId</span>
                                        @if (!string.IsNullOrEmpty(p.TransactionReference))
                                        {
                                            <span>·</span>
                                            <span class="ref-tag">@p.TransactionReference</span>
                                        }
                                    </div>
                                </td>

                                <!-- Center & Period -->
                                <td>
                                    <div class="td-center-name">
                                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:3px;vertical-align:middle;">
                                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                        @p.CenterName
                                    </div>
                                    <div class="td-date">
                                        @p.FromDate.ToString("dd MMM yyyy") → @p.ToDate.ToString("dd MMM yyyy")
                                    </div>
                                </td>

                                <!-- Qty -->
                                <td class="col-right">
                                    <span class="td-num">@p.TotalQty.ToString("N1")</span>
                                    <span class="td-unit">L</span>
                                </td>

                                <!-- Amount -->
                                <td class="col-right">
                                    <span class="td-amount">₹@p.TotalAmount.ToString("N2")</span>
                                </td>

                                <!-- Status -->
                                <td>
                                    <span class="sp-badge @badgeClass">@p.PaymentStatus</span>
                                    @if (!string.IsNullOrEmpty(p.BankStatus) && p.BankStatus != p.PaymentStatus)
                                    {
                                        <div style="font-size:11px;color:var(--ink-4);margin-top:3px;">Bank: @p.BankStatus</div>
                                    }
                                </td>

                                <!-- Actions -->
                                <td>
                                    <div class="row-action-wrap">
                                        <button class="act-more" onclick="toggleActDrop(event, this)">···</button>
                                        <div class="act-dropdown">
                                            <a class="act-dd-item" asp-action="Detail" asp-route-id="@p.PaymentId">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                    <circle cx="12" cy="12" r="3" />
                                                </svg>
                                                View
                                            </a>

                                            @if (canPrint)
                                            {
                                                <a class="act-dd-item" asp-action="ViewReceipt" asp-route-id="@p.PaymentId" target="_blank" rel="noopener">
                                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <polyline points="6 9 6 2 18 2 18 9" />
                                                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                                                        <rect x="6" y="14" width="12" height="8" />
                                                    </svg>
                                                    Print receipt
                                                </a>
                                            }

                                            @if (canCancel)
                                            {
                                                <div class="act-dd-divider"></div>
                                                <button class="act-dd-item danger"
                                                        onclick="openCancel(@p.PaymentId,'FP-@p.PaymentId','@Html.Raw(p.FarmerName?.Replace("'", "\\'"))')">
                                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <circle cx="12" cy="12" r="10" />
                                                        <line x1="15" y1="9" x2="9" y2="15" />
                                                        <line x1="9" y1="9" x2="15" y2="15" />
                                                    </svg>
                                                    Cancel
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Table footer with pagination -->
            <div class="sp-tf">
                <span id="recordCount">@Model.Count result@(Model.Count != 1 ? "s" : "")</span>
                <div class="sp-pager" id="pagerContainer"></div>
            </div>
        </div>
    </div>

    <!-- ── CENTER WALLET SECTION ── -->
    <div id="section-center" style="display:none;">
        <div id="cw-container"></div>
    </div>

</div>

<!-- CANCEL MODAL -->
<div class="sp-overlay" id="cancelOverlay">
    <div class="sp-modal">
        <div class="sp-modal-icon danger">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="15" y1="9" x2="9" y2="15" />
                <line x1="9" y1="9" x2="15" y2="15" />
            </svg>
        </div>
        <div class="sp-modal-title">Cancel Payment</div>
        <div class="sp-modal-body">
            You are about to cancel <strong id="cancelRef"></strong> for <strong id="cancelFarmer"></strong>.
        </div>
        <div class="sp-modal-warn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            Cancelled payments cannot be reactivated. A new payment can be created for the same farmer.
        </div>
        <div class="sp-modal-actions">
            <button class="sp-modal-cancel" onclick="closeModals()">Keep Payment</button>
            <form id="cancelForm" asp-action="CancelFarmerPayment" method="post" style="margin:0;">
                <input type="hidden" name="paymentId" id="cancelId" />
                <button type="submit" class="sp-modal-danger">Yes, Cancel It</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── State ─────────────────────────────────────────────────
        const PAGE_SIZE     = 15;
        let activeTabStatus = '';
        let chipStatuses    = [];
        let currentPage     = 1;
        let cwLoaded        = false;
        let visibleRows     = [];

        // ── Collect all rows once ─────────────────────────────────
        function getAllRows() {
            return [...document.querySelectorAll('#tableBody tr[data-status]')];
        }

        // ── Tabs ──────────────────────────────────────────────────
        function setTab(status, el) {
            activeTabStatus = status;
            chipStatuses    = [];
            currentPage     = 1;
            document.querySelectorAll('.fd-s-cb').forEach(c => c.checked = false);
            document.querySelectorAll('.sp-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            renderChips();
            run();
        }

        // ── Filter dropdowns ──────────────────────────────────────
        function toggleDrop(id) {
            const dd  = document.getElementById(id);
            const was = dd.classList.contains('open');
            document.querySelectorAll('.f-dropdown').forEach(d => d.classList.remove('open'));
            if (!was) dd.classList.add('open');
        }
        document.addEventListener('click', e => {
            if (!e.target.closest('.f-drop-wrap'))
                document.querySelectorAll('.f-dropdown').forEach(d => d.classList.remove('open'));
        });

        function applyStatus() {
            chipStatuses = [...document.querySelectorAll('.fd-s-cb:checked')].map(c => c.value);
            currentPage  = 1;
            document.getElementById('statusDrop').classList.remove('open');
            renderChips();
            run();
        }

        function clearAll() {
            chipStatuses = [];
            document.querySelectorAll('.fd-s-cb').forEach(c => c.checked = false);
            currentPage = 1;
            renderChips();
            run();
        }

        // ── Chips ─────────────────────────────────────────────────
        function renderChips() {
            const bar    = document.getElementById('filterBar');
            const anchor = bar.querySelector('.f-drop-wrap');
            bar.querySelectorAll('.f-chip').forEach(c => c.remove());
            chipStatuses.forEach(s => bar.insertBefore(makeChip('Status: ' + s, () => {
                chipStatuses = chipStatuses.filter(x => x !== s);
                document.querySelectorAll('.fd-s-cb').forEach(cb => { if (cb.value === s) cb.checked = false; });
                currentPage = 1;
                renderChips(); run();
            }), anchor));
            document.getElementById('clearBtn').style.display = chipStatuses.length ? '' : 'none';
        }

        function makeChip(label, removeFn) {
            const c = document.createElement('span');
            c.className = 'f-chip';
            c.innerHTML = `${label}<button class="f-chip-x">✕</button>`;
            c.querySelector('.f-chip-x').addEventListener('click', removeFn);
            return c;
        }

        // ── Core filter + paginate ────────────────────────────────
        function run() {
            const rows = getAllRows();

            visibleRows = rows.filter(row => {
                const matchTab  = !activeTabStatus || row.dataset.status === activeTabStatus;
                const matchChip = !chipStatuses.length || chipStatuses.includes(row.dataset.status);
                return matchTab && matchChip;
            });

            rows.forEach(r => r.style.display = 'none');

            const totalPages = Math.max(1, Math.ceil(visibleRows.length / PAGE_SIZE));
            if (currentPage > totalPages) currentPage = totalPages;

            const start = (currentPage - 1) * PAGE_SIZE;
            const end   = start + PAGE_SIZE;
            visibleRows.slice(start, end).forEach(r => r.style.display = '');

            document.getElementById('recordCount').textContent =
                `${visibleRows.length} result${visibleRows.length !== 1 ? 's' : ''}`;

            renderPager(totalPages);
        }

        // ── Pagination renderer ───────────────────────────────────
        function renderPager(totalPages) {
            const container = document.getElementById('pagerContainer');
            container.innerHTML = '';
            if (totalPages <= 1) return;

            function mkBtn(label, page, cls) {
                const b = document.createElement('button');
                b.className = 'pg-btn' + (cls ? ' ' + cls : '');
                b.innerHTML = label;
                if (!cls || (!cls.includes('disabled') && !cls.includes('active'))) {
                    b.addEventListener('click', () => { currentPage = page; run(); });
                }
                return b;
            }

            container.appendChild(mkBtn('← Prev', currentPage - 1,
                currentPage === 1 ? 'disabled' : ''));

            const pages = getPageRange(currentPage, totalPages);
            let prevP = null;
            pages.forEach(p => {
                if (prevP !== null && p - prevP > 1) {
                    const el = document.createElement('span');
                    el.className = 'pg-ellipsis'; el.textContent = '…';
                    container.appendChild(el);
                }
                container.appendChild(mkBtn(p, p, p === currentPage ? 'active' : ''));
                prevP = p;
            });

            container.appendChild(mkBtn('Next →', currentPage + 1,
                currentPage === totalPages ? 'disabled' : ''));
        }

        function getPageRange(current, total) {
            if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
            const pages = new Set([1, total, current]);
            if (current > 1) pages.add(current - 1);
            if (current < total) pages.add(current + 1);
            return [...pages].sort((a, b) => a - b);
        }

        // ── 3-dot action dropdown ─────────────────────────────────
        function toggleActDrop(e, btn) {
            e.stopPropagation();
            const dd  = btn.nextElementSibling;
            const was = dd.classList.contains('open');
            closeAllActDrops();
            if (!was) dd.classList.add('open');
        }
        function closeAllActDrops() {
            document.querySelectorAll('.act-dropdown.open').forEach(d => d.classList.remove('open'));
        }
        document.addEventListener('click', () => closeAllActDrops());
        document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModals(); closeAllActDrops(); } });

        // ── Modals ────────────────────────────────────────────────
        function openCancel(id, ref, name) {
            closeAllActDrops();
            document.getElementById('cancelId').value           = id;
            document.getElementById('cancelRef').textContent    = ref;
            document.getElementById('cancelFarmer').textContent = name;
            document.getElementById('cancelOverlay').classList.add('open');
        }
        function closeModals() {
            document.querySelectorAll('.sp-overlay').forEach(o => o.classList.remove('open'));
        }
        document.querySelectorAll('.sp-overlay').forEach(o => {
            o.addEventListener('click', e => { if (e.target === o) closeModals(); });
        });

        // ── Init ──────────────────────────────────────────────────
        run();
    </script>
}
