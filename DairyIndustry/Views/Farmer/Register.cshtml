@model DairyIndustry.Models.FarmerModel.SelfRegisterViewModel

@{
    ViewData["Title"] = "Farmer Registration";
    Layout = "_DairyLayout"; // public page — no staff/farmer layout needed
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Farmer Registration</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">

                <div class="text-center mb-4">
                    <h3 class="fw-bold">Farmer Registration</h3>
                    <p class="text-muted mb-1">
                        Register yourself to start delivering milk at your nearest collection center.
                    </p>
                    <small>
                        Already registered?
                        <a asp-controller="Farmer" asp-action="Login">Login here</a>
                        &nbsp;|&nbsp;
                        <a asp-controller="Farmer" asp-action="CheckStatus">Check your status</a>
                    </small>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-controller="Farmer" asp-action="Register" method="post"
                      id="regForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="card mb-3">
                        <div class="card-header bg-white">
                            <strong>Personal Details</strong>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label">
                                        Full Name <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="FarmerName"
                                           class="form-control"
                                           placeholder="Enter your full name" />
                                    <span asp-validation-for="FarmerName"
                                          class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">
                                        Mobile Number <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Phone"
                                           class="form-control"
                                           placeholder="10-digit mobile number"
                                           maxlength="10" />
                                    <div class="form-text">
                                        Last 4 digits of your mobile will be your default login password.
                                    </div>
                                    <span asp-validation-for="Phone"
                                          class="text-danger small"></span>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header bg-white">
                            <strong>Location</strong>
                           
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label">
                                        State <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="StateId"
                                            id="StateId"
                                            class="form-select">
                                        <option value="">-- Select State --</option>
                                        @foreach (var s in Model.States)
                                        {
                                            <option value="@s.StateId"
                                                    selected="@(Model.StateId == s.StateId)">
                                                @s.StateName
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">
                                        City <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="CityId"
                                            id="CityId"
                                            class="form-select">
                                        <option value="">-- Select State --</option>
                                        @if (Model.Cities != null)
                                        {
                                            @foreach (var c in Model.Cities)
                                            {
                                                <option value="@c.CityId"
                                                        selected="@(Model.CityId == c.CityId)">
                                                    @c.CityName
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">
                                        Village <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="VillageId"
                                            id="VillageId"
                                            class="form-select">
                                        <option value="">-- Select City --</option>
                                        @if (Model.Villages != null)
                                        {
                                            @foreach (var v in Model.Villages)
                                            {
                                                <option value="@v.VillageId"
                                                        selected="@(Model.VillageId == v.VillageId)">
                                                    @v.VillageName
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">
                                        Collection Center <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="CenterId"
                                            id="CenterId"
                                            class="form-select">
                                        <option value="">-- Select Village --</option>
                                        @if (Model.Centers != null)
                                        {
                                            @foreach (var c in Model.Centers)
                                            {
                                                <option value="@c.CenterId"
                                                        selected="@(Model.CenterId == c.CenterId)">
                                                    @c.CenterName
                                                    @(!string.IsNullOrEmpty(c.Location) ? "— " + c.Location : "")
                                                </option>
                                            }
                                        }
                                    </select>
                                    @* Shown by JS when no centers found in selected village *@
                                    <div id="noCenterMsg"
                                         class="alert alert-warning mt-2 mb-0 d-none">
                                        No collection center found in your village.
                                        Please visit the nearest center and ask staff to register you.
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header bg-white">
                            <strong>Bank Details</strong>
                            <small class="text-muted ms-2 fw-normal">
                                Optional — can be added later at the collection center
                            </small>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                <div class="col-md-4">
                                    <label class="form-label">Bank Name</label>
                                    <input asp-for="BankName"
                                           class="form-control"
                                           placeholder="e.g. State Bank of India" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Account Number</label>
                                    <input asp-for="AccountNumber"
                                           class="form-control"
                                           placeholder="Enter account number" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">IFSC Code</label>
                                    <input asp-for="IFSCCode"
                                           class="form-control"
                                           placeholder="e.g. SBIN0001234" />
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-controller="Farmer"
                           asp-action="Register"
                           class="btn btn-outline-secondary">
                             Reset
                        </a>
                        <button type="submit" class="btn btn-success px-5">
                            Submit Registration
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        // ?? Helper: reset a dropdown to placeholder 
        function resetDropdown(selector, placeholder) {
            $(selector).html('<option value="">' + placeholder + '</option>');
        }

        // ?? STATE ? CITY 
        $('#StateId').on('change', function () {
            var stateId = $(this).val();

            resetDropdown('#CityId',    '-- Select City --');
            resetDropdown('#VillageId', '-- Select City first --');
            resetDropdown('#CenterId',  '-- Select Village first --');
            $('#noCenterMsg').addClass('d-none');

            if (!stateId) return;

            $.get('/Farmer/GetCities', { stateId: stateId }, function (data) {
                var dd = $('#CityId').empty();
                dd.append('<option value="">-- Select City --</option>');
                $.each(data, function (i, c) {
                    dd.append('<option value="' + c.cityId + '">' + c.cityName + '</option>');
                });
            });
        });

        // ?? CITY 
        $('#CityId').on('change', function () {
            var cityId = $(this).val();

            resetDropdown('#VillageId', '-- Select Village --');
            resetDropdown('#CenterId',  '-- Select Village first --');
            $('#noCenterMsg').addClass('d-none');

            if (!cityId) return;

            $.get('/Farmer/GetVillages', { cityId: cityId }, function (data) {
                var dd = $('#VillageId').empty();
                dd.append('<option value="">-- Select Village --</option>');
                $.each(data, function (i, v) {
                    dd.append('<option value="' + v.villageId + '">' + v.villageName + '</option>');
                });
            });
        });

        // ?? VILLAGE ? CENTER 
        $('#VillageId').on('change', function () {
            var villageId = $(this).val();

            resetDropdown('#CenterId', '-- Select Center --');
            $('#noCenterMsg').addClass('d-none');

            if (!villageId) return;

            $.get('/Farmer/GetCenters', { villageId: villageId }, function (data) {
                var dd = $('#CenterId').empty();

                if (data.length === 0) {
                    dd.append('<option value="">No centers available</option>');
                    $('#noCenterMsg').removeClass('d-none');
                    return;
                }

                dd.append('<option value="">-- Select Center --</option>');
                $.each(data, function (i, c) {
                    var label = c.centerName + (c.location ? ' — ' + c.location : '');
                    dd.append('<option value="' + c.centerId + '">' + label + '</option>');
                });
            });
        });

        // ?? CLIENT-SIDE VALIDATION BEFORE SUBMIT ?????????????????
        $('#regForm').on('submit', function (e) {
            var ok = true;
            var msg = [];

            if (!$('#regForm [name="FarmerName"]').val().trim())  { msg.push('Full Name is required.');            ok = false; }
            if ($('#regForm [name="Phone"]').val().trim().length !== 10) { msg.push('Valid 10-digit mobile number is required.'); ok = false; }
            if (!$('#StateId').val())   { msg.push('Please select a State.');             ok = false; }
            if (!$('#CityId').val())    { msg.push('Please select a City.');              ok = false; }
            if (!$('#VillageId').val()) { msg.push('Please select a Village.');           ok = false; }
            if (!$('#CenterId').val())  { msg.push('Please select a Collection Center.'); ok = false; }

            if (!ok) {
                e.preventDefault();
                var errDiv = $('<div class="alert alert-danger alert-dismissible mb-3">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    msg.join('<br />') +
                    '</div>');
                $('#regForm').before(errDiv);
                window.scrollTo(0, 0);
            }
        });

    </script>

</body>
</html>
