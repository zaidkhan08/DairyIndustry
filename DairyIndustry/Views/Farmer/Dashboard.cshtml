@model DairyIndustry.Models.FarmerModel.FarmerDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_FarmerLayout";

    var farmerName = Context.Session.GetString("FarmerName");
    var farmerCode = Context.Session.GetString("FarmerCode");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid py-4" style="background:#f8fafc;">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h4 class="fw-bold mb-1">
                Good Morning, @farmerName 
            </h4>

            <p class="text-muted small mb-0">
                Here’s your milk collection overview for today
            </p>

            <span class="badge bg-light text-dark border mt-2">
                Farmer Code: @farmerCode
            </span>
        </div>

        <div class="text-muted small">
            <i class="bi bi-calendar3"></i>
            @DateTime.Today.ToString("dd MMM yyyy")
        </div>

    </div>

    <!-- ================= TODAY SUMMARY ================= -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <h6 class="fw-bold text-dark mb-3">Today’s Milk Summary</h6>

            <div class="row g-3">

                <div class="col-md-3">
                    <div class="p-3 bg-light rounded-3">
                        <small class="text-muted">Morning</small>
                        <h5 class="mb-0">@Model.TodayMorningQty.ToString("F2") L</h5>
                        <small class="text-success">₹@Model.TodayMorningAmount.ToString("N0")</small>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-light rounded-3">
                        <small class="text-muted">Evening</small>
                        <h5 class="mb-0">@Model.TodayEveningQty.ToString("F2") L</h5>
                        <small class="text-success">₹@Model.TodayEveningAmount.ToString("N0")</small>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-light rounded-3 border">
                        <small class="text-muted">Total Today</small>
                        <h5 class="mb-0 fw-bold">
                            @Model.TodayTotalQty.ToString("F2") L
                        </h5>
                        <small class="text-success">
                            ₹@Model.TodayTotalAmount.ToString("N0")
                        </small>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-light rounded-3">
                        <small class="text-muted">Avg Rate</small>
                        <h5 class="mb-0">
                            ₹@(Model.TodayTotalQty > 0
                                                        ? (Model.TodayTotalAmount / Model.TodayTotalQty)
                                                        : 0)
                        </h5>
                        <small class="text-muted">per liter</small>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ================= FINANCIAL SUMMARY ================= -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <small class="text-muted">This Month Earnings</small>
                    <h4 class="text-success fw-bold">₹@Model.MonthTotalAmount.ToString("N0")</h4>
                    <p class="text-muted small mb-0">@Model.MonthTotalQty.ToString("F2") L collected</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 border-start border-warning border-4">
                <div class="card-body">
                    <small class="text-muted">Pending Payment</small>
                    <h4 class="text-warning fw-bold">₹@Model.PendingAmount.ToString("N2")</h4>
                    <p class="text-muted small mb-0">To be processed</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 border-start border-success border-4">
                <div class="card-body">
                    <small class="text-muted">Last Payment</small>

                    @if (Model.LastPaymentAmount.HasValue)
                    {
                        <h4 class="text-success fw-bold">
                            ₹@Model.LastPaymentAmount.Value.ToString("N2")
                        </h4>
                        <p class="text-muted small mb-0">
                            @Model.LastPaymentDate?.ToString("dd MMM yyyy")
                        </p>
                    }
                    else
                    {
                        <h4 class="text-muted">No Payment</h4>
                    }

                </div>
            </div>
        </div>

    </div>

    <!-- ================= REJECTION ALERT ================= -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h6 class="text-danger fw-bold mb-1">⚠ Rejections (Last 30 Days)</h6>

                <p class="mb-0 text-muted small">
                    Total: <b>@Model.TotalRejectionsLast30Days</b> |
                    Lost Milk: <b>@Model.TotalRejectedQtyLast30Days.ToString("F1") L</b>
                </p>
            </div>

            <a asp-action="RejectionHistory" class="btn btn-outline-danger btn-sm rounded-pill">
                View Details
            </a>

        </div>
    </div>

    <!-- ================= RECENT ACTIONS ================= -->
    <h6 class="fw-bold text-muted mb-3">Quick Actions</h6>

    <div class="row g-2 mb-4">

        <div class="col-6 col-md-3">
            <a asp-action="TodayMilk" class="btn btn-light border w-100 py-3 shadow-sm rounded-3">
                <i class="bi bi-droplet text-primary"></i><br />Today Milk
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a asp-action="AllMilkEntries" class="btn btn-light border w-100 py-3 shadow-sm rounded-3">
                <i class="bi bi-list-ul text-primary"></i><br />History
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a asp-action="RejectionHistory" class="btn btn-light border w-100 py-3 shadow-sm rounded-3">
                <i class="bi bi-x-circle text-danger"></i><br />Rejections
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a asp-action="Profile" class="btn btn-light border w-100 py-3 shadow-sm rounded-3">
                <i class="bi bi-person text-primary"></i><br />Profile
            </a>
        </div>

    </div>

</div>