@model DairyIndustry.Models.FarmerModel.FarmerDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_FarmerLayout";
    var farmerName = Context.Session.GetString("FarmerName");
    var farmerCode = Context.Session.GetString("FarmerCode");
}

<div class="container py-4">
    <!-- Header Section -->
    <div class="row align-items-center mb-4">
        <div class="col">
            <h4 class="mb-0 fw-bold">Hello, @farmerName</h4>
            <span class="badge bg-secondary">ID: @farmerCode</span>
        </div>
        <div class="col-auto text-end text-muted small">
            <i class="bi bi-calendar3"></i> @DateTime.Today.ToString("dd MMM yyyy")
        </div>
    </div>

    <!-- Collection Section -->
    <h6 class="text-uppercase text-muted fw-bold mb-3 small" style="letter-spacing: 1px;">Collection Summary</h6>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body p-3">
                    <p class="text-muted small mb-1">Morning</p>
                    <h5 class="mb-0">@Model.TodayMorningQty.ToString("F2") L</h5>
                    <div class="text-success small">₹@Model.TodayMorningAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body p-3">
                    <p class="text-muted small mb-1">Evening</p>
                    <h5 class="mb-0">@Model.TodayEveningQty.ToString("F2") L</h5>
                    <div class="text-success small">₹@Model.TodayEveningAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm bg-primary text-white">
                <div class="card-body p-3">
                    <p class="text-white-50 small mb-1">Total Today</p>
                    <h5 class="mb-0">@Model.TodayTotalQty.ToString("F2") L</h5>
                    <div class="small">₹@Model.TodayTotalAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body p-3">
                    <p class="text-muted small mb-1">Month Total</p>
                    <h5 class="mb-0">@Model.MonthTotalQty.ToString("F2") L</h5>
                    <div class="text-success small fw-bold">₹@Model.MonthTotalAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payments & Rejections Section -->
    <h6 class="text-uppercase text-muted fw-bold mb-3 small" style="letter-spacing: 1px;">Status & Alerts</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100 border-start border-warning border-4 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Pending Payment</p>
                    <h4 class="mb-0 text-warning fw-bold">₹@Model.PendingAmount.ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-start border-success border-4 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Last Payment</p>
                    @if (Model.LastPaymentAmount.HasValue)
                    {
                        <h4 class="mb-0 text-success fw-bold">₹@Model.LastPaymentAmount.Value.ToString("N2")</h4>
                        <small class="text-muted">Paid on @Model.LastPaymentDate?.ToString("dd MMM")</small>
                    }
                    else
                    {
                        <h4 class="mb-0 text-muted">₹0.00</h4>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-start border-danger border-4 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Rejections (30 Days)</p>
                        @if (Model.TotalRejectionsLast30Days > 0)
                        {
                            <h4 class="mb-0 text-danger fw-bold">@Model.TotalRejectionsLast30Days</h4>
                            <small class="text-muted">@Model.TotalRejectedQtyLast30Days.ToString("F1") L Lost</small>
                        }
                        else
                        {
                            <h4 class="mb-0 text-muted">0</h4>
                            <small class="text-muted">All clear</small>
                        }
                    </div>
                    @if (Model.TotalRejectionsLast30Days > 0)
                    {
                        <a asp-action="RejectionHistory" class="btn btn-sm btn-outline-danger px-3 rounded-pill">View</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Actions Section -->
    <h6 class="text-uppercase text-muted fw-bold mb-3 small" style="letter-spacing: 1px;">Quick Actions</h6>
    <div class="row g-2">
        <div class="col-6 col-md-3">
            <a asp-action="TodayMilk" class="btn btn-light border w-100 py-3 shadow-sm">
                <i class="bi bi-droplet text-primary"></i><br />Today's Milk
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="AllMilkEntries" class="btn btn-light border w-100 py-3 shadow-sm">
                <i class="bi bi-list-ul text-primary"></i><br />History
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="RejectionHistory" class="btn btn-light border w-100 py-3 shadow-sm">
                <i class="bi bi-x-circle text-danger"></i><br />Rejections
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Profile" class="btn btn-light border w-100 py-3 shadow-sm">
                <i class="bi bi-person text-primary"></i><br />My Profile
            </a>
        </div>
    </div>
</div>
