@model DairyIndustry.Models.FarmerModel.FarmerDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_FarmerLayout";
    var farmerName = Context.Session.GetString("FarmerName");
    var farmerCode = Context.Session.GetString("FarmerCode");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --dash-bg: #f4f6fb;
        --card-bg: #ffffff;
        --card-border: #e8ecf1;
        --muted: #6c757d;
        --label: #9aa0ac;
        --text: #1a1d23;
        --green: #1d9e75;
        --green-light: #e1f5ee;
        --green-dark: #0f6e56;
        --blue: #378add;
        --blue-light: #e6f1fb;
        --blue-dark: #185fa5;
        --amber: #ba7517;
        --amber-light: #faeeda;
        --amber-dark: #854f0b;
        --red: #e24b4a;
        --red-light: #fcebeb;
        --red-dark: #a32d2d;
        --radius: 12px;
        --radius-sm: 8px;
    }

    body {
        background: var(--dash-bg);
    }

    .dash-wrap {
        padding: 24px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .dash-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--radius);
        padding: 20px 22px;
        margin-bottom: 16px;
    }

    .sec-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: var(--label);
        margin-bottom: 14px;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
    }

    .kpi-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--radius);
        padding: 16px 18px;
    }

    .kpi-icon {
        width: 38px;
        height: 38px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        margin-bottom: 12px;
    }

    .kpi-label {
        font-size: 11px;
        color: var(--label);
        margin-bottom: 4px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .kpi-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.1;
    }

    .kpi-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 5px;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 20px;
    }

    .bp-green {
        background: var(--green-light);
        color: var(--green-dark);
    }

    .bp-blue {
        background: var(--blue-light);
        color: var(--blue-dark);
    }

    .bp-amber {
        background: var(--amber-light);
        color: var(--amber-dark);
    }

    .bp-red {
        background: var(--red-light);
        color: var(--red-dark);
    }

    .action-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--radius);
        padding: 20px 12px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
        transition: border-color .15s, background .15s;
    }

    .action-btn:hover {
        border-color: #c0c8d4;
        background: #fafbfc;
        color: var(--text);
    }

    .action-btn i {
        font-size: 22px;
    }

    .dash-divider {
        border: none;
        border-top: 1px solid var(--card-border);
        margin: 12px 0;
    }

    @@media (max-width: 768px) {
        .kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="dash-wrap">

    <!-- HEADER -->
    <div class="dash-card" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:16px;">
        <div>
            <div style="font-size:18px; font-weight:700; color:var(--text);">@farmerName</div>
            <div style="font-size:12px; color:var(--muted); margin-top:3px;">
                <i class="bi bi-person-badge"></i>&nbsp;@farmerCode
                &nbsp;&middot;&nbsp;
                <i class="bi bi-calendar3"></i>&nbsp;@DateTime.Today.ToString("dd MMM yyyy")
            </div>
        </div>
        <span class="badge-pill bp-green"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Active</span>
    </div>

    <!-- TODAY KPIs -->
    <div class="sec-label">Today's collection</div>
    <div class="kpi-grid" style="margin-bottom:16px;">

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--blue-light); color:var(--blue-dark);">
                <i class="bi bi-sunrise"></i>
            </div>
            <div class="kpi-label">Morning</div>
            <div class="kpi-value">
                @Model.TodayMorningQty.ToString("F1")
                <span style="font-size:14px; font-weight:400; color:var(--muted);">L</span>
            </div>
            <div class="kpi-sub"><i class="bi bi-currency-rupee"></i>@Model.TodayMorningAmount.ToString("N0")</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--blue-light); color:var(--blue-dark);">
                <i class="bi bi-moon-stars"></i>
            </div>
            <div class="kpi-label">Evening</div>
            <div class="kpi-value">
                @Model.TodayEveningQty.ToString("F1")
                <span style="font-size:14px; font-weight:400; color:var(--muted);">L</span>
            </div>
            <div class="kpi-sub"><i class="bi bi-currency-rupee"></i>@Model.TodayEveningAmount.ToString("N0")</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--green-light); color:var(--green-dark);">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <div class="kpi-label">Total today</div>
            <div class="kpi-value">
                @Model.TodayTotalQty.ToString("F1")
                <span style="font-size:14px; font-weight:400; color:var(--muted);">L</span>
            </div>
            <div class="kpi-sub"><i class="bi bi-currency-rupee"></i>@Model.TodayTotalAmount.ToString("N0")</div>
        </div>
    </div>

    <!-- FINANCIAL KPIs -->
    <div class="sec-label">Financials</div>
    <div class="kpi-grid" style="margin-bottom:16px;">

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--green-light); color:var(--green-dark);">
                <i class="bi bi-wallet2"></i>
            </div>
            <div class="kpi-label">This month</div>
            <div class="kpi-value">
                <i class="bi bi-currency-rupee" style="font-size:18px;"></i>@Model.MonthTotalAmount.ToString("N0")
            </div>
            <div class="kpi-sub">@Model.MonthTotalQty.ToString("F1") L collected</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--amber-light); color:var(--amber-dark);">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div class="kpi-label">Pending payment</div>
            <div class="kpi-value">
                <i class="bi bi-currency-rupee" style="font-size:18px;"></i>@Model.PendingAmount.ToString("N0")
            </div>
            <div class="kpi-sub">To be processed</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--blue-light); color:var(--blue-dark);">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="kpi-label">Last payment</div>
            @if (Model.LastPaymentAmount.HasValue)
            {
                <div class="kpi-value">
                    <i class="bi bi-currency-rupee" style="font-size:18px;"></i>@Model.LastPaymentAmount.Value.ToString("N0")
                </div>
                <div class="kpi-sub">@Model.LastPaymentDate?.ToString("dd MMM yyyy")</div>
            }
            else
            {
                <div class="kpi-value" style="font-size:18px; color:var(--muted);">—</div>
                <div class="kpi-sub">No payment yet</div>
            }
        </div>

        <div class="kpi-card">
            <div class="kpi-icon" style="background:var(--red-light); color:var(--red-dark);">
                <i class="bi bi-x-circle-fill"></i>
            </div>
            <div class="kpi-label">Rejections (30d)</div>
            <div class="kpi-value">@Model.TotalRejectionsLast30Days</div>
            <div class="kpi-sub">@Model.TotalRejectedQtyLast30Days.ToString("F1") L lost</div>
        </div>

    </div>

    <!-- QUICK ACTIONS -->
    <div class="sec-label">Quick actions</div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:12px; margin-bottom:16px;">

        <a asp-action="TodayMilk" class="action-btn">
            <i class="bi bi-droplet" style="color:var(--blue);"></i>
            Today Milk
        </a>

        <a asp-action="AllMilkEntriesFarmer" class="action-btn">
            <i class="bi bi-list-ul" style="color:var(--blue);"></i>
            History
        </a>

        <a asp-action="RejectionHistory" class="action-btn">
            <i class="bi bi-x-circle" style="color:var(--red);"></i>
            Rejections
        </a>

        <a asp-action="Profile" class="action-btn">
            <i class="bi bi-person" style="color:var(--blue);"></i>
            Profile
        </a>

    </div>

</div>