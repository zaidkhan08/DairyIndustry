@model DairyIndustry.Models.FarmerModel.FarmerStatusViewModel

@{
    ViewData["Title"] = "Check Registration Status";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card mb-3">
                <div class="card-body">
                    <h4 class="mb-0">Check Registration Status</h4>
                    <small class="text-muted">
                        Enter your registered phone number to see your application status.
                    </small>
                </div>
            </div>

            @* ── Search Form ──────────────────────────────────── *@
            <div class="card mb-3">
                <div class="card-body">
                    <form method="post" asp-controller="Farmer" asp-action="CheckStatus">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Phone Number <span class="text-danger">*</span>
                            </label>
                            <input type="text"
                                   name="Phone"
                                   class="form-control"
                                   value="@Model.Phone"
                                   maxlength="10"
                                   placeholder="Enter your 10-digit phone number" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Check Status
                        </button>
                    </form>
                </div>
            </div>

            @* ── Result ───────────────────────────────────────── *@
            @if (Model.Searched)
            {
                @if (Model.FarmerId == null)
                {
                    @* No record found *@
                    <div class="alert alert-warning">
                        <strong>No Record Found</strong><br />
                        No registration found for this phone number.
                        <hr />
                        <a asp-controller="Farmer"
                           asp-action="Register"
                           class="btn btn-sm btn-warning">
                            Register Now
                        </a>
                    </div>
                }
                else if (Model.ApprovalStatus == "Pending")
                {
                    @* Pending *@
                    <div class="card border-warning">
                        <div class="card-header bg-warning text-dark">
                            <strong>Application Status: Pending Review</strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered mb-3">
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.FarmerName</td>
                                </tr>
                                <tr>
                                    <th>Center</th>
                                    <td>@Model.CenterName</td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    </td>
                                </tr>
                            </table>
                            <p class="text-muted mb-0">
                                Your request is under review by the center staff.
                                Please visit the center or wait for staff to contact you.
                            </p>
                        </div>
                    </div>
                }
                else if (Model.ApprovalStatus == "Approved")
                {
                    @* Approved *@
                    <div class="card border-success">
                        <div class="card-header bg-success text-white">
                            <strong>Application Status: Approved</strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered mb-3">
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.FarmerName</td>
                                </tr>
                                <tr>
                                    <th>Center</th>
                                    <td>@Model.CenterName</td>
                                </tr>
                                <tr>
                                    <th>Farmer Code</th>
                                    <td>
                                        <strong class="text-success fs-5">@Model.FarmerCode</strong>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Default Password</th>
                                    <td>Last 4 digits of your phone number</td>
                                </tr>
                            </table>

                            <div class="alert alert-success mb-3">
                                Your account is active! You can now login using your
                                Farmer Code and password.
                            </div>

                            <a asp-controller="Farmer"
                               asp-action="Login"
                               class="btn btn-success w-100">
                                Go to Login →
                            </a>
                        </div>
                    </div>
                }
                else if (Model.ApprovalStatus == "Rejected")
                {
                    @* Rejected *@
                    <div class="card border-danger">
                        <div class="card-header bg-danger text-white">
                            <strong>Application Status: Rejected</strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered mb-3">
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.FarmerName</td>
                                </tr>
                                <tr>
                                    <th>Center</th>
                                    <td>@Model.CenterName</td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>
                                        <span class="badge bg-danger">Rejected</span>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(Model.ApprovalRemark))
                                {
                                    <tr>
                                        <th>Reason</th>
                                        <td class="text-danger">@Model.ApprovalRemark</td>
                                    </tr>
                                }
                            </table>

                            <p class="text-muted mb-3">
                                Your registration was rejected. Please correct the issue
                                and re-apply from the registration page.
                            </p>

                            <a asp-controller="Farmer"
                               asp-action="Register"
                               class="btn btn-outline-danger w-100">
                                Re-Apply →
                            </a>
                        </div>
                    </div>
                }
            }

            @* ── Bottom links ─────────────────────────────────── *@
            <div class="mt-3 text-center">
                <a asp-controller="Farmer" asp-action="Login">Back to Login</a>
                &nbsp;|&nbsp;
                <a asp-controller="Farmer" asp-action="Register">New Registration</a>
            </div>

        </div>
    </div>
</div>
