@{
    Layout = "_DairyLayout";
    ViewData["Title"] = "Reset Password";
    string farmerCode = ViewBag.FarmerCode ?? "";
    string otp = ViewBag.Otp ?? "";
}

<style>
    .rp-card {
        width: 100%;
        max-width: 420px;
        border-radius: 18px;
        border: none;
        box-shadow: 0 8px 32px rgba(13,27,64,.13);
    }

    .rp-icon-wrap {
        background: #e8eef8;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 68px;
        height: 68px;
    }

    .rp-input {
        border-radius: 10px !important;
        border: 1.5px solid #d0d8e8 !important;
        transition: border-color .2s,box-shadow .2s;
    }

        .rp-input:focus {
            border-color: #1a3a6b !important;
            box-shadow: 0 0 0 3px rgba(26,58,107,.12) !important;
            outline: none;
        }

        .rp-input.is-invalid {
            border-color: #d32f2f !important;
        }

    .ig-left {
        background: #f4f7fb;
        border: 1.5px solid #d0d8e8;
        border-right: none;
        border-radius: 10px 0 0 10px !important;
    }

    .ig-right {
        border: 1.5px solid #d0d8e8;
        border-left: none;
        border-radius: 0 10px 10px 0 !important;
        color: #1a3a6b;
        background: #f4f7fb;
    }

    .btn-navy {
        background: #1a3a6b;
        border: none;
        border-radius: 11px;
        font-weight: 600;
        transition: background .2s;
    }

        .btn-navy:hover {
            background: #122a52;
        }

    .rp-footer {
        border-top: 1px solid #eef1f7;
        border-radius: 0 0 18px 18px;
        background: #fff;
    }

        .rp-footer a {
            color: #6b7a99;
        }

    .alert-danger {
        border-left: 4px solid #d32f2f;
        background: #fff5f5;
        color: #b71c1c;
        border-radius: 10px;
    }

    .strength-wrap .progress {
        height: 5px;
        border-radius: 4px;
        background: #e8eef8;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card rp-card">
        <div class="card-body p-4">

            <div class="text-center mb-4">
                <div class="mb-3">
                    <span class="rp-icon-wrap">
                        <i class="bi bi-key-fill" style="font-size:28px; color:#1a3a6b;"></i>
                    </span>
                </div>
                <h4 class="fw-bold mb-1" style="color:#0d1b40;">Set New Password</h4>
                <p class="text-muted small mb-0">Choose a strong password for your account.</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible small py-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post" asp-action="ConfirmResetPassword" id="resetForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="farmerCode" value="@farmerCode" />
                <input type="hidden" name="otp" value="@otp" />

                <!-- New Password -->
                <div class="mb-3">
                    <label class="form-label fw-semibold small" style="color:#1a3a6b;">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text ig-left">
                            <i class="bi bi-lock" style="color:#1a3a6b;"></i>
                        </span>
                        <input type="password" id="newPasswordInput" name="newPassword"
                               class="form-control rp-input border-start-0 border-end-0 ps-1"
                               placeholder="Min. 6 characters" autocomplete="new-password"
                               style="border-radius:0 !important;" />
                        <button class="btn ig-right" type="button" id="toggleNew">
                            <i class="bi bi-eye" id="eyeNew"></i>
                        </button>
                    </div>
                    <!-- Strength bar -->
                    <div class="strength-wrap mt-2">
                        <div class="progress">
                            <div id="strengthBar" class="progress-bar" style="width:0%; transition:width .3s,background .3s;"></div>
                        </div>
                        <small id="strengthLabel" class="text-muted" style="font-size:.72rem;"></small>
                    </div>
                    <div id="pwdError" class="text-danger small mt-1 d-none">
                        <i class="bi bi-exclamation-circle me-1"></i><span id="pwdErrorMsg"></span>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="mb-4">
                    <label class="form-label fw-semibold small" style="color:#1a3a6b;">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-text ig-left">
                            <i class="bi bi-lock-fill" style="color:#1a3a6b;"></i>
                        </span>
                        <input type="password" id="confirmPasswordInput" name="confirmPassword"
                               class="form-control rp-input border-start-0 border-end-0 ps-1"
                               placeholder="Re-enter new password" autocomplete="new-password"
                               style="border-radius:0 !important;" />
                        <button class="btn ig-right" type="button" id="toggleConfirm">
                            <i class="bi bi-eye" id="eyeConfirm"></i>
                        </button>
                    </div>
                    <!-- Match indicator -->
                    <div id="matchIndicator" class="small mt-1 d-none">
                        <i id="matchIcon" class="bi me-1"></i><span id="matchMsg"></span>
                    </div>
                    <div id="confirmError" class="text-danger small mt-1 d-none">
                        <i class="bi bi-exclamation-circle me-1"></i><span id="confirmErrorMsg"></span>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="button" id="btnReset" class="btn btn-navy btn-lg text-white">
                        <i class="bi bi-check2-circle me-2"></i>Reset Password
                    </button>
                </div>
            </form>
        </div>

        <div class="card-footer text-center py-3 rp-footer">
            <a asp-controller="Farmer" asp-action="ForgotPassword" class="small text-decoration-none fw-semibold">
                <i class="bi bi-arrow-left me-1"></i>Start Over
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const newPwd    = document.getElementById('newPasswordInput');
        const confPwd   = document.getElementById('confirmPasswordInput');
        const btnReset  = document.getElementById('btnReset');
        const pwdError  = document.getElementById('pwdError');
        const pwdErrMsg = document.getElementById('pwdErrorMsg');
        const confErr   = document.getElementById('confirmError');
        const confErrMsg= document.getElementById('confirmErrorMsg');
        const strengthBar   = document.getElementById('strengthBar');
        const strengthLabel = document.getElementById('strengthLabel');
        const matchIndicator= document.getElementById('matchIndicator');
        const matchIcon     = document.getElementById('matchIcon');
        const matchMsg      = document.getElementById('matchMsg');

        // Toggle visibility
        document.getElementById('toggleNew').addEventListener('click', () => {
            newPwd.type = newPwd.type === 'password' ? 'text' : 'password';
            document.getElementById('eyeNew').classList.toggle('bi-eye');
            document.getElementById('eyeNew').classList.toggle('bi-eye-slash');
        });
        document.getElementById('toggleConfirm').addEventListener('click', () => {
            confPwd.type = confPwd.type === 'password' ? 'text' : 'password';
            document.getElementById('eyeConfirm').classList.toggle('bi-eye');
            document.getElementById('eyeConfirm').classList.toggle('bi-eye-slash');
        });

        // Password strength
        newPwd.addEventListener('input', () => {
            const v = newPwd.value;
            let score = 0;
            if (v.length >= 6)  score++;
            if (v.length >= 10) score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[0-9]/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;
            const levels = [
                { pct:'0%',   cls:'',            lbl:'',            color:'text-muted'    },
                { pct:'25%',  cls:'bg-danger',   lbl:'Weak',        color:'text-danger'   },
                { pct:'50%',  cls:'bg-warning',  lbl:'Fair',        color:'text-warning'  },
                { pct:'75%',  cls:'bg-info',     lbl:'Good',        color:'text-info'     },
                { pct:'100%', cls:'bg-primary',  lbl:'Strong',      color:'text-primary'  },
                { pct:'100%', cls:'bg-success',  lbl:'Very Strong', color:'text-success'  },
            ];
            const l = levels[score] || levels[0];
            strengthBar.style.width = l.pct;
            strengthBar.className = 'progress-bar ' + l.cls;
            strengthLabel.textContent = l.lbl;
            strengthLabel.className = 'small ' + l.color;
            checkMatch();
        });

        // Password match indicator
        confPwd.addEventListener('input', checkMatch);
        function checkMatch() {
            if (!confPwd.value) { matchIndicator.classList.add('d-none'); return; }
            matchIndicator.classList.remove('d-none');
            if (newPwd.value === confPwd.value) {
                matchIcon.className = 'bi bi-check-circle-fill me-1 text-success';
                matchMsg.textContent = 'Passwords match';
                matchMsg.className = 'text-success';
            } else {
                matchIcon.className = 'bi bi-x-circle-fill me-1 text-danger';
                matchMsg.textContent = 'Passwords do not match';
                matchMsg.className = 'text-danger';
            }
        }

        // Submit
        btnReset.addEventListener('click', () => {
            let valid = true;
            pwdError.classList.add('d-none');
            confErr.classList.add('d-none');

            if (!newPwd.value || newPwd.value.length < 6) {
                pwdErrMsg.textContent = 'Password must be at least 6 characters.';
                pwdError.classList.remove('d-none');
                newPwd.classList.add('is-invalid');
                valid = false;
            } else { newPwd.classList.remove('is-invalid'); }

            if (newPwd.value !== confPwd.value) {
                confErrMsg.textContent = 'Passwords do not match.';
                confErr.classList.remove('d-none');
                confPwd.classList.add('is-invalid');
                valid = false;
            } else { confPwd.classList.remove('is-invalid'); }

            if (valid) {
                btnReset.disabled = true;
                btnReset.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Resetting...';
                document.getElementById('resetForm').submit();
            }
        });
    </script>
}
