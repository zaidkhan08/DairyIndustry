@model List<DairyIndustry.Models.FarmerModel.AllMilkHistoryModel>

@{
    ViewData["Title"] = "Milk History";
    Layout = "_FarmerLayout";

    int srNo = 1;
    decimal totalQty = Model?.Sum(x => x.Quantity) ?? 0;
    decimal totalAmount = Model?.Sum(x => x.Amount) ?? 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid py-4">

    <!-- PAGE HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h4 class="mb-1 text-dark fw-bold tracking-tight">Milk History</h4>
            <p class="text-muted small mb-0">View all accepted milk collection entries and quality metrics.</p>
        </div>
        <div>
            <span class="badge bg-light text-dark border fw-medium rounded-pill px-3 py-2">
                Total Records: @(Model?.Count ?? 0)
            </span>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">

        <!-- TOTAL QUANTITY -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-uppercase text-muted fw-semibold d-block mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Total Quantity</span>
                            <h4 class="text-primary fw-bold mb-0">
                                @totalQty.ToString("N2") <span class="fs-6 fw-normal text-muted">L</span>
                            </h4>
                        </div>
                        <div class="bg-primary-subtle text-primary rounded-circle p-2.5 d-inline-flex">
                            <i class="bi bi-droplet-fill fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TOTAL AMOUNT -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-uppercase text-muted fw-semibold d-block mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Total Earnings</span>
                            <h4 class="text-success fw-bold mb-0">
                                ₹@totalAmount.ToString("N2")
                            </h4>
                        </div>
                        <div class="bg-success-subtle text-success rounded-circle p-2.5 d-inline-flex">
                            <i class="bi bi-currency-rupee fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- AVG FAT -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-uppercase text-muted fw-semibold d-block mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Average Fat</span>
                            <h4 class="text-warning fw-bold mb-0">
                                @(Model != null && Model.Any(x => x.AppliedFat != null)
                                                                ? Model.Average(x => x.AppliedFat ?? 0).ToString("0.0")
                                                                : "0.0")<span class="fs-6 fw-normal text-muted">%</span>
                            </h4>
                        </div>
                        <div class="bg-warning-subtle text-warning rounded-circle p-2.5 d-inline-flex">
                            <i class="bi bi-graph-up-arrow fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RECEIPTS COUNT -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-uppercase text-muted fw-semibold d-block mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Generated Receipts</span>
                            <h4 class="text-dark fw-bold mb-0">
                                @Model?.Count(x => !string.IsNullOrEmpty(x.ReceiptNumber))
                            </h4>
                        </div>
                        <div class="bg-secondary-subtle text-secondary rounded-circle p-2.5 d-inline-flex">
                            <i class="bi bi-receipt fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <!-- FILTER BAR -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">

                <!-- SEARCH -->
                <div class="col-md-4">
                    <label class="form-label small text-muted">Search</label>
                    <input type="text" id="searchBox" class="form-control form-control-sm"
                           placeholder="Center / Milk Type / Receipt..." />
                </div>

                <!-- SHIFT FILTER -->
                <div class="col-md-2">
                    <label class="form-label small text-muted">Shift</label>
                    <select id="shiftFilter" class="form-select form-select-sm">
                        <option value="">All</option>
                        <option value="Morning">Morning</option>
                        <option value="Evening">Evening</option>
                    </select>
                </div>

                <!-- FROM DATE -->
                <div class="col-md-2">
                    <label class="form-label small text-muted">From</label>
                    <input type="date" id="fromDate" class="form-control form-control-sm" />
                </div>

                <!-- TO DATE -->
                <div class="col-md-2">
                    <label class="form-label small text-muted">To</label>
                    <input type="date" id="toDate" class="form-control form-control-sm" />
                </div>

                <!-- RESET -->
                <div class="col-md-2">
                    <button type="button" class="btn btn-sm btn-dark w-100" onclick="resetFilters()">
                        Reset
                    </button>
                </div>

            </div>
        </div>
    </div>
    <!-- DATA TABLE CARD -->
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
       
        <div class="card-body p-0">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5 my-4">
                    <div class="bg-light text-muted rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-droplet fs-3"></i>
                    </div>
                    <h5 class="text-dark fw-semibold mb-1">No Collection History</h5>
                    <p class="text-muted small mb-0">Accepted collection records will populate here dynamically.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-uppercase tracking-wider" style="font-size: 0.75rem;">
                            <tr>
                                <th class="ps-4 py-3 text-muted fw-semibold">#</th>
                                <th class="py-3 text-muted fw-semibold">Date</th>
                                <th class="py-3 text-muted fw-semibold">Shift</th>
                                <th class="py-3 text-muted fw-semibold">Center</th>
                                <th class="py-3 text-muted fw-semibold">Milk Type</th>
                                <th class="py-3 text-muted fw-semibold text-end">Qty</th>
                                <th class="py-3 text-muted fw-semibold text-end">Fat</th>
                                <th class="py-3 text-muted fw-semibold text-end">CLR</th>
                                <th class="py-3 text-muted fw-semibold text-end">Rate</th>
                                <th class="py-3 text-muted fw-semibold text-end">Amount</th>
                                <th class="py-3 text-muted fw-semibold text-center">Status</th>
                                <th class="pe-4 py-3 text-muted fw-semibold text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0" style="font-size: 0.85rem;">
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted small">@srNo</td>

                                    <!-- DATE -->
                                    <td>
                                        <span class="fw-semibold text-dark d-block">
                                            @item.CollectionDate.ToString("dd-MM-yyyy")
                                        </span>
                                        <span class="text-muted text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.02em;">
                                            @item.CollectionDate.ToString("dddd")
                                        </span>
                                    </td>

                                    <!-- SHIFT -->
                                    <td>
                                        @if (item.Shift == "Morning")
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1">
                                                <i class="bi bi-sun-fill me-1"></i>Morning
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle px-2 py-1">
                                                <i class="bi bi-moon-stars-fill me-1"></i>Evening
                                            </span>
                                        }
                                    </td>

                                    <!-- CENTER -->
                                    <td class="text-dark fw-medium">@item.CenterName</td>

                                    <!-- MILK TYPE -->
                                    <td>
                                        <span class="badge bg-light text-secondary border px-2 py-1 rounded-pill">
                                            @item.MilkTypeName
                                        </span>
                                    </td>

                                    <!-- QUANTITY -->
                                    <td class="text-end fw-semibold text-dark font-monospace">
                                        @item.Quantity.ToString("0.00") L
                                    </td>

                                    <!-- FAT -->
                                    <td class="text-end text-muted font-monospace">
                                        @(item.AppliedFat?.ToString("0.0") ?? "—")
                                    </td>

                                    <!-- CLR -->
                                    <td class="text-end text-muted font-monospace">
                                        @(item.AppliedCLR?.ToString("0.0") ?? "—")
                                    </td>

                                    <!-- RATE -->
                                    <td class="text-end text-muted font-monospace">
                                        ₹@item.RatePerLiter.ToString("0.00")
                                    </td>

                                    <!-- AMOUNT -->
                                    <td class="text-end fw-bold text-success font-monospace">
                                        ₹@item.Amount.ToString("0.00")
                                    </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                        <span class="badge bg-success-subtle text-success-emphasis rounded-1 small px-2 py-0.5 border border-success-subtle">
                                            Accepted
                                        </span>
                                    </td>

                                    <!-- ACTION/RECEIPT -->
                                    <td class="pe-4 text-center">
                                        @if (!string.IsNullOrEmpty(item.ReceiptNumber))
                                        {
                                            <a href="/Farmer/ViewReceipt/@item.CollectionId"
                                               class="btn btn-sm btn-outline-dark rounded-2 px-2.5 py-1"
                                               style="font-size: 0.75rem;">
                                                <i class="bi bi-file-earmark-text me-1"></i>View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                                srNo++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
<script>
    const searchBox = document.getElementById("searchBox");
    const shiftFilter = document.getElementById("shiftFilter");
    const fromDate = document.getElementById("fromDate");
    const toDate = document.getElementById("toDate");

    const rows = document.querySelectorAll("tbody tr");

    function filterTable() {

        const search = searchBox.value.toLowerCase();
        const shift = shiftFilter.value;
        const from = fromDate.value ? new Date(fromDate.value) : null;
        const to = toDate.value ? new Date(toDate.value) : null;

        rows.forEach(row => {

            const dateText = row.children[1].innerText.trim().split("\n")[0];
            const shiftText = row.children[2].innerText.trim();
            const center = row.children[3].innerText.toLowerCase();
            const milkType = row.children[4].innerText.toLowerCase();

            const rowDate = new Date(dateText.split("-").reverse().join("-"));

            let match = true;

            // SEARCH FILTER
            if (search &&
                !center.includes(search) &&
                !milkType.includes(search)) {
                match = false;
            }

            // SHIFT FILTER
            if (shift && !shiftText.includes(shift)) {
                match = false;
            }

            // DATE FILTER
            if (from && rowDate < from) match = false;
            if (to && rowDate > to) match = false;

            row.style.display = match ? "" : "none";
        });
    }

    function resetFilters() {
        searchBox.value = "";
        shiftFilter.value = "";
        fromDate.value = "";
        toDate.value = "";
        filterTable();
    }

    searchBox.addEventListener("keyup", filterTable);
    shiftFilter.addEventListener("change", filterTable);
    fromDate.addEventListener("change", filterTable);
    toDate.addEventListener("change", filterTable);
</script>