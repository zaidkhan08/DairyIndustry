@model FarmerLoginViewModel

@{
    Layout = "_DairyLayout";
    ViewData["Title"] = "Farmer Login";
}

<style>
    .gradient-bg {
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    }

    .input-wrap {
        display: flex;
        align-items: center;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        overflow: hidden;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .input-wrap:focus-within {
            border-color: #1d4ed8;
            box-shadow: 0 0 0 3px rgba(29,78,216,0.12);
        }

    .input-prefix {
        padding: 0 13px;
        height: 48px;
        display: flex;
        align-items: center;
        background: #eff6ff;
        border-right: 1px solid #d1d5db;
        flex-shrink: 0;
        color: #1d4ed8;
        font-size: 17px;
    }

    .input-wrap input {
        flex: 1;
        height: 48px;
        padding: 0 14px;
        font-size: 14px;
        border: none;
        outline: none;
        background: transparent;
        color: #1a1a2e;
    }

        .input-wrap input::placeholder {
            color: #9ca3af;
        }

    .toggle-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 13px;
        height: 48px;
        display: flex;
        align-items: center;
        color: #6b7280;
        font-size: 17px;
    }

        .toggle-btn:hover {
            color: #1d4ed8;
        }

    .btn-signin {
        width: 100%;
        height: 48px;
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.15s, box-shadow 0.15s;
    }

        .btn-signin:hover {
            opacity: 0.92;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -10px rgba(29,78,216,0.4);
        }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(255,255,255,0.12);
        border-radius: 10px;
        padding: 10px 14px;
        border: 0.5px solid rgba(255,255,255,0.2);
    }

    .login-alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 0.5rem;
        padding: 0.6rem 0.9rem;
        font-size: 0.85rem;
        text-align: center;
        margin-bottom: 1rem;
    }

    .login-panel-left {
        width: 50%;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
    }

    .login-panel-right {
        width: 50%;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    @@media (max-width: 767px) {
        .login-panel-left {
            width: 100%;
        }

        .login-panel-right {
            width: 100%;
        }

        .login-card {
            flex-direction: column !important;
        }
    }
</style>

<div style="min-height: 100vh;display:flex;align-items:center;justify-content:center;padding:2rem 1rem;">

    <div class="login-card" style="width:100%;max-width:960px;background:#fff;border-radius:16px;box-shadow:0 4px 24px rgba(0,0,0,0.09);overflow:hidden;display:flex;">

        <!-- ── LEFT: Brand identity ── -->
        <div class="login-panel-left gradient-bg text-white">

            <!-- Logo + System name -->
            <div style="text-align:center;">
                
                <h1 style="font-size:2.25rem;font-weight:700;margin-bottom:.25rem;letter-spacing:-0.5px;">DMS</h1>
                <p style="color:rgba(255,255,255,0.6);font-size:.72rem;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:.9rem;">Dairy Management System</p>
                <p style="color:rgba(255,255,255,0.8);font-size:.875rem;max-width:270px;margin:0 auto;line-height:1.6;">
                    Manage your milk collection, track payments, and stay connected with your dairy center — all in one place.
               
                </p>
            </div>

            <!-- What the system offers -->
            <div style="display:flex;flex-direction:column;gap:.75rem;width:100%;max-width:300px;">
                <div class="feature-item">
                    <i class="bi bi-droplet-half" style="font-size:18px;color:#bfdbfe;flex-shrink:0;"></i>
                    <span style="font-size:13px;color:rgba(255,255,255,0.85);">Daily milk collection tracking</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-cash-coin" style="font-size:18px;color:#bfdbfe;flex-shrink:0;"></i>
                    <span style="font-size:13px;color:rgba(255,255,255,0.85);">Payment & settlement records</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-building" style="font-size:18px;color:#bfdbfe;flex-shrink:0;"></i>
                    <span style="font-size:13px;color:rgba(255,255,255,0.85);">Collection center coordination</span>
                </div>
                
            </div>

        </div>

        <!-- ── RIGHT: Login form ── -->
        <div class="login-panel-right">

            <div style="text-align:center;margin-bottom:2rem;">
                <h2 style="font-size:1.75rem;font-weight:700;color:#111827;margin-bottom:.25rem;">Farmer login</h2>
                <p style="color:#6b7280;font-size:.875rem;margin:0;">Sign in with your farmer code and password</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="login-alert-danger">@ViewBag.Error</div>
            }

            <form method="post" style="display:flex;flex-direction:column;gap:1.25rem;">

                @Html.AntiForgeryToken()

                <!-- Farmer Code -->
                <div>
                    <label asp-for="FarmerCode" style="display:block;font-size:.875rem;font-weight:600;color:#374151;margin-bottom:6px;">
                        Farmer code
                    </label>
                    <div class="input-wrap">
                        <div class="input-prefix"><i class="bi bi-person-badge"></i></div>
                        <input asp-for="FarmerCode" type="text" placeholder="e.g. FARM00001" autocomplete="username" />
                    </div>
                    <span asp-validation-for="FarmerCode" style="color:#ef4444;font-size:.75rem;"></span>
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password" style="display:block;font-size:.875rem;font-weight:600;color:#374151;margin-bottom:6px;">
                        Password
                    </label>
                    <div class="input-wrap">
                        <div class="input-prefix"><i class="bi bi-lock"></i></div>
                        <input asp-for="Password" type="password" id="passwordInput" placeholder="Last 4 digits of your mobile" autocomplete="current-password" />
                        <button class="toggle-btn" type="button" id="togglePassword">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" style="color:#ef4444;font-size:.75rem;"></span>
                </div>

                <!-- Remember me -->
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <label style="display:flex;align-items:center;gap:8px;font-size:.875rem;color:#6b7280;cursor:pointer;">
                        <input type="checkbox" id="rememberMe" style="accent-color:#1d4ed8;width:15px;height:15px;" />
                        Remember me
                    </label>
                    <a asp-action="ForgotPassword" style="font-size:.875rem;font-weight:500;color:#1d4ed8;text-decoration:none;">Forgot password?</a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-signin">
                    Sign in &nbsp;<i class="bi bi-arrow-right"></i>
                </button>

                <div asp-validation-summary="ModelOnly" style="color:#ef4444;font-size:.875rem;"></div>
            </form>

            <!-- Divider -->
            <div style="position:relative;margin:1.5rem 0;text-align:center;">
                <div style="position:absolute;inset:0;display:flex;align-items:center;">
                    <div style="width:100%;border-top:1px solid #e5e7eb;"></div>
                </div>
                <span style="position:relative;background:#fff;padding:0 12px;font-size:.75rem;color:#9ca3af;">OR</span>
            </div>

           
            <!-- Footer links -->
            <div style="display:flex;flex-direction:column;gap:.5rem;text-align:center;">
                <p style="font-size:.875rem;color:#6b7280;margin:0;">
                    Not registered yet?
                    <a asp-controller="Farmer" asp-action="FarmerSelfRegistration"
                       >Register here</a>
                </p>
                <p style="font-size:.875rem;color:#6b7280;margin:0;">
                    Applied already?
                    <a asp-controller="Farmer" asp-action="CheckStatus"
                       >Check your status</a>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            var input = document.getElementById('passwordInput');
            var icon  = document.getElementById('eyeIcon');
            var isPass = input.getAttribute('type') === 'password';
            input.setAttribute('type', isPass ? 'text' : 'password');
            icon.className = isPass ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
    </script>
}
