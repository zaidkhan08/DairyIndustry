@model List<DairyIndustry.Models.Collection.MilkCollectionModel>

@{
    Layout = "_FarmerLayout";
    ViewData["Title"] = "Today's Milk";

    var totalQty = Model?.Sum(x => x.Quantity) ?? 0;
    var totalAmount = Model?.Sum(x => x.Amount) ?? 0;
    var hasData = Model != null && Model.Any();
    var today = DateTime.Today.ToString("dd MMMM yyyy");
}

<style>
    .kpi-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .kpi-icon {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .kpi-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 2px;
    }

    .kpi-value {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0a2540;
        line-height: 1.2;
    }

    .kpi-sub {
        font-size: 0.7rem;
        color: #94a3b8;
        margin-top: 1px;
    }

    .table-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 16px;
        overflow: hidden;
    }

    .table-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .milk-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.84rem;
    }

    .milk-table thead th {
        background: #f8fafc;
        padding: 11px 16px;
        font-size: 0.68rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        border-bottom: 1px solid #e8eef6;
        white-space: nowrap;
    }

    .milk-table tbody td {
        padding: 13px 16px;
        color: #1e293b;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    .milk-table tbody tr:last-child td {
        border-bottom: none;
    }

    .milk-table tbody tr:hover td {
        background: #fafbfd;
    }

    .row-num {
        color: #cbd5e1;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .shift-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .shift-morning {
        background: #fff7ed;
        color: #c2410c;
    }

    .shift-evening {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .milk-chip {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        font-size: 0.76rem;
        color: #475569;
        background: #f8fafc;
    }

    .qty-val {
        color: #0a2540;
        font-weight: 700;
    }

    .qty-unit {
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .amt-val {
        color: #d97706;
        font-weight: 700;
    }

    .receipt-chip {
        background: #f1f5f9;
        color: #475569;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-family: monospace;
    }

    .status-pill {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.74rem;
        font-weight: 600;
    }

    .status-accepted {
        background: #f0fdf4;
        color: #16a34a;
    }

    .status-rejected {
        background: #fff5f5;
        color: #dc2626;
    }

    .status-pending {
        background: #fffbeb;
        color: #d97706;
    }


    .date-main {
        font-weight: 700;
        color: #0a2540;
        font-size: 0.84rem;
    }

    .date-day {
        font-size: 0.68rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-top: 1px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 30px;
        color: #94a3b8;
    }

    .empty-state i {
        font-size: 2.6rem;
        opacity: .35;
        margin-bottom: 12px;
        display: block;
    }

    .date-badge {
        background: #f0f7ff;
        color: #1d6fce;
        border: 1px solid #dbeafe;
        padding: 5px 13px;
        border-radius: 10px;
        font-size: 0.78rem;
        font-weight: 600;
    }
</style>

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h5 class="fw-bold m-0" style="color:#0a2540;">Today's Milk Entries</h5>
        <div class="text-muted" style="font-size:.78rem; margin-top:2px;">Entries recorded for today</div>
    </div>
    <span class="date-badge">
        <i class="bi bi-calendar3 me-1"></i>@today
    </span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#eef6ff;">
                <i class="bi bi-droplet-fill" style="color:#1d6fce;"></i>
            </div>
            <div>
                <div class="kpi-label">Total Quantity</div>
                <div class="kpi-value">@totalQty.ToString("0.00") <span style="font-size:.78rem;color:#64748b;font-weight:500;">L</span></div>
                <div class="kpi-sub">Litres today</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#f0fdf4;">
                <i class="bi bi-currency-rupee" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="kpi-label">Total Earnings</div>
                <div class="kpi-value" style="color:#16a34a;">₹@totalAmount.ToString("0.00")</div>
                <div class="kpi-sub">Estimated payout</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#fff7ed;">
                <i class="bi bi-clock-history" style="color:#c2410c;"></i>
            </div>
            <div>
                <div class="kpi-label">Shifts Covered</div>
                <div class="kpi-value">
                    @if (hasData)
                    {
                        var shifts = Model.Select(x => x.Shift).Distinct().ToList();
                        @string.Join(" + ", shifts)
                    }
                    else
                    {
                        <span style="font-size:.9rem;color:#94a3b8;">—</span>
                    }
                </div>
                <div class="kpi-sub">@(hasData? Model.Count + " record(s)" : "No entries")</div>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="table-card">
    <div class="table-card-header">
        <span class="fw-semibold" style="font-size:.88rem;color:#0a2540;">
            <i class="bi bi-table me-2" style="color:#94a3b8;"></i>Entry Details
        </span>
        @if (hasData)
        {
            <span style="font-size:.75rem;color:#94a3b8;">@Model.Count entr@(Model.Count == 1 ? "y" : "ies") found</span>
        }
    </div>

    @if (!hasData)
    {
        <div class="empty-state">
            <i class="bi bi-droplet"></i>
            <div style="font-size:.95rem;font-weight:600;color:#475569;margin-bottom:4px;">No entries for today</div>
            <div style="font-size:.82rem;">Your milk entries will appear here after the shift opens.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="milk-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Shift</th>
                        <th>Milk Type</th>
                        <th>Qty (L)</th>
                        <th>Fat</th>
                        <th>CLR</th>
                        <th>Rate / L</th>
                        <th>Amount</th>
                        <th>Receipt</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rowNum = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="row-num">@rowNum</span></td>
                            <td>
                                @if (item.Shift == "Morning")
                                {
                                    <span class="shift-pill shift-morning">
                                        <i class="bi bi-brightness-high" style="font-size:.72rem;"></i> Morning
                                    </span>
                                }
                                else
                                {
                                    <span class="shift-pill shift-evening">
                                        <i class="bi bi-moon-stars" style="font-size:.72rem;"></i> Evening
                                    </span>
                                }
                            </td>
                            <td><span class="milk-chip">@item.MilkTypeName</span></td>
                            <td>
                                <span class="qty-val">@item.Quantity.ToString("0.00")</span>
                                <span class="qty-unit"> L</span>
                            </td>
                            <td style="color:#475569;">@(item.AppliedFat.HasValue? item.AppliedFat.Value.ToString("0.0") : "—")</td>
                            <td style="color:#475569;">@(item.AppliedCLR.HasValue? item.AppliedCLR.Value.ToString("0.0") : "—")</td>
                            <td style="color:#475569;">₹@item.RatePerLiter</td>
                            <td><span class="amt-val">₹@item.Amount</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ReceiptNumber))
                                {
                                    <span class="receipt-chip">@item.ReceiptNumber</span>
                                }
                                else
                                {
                                    <span style="color:#cbd5e1;">—</span>
                                }
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>
