@model List<DairyIndustry.Models.Collection.MilkCollectionModel>

@{
    Layout = "_FarmerLayout";
    // ViewData["Title"] = "Today's Milk";
    Layout = "_AdminLayout";


    var totalQty = Model?.Sum(x => x.Quantity) ?? 0;
    var totalAmount = Model?.Sum(x => x.Amount) ?? 0;
    var hasData = Model != null && Model.Any();
    var today = DateTime.Today.ToString("dd MMMM yyyy");
}

<style>
    .kpi-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .kpi-icon {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .kpi-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 2px;
    }

    .kpi-value {
        font-size: 1.05rem;
        font-weight: normal;
        color: #0a2540;
        line-height: 1.2;
    }

    .kpi-sub {
        font-size: 0.7rem;
        color: #94a3b8;
        margin-top: 1px;
    }

    .table-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 16px;
        overflow: hidden;
    }

    .table-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .milk-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.84rem;
    }

        .milk-table thead th {
            background: #f8fafc;
            padding: 11px 16px;
            font-size: 0.68rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border-bottom: 1px solid #e8eef6;
            white-space: nowrap;
        }

        .milk-table tbody td {
            padding: 13px 16px;
            color: #1e293b;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .milk-table tbody tr:last-child td {
            border-bottom: none;
        }

        .milk-table tbody tr:hover td {
            background: #fafbfd;
        }

    .row-num {
        color: #cbd5e1;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .shift-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .shift-morning {
        background: #fff7ed;
        color: #c2410c;
    }

    .shift-evening {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .milk-chip {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        font-size: 0.76rem;
        color: #475569;
        background: #f8fafc;
    }

    .qty-val {
        color: #64748b;
        font-weight: normal;
    }

    .qty-unit {
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .amt-val {
        color: #64748b;
        font-weight: normal;
    }

    .receipt-chip {
        background: #f1f5f9;
        color: #475569;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-family: monospace;
    }

    .status-pill {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.74rem;
        font-weight: 600;
    }

    .status-accepted {
        background: #f0fdf4;
        color: #16a34a;
    }

    .status-rejected {
        background: #fff5f5;
        color: #dc2626;
    }

    .status-pending {
        background: #fffbeb;
        color: #d97706;
    }


    .date-main {
        font-weight: 700;
        color: #0a2540;
        font-size: 0.84rem;
    }

    .date-day {
        font-size: 0.68rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-top: 1px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 30px;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 2.6rem;
            opacity: .35;
            margin-bottom: 12px;
            display: block;
        }

    .date-badge {
        background: #f0f7ff;
        color: #1d6fce;
        border: 1px solid #dbeafe;
        padding: 5px 13px;
        border-radius: 10px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    /* PAGINATION */
    .tm-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-top: 1px solid #f1f5f9;
        font-size: 0.78rem;
        color: #94a3b8;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tm-page-btns {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .pg-btn {
        min-width: 30px;
        height: 30px;
        padding: 0 7px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: #fff;
        font-size: 0.78rem;
        color: #475569;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s;
        line-height: 1;
    }

    .btn-view {
        font-size: 0.75rem;
        border: 1px solid #d5d5d2;
        border-radius: 6px;
        padding: 4px 12px;
        color: #444;
        background: #fafaf8;
        text-decoration: none;
        display: inline-block;
    }

        .btn-view:hover {
            background: #f0f0ee;
            color: #222;
        }

        .pg-btn:hover {
            background: #f8fafc;
        }

        .pg-btn.active {
            background: #1d6fce;
            color: #fff;
            border-color: #1d6fce;
            font-weight: 600;
        }

        .pg-btn.disabled {
            opacity: 0.35;
            pointer-events: none;
            cursor: default;
        }
</style>

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h5 class="fw-bold m-0" style="color:#0a2540;">Today's Milk Entries</h5>
        <div class="text-muted" style="font-size:.78rem; margin-top:2px;">Entries recorded for today</div>
    </div>
    <span class="date-badge">
        <i class="bi bi-calendar3 me-1"></i>@today
    </span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#eef6ff;">
                <i class="bi bi-droplet-fill" style="color:#1d6fce;"></i>
            </div>
            <div>
                <div class="kpi-label">Total Quantity</div>
                <div class="kpi-value">@totalQty.ToString("0.00") <span style="font-size:.78rem;color:#64748b;font-weight:500;">L</span></div>
                <div class="kpi-sub">Litres today</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#f0fdf4;">
                <i class="bi bi-currency-rupee" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="kpi-label">Total Earnings</div>
                <div class="kpi-value">
                    <i class="bi bi-currency-rupee" style="font-size:.9rem;color:#0a2540;"></i>@totalAmount.ToString("0.00")
                </div>
                <div class="kpi-sub">Estimated payout</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:#fff7ed;">
                <i class="bi bi-clock-history" style="color:#c2410c;"></i>
            </div>
            <div>
                <div class="kpi-label">Shifts Covered</div>
                <div class="kpi-value">
                    @if (hasData)
                    {
                        var shifts = Model.Select(x => x.Shift).Distinct().ToList();
                        @string.Join(" + ", shifts)
                    }
                    else
                    {
                        <span style="font-size:.9rem;color:#94a3b8;">—</span>
                    }
                </div>
                <div class="kpi-sub">@(hasData? Model.Count + " record(s)" : "No entries")</div>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="table-card">
    <div class="table-card-header">
        <span class="fw-semibold" style="font-size:.88rem;color:#0a2540;">
            <i class="bi bi-table me-2" style="color:#94a3b8;"></i>Entry Details
        </span>
        @if (hasData)
        {
            <span style="font-size:.75rem;color:#94a3b8;">@Model.Count entr@(Model.Count == 1 ? "y" : "ies") found</span>
        }
    </div>

    @if (!hasData)
    {
        <div class="empty-state">
            <i class="bi bi-droplet"></i>
            <div style="font-size:.95rem;font-weight:600;color:#475569;margin-bottom:4px;">No entries for today</div>
            <div style="font-size:.82rem;">Your milk entries will appear here after the shift opens.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="milk-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Shift</th>
                        <th>Milk Type</th>
                        <th>Qty (L)</th>
                        <th>Fat %</th>
                        <th>CLR</th>
                        <th>Rate / L</th>
                        <th>Amount</th>
                        <th style="text-align:center; padding-right:20px;">Receipt</th>
                    </tr>
                </thead>
                <tbody id="tmTableBody">
                    @{
                        int rowNum = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr class="tm-data-row">
                            <td><span class="row-num tm-sr">@rowNum</span></td>
                            <td>
                                @if (item.Shift == "Morning")
                                {
                                    <span class="shift-pill shift-morning">Morning</span>
                                }
                                else
                                {
                                    <span class="shift-pill shift-evening">Evening</span>
                                }
                            </td>
                            <td><span class="milk-chip">@item.MilkTypeName</span></td>
                            <td>
                                <span class="qty-val">@item.Quantity.ToString("0.00")</span>
                                <span class="qty-unit"> L</span>
                            </td>
                            <td style="color:#475569;">@(item.AppliedFat.HasValue? item.AppliedFat.Value.ToString("0.0") : "—")</td>
                            <td style="color:#475569;">@(item.AppliedCLR.HasValue? item.AppliedCLR.Value.ToString("0.0") : "—")</td>

                            <td style="color:#1e293b;"><i class="bi bi-currency-rupee" style="font-size:.78rem;color:#475569;"></i>@item.RatePerLiter</td>

                            <td><i class="bi bi-currency-rupee" style="font-size:.78rem;color:#475569;"></i>@item.Amount</td>

                            <td style="text-align:center; padding-right:20px;">
                                @if (!string.IsNullOrEmpty(item.ReceiptNumber))
                                {
                                    <a href="/Farmer/ViewReceipt/@item.CollectionId" class="btn-view">
                                        <i class="bi bi-file-earmark-text me-1"></i>View
                                    </a>
                                }
                                else
                                {
                                    <span style="color:#ddd;">—</span>
                                }
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION BAR -->
        <div class="tm-pagination" id="tmPaginationBar">
            <span id="tmPaginationInfo">Showing 1–@(Math.Min(10, Model.Count)) of @Model.Count entries</span>
            <div class="tm-page-btns" id="tmPaginationBtns"></div>
        </div>
    }
</div>

<script>
    const TM_PAGE_SIZE = 10;
    let tmCurrentPage = 1;

    const tmAllRows = Array.from(document.querySelectorAll(".tm-data-row"));
    const tmPaginationInfo = document.getElementById("tmPaginationInfo");
    const tmPaginationBtns = document.getElementById("tmPaginationBtns");

    function tmRenderPage() {
        const total = tmAllRows.length;
        const totalPages = Math.max(1, Math.ceil(total / TM_PAGE_SIZE));
        tmCurrentPage = Math.min(tmCurrentPage, totalPages);

        const start = (tmCurrentPage - 1) * TM_PAGE_SIZE;
        const end = Math.min(start + TM_PAGE_SIZE, total);

        tmAllRows.forEach((row, i) => {
            const visible = i >= start && i < end;
            row.style.display = visible ? "" : "none";
            if (visible) {
                const srCell = row.querySelector(".tm-sr");
                if (srCell) srCell.textContent = i + 1;
            }
        });

        if (tmPaginationInfo) {
            const from = total === 0 ? 0 : start + 1;
            tmPaginationInfo.textContent =
                `Showing ${from}–${end} of ${total} entr${total !== 1 ? "ies" : "y"}`;
        }

        tmRenderPagination(totalPages);
    }

    function tmRenderPagination(totalPages) {
        if (!tmPaginationBtns) return;
        tmPaginationBtns.innerHTML = "";

        function addBtn(html, page, extraClass) {
            const btn = document.createElement("button");
            btn.className = "pg-btn" + (extraClass ? " " + extraClass : "");
            btn.innerHTML = html;
            if (extraClass !== "disabled") {
                btn.onclick = () => { tmCurrentPage = page; tmRenderPage(); };
            }
            tmPaginationBtns.appendChild(btn);
        }

        // Prev
        addBtn('<i class="bi bi-chevron-left" style="font-size:10px;"></i>',
            tmCurrentPage - 1, tmCurrentPage === 1 ? "disabled" : "");

        // Page numbers
        tmBuildPageList(tmCurrentPage, totalPages).forEach(p => {
            if (p === "…") {
                const el = document.createElement("span");
                el.className = "pg-btn disabled";
                el.textContent = "…";
                tmPaginationBtns.appendChild(el);
            } else {
                addBtn(p, p, p === tmCurrentPage ? "active" : "");
            }
        });

        // Next
        addBtn('<i class="bi bi-chevron-right" style="font-size:10px;"></i>',
            tmCurrentPage + 1, tmCurrentPage === totalPages ? "disabled" : "");
    }

    function tmBuildPageList(cur, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages = [];
        if (cur <= 4) {
            for (let i = 1; i <= 5; i++) pages.push(i);
            pages.push("…"); pages.push(total);
        } else if (cur >= total - 3) {
            pages.push(1); pages.push("…");
            for (let i = total - 4; i <= total; i++) pages.push(i);
        } else {
            pages.push(1); pages.push("…");
            pages.push(cur - 1); pages.push(cur); pages.push(cur + 1);
            pages.push("…"); pages.push(total);
        }
        return pages;
    }

    if (tmAllRows.length > 0) {
        tmRenderPage();
    }
</script>