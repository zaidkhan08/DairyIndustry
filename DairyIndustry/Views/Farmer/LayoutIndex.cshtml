@{
    Layout = "_DairyLayout";
}

<!-- ── HERO IMAGE SLIDER ── -->
<div id="dairyHeroCarousel"
     class="carousel slide carousel-fade mb-5"
     data-bs-ride="carousel"
     data-bs-interval="2000"
     data-bs-pause="false">

    <!-- Indicators -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#dairyHeroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#dairyHeroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#dairyHeroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner shadow-sm" style="border-radius: 20px; overflow:hidden;">

        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="https://images.pexels.com/photos/248412/pexels-photo-248412.jpeg"
                 class="d-block w-100 hero-img"
                 alt="Milk Collection">

            <div class="carousel-caption d-none d-md-block text-start">
                <h2 class="display-5 fw-bold text-white">Smart Milk Collection</h2>
                <p class="fs-5 text-white">
                    Real-time tracking of milk procurement with automated SNF and Fat analysis.
                </p>
                <a asp-controller="Collection" asp-action="Index"
                   class="btn btn-primary btn-lg px-4">
                    Start Collection
                </a>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg"
                 class="d-block w-100 hero-img"
                 alt="Farmer Support">

            <div class="carousel-caption d-none d-md-block text-start">
                <h2 class="display-5 fw-bold text-white">Empowering Farmers</h2>
                <p class="fs-5 text-white">
                    Instant digital payments and transparent farmer records.
                </p>
                <a asp-controller="Farmer" asp-action="Login"
                   class="btn btn-light btn-lg px-4 text-primary fw-bold">
                    Learn More
                </a>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="https://images.pexels.com/photos/416978/pexels-photo-416978.jpeg"
                 class="d-block w-100 hero-img"
                 alt="Quality Control">

            <div class="carousel-caption d-none d-md-block text-start">
                <h2 class="display-5 fw-bold text-white">Quality You Can Trust</h2>
                <p class="fs-5 text-white">
                    Cold chain monitoring ensures freshness from farm to consumer.
                </p>
                <a class="btn btn-warning btn-lg px-4">
                    Our Standards
                </a>
            </div>
        </div>

    </div>

    <!-- Controls -->
    <button class="carousel-control-prev" type="button" data-bs-target="#dairyHeroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#dairyHeroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

</div>

<!-- ── STYLING ── -->
<style>
    .hero-img {
        height: 520px;
        object-fit: cover;
        filter: brightness(0.75);
    }

    .carousel-caption {
        bottom: 20%;
    }

        .carousel-caption h2 {
            text-shadow: 0 2px 10px rgba(0,0,0,0.6);
        }

        .carousel-caption p {
            text-shadow: 0 2px 8px rgba(0,0,0,0.5);
        }
</style>