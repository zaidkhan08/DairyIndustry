@{
    Layout = "_DairyLayout";
    ViewData["Title"] = "Forgot Password";
}

<style>
    .fp-card {
        width: 100%;
        max-width: 420px;
        border-radius: 18px;
        border: none;
        box-shadow: 0 8px 32px rgba(13,27,64,0.13);
    }

    .fp-icon-wrap {
        background: #e8eef8;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 68px;
        height: 68px;
    }

    .fp-btn-primary {
        background: #1a3a6b;
        border: none;
        border-radius: 11px;
        font-weight: 600;
        letter-spacing: .3px;
        transition: background .2s;
    }

        .fp-btn-primary:hover:not(:disabled) {
            background: #122a52;
        }

        .fp-btn-primary:disabled {
            background: #6b87b0;
        }

    .fp-input {
        border-radius: 10px !important;
        border: 1.5px solid #d0d8e8 !important;
        transition: border-color .2s, box-shadow .2s;
    }

        .fp-input:focus {
            border-color: #1a3a6b !important;
            box-shadow: 0 0 0 3px rgba(26,58,107,.12) !important;
        }

        .fp-input.is-invalid {
            border-color: #d32f2f !important;
        }

    .ig-left {
        background: #f4f7fb;
        border: 1.5px solid #d0d8e8;
        border-right: none;
        border-radius: 10px 0 0 10px !important;
    }

    .fp-footer {
        border-top: 1px solid #eef1f7;
        border-radius: 0 0 18px 18px;
        background: #fff;
    }

        .fp-footer a {
            color: #1a3a6b;
        }

    .alert-danger {
        border-left: 4px solid #d32f2f;
        background: #fff5f5;
        color: #b71c1c;
        border-radius: 10px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card fp-card">
        <div class="card-body p-4">

            <div class="text-center mb-4">
                <div class="mb-3">
                    <span class="fp-icon-wrap">
                        <i class="bi bi-shield-lock-fill" style="font-size:30px; color:#1a3a6b;"></i>
                    </span>
                </div>
                <h4 class="fw-bold mb-1" style="color:#0d1b40;">Forgot Password?</h4>
                <p class="text-muted small mb-0">Enter your Farmer Code. We'll send an OTP to your registered email.</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible small py-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold small" style="color:#1a3a6b;">Farmer Code</label>
                <div class="input-group">
                    <span class="input-group-text ig-left">
                        <i class="bi bi-person-badge" style="color:#1a3a6b;"></i>
                    </span>
                    <input type="text" id="farmerCodeInput"
                           class="form-control fp-input border-start-0 ps-1"
                           placeholder="e.g. F-10293"
                           maxlength="20" autocomplete="off"
                           style="border-radius:0 10px 10px 0 !important;" />
                </div>
                <div id="farmerCodeError" class="text-danger small mt-1 d-none">
                    <i class="bi bi-exclamation-circle me-1"></i><span id="errorMsg"></span>
                </div>
            </div>

            <div id="otpSentInfo" class="alert alert-success small py-2 rounded-3 d-none mb-3">
                <i class="bi bi-envelope-check-fill me-1"></i>
                OTP sent to <strong id="maskedEmailDisplay"></strong>. Redirecting&hellip;
            </div>

            <div class="d-grid">
                <button type="button" id="btnSendOtp" class="btn btn-primary fp-btn-primary btn-lg">
                    <span id="sendOtpText"><i class="bi bi-send me-2"></i>Send OTP</span>
                    <span id="sendOtpSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                </button>
            </div>
        </div>
        <div class="card-footer text-center py-3 fp-footer">
            <a asp-controller="Farmer" asp-action="Login" class="small text-decoration-none fw-semibold">
                <i class="bi bi-arrow-left me-1"></i>Back to Login
            </a>
        </div>
    </div>
</div>

<form id="proceedForm" method="get" asp-controller="Farmer" asp-action="VerifyOtp">
    <input type="hidden" name="farmerCode" id="hiddenFarmerCode" />
</form>

@section Scripts {
    <script>
        const farmerCodeInput    = document.getElementById('farmerCodeInput');
        const btnSendOtp         = document.getElementById('btnSendOtp');
        const sendOtpText        = document.getElementById('sendOtpText');
        const sendOtpSpinner     = document.getElementById('sendOtpSpinner');
        const otpSentInfo        = document.getElementById('otpSentInfo');
        const maskedEmailDisplay = document.getElementById('maskedEmailDisplay');
        const farmerCodeError    = document.getElementById('farmerCodeError');
        const errorMsg           = document.getElementById('errorMsg');

        function showError(msg) { errorMsg.textContent = msg; farmerCodeError.classList.remove('d-none'); farmerCodeInput.classList.add('is-invalid'); }
        function clearError()   { farmerCodeError.classList.add('d-none'); farmerCodeInput.classList.remove('is-invalid'); }

        function setLoading(on) {
            btnSendOtp.disabled = on;
            sendOtpSpinner.classList.toggle('d-none', !on);
            sendOtpText.innerHTML = on ? 'Sending...' : '<i class="bi bi-send me-2"></i>Send OTP';
        }

        async function sendOtp() {
            clearError();
            const code = farmerCodeInput.value.trim();
            if (!code) { showError('Please enter your Farmer Code.'); return; }
            setLoading(true);
            try {
                const res  = await fetch('@Url.Action("SendForgotPasswordOTP", "Farmer")', {
                    method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
                    body:`farmerCode=${encodeURIComponent(code)}`
                });
                const data = await res.json();
                if (data.success) {
                    maskedEmailDisplay.textContent = data.maskedEmail;
                    otpSentInfo.classList.remove('d-none');
                    sendOtpText.innerHTML = '<i class="bi bi-check-circle me-2"></i>OTP Sent';
                    sendOtpSpinner.classList.add('d-none');
                    setTimeout(() => {
                        document.getElementById('hiddenFarmerCode').value = code;
                        document.getElementById('proceedForm').submit();
                    }, 1400);
                } else {
                    showError(data.message);
                    setLoading(false);
                }
            } catch { showError('Network error. Please try again.'); setLoading(false); }
        }

        btnSendOtp.addEventListener('click', sendOtp);
        farmerCodeInput.addEventListener('keypress', e => { if (e.key === 'Enter') sendOtp(); });
    </script>
}
