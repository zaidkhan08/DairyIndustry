@model DairyIndustry.Models.FarmerModel.SelfRegisterViewModel

@{
    ViewData["Title"] = "Farmer Registration";
    Layout = "_DairyLayout";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-xl-9 col-lg-10">

            <div class="text-center mb-4">
                <h2 class="fw-bold text-dark">
                    Farmer Self Registration
                </h2>

                <p class="text-muted">
                    Register yourself for dairy collection services
                </p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>
                </div>
            }

            <form asp-action="FarmerSelfRegistration"
                  asp-controller="Farmer"
                  method="post"
                  enctype="multipart/form-data"
                  id="regForm">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <!-- ================= PERSONAL DETAILS ================= -->

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-light text-dark">
                        <h5 class="mb-0">
                            Personal Details
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- NAME -->

                            <div class="col-md-6">

                                <label asp-for="FarmerName"
                                       class="form-label fw-semibold">
                                    Full Name *
                                </label>

                                <input asp-for="FarmerName"
                                       class="form-control"
                                       placeholder="Enter full name" />

                                <span asp-validation-for="FarmerName"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- PHONE -->

                            <div class="col-md-6">

                                <label asp-for="Phone"
                                       class="form-label fw-semibold">
                                    Mobile Number *
                                </label>

                                <input asp-for="Phone"
                                       class="form-control"
                                       maxlength="10"
                                       placeholder="10 digit mobile number" />

                                <span asp-validation-for="Phone"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- EMAIL -->

                            <div class="col-md-6">

                                <label asp-for="Email"
                                       class="form-label fw-semibold">

                                    Email Address *

                                </label>

                                <div class="input-group">

                                    <input asp-for="Email" class="form-control" id="Email" placeholder="Enter email address" />
                                    <button type="button" class="btn btn-outline-primary" id="sendOtpBtn">
                                        Send OTP
                                    </button>

                                </div>

                                <span asp-validation-for="Email" class="text-danger small"></span>

                                <div class="mt-2">
                                    <span id="emailVerifiedBadge" class="badge bg-success d-none">✓</span>
                                </div>

                            </div>

                            <input type="hidden" asp-for="IsEmailVerified" id="IsEmailVerified" />

                            <!-- GENDER -->

                            <div class="col-md-4">

                                <label asp-for="Gender"
                                       class="form-label fw-semibold">
                                    Gender
                                </label>

                                <select asp-for="Gender"
                                        class="form-select">

                                    <option value="">
                                        Select Gender
                                    </option>

                                    <option value="Male">
                                        Male
                                    </option>

                                    <option value="Female">
                                        Female
                                    </option>

                                    <option value="Other">
                                        Other
                                    </option>

                                </select>

                                <span asp-validation-for="Gender"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- DOB -->

                            <div class="col-md-4">
                                <label asp-for="DateOfBirth" class="form-label fw-semibold">Date Of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" onkeydown="return false" onpaste="return false"
                                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       min="@DateTime.Today.AddYears(-100).ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>

                            <!-- AADHAAR -->

                            <div class="col-md-4">
                                <label asp-for="AadhaarNumber" class="form-label fw-semibold">Aadhaar Number</label>
                                <input asp-for="AadhaarNumber" class="form-control" maxlength="12" placeholder="12 digit Aadhaar number" />
                                <span asp-validation-for="AadhaarNumber"class="text-danger small"></span>
                            </div>

                        </div>

                    </div>

                </div>

                <!-- ================= LOCATION DETAILS ================= -->

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-light text-dark">
                        <h5 class="mb-0">
                            Location Details
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- Select State -->

                            <div class="col-md-6">

                                <label class="form-label fw-semibold">State *</label>
                                <select asp-for="StateId" id="StateId" class="form-select">
                                    <option value="">Select State</option>
                                    @foreach (var s in Model.States)
                                    {
                                        <option value="@s.StateId">@s.StateName</option>
                                    }
                                </select>
                                <span asp-validation-for="StateId" class="text-danger small"></span>

                            </div>

                            <!-- Select City -->

                            <div class="col-md-6">

                                <label class="form-label fw-semibold">
                                    City *
                                </label>

                                <select asp-for="CityId"
                                        id="CityId"
                                        class="form-select">

                                    <option value="">
                                        Select City
                                    </option>

                                </select>

                                <span asp-validation-for="CityId"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- VILLAGE -->

                            <div class="col-md-6">

                                <label class="form-label fw-semibold">
                                    Village *
                                </label>

                                <select asp-for="VillageId"
                                        id="VillageId"
                                        class="form-select">

                                    <option value="">
                                        Select Village
                                    </option>

                                </select>

                                <span asp-validation-for="VillageId"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- CENTER -->

                            <div class="col-md-6">

                                <label class="form-label fw-semibold">
                                    Collection Center *
                                </label>

                                <select asp-for="CenterId"
                                        id="CenterId"
                                        class="form-select">

                                    <option value="">
                                        Select Center
                                    </option>

                                </select>

                                <span asp-validation-for="CenterId"
                                      class="text-danger small">
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- ================= BANK DETAILS ================= -->

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-light text-dark">
                        <h5 class="mb-0">
                            Bank Details
                            <small>(Optional)</small>
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- BANK NAME -->

                            <div class="col-md-4">

                                <label asp-for="BankName"
                                       class="form-label fw-semibold">

                                    Bank Name

                                </label>

                                <input asp-for="BankName"
                                       class="form-control"
                                       placeholder="Enter bank name" />

                                <span asp-validation-for="BankName"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- ACCOUNT NUMBER -->

                            <div class="col-md-4">

                                <label asp-for="AccountNumber"
                                       class="form-label fw-semibold">

                                    Account Number

                                </label>

                                <input asp-for="AccountNumber"
                                       class="form-control"
                                       placeholder="Enter account number" />

                                <span asp-validation-for="AccountNumber"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- IFSC -->

                            <div class="col-md-4">

                                <label asp-for="IFSCCode"
                                       class="form-label fw-semibold">

                                    IFSC Code

                                </label>

                                <input asp-for="IFSCCode"
                                       class="form-control text-uppercase"
                                       placeholder="SBIN0001234" />

                                <span asp-validation-for="IFSCCode"
                                      class="text-danger small">
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- ================= DOCUMENTS ================= -->

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-light text-dark">
                        <h5 class="mb-0">
                            Upload Documents
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- PROFILE PHOTO -->

                            <div class="col-md-4">

                                <label asp-for="ProfilePhotoFile"
                                       class="form-label fw-semibold">

                                    Profile Photo

                                </label>

                                <input asp-for="ProfilePhotoFile"
                                       type="file"
                                       class="form-control"
                                       accept=".jpg,.jpeg" />
                                <span asp-validation-for="ProfilePhotoFile"
                                      class="text-danger small">
                                </span>
                            </div>

                            <!-- AADHAAR -->

                            <div class="col-md-4">

                                <label asp-for="AadhaarFile"
                                       class="form-label fw-semibold">

                                    Aadhaar Document

                                </label>

                                <input asp-for="AadhaarFile"
                                       type="file"
                                       class="form-control"
                                       accept=".jpg,.jpeg,.pdf" />
                                <span asp-validation-for="AadhaarFile"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- PASSBOOK -->

                            <div class="col-md-4">

                                <label asp-for="PassbookFile"
                                       class="form-label fw-semibold">

                                    Bank Passbook
                                    <small>(Optional)</small>

                                </label>

                                <input asp-for="PassbookFile"
                                       type="file"
                                       class="form-control"
                                       accept=".jpg,.jpeg,.pdf" />
                                <span asp-validation-for="PassbookFile"
                                      class="text-danger small">
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- ================= BUTTONS ================= -->

                <div class="d-flex justify-content-between">

                    <a asp-action="FarmerSelfRegistration"
                       class="btn btn-outline-secondary px-4">

                        Reset

                    </a>

                    <button type="submit"
                            class="btn btn-success px-5">

                        Submit Registration

                    </button>

                </div>

            </form>

        </div>

    </div>
    <!-- OTP MODAL -->

    <div class="modal fade"
         id="otpModal"
         tabindex="-1"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content border-0 shadow">

                <div class="modal-header bg-success text-white">

                    <h5 class="modal-title">
                        Email Verification
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body">

                    <p class="text-muted mb-3">
                        Enter the OTP sent to your email.
                    </p>

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            OTP
                        </label>

                        <input type="text"
                               id="otpInput"
                               maxlength="6"
                               class="form-control"
                               placeholder="Enter 6 digit OTP" />

                    </div>

                    <div id="otpError"
                         class="text-danger small d-none">

                        Invalid OTP

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button" class="btn btn-success" id="verifyOtpBtn">
                        Verify OTP
                    </button>
                </div>

            </div>

        </div>

    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        // ================= RESET DROPDOWN =================

        function resetDropdown(selector, placeholder) {

            $(selector).html(
                '<option value="">' + placeholder + '</option>'
            );
        }

                 // ================= SEND OTP =================

        $('#sendOtpBtn').click(function () {

            let email = $('#Email').val();

            if (!email) {

                alert("Please enter email");
                return;
            }

            $(this)
                .prop('disabled', true)
                .text('Sending...');

            $.post('/Farmer/SendEmailOTP',
            {
                email: email
            },
            function (res) {

                $('#sendOtpBtn')
                    .prop('disabled', false)
                    .text('Resend OTP');

                if (res.success) {

                    $('#otpInput').val('');

                    $('#otpError').addClass('d-none');

                    let otpModal = new bootstrap.Modal(
                        document.getElementById('otpModal')
                    );

                    otpModal.show();

                }
                else {

                    alert(res.message);

                }

            });

        });


        // ================= VERIFY OTP =================

        $('#verifyOtpBtn').click(function () {

            let email = $('#Email').val();

            let otp = $('#otpInput').val();

            if (!otp) {

                $('#otpError')
                    .removeClass('d-none')
                    .text('Please enter OTP');

                return;
            }

            $.post('/Farmer/VerifyEmailOTP',
            {
                email: email,
                otp: otp
            },
            function (res) {

                if (res.success) {

                    $('#IsEmailVerified').val(true);

                    $('#emailVerifiedBadge')
                        .removeClass('d-none');

                    $('#Email').prop('readonly', true);

                    $('#sendOtpBtn')
                        .removeClass('btn-outline-primary')
                        .addClass('btn-success')
                        .html('Verified')
                        .prop('disabled', true);

                    bootstrap.Modal
                        .getInstance(document.getElementById('otpModal'))
                        .hide();

                }
                else {

                    $('#otpError')
                        .removeClass('d-none')
                        .text('Invalid OTP');

                }

            });

        });

        // ================= STATE -> CITY =================

        $('#StateId').on('change', function () {

            var stateId = $(this).val();

            resetDropdown('#CityId', 'Select City');
            resetDropdown('#VillageId', 'Select Village');
            resetDropdown('#CenterId', 'Select Center');

            if (!stateId) return;

            $.get('/Farmer/GetCities',
            {
                stateId: stateId
            },
            function (data) {

                var dd = $('#CityId').empty();

                dd.append('<option value="">Select City</option>');

                $.each(data, function (i, c) {

                    dd.append(
                        '<option value="' + c.cityId + '">' +
                        c.cityName +
                        '</option>'
                    );

                });

            });

        });

        // ================= CITY -> VILLAGE =================

        $('#CityId').on('change', function () {

            var cityId = $(this).val();

            resetDropdown('#VillageId', 'Select Village');
            resetDropdown('#CenterId', 'Select Center');

            if (!cityId) return;

            $.get('/Farmer/GetVillages',
            {
                cityId: cityId
            },
            function (data) {

                var dd = $('#VillageId').empty();

                dd.append('<option value="">Select Village</option>');

                $.each(data, function (i, v) {

                    dd.append(
                        '<option value="' + v.villageId + '">' +
                        v.villageName +
                        '</option>'
                    );

                });

            });

        });

        // ================= VILLAGE -> CENTER =================

        $('#VillageId').on('change', function () {

            var villageId = $(this).val();

            resetDropdown('#CenterId', 'Select Center');

            if (!villageId) return;

            $.get('/Farmer/GetCenters',
            {
                villageId: villageId
            },
            function (data) {

                var dd = $('#CenterId').empty();

                if (data.length === 0) {

                    dd.append(
                        '<option value="">No centers available</option>'
                    );

                    return;
                }

                dd.append(
                    '<option value="">Select Center</option>'
                );

                $.each(data, function (i, c) {

                    var label =
                        c.centerName +
                        (c.location
                            ? ' - ' + c.location
                            : '');

                    dd.append(
                        '<option value="' + c.centerId + '">' +
                        label +
                        '</option>'
                    );

                });

            });

        });

        // ================= FINAL SUBMIT VALIDATION =================

        $('#regForm').on('submit', function (e) {

            if ($('#IsEmailVerified').val() !== "true") {

                e.preventDefault();

                return false;
            }

        });

    </script>

}