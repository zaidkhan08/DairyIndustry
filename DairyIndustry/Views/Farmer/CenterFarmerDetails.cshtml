@model DairyIndustry.Models.FarmerModel.FarmerEditModel

@{
    ViewData["Title"] = "Farmer Details";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>

    body {
        background: #f6f8fb;
    }

    .fd-page {
        padding: 22px;
        color: #333;
    }

    .fd-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .fd-back {
        text-decoration: none;
        font-size: 13px;
        color: #666;
    }

    .fd-btn {
        padding: 7px 14px;
        border-radius: 8px;
        border: 1px solid #ddd;
        background: #fff;
        font-size: 13px;
        color: #444;
    }

        .fd-btn:hover {
            background: #f3f4f6;
        }

    .fd-header {
        background: #fff;
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .fd-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eaeaea;
    }

    .fd-name {
        font-size: 18px;
        margin: 0;
        color: #222;
    }

    .fd-code {
        font-size: 12px;
        color: #777;
        margin-top: 4px;
    }

    .badge-active {
        background: #eaf7ef;
        color: #2e7d32;
        border: 1px solid #cde8d2;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
    }

    .badge-inactive {
        background: #fdecec;
        color: #b91c1c;
        border: 1px solid #f5b5b5;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
    }

    .fd-card {
        background: #fff;
        border: 1px solid #eaeaea;
        border-radius: 14px;
        padding: 18px;
        margin-bottom: 16px;
    }

    .fd-title {
        font-size: 11px;
        letter-spacing: .4px;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .fd-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .fd-label {
        font-size: 11px;
        color: #999;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .fd-value {
        font-size: 14px;
        color: #222;
    }

    .fd-side {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .fd-box {
        background: #fff;
        border: 1px solid #eaeaea;
        border-radius: 14px;
        padding: 18px;
    }

    .fd-doc {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }

        .fd-doc:last-child {
            border-bottom: none;
        }

    .fd-link {
        font-size: 12px;
        padding: 5px 10px;
        border-radius: 7px;
        border: 1px solid #ddd;
        text-decoration: none;
        color: #333;
        background: #fff;
    }

        .fd-link:hover {
            background: #f5f5f5;
        }

</style>


<div class="fd-page">

    <!-- TOP -->
    <div class="fd-topbar">

        <a asp-action="ListAllFarmers" class="fd-back">
            <i class="bi bi-arrow-left"></i> Back
        </a>

        <a asp-action="Edit" asp-route-id="@Model.FarmerId" class="fd-btn">
            <i class="bi bi-pencil"></i> Edit
        </a>

    </div>

    <!-- HEADER -->
    <div class="fd-header">

        <img src="@(string.IsNullOrEmpty(Model.ProfilePhoto) ? "/images/user.png" : Model.ProfilePhoto)"
             class="fd-avatar" />

        <div style="flex:1">

            <h3 class="fd-name">@Model.FarmerName</h3>

            <div class="fd-code">
                Farmer Code: @Model.FarmerCode
            </div>

        </div>

        <div>
            @if (Model.IsActive)
            {
                <span class="badge-active">Active</span>
            }
            else
            {
                <span class="badge-inactive">Inactive</span>
            }
        </div>

    </div>

    <div class="row g-3">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="fd-card">

                <div class="fd-title">
                    <i class="bi bi-person"></i> Personal Details
                </div>

                <div class="fd-grid">

                    <div>
                        <div class="fd-label">Full Name</div>
                        <div class="fd-value">@Model.FarmerName</div>
                    </div>

                    <div>
                        <div class="fd-label">Gender</div>
                        <div class="fd-value">@Model.Gender</div>
                    </div>

                    <div>
                        <div class="fd-label">Date of Birth</div>
                        <div class="fd-value">
                            @(Model.DateOfBirth.HasValue? Model.DateOfBirth.Value.ToString("dd MMM yyyy") : "—")
                        </div>
                    </div>

                    <div>
                        <div class="fd-label">Aadhaar</div>
                        <div class="fd-value">
                            @(string.IsNullOrEmpty(Model.AadhaarNumber)
                                                        ? "—"
                                                        : "XXXX-XXXX-" + Model.AadhaarNumber[^4..])
                        </div>
                    </div>

                </div>

            </div>

            <div class="fd-card">

                <div class="fd-title">
                    <i class="bi bi-telephone"></i> Contact
                </div>

                <div class="fd-grid">

                    <div>
                        <div class="fd-label">Phone</div>
                        <div class="fd-value">@Model.Phone</div>
                    </div>

                    <div>
                        <div class="fd-label">Email</div>
                        <div class="fd-value">@Model.Email</div>
                    </div>

                </div>

            </div>

            <div class="fd-card">

                <div class="fd-title">
                    <i class="bi bi-file-earmark"></i> Documents
                </div>

                <div class="fd-doc">
                    <div>Aadhaar Card</div>
                    @if (!string.IsNullOrEmpty(Model.AadhaarCardPath))
                    {
                        <a href="@Model.AadhaarCardPath" target="_blank" class="fd-link">View</a>
                    }
                    else
                    {
                        <span style="color:#999;">Not Provided</span>
                    }
                </div>

                <div class="fd-doc">
                    <div>Bank Passbook</div>
                    @if (!string.IsNullOrEmpty(Model.PassbookPath))
                    {
                        <a href="@Model.PassbookPath" target="_blank" class="fd-link">View</a>
                    }
                    else
                    {
                        <span style="color:#999;">Not Provided</span>
                    }
                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4 fd-side">

            <div class="fd-box">

                <div class="fd-title">
                    <i class="bi bi-geo-alt"></i> Location
                </div>

                <div class="fd-label">Village</div>
                <div class="fd-value">@Model.VillageName</div>

                <div class="fd-label">City</div>
                <div class="fd-value">@Model.CityName</div>

                <div class="fd-label">State</div>
                <div class="fd-value">@Model.StateName</div>

            </div>

            <div class="fd-box">

                <div class="fd-title">
                    <i class="bi bi-bank"></i> Bank
                </div>

                <div class="fd-label">Bank Name</div>
                <div class="fd-value">@Model.BankName</div>

                <div class="fd-label">Account Number</div>
                <div class="fd-value">@Model.AccountNumber</div>

                <div class="fd-label">IFSC Code</div>
                <div class="fd-value">@Model.IFSCCode</div>

            </div>

        </div>

    </div>

</div>