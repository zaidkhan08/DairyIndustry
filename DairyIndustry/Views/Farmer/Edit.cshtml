@model DairyIndustry.Models.FarmerModel.FarmerEditModel

@{
    ViewData["Title"] = "Edit Farmer";
    Layout = "_CollectionCenterLayout";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container py-4">

    <!-- HEADER -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h3 class="fw-bold text-dark mb-1">
                    <i class="bi bi-pencil-square text-success me-2"></i>
                    Edit Farmer
                </h3>

                <div class="text-muted">
                    @Model.FarmerCode
                </div>
            </div>

            <a asp-action="CenterFarmerDetails"
               asp-route-id="@Model.FarmerId"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>

        </div>
    </div>

    <!-- ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="FarmerId" />
        <input type="hidden" asp-for="ProfilePhoto" />

        <!-- ================= PERSONAL ================= -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-person-fill text-success me-2"></i>
                    Personal Information
                </h5>
            </div>

            <div class="card-body">

                <div class="row mb-4 align-items-center">

                    <div class="col-md-2 text-center">
                        <img id="photoPreview"
                             src="@(string.IsNullOrEmpty(Model.ProfilePhoto) ? "/images/user.png" : Model.ProfilePhoto)"
                             class="rounded-circle border"
                             style="width:120px;height:120px;object-fit:cover;" />
                    </div>

                    <div class="col-md-10">
                        <label class="form-label fw-semibold">Profile Photo</label>
                        <input type="file"
                               name="PhotoFile"
                               class="form-control"
                               accept="image/*"
                               onchange="previewPhoto(this)" />
                    </div>

                </div>

                <div class="row g-3">

                    <div class="col-md-6">
                        <label>Farmer Name</label>
                        <input asp-for="FarmerName" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Phone</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Email</label>
                        <input asp-for="Email" class="form-control" readonly />
                    </div>

                    <div class="col-md-6">
                        <label>DOB</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label>Aadhaar</label>
                        <input class="form-control bg-light"
                               value="@Model.AadhaarNumber"
                               readonly />
                    </div>

                </div>
            </div>
        </div>

        <!-- ================= LOCATION ================= -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-geo-alt-fill text-success me-2"></i>
                    Location
                </h5>
            </div>

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-4">
                        <label>State</label>
                        <select asp-for="StateId"
                                id="stateSelect"
                                class="form-select"
                                onchange="loadCities(this.value)">
                            <option value="">Select</option>
                            @foreach (var s in Model.States)
                            {
                                <option value="@s.StateId"
                                        selected="@(Model.StateId == s.StateId)">
                                    @s.StateName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label>City</label>
                        <select asp-for="CityId"
                                id="citySelect"
                                class="form-select"
                                onchange="loadVillages(this.value)">
                            <option value="">Select</option>
                            @foreach (var c in Model.Cities)
                            {
                                <option value="@c.CityId"
                                        selected="@(Model.CityId == c.CityId)">
                                    @c.CityName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label>Village</label>
                        <select asp-for="VillageId"
                                id="villageSelect"
                                class="form-select">
                            <option value="">Select</option>
                            @foreach (var v in Model.Villages)
                            {
                                <option value="@v.VillageId"
                                        selected="@(Model.VillageId == v.VillageId)">
                                    @v.VillageName
                                </option>
                            }
                        </select>
                    </div>

                </div>

            </div>
        </div>

        <!-- ================= BANK ================= -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-bank2 text-success me-2"></i>
                    Bank Details
                </h5>
            </div>

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-4">
                        <label>Bank Name</label>
                        <input asp-for="BankName" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label>Account Number</label>
                        <input asp-for="AccountNumber" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label>IFSC Code</label>
                        <input asp-for="IFSCCode" class="form-control text-uppercase" />
                    </div>

                </div>

            </div>
        </div>

        <!-- ================= DOCUMENTS ================= -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-file-earmark-text text-success me-2"></i>
                    Documents
                </h5>
            </div>

            <div class="card-body">
                <div class="row g-4">

                    <!-- AADHAAR -->
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100 bg-light">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 fw-semibold">Aadhaar Card</h6>

                                @if (!string.IsNullOrEmpty(Model.AadhaarCardPath))
                                {
                                    <a href="@Model.AadhaarCardPath"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                }
                            </div>

                            <div class="text-center mb-3">
                                <img src="@(string.IsNullOrEmpty(Model.AadhaarCardPath)
                                                                         ? "/images/no-document.png"
                                                                         : Model.AadhaarCardPath)"
                                     class="img-fluid rounded border"
                                     style="height:180px; width:100%; object-fit:contain;" />
                            </div>

                            <input type="file"
                                   name="AadhaarFile"
                                   class="form-control form-control-sm"
                                   accept="image/*,.pdf" />
                        </div>
                    </div>

                    <!-- PASSBOOK -->
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100 bg-light">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 fw-semibold">Passbook</h6>

                                @if (!string.IsNullOrEmpty(Model.PassbookPath))
                                {
                                    <a href="@Model.PassbookPath"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                }
                            </div>

                            <div class="text-center mb-3">
                                <img src="@(string.IsNullOrEmpty(Model.PassbookPath)
                                                                         ? "/images/no-document.png"
                                                                         : Model.PassbookPath)"
                                     class="img-fluid rounded border"
                                     style="height:180px; width:100%; object-fit:contain;" />
                            </div>

                            <input type="file"
                                   name="PassbookFile"
                                   class="form-control form-control-sm"
                                   accept="image/*,.pdf" />
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <!-- BUTTONS -->
        <div class="d-flex justify-content-end gap-2 mb-5">

            <a asp-action="CenterFarmerDetails"
               asp-route-id="@Model.FarmerId"
               class="btn btn-light border">
                Cancel
            </a>

            <button type="submit" class="btn btn-success px-4">
                Save Changes
            </button>

        </div>

    </form>
</div>

@section Scripts {

    <script>

        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e =>
                    document.getElementById('photoPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }

        // =========================
        // LOAD CITIES
        // =========================
        function loadCities(stateId, selectedCityId = null, callback = null) {

            document.getElementById("citySelect").innerHTML =
                '<option value="">Select City</option>';

            document.getElementById("villageSelect").innerHTML =
                '<option value="">Select Village</option>';

            if (!stateId) return;

            fetch(`/Farmer/GetCities?stateId=${stateId}`)
                .then(r => r.json())
                .then(data => {

                    let city = document.getElementById("citySelect");

                    data.forEach(x => {
                        let selected = x.cityId == selectedCityId ? "selected" : "";
                        city.innerHTML +=
                            `<option value="${x.cityId}" ${selected}>${x.cityName}</option>`;
                    });

                    if (callback) callback();
                });
        }

        // =========================
        // LOAD VILLAGES
        // =========================
        function loadVillages(cityId, selectedVillageId = null) {

            document.getElementById("villageSelect").innerHTML =
                '<option value="">Select Village</option>';

            if (!cityId) return;

            fetch(`/Farmer/GetVillages?cityId=${cityId}`)
                .then(r => r.json())
                .then(data => {

                    let village = document.getElementById("villageSelect");

                    data.forEach(x => {
                        let selected = x.villageId == selectedVillageId ? "selected" : "";
                        village.innerHTML +=
                            `<option value="${x.villageId}" ${selected}>${x.villageName}</option>`;
                    });
                });
        }

        // =========================
        // AUTO LOAD ON EDIT (FIXED FLOW)
        // =========================
        window.onload = function () {

            let stateId = document.getElementById("stateSelect").value;
            let cityId = document.getElementById("citySelect").value;
            let villageId = document.getElementById("villageSelect").value;

            if (stateId) {
                loadCities(stateId, cityId, function () {
                    if (cityId) {
                        loadVillages(cityId, villageId);
                    }
                });
            }
        };

    </script>
}