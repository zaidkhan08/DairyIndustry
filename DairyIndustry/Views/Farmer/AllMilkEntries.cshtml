
@model List<DairyIndustry.Models.Collection.MilkCollectionViewModel>

@{
    ViewData["Title"] = "All Milk Entries";
    Layout = "_FarmerLayout";

    // var totalQty = Model?.Sum(x => x.Quantity) ?? 0;
    // var totalAmount = Model?.Sum(x => x.Amount) ?? 0;
}

<div class="container mt-4">

    <h4 class="mb-3">All Milk Entries</h4>

    <!-- Summary -->
   @*  <div class="row mb-3">
        <div class="col-md-6">
            <div class="alert alert-primary">
                Total Quantity: <strong>@totalQty.ToString("0.00") L</strong>
            </div>
        </div>
        <div class="col-md-6">
            <div class="alert alert-success">
                Total Amount: <strong>₹@totalAmount.ToString("0.00")</strong>
            </div>
        </div>
    </div> *@

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            No milk entries found for today
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Shift</th>
                        <th>Center</th>
                        <th>Milk Type</th>
                        <th>Qty (L)</th>
                        <th>Fat</th>
                        <th>CLR</th>
                        <th>Rate</th>
                        <th>Amount</th>
                        <th>Receipt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CollectionDate.ToString("dd-MM-yyyy")</td>
                            <td>
                                <span class="badge @(item.Shift == "Morning" ? "bg-warning text-dark" : "bg-info")">
                                    @item.Shift
                                </span>
                            </td>
                            <td>@item.CenterName</td>
                            <td>@item.MilkTypeName</td>
                            <td>@item.Quantity.ToString("0.00")</td>
                            <td>@item.AppliedFat</td>
                            <td>@item.AppliedCLR</td>
                            <td>@item.RatePerLiter</td>
                            <td class="text-success fw-bold">₹@item.Amount</td>
                            <td>@item.ReceiptNumber</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>