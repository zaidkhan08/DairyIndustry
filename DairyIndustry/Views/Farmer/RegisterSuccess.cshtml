@{
    ViewData["Title"] = "Registration Submitted";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card border-success">
                <div class="card-body text-center p-5">

                    <span class="display-1 text-success">✓</span>

                    <h3 class="mt-3">Registration Submitted!</h3>

                    <p class="text-muted mt-3">
                        Your registration request has been sent to the collection center.
                        The center staff will review your details and approve your account.
                    </p>

                    <hr />

                    <p class="mb-1">
                        <strong>What happens next?</strong>
                    </p>
                    <ul class="list-unstyled text-start">
                        <li class="mb-1">✅ Staff reviews your request</li>
                        <li class="mb-1">✅ On approval, your Farmer Code is generated</li>
                        <li class="mb-1">✅ Your password will be the last 4 digits of your phone</li>
                        <li class="mb-1">✅ You can then login using your Farmer Code and password</li>
                    </ul>

                    <hr />

                    <div class="d-grid gap-2">
                        <a asp-controller="Farmer"
                           asp-action="CheckStatus"
                           class="btn btn-outline-primary">
                            Check My Registration Status
                        </a>
                        <a asp-controller="Farmer"
                           asp-action="Login"
                           class="btn btn-outline-secondary">
                            Go to Login
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
