            <div class="fr-modal-head-ico"><i class="bi bi-envelope"></i></div>
            <div class="fr-modal-head-text">
                <h5>Email Verification</h5>
                <p>One-time password</p>
            </div>
        </div>
        <div class="fr-modal-body">
            <div class="fr-otp-dest">
                <i class="bi bi-envelope-at"></i>
                A 6-digit code was sent to <strong id="otpTargetEmail" style="margin-left:.25rem"></strong>.
                It is valid for 10 minutes.
            </div>
            <div class="fr-modal-lbl">Enter Verification Code</div>
            <div class="fr-otp-boxes">
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="0" />
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="1" />
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="2" />
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="3" />
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="4" />
                <input class="fr-otp-box" type="text" maxlength="1" inputmode="numeric" autocomplete="off" data-idx="5" />
