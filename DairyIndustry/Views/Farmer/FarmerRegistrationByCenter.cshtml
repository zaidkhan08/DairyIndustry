            </button>
            <button type="button" class="fr-modal-verify" id="verifyOtpBtn">
                <i class="bi bi-shield-check"></i> Verify
            </button>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="~/js/email-regex.js"></script>

@section Scripts {
    <script>
        function showFile(input, fnId, tileId, errId) {
            const fnEl  = document.getElementById(fnId);
            const tile  = document.getElementById(tileId);
            const inp   = input;
            if (inp.files && inp.files[0]) {
                const f  = inp.files[0];
                const mb = (f.size / 1024 / 1024).toFixed(2);
                fnEl.innerHTML = '<i class="bi bi-check-circle-fill" style="color:var(--success)"></i> ' + f.name + ' (' + mb + ' MB)';
                tile.classList.remove('is-invalid');
                hideErr(errId);
                inp.classList.remove('is-invalid');
            } else {
                fnEl.textContent = '';
            }
        }

        function showErr(id, msg) {
            const el = document.getElementById(id);
            if (!el) return;
            el.querySelector('.fr-err-msg').textContent = msg;
            el.classList.add('show');
        }
        function hideErr(id) {
            const el = document.getElementById(id);
            if (el) el.classList.remove('show');
        }
        function markInvalid(el) { el.classList.add('is-invalid'); el.classList.remove('is-valid'); }
        function markValid(el)   { el.classList.remove('is-invalid'); el.classList.add('is-valid'); }
        function markNeutral(el) { el.classList.remove('is-invalid', 'is-valid'); }

        function showEmailMsg(type, msg) {
            const el = document.getElementById('emailMsg');
            el.className = 'fr-inline-msg ' + type + ' show';
            el.innerHTML = '<i class="bi bi-' + (type === 'error' ? 'exclamation-circle' : 'info-circle') + '"></i> ' + msg;
        }
        function hideEmailMsg() {
            const el = document.getElementById('emailMsg');
            el.className = 'fr-inline-msg';
            el.textContent = '';
        }

        document.addEventListener('DOMContentLoaded', function () {

            /* ── Anti-forgery on all AJAX ── */
            $.ajaxSetup({
                beforeSend: function (xhr) {
                    xhr.setRequestHeader('RequestVerificationToken',
                        document.querySelector('input[name="__RequestVerificationToken"]').value);
                }
            });

            /* ── Success toast auto-dismiss ── */
            const toast = document.getElementById('successToast');
            if (toast) {
                setTimeout(function () {
                    toast.style.transition = 'opacity .4s';
                    toast.style.opacity = '0';
                    setTimeout(function () { toast.remove(); }, 420);
                }, 5000);
            }

            /* ── Validation rules ── */
            const rules = {
                FarmerName:    { req: true, pattern: /^[a-zA-Z\s]+$/,          msg: 'Only alphabets allowed.',              maxlen: 100 },
                Gender:        { req: true, select: true },
                DateOfBirth:   { req: true, date: true },
                Phone:         { req: true, pattern: /^[6-9]\d{9}$/,           msg: 'Enter valid 10-digit mobile number starting with 6-9.' },
                StateId:       { req: true, select: true },
                CityId:        { req: true, select: true },
                VillageId:     { req: true, select: true },
                BankName:      { req: true, pattern: /^[a-zA-Z\s&.\-]+$/,      msg: 'Invalid bank name.' },
                AccountNumber: { req: true, pattern: /^\d{9,18}$/,             msg: 'Account number must be 9-18 digits.' },
                IFSCCode:      { req: true, pattern: /^[A-Z]{4}0[A-Z0-9]{6}$/i, msg: 'Invalid IFSC code (e.g. SBIN0001234).' },
                AadhaarNumber: { req: true, pattern: /^\d{12}$/,               msg: 'Aadhaar must be exactly 12 digits.' }
            };

            function validateField(id) {
                const rule = rules[id];
                if (!rule) return true;
                const el  = document.getElementById(id);
                if (!el) return true;
                const val = el.value.trim();

                if (rule.req && !val) {
                    markInvalid(el); showErr('err-' + id, 'This field is required.'); return false;
                }
                if (rule.maxlen && val.length > rule.maxlen) {
                    markInvalid(el); showErr('err-' + id, 'Maximum ' + rule.maxlen + ' characters allowed.'); return false;
                }
                if (rule.pattern && val && !rule.pattern.test(val)) {
                    markInvalid(el); showErr('err-' + id, rule.msg); return false;
                }
                if (rule.date && val) {
                    const d   = new Date(val);
                    const now = new Date();
                    if (isNaN(d.getTime()))    { markInvalid(el); showErr('err-' + id, 'Invalid date.'); return false; }
                    if (d >= now)              { markInvalid(el); showErr('err-' + id, 'Date of birth must be in the past.'); return false; }
                    const age = (now - d) / (1000 * 60 * 60 * 24 * 365.25);
                    if (age < 18)              { markInvalid(el); showErr('err-' + id, 'Farmer must be at least 18 years old.'); return false; }
                }
                markValid(el); hideErr('err-' + id); return true;
            }

            /* Blur/input/change listeners */
            Object.keys(rules).forEach(function (id) {
                const el = document.getElementById(id);
                if (!el) return;
                el.addEventListener('blur',   function () { validateField(id); });
                el.addEventListener('change', function () { validateField(id); });
                el.addEventListener('input',  function () { if (el.classList.contains('is-invalid')) validateField(id); });
            });

            /* Email blur */
            document.getElementById('Email').addEventListener('blur', function () {
                const val = this.value.trim();

                if (!val) {
                    markNeutral(this);
                    hideEmailMsg();
                    return;
                }

                if (!emailRegex.test(val)) {
                    markInvalid(this);
                    showEmailMsg('error', 'Invalid email address format.');
                }
                else {
                    markNeutral(this);
                    hideEmailMsg();
                }
            });

            /* File validation */
            function validateFile(inputId, tileId, errId, required) {
                const inp  = document.getElementById(inputId);
                const tile = document.getElementById(tileId);
                if (required && (!inp.files || !inp.files[0])) {
                    tile.classList.add('is-invalid');
                    showErr(errId, 'This document is required.');
                    return false;
                }
                tile.classList.remove('is-invalid');
                hideErr(errId);
                return true;
            }

            /* ── SUBMIT HANDLER ── */
            document.getElementById('regForm').addEventListener('submit', function (e) {
                e.preventDefault(); // always prevent first, then submit manually if ok

                let ok = true;

                Object.keys(rules).forEach(function (id) {
                    if (!validateField(id)) ok = false;
                });

                // Email
                const emailEl  = document.getElementById('Email');
                const emailVal = emailEl.value.trim();
                const isVerified = document.getElementById('IsEmailVerified').value === 'true';

                if (!emailVal) {
                    markInvalid(emailEl);
                    showEmailMsg('error', 'Email address is required.');
                    ok = false;
                }
                else if (!emailRegex.test(emailVal)) {
                    markInvalid(emailEl);
                    showEmailMsg('error', 'Invalid email address format.');
                    ok = false;
                }else if (!isVerified) {
                    markInvalid(emailEl); showEmailMsg('error', 'Please verify this email (click Send OTP) before submitting.'); ok = false;
                } else {
                    markValid(emailEl); hideEmailMsg();
                }

                // Files
                if (!validateFile('PhotoFileInput',    'tile-photo',    'err-PhotoFile',    true)) ok = false;
                if (!validateFile('AadhaarFileInput',  'tile-aadhaar',  'err-AadhaarFile',  true)) ok = false;
                if (!validateFile('PassbookFileInput', 'tile-passbook', 'err-PassbookFile', true)) ok = false;

                if (!ok) {
                    // Scroll to first error
                    const first = document.querySelector('.is-invalid, .fr-err.show, .fr-upload-tile.is-invalid');
                    if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return; // stop — form stays
                }

                // All valid — submit for real
                this.submit();
            });

            /* ── CLEAR FORM ── */
            document.getElementById('clearFormBtn').addEventListener('click', function () {
                if (document.getElementById('confirmClear')) return;
                const bar = document.createElement('div');
                bar.id = 'confirmClear';
                bar.style.cssText = 'display:flex;align-items:center;gap:.6rem;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:.6rem 1rem;margin-bottom:1rem;font-size:.8rem;color:#991b1b;';
                bar.innerHTML =
                    '<i class="bi bi-exclamation-triangle-fill"></i>' +
                    '<span>This will clear all form fields. Are you sure?</span>' +
                    '<button id="confirmClearYes" style="margin-left:auto;background:#dc2626;color:#fff;border:none;border-radius:5px;padding:.3rem .8rem;font-size:.78rem;font-weight:600;cursor:pointer;">Yes, Clear</button>' +
                    '<button id="confirmClearNo"  style="background:#fff;border:1px solid #e5e7eb;border-radius:5px;padding:.3rem .8rem;font-size:.78rem;font-weight:600;cursor:pointer;color:#374151;">Cancel</button>';
                document.querySelector('.fr-page').insertBefore(bar, document.getElementById('regForm'));
                document.getElementById('confirmClearYes').addEventListener('click', function () { doClearForm(); bar.remove(); });
                document.getElementById('confirmClearNo').addEventListener('click',  function () { bar.remove(); });
            });

            function doClearForm() {
                const form = document.getElementById('regForm');
                form.querySelectorAll('input:not([type=hidden])').forEach(function (el) { el.value = ''; markNeutral(el); });
                form.querySelectorAll('select').forEach(function (el) { el.selectedIndex = 0; markNeutral(el); });
                ['fn-photo','fn-aadhaar','fn-passbook'].forEach(function (id) {
                    const el = document.getElementById(id); if (el) el.textContent = '';
                });
                ['tile-photo','tile-aadhaar','tile-passbook'].forEach(function (id) {
                    const el = document.getElementById(id); if (el) el.classList.remove('is-invalid');
                });
                document.querySelectorAll('.fr-err[id^="err-"]').forEach(function (el) { el.classList.remove('show'); });
                document.getElementById('IsEmailVerified').value = 'false';
                document.getElementById('emailVerifiedBadge').classList.remove('show');
                document.getElementById('sendOtpBtn').style.display = '';
                document.getElementById('sendOtpBtn').disabled = false;
                document.getElementById('sendOtpBtn').innerHTML = '<i class="bi bi-send"></i> Send OTP';
                document.getElementById('Email').readOnly = false;
                hideEmailMsg();
                document.getElementById('CityId').innerHTML    = '<option value="">Select City</option>';
                document.getElementById('VillageId').innerHTML = '<option value="">Select Village</option>';
            }

            /* ── OTP MODAL ── */
            const overlay = document.getElementById('otpOverlay');
            let expireInterval = null;
            let resendInterval = null;

            function openModal()  { overlay.classList.add('open'); }
            function closeModal() { overlay.classList.remove('open'); clearInterval(expireInterval); clearInterval(resendInterval); }

            document.getElementById('otpCancelBtn').addEventListener('click', closeModal);
            overlay.addEventListener('click', function (e) { if (e.target === overlay) closeModal(); });

            const boxes = Array.from(document.querySelectorAll('.fr-otp-box'));
            boxes.forEach(function (box, idx) {
                box.addEventListener('input', function () {
                    const v = this.value.replace(/\D/g, '');
                    this.value = v ? v[0] : '';
                    this.classList.toggle('filled', !!this.value);
                    this.classList.remove('error');
                    if (this.value && idx < boxes.length - 1) boxes[idx + 1].focus();
                });
                box.addEventListener('keydown', function (e) {
                    if (e.key === 'Backspace' && !this.value && idx > 0) {
                        boxes[idx - 1].value = '';
                        boxes[idx - 1].classList.remove('filled', 'error');
                        boxes[idx - 1].focus();
                    }
                });
                box.addEventListener('paste', function (e) {
                    e.preventDefault();
                    const p = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
                    p.split('').forEach(function (ch, i) { if (boxes[i]) { boxes[i].value = ch; boxes[i].classList.add('filled'); } });
                    const nxt = boxes[Math.min(p.length, boxes.length - 1)];
                    if (nxt) nxt.focus();
                });
            });

            function getOtp()     { return boxes.map(function (b) { return b.value; }).join(''); }
            function clearBoxes() { boxes.forEach(function (b) { b.value = ''; b.classList.remove('filled', 'error'); }); if (boxes[0]) boxes[0].focus(); }

            function showOtpErr(msg) {
                document.getElementById('otpErrMsg').textContent = msg;
                document.getElementById('otpError').classList.add('show');
                boxes.forEach(function (b) { b.classList.add('error'); });
            }
            function hideOtpErr() {
                document.getElementById('otpError').classList.remove('show');
                boxes.forEach(function (b) { b.classList.remove('error'); });
            }

            function startExpire(sec) {
                clearInterval(expireInterval);
                const el = document.getElementById('otpCountdown');
                let r = sec;
                function tick() {
                    el.textContent = String(Math.floor(r / 60)).padStart(2, '0') + ':' + String(r % 60).padStart(2, '0');
                    if (r <= 0) { clearInterval(expireInterval); return; }
                    r--;
                }
                tick(); expireInterval = setInterval(tick, 1000);
            }

            function startResend(sec) {
                clearInterval(resendInterval);
                const cool  = document.getElementById('otpResendCooldown');
                const secEl = document.getElementById('otpResendSec');
                const btn   = document.getElementById('otpResendBtn');
                cool.style.display = 'inline'; btn.style.display = 'none';
                let r = sec; secEl.textContent = r;
                resendInterval = setInterval(function () {
                    r--; secEl.textContent = r;
                    if (r <= 0) { clearInterval(resendInterval); cool.style.display = 'none'; btn.style.display = 'inline'; }
                }, 1000);
            }

            function doSendOtp() {


               const email = document.getElementById('Email').value.trim();

                if (!email) {
                    markInvalid(document.getElementById('Email'));
                    showEmailMsg('error', 'Please enter an email address before sending OTP.');
                    return;
                }

                if (!emailRegex.test(email)) {
                    markInvalid(document.getElementById('Email'));
                    showEmailMsg('error', 'Please enter a valid email address.');
                    return;
                }
                const btn = document.getElementById('sendOtpBtn');
                btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Sending...';

                $.ajax({
                    url: '/Farmer/SendEmailOTP', type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    data: 'email=' + encodeURIComponent(email),
                    success: function (res) {
                        if (res.success) {
                            document.getElementById('otpTargetEmail').textContent = email;
                            clearBoxes(); hideOtpErr(); openModal();
                            startExpire(600); startResend(30);
                            btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Resend OTP';
                            hideEmailMsg();
                        } else {
                            btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Send OTP';
                            showEmailMsg('error', res.message || 'Could not send OTP. Please try again.');
                        }
                    },
                    error: function () {
                        btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Send OTP';
                        showEmailMsg('error', 'Server error. Could not send OTP.');
                    }
                });
            }

            document.getElementById('sendOtpBtn').addEventListener('click', doSendOtp);

            document.getElementById('otpResendBtn').addEventListener('click', function () {
                const email = document.getElementById('Email').value.trim();
                if (!email) return;
                this.style.display = 'none';
                $.ajax({
                    url: '/Farmer/SendEmailOTP', type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    data: 'email=' + encodeURIComponent(email),
                    success: function (res) { if (res.success) { clearBoxes(); hideOtpErr(); startExpire(600); startResend(30); } }
                });
            });

            document.getElementById('verifyOtpBtn').addEventListener('click', function () {
                const email = document.getElementById('Email').value.trim();
                const otp   = getOtp();
                if (otp.length < 6) { showOtpErr('Please enter all 6 digits.'); return; }
                const btn = this;
                btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Verifying...';
                $.ajax({
                    url: '/Farmer/VerifyEmailOTP', type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    data: 'email=' + encodeURIComponent(email) + '&otp=' + encodeURIComponent(otp),
                    success: function (res) {
                        btn.disabled = false; btn.innerHTML = '<i class="bi bi-shield-check"></i> Verify';
                        if (res.success) {
                            document.getElementById('IsEmailVerified').value = 'true';
                            document.getElementById('emailVerifiedBadge').classList.add('show');
                            document.getElementById('Email').readOnly = true;
                            markValid(document.getElementById('Email'));
                            document.getElementById('sendOtpBtn').style.display = 'none';
                            closeModal();
                        } else {
                            showOtpErr('Invalid OTP. Please try again.'); clearBoxes();
                        }
                    },
                    error: function () {
                        btn.disabled = false; btn.innerHTML = '<i class="bi bi-shield-check"></i> Verify';
                        showOtpErr('Server error. Please try again.');
                    }
                });
            });

            /* Restore verified state on postback */
            if (document.getElementById('IsEmailVerified').value === 'true') {
                document.getElementById('emailVerifiedBadge').classList.add('show');
                document.getElementById('sendOtpBtn').style.display = 'none';
                document.getElementById('Email').readOnly = true;
                markValid(document.getElementById('Email'));
            }

            /* ── CASCADING DROPDOWNS ── */
            document.getElementById('StateId').addEventListener('change', function () {
                const stateId = this.value;
                document.getElementById('CityId').innerHTML    = '<option value="">Select City</option>';
                document.getElementById('VillageId').innerHTML = '<option value="">Select Village</option>';
                if (!stateId) return;
                $.get('/Farmer/GetCities', { stateId: stateId }, function (data) {
                    data.forEach(function (c) {
                        document.getElementById('CityId').insertAdjacentHTML('beforeend', '<option value="' + c.cityId + '">' + c.cityName + '</option>');
                    });
                });
            });

            document.getElementById('CityId').addEventListener('change', function () {
                const cityId = this.value;
                document.getElementById('VillageId').innerHTML = '<option value="">Select Village</option>';
                if (!cityId) return;
                $.get('/Farmer/GetVillages', { cityId: cityId }, function (data) {
                    data.forEach(function (v) {
                        document.getElementById('VillageId').insertAdjacentHTML('beforeend', '<option value="' + v.villageId + '">' + v.villageName + '</option>');
                    });
                });
            });

        }); // end DOMContentLoaded
    </script>
}