                    <button type="button" class="fr-otp-resend-btn" id="otpResendBtn">Resend OTP</button>
                </div>
            </div>
        </div>
        <div class="fr-modal-foot">
            <button type="button" class="fr-modal-cancel" id="otpCancelBtn">
