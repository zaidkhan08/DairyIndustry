@{
    Layout = "_DairyLayout";
    ViewData["Title"] = "Verify OTP";
    string farmerCode = ViewBag.FarmerCode ?? "";
    string maskedEmail = ViewBag.MaskedEmail ?? "your registered email";
}

<style>
    .vf-card {
        width: 100%;
        max-width: 440px;
        border-radius: 18px;
        border: none;
        box-shadow: 0 8px 32px rgba(13,27,64,.13);
    }

    .vf-icon-wrap {
        background: #e8f5e9;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 68px;
        height: 68px;
    }

    .otp-box {
        width: 52px;
        height: 58px;
        font-size: 1.5rem;
        font-weight: 700;
        border: 2px solid #c8d6ea;
        border-radius: 12px;
        text-align: center;
        color: #0d1b40;
        background: #f8fafd;
        transition: border-color .18s, box-shadow .18s, background .18s;
        caret-color: #1a3a6b;
    }

        .otp-box:focus {
            outline: none;
            border-color: #1a3a6b;
            box-shadow: 0 0 0 3px rgba(26,58,107,.15);
            background: #fff;
        }

        .otp-box.filled {
            border-color: #1a3a6b;
            background: #eef3fb;
            color: #1a3a6b;
        }

        .otp-box.invalid {
            border-color: #d32f2f !important;
            background: #fff5f5;
            animation: shake .3s;
        }
    @@keyframes shake {
        0%,100%

    {
        transform: translateX(0)
    }

    25% {
        transform: translateX(-4px)
    }

    75% {
        transform: translateX(4px)
    }

    }

    .btn-navy {
        background: #1a3a6b;
        border: none;
        border-radius: 11px;
        font-weight: 600;
        transition: background .2s;
    }

        .btn-navy:hover {
            background: #122a52;
        }

        .btn-navy:disabled {
            background: #6b87b0;
        }

    .vf-footer {
        border-top: 1px solid #eef1f7;
        border-radius: 0 0 18px 18px;
        background: #fff;
    }

        .vf-footer a {
            color: #1a3a6b;
        }

    .alert-danger {
        border-left: 4px solid #d32f2f;
        background: #fff5f5;
        color: #b71c1c;
        border-radius: 10px;
    }

    .resend-link {
        color: #1a3a6b;
        font-weight: 600;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card vf-card">
        <div class="card-body p-4">

            <div class="text-center mb-4">
                <div class="mb-3">
                    <span class="vf-icon-wrap">
                        <i class="bi bi-envelope-open-fill" style="font-size:28px; color:#2e7d32;"></i>
                    </span>
                </div>
                <h4 class="fw-bold mb-1" style="color:#0d1b40;">Check Your Email</h4>
                <p class="text-muted small mb-0">
                    We sent a 6-digit OTP to<br>
                    <strong style="color:#1a3a6b;">@maskedEmail</strong>
                </p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible small py-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- 6 OTP Boxes -->
            <div class="mb-4">
                <label class="form-label fw-semibold small d-block text-center mb-3" style="color:#1a3a6b;">Enter OTP</label>
                <div class="d-flex justify-content-center gap-2" id="otpBoxes">
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                </div>
                <div id="otpError" class="text-danger small mt-2 text-center d-none">
                    <i class="bi bi-exclamation-circle me-1"></i><span id="otpErrorMsg"></span>
                </div>
            </div>

            <!-- Verify Button -->
            <div class="d-grid mb-3">
                <button type="button" id="btnVerifyOtp" class="btn btn-navy btn-lg text-white">
                    <span id="verifyText"><i class="bi bi-check-circle me-2"></i>Verify OTP</span>
                    <span id="verifySpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                </button>
            </div>

            <!-- Resend -->
            <div class="text-center">
                <span id="resendCooldown" class="text-muted small">
                    <i class="bi bi-clock me-1"></i>Resend OTP in <span id="cooldownSeconds">30</span>s
                </span>
                <a href="#" id="resendLink" class="small resend-link d-none text-decoration-none">
                    <i class="bi bi-arrow-clockwise me-1"></i>Resend OTP
                </a>
            </div>
        </div>

        <div class="card-footer text-center py-3 vf-footer">
            <a asp-controller="Farmer" asp-action="ForgotPassword" class="small text-decoration-none fw-semibold">
                <i class="bi bi-arrow-left me-1"></i>Change Farmer Code
            </a>
        </div>
    </div>
</div>

<!-- POST to ResetPassword — carries farmerCode + otp -->
<form id="verifiedForm" method="post" asp-controller="Farmer" asp-action="ResetPassword">
    @Html.AntiForgeryToken()
    <input type="hidden" name="farmerCode" value="@farmerCode" />
    <input type="hidden" name="otp" id="hiddenOtp" />
</form>

@section Scripts {
    <script>
        const boxes          = Array.from(document.querySelectorAll('.otp-box'));
        const btnVerifyOtp   = document.getElementById('btnVerifyOtp');
        const verifyText     = document.getElementById('verifyText');
        const verifySpinner  = document.getElementById('verifySpinner');
        const otpError       = document.getElementById('otpError');
        const otpErrorMsg    = document.getElementById('otpErrorMsg');
        const resendCooldown = document.getElementById('resendCooldown');
        const resendLink     = document.getElementById('resendLink');
        const cooldownEl     = document.getElementById('cooldownSeconds');
        const farmerCode     = '@farmerCode';

        // ── Box behaviours ────────────────────────────────────────────────
        boxes.forEach((box, idx) => {
            box.addEventListener('input', () => {
                box.value = box.value.replace(/\D/g, '').slice(0, 1);
                box.classList.toggle('filled', box.value.length === 1);
                box.classList.remove('invalid');
                clearOtpError();
                if (box.value && idx < 5) boxes[idx + 1].focus();
            });
            box.addEventListener('keydown', e => {
                if (e.key === 'Backspace' && !box.value && idx > 0) {
                    boxes[idx - 1].value = '';
                    boxes[idx - 1].classList.remove('filled');
                    boxes[idx - 1].focus();
                }
                if (e.key === 'ArrowLeft'  && idx > 0) boxes[idx - 1].focus();
                if (e.key === 'ArrowRight' && idx < 5) boxes[idx + 1].focus();
                if (e.key === 'Enter') verifyOtp();
            });
            box.addEventListener('paste', e => {
                e.preventDefault();
                const digits = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 6);
                digits.split('').forEach((d, i) => {
                    if (boxes[i]) { boxes[i].value = d; boxes[i].classList.add('filled'); }
                });
                boxes[Math.min(digits.length, 5)].focus();
            });
        });

        boxes[0].focus();

        function getOtp() { return boxes.map(b => b.value).join(''); }
        function showOtpError(msg) {
            otpErrorMsg.textContent = msg;
            otpError.classList.remove('d-none');
            boxes.forEach(b => { b.classList.add('invalid'); b.classList.remove('filled'); });
        }
        function clearOtpError() { otpError.classList.add('d-none'); }

        // ── Verify ────────────────────────────────────────────────────────
        function verifyOtp() {
            clearOtpError();
            const otp = getOtp();
            if (otp.length < 6) { showOtpError('Please enter all 6 digits of the OTP.'); return; }
            btnVerifyOtp.disabled = true;
            verifyText.textContent = 'Verifying...';
            verifySpinner.classList.remove('d-none');
            document.getElementById('hiddenOtp').value = otp;
            document.getElementById('verifiedForm').submit();
        }

        btnVerifyOtp.addEventListener('click', verifyOtp);

        // ── Resend countdown ──────────────────────────────────────────────
        let secs = 30;
        const timer = setInterval(() => {
            secs--;
            cooldownEl.textContent = secs;
            if (secs <= 0) {
                clearInterval(timer);
                resendCooldown.classList.add('d-none');
                resendLink.classList.remove('d-none');
            }
        }, 1000);

        resendLink.addEventListener('click', async e => {
            e.preventDefault();
            resendLink.classList.add('d-none');
            resendCooldown.classList.remove('d-none');
            secs = 30; cooldownEl.textContent = secs;
            boxes.forEach(b => { b.value = ''; b.classList.remove('filled','invalid'); });
            boxes[0].focus();
            clearOtpError();
            try {
                const res  = await fetch('@Url.Action("SendForgotPasswordOTP", "Farmer")', {
                    method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
                    body:`farmerCode=${encodeURIComponent(farmerCode)}`
                });
                const data = await res.json();
                if (!data.success) showOtpError(data.message || 'Could not resend OTP.');
                else {
                    let s2 = 30;
                    const t2 = setInterval(() => {
                        s2--; cooldownEl.textContent = s2;
                        if (s2 <= 0) { clearInterval(t2); resendCooldown.classList.add('d-none'); resendLink.classList.remove('d-none'); }
                    }, 1000);
                }
            } catch { showOtpError('Network error. Please try again.'); }
        });
    </script>
}
