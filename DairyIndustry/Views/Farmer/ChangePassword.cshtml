@{
    ViewData["Title"] = "Change Password";
    Layout = "_DairyLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-shield-lock me-2"></i>Set Your New Password
                    </h5>
                </div>

                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible">
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            @TempData["Error"]
                        </div>
                    }

                    <p class="text-muted small mb-4">
                        Your default password is the <strong>last 4 digits of your registered mobile number</strong>.
                        Please create a new password to secure your account.
                    </p>

                    <form asp-action="ChangePassword" method="post" id="changePwdForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Current Password</label>
                            <div class="input-group">
                                <input type="password"
                                       name="currentPassword"
                                       id="currentPassword"
                                       class="form-control"
                                       placeholder="Last 4 digits of your phone"
                                       maxlength="20"
                                       required />
                                <button class="btn btn-outline-secondary toggle-eye" type="button" data-target="currentPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">New Password</label>
                            <div class="input-group">
                                <input type="password"
                                       name="newPassword"
                                       id="newPassword"
                                       class="form-control"
                                       placeholder="Minimum 6 characters"
                                       minlength="6"
                                       maxlength="20"
                                       required
                                       oninput="checkStrength(this.value)" />
                                <button class="btn btn-outline-secondary toggle-eye" type="button" data-target="newPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>

                            <!-- Strength bar -->
                            <div class="progress mt-2" style="height:5px">
                                <div id="strengthBar" class="progress-bar" style="width:0%;transition:width .3s,background .3s"></div>
                            </div>
                            <small id="strengthLabel" class="text-muted"></small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Confirm New Password</label>
                            <div class="input-group">
                                <input type="password"
                                       name="confirmPassword"
                                       id="confirmPassword"
                                       class="form-control"
                                       placeholder="Re-enter new password"
                                       maxlength="20"
                                       required
                                       oninput="checkMatch()" />
                                <button class="btn btn-outline-secondary toggle-eye" type="button" data-target="confirmPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <small id="matchMsg" class="text-danger d-none">Passwords do not match.</small>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg" id="submitBtn">
                                Change Password
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Toggle password visibility ─────────────────────────────────
        document.querySelectorAll('.toggle-eye').forEach(btn => {
            btn.addEventListener('click', function () {
                const inp = document.getElementById(this.dataset.target);
                const icon = this.querySelector('i');
                if (inp.type === 'password') {
                    inp.type = 'text';
                    icon.classList.replace('bi-eye', 'bi-eye-slash');
                } else {
                    inp.type = 'password';
                    icon.classList.replace('bi-eye-slash', 'bi-eye');
                }
            });
        });

        // ── Password strength ──────────────────────────────────────────
        function checkStrength(val) {
            const bar   = document.getElementById('strengthBar');
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { pct: '20%', bg: '#e53935', text: 'Very weak' },
                { pct: '40%', bg: '#fb8c00', text: 'Weak' },
                { pct: '60%', bg: '#fdd835', text: 'Fair' },
                { pct: '80%', bg: '#43a047', text: 'Strong' },
                { pct: '100%', bg: '#1b5e20', text: 'Very strong' },
            ];
            const lvl = levels[Math.min(score - 1, 4)] ?? { pct: '0%', bg: 'transparent', text: '' };
            bar.style.width      = lvl.pct;
            bar.style.background = lvl.bg;
            label.textContent    = lvl.text;
            label.style.color    = lvl.bg;
        }

        // ── Confirm match ──────────────────────────────────────────────
        function checkMatch() {
            const np = document.getElementById('newPassword').value;
            const cp = document.getElementById('confirmPassword').value;
            const msg = document.getElementById('matchMsg');
            const btn = document.getElementById('submitBtn');

            if (cp && np !== cp) {
                msg.classList.remove('d-none');
                btn.disabled = true;
            } else {
                msg.classList.add('d-none');
                btn.disabled = false;
            }
        }

        // ── Block submit if passwords do not match ─────────────────────
        document.getElementById('changePwdForm').addEventListener('submit', function (e) {
            const np = document.getElementById('newPassword').value;
            const cp = document.getElementById('confirmPassword').value;
            if (np !== cp) {
                e.preventDefault();
                document.getElementById('matchMsg').classList.remove('d-none');
            }
        });
    </script>
}
