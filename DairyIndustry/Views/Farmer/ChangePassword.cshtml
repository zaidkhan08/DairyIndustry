@{
    ViewData["Title"] = "Change Password";
    Layout = "_DairyLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0
    }

    :root {
        --navy: #1B3A6B;
        --navy-dark: #122850;
        --navy-mid: #2E5496;
        --navy-light: #E8EEF8;
        --navy-border: #C2D0E8;
        --accent: #2563EB;
        --red: #DC2626;
        --red-light: #FEF2F2;
        --green-ok: #16A34A;
        --gray-bg: #F5F7FA;
        --gray-border: #D1D5DB;
        --gray-text: #6B7280;
        --gray-hint: #9CA3AF;
        --white: #FFFFFF;
        --radius: 12px;
        --radius-sm: 8px;
    }

    body {
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        background: var(--gray-bg);
        color: #111827
    }

    .page-wrap {
        max-width: 480px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem
    }

    /* ── HEADER ── */
    .page-header {
        text-align: center;
        margin-bottom: 1.75rem
    }

    .brand-chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--navy-light);
        color: var(--navy);
        font-size: 12px;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 14px;
        border: 1px solid var(--navy-border);
        letter-spacing: 0.3px
    }

        .brand-chip i {
            font-size: 15px
        }

    .page-header h1 {
        font-size: 22px;
        font-weight: 700;
        color: var(--navy-dark);
        margin-bottom: 5px;
        letter-spacing: -0.3px
    }

    .page-header p {
        font-size: 13.5px;
        color: var(--gray-text);
        line-height: 1.6
    }

    /* ── CARD ── */
    .card {
        background: var(--white);
        border: 1px solid var(--gray-border);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05)
    }

    .card-head {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-border);
        display: flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-mid) 100%)
    }

    .card-head-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        background: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 20px;
        flex-shrink: 0
    }

    .card-head-text h2 {
        font-size: 15px;
        font-weight: 600;
        color: #fff
    }

    .card-head-text p {
        font-size: 12px;
        color: rgba(255,255,255,0.7);
        margin-top: 2px
    }

    .card-body {
        padding: 1.5rem
    }

    /* ── ERROR BANNER ── */
    .error-banner {
        background: var(--red-light);
        border: 1px solid #FECACA;
        border-radius: var(--radius-sm);
        padding: 11px 14px;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        font-size: 13px;
        color: #991B1B
    }

        .error-banner i {
            font-size: 15px;
            flex-shrink: 0;
            margin-top: 1px;
            color: var(--red)
        }

    /* ── INFO BOX ── */
    .info-box {
        background: var(--navy-light);
        border: 1px solid var(--navy-border);
        border-radius: var(--radius-sm);
        padding: 11px 14px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        font-size: 12.5px;
        color: var(--navy-dark);
        line-height: 1.6
    }

        .info-box i {
            font-size: 15px;
            flex-shrink: 0;
            margin-top: 1px;
            color: var(--navy)
        }

    /* ── FIELD ── */
    .field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 1.1rem
    }

        .field label {
            font-size: 12.5px;
            font-weight: 600;
            color: #374151
        }

    .input-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--gray-border);
        border-radius: var(--radius-sm);
        overflow: hidden;
        transition: border .15s, box-shadow .15s;
        background: var(--white)
    }

        .input-wrap:focus-within {
            border-color: var(--navy);
            box-shadow: 0 0 0 3px rgba(27,58,107,0.12)
        }

        .input-wrap.err {
            border-color: var(--red)
        }

        .input-wrap input {
            flex: 1;
            height: 42px;
            padding: 0 12px;
            font-size: 14px;
            color: #111827;
            background: transparent;
            border: none;
            outline: none;
            font-family: inherit
        }

    .toggle-eye {
        width: 42px;
        height: 42px;
        background: none;
        border: none;
        border-left: 1px solid var(--gray-border);
        cursor: pointer;
        color: var(--gray-hint);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
        transition: color .15s, background .15s
    }

        .toggle-eye:hover {
            color: var(--navy);
            background: var(--navy-light)
        }

    .field-err {
        font-size: 11.5px;
        color: var(--red);
        display: none;
        align-items: center;
        gap: 4px;
        font-weight: 500;
        margin-top: 3px
    }

        .field-err.show {
            display: flex
        }

        .field-err i {
            font-size: 13px
        }

    /* ── STRENGTH BAR ── */
    .strength-wrap {
        margin-top: 8px
    }

    .strength-track {
        height: 5px;
        background: var(--gray-border);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 5px
    }

    .strength-fill {
        height: 100%;
        width: 0;
        border-radius: 3px;
        transition: width .3s, background .3s
    }

    .strength-label {
        font-size: 11.5px;
        font-weight: 600
    }

    /* ── BUTTON ── */
    .btn-submit {
        height: 46px;
        width: 100%;
        border-radius: var(--radius-sm);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--navy);
        color: #fff;
        transition: background .15s, transform .1s;
        margin-top: 0.5rem
    }

        .btn-submit:hover:not(:disabled) {
            background: var(--navy-dark)
        }

        .btn-submit:active {
            transform: scale(0.98)
        }

        .btn-submit:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            transform: none
        }

    /* ── DIVIDER ── */
    .divider {
        height: 1px;
        background: var(--gray-border);
        margin: 1.25rem 0
    }

    @@media(max-width: 480px) {
        .page-wrap {
            padding: 1.25rem 0.75rem 2rem
        }

        .card-body {
            padding: 1.25rem
        }
    }
</style>

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header">
        <h1>Set new password</h1>
        <p>Create a strong password to secure your farmer account</p>
    </div>

    <!-- Card -->
    <div class="card">

        <!-- Card head -->
        <div class="card-head">
            <div class="card-head-icon"><i class="ti ti-shield-lock"></i></div>
            <div class="card-head-text">
                <h2>Change password</h2>
               
            </div>
        </div>

        <div class="card-body">

            <!-- Error banner -->
            @if (TempData["Error"] != null)
            {
                <div class="error-banner">
                    <i class="ti ti-alert-circle"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <!-- Info note -->
            <div class="info-box">
                <i class="ti ti-info-circle"></i>
                <span>Your default password is the <strong>last 4 digits of your registered mobile number</strong>. Please create a new password to secure your account.</span>
            </div>

            <form asp-action="ChangePassword" method="post" id="changePwdForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- Current password -->
                <div class="field">
                    <label>Current password</label>
                    <div class="input-wrap" id="wrap-current">
                        <input type="password" name="currentPassword" id="currentPassword"
                               placeholder="Last 4 digits of your phone" maxlength="20" />
                        <button type="button" class="toggle-eye" data-target="currentPassword" aria-label="Toggle visibility">
                            <i class="ti ti-eye"></i>
                        </button>
                    </div>
                    <div class="field-err" id="err-current"><i class="ti ti-alert-circle"></i><span>Current password is required</span></div>
                </div>


                <!-- New password -->
                <div class="field">
                    <label>New password</label>
                    <div class="input-wrap" id="wrap-new">
                        <input type="password" name="newPassword" id="newPassword"
                               placeholder="Minimum 6 characters" minlength="6" maxlength="20"
                               oninput="checkStrength(this.value); checkMatch()" />
                        <button type="button" class="toggle-eye" data-target="newPassword" aria-label="Toggle visibility">
                            <i class="ti ti-eye"></i>
                        </button>
                    </div>
                    <div class="strength-wrap">
                        <div class="strength-track"><div class="strength-fill" id="strengthBar"></div></div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>
                    <div class="field-err" id="err-new"><i class="ti ti-alert-circle"></i><span>Minimum 6 characters required</span></div>
                </div>

                <!-- Confirm password -->
                <div class="field">
                    <label>Confirm new password</label>
                    <div class="input-wrap" id="wrap-confirm">
                        <input type="password" name="confirmPassword" id="confirmPassword"
                               placeholder="Re-enter new password" maxlength="20"
                               oninput="checkMatch()" />
                        <button type="button" class="toggle-eye" data-target="confirmPassword" aria-label="Toggle visibility">
                            <i class="ti ti-eye"></i>
                        </button>
                    </div>
                    <div class="field-err" id="err-match"><i class="ti ti-alert-circle"></i><span>Passwords do not match</span></div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="ti ti-shield-check" style="font-size:18px"></i> Change password
                </button>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Toggle eye ─────────────────────────────────────────────────
        document.querySelectorAll('.toggle-eye').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var inp  = document.getElementById(this.dataset.target);
                var icon = this.querySelector('i');
                if (inp.type === 'password') {
                    inp.type = 'text';
                    icon.className = 'ti ti-eye-off';
                } else {
                    inp.type = 'password';
                    icon.className = 'ti ti-eye';
                }
            });
        });

        // ── Password strength ──────────────────────────────────────────
        function checkStrength(val) {
            var bar   = document.getElementById('strengthBar');
            var label = document.getElementById('strengthLabel');
            var score = 0;
            if (val.length >= 6)           score++;
            if (val.length >= 10)          score++;
            if (/[A-Z]/.test(val))         score++;
            if (/[0-9]/.test(val))         score++;
            if (/[^A-Za-z0-9]/.test(val))  score++;

            var levels = [
                { pct: '20%', bg: '#DC2626', text: 'Very weak' },
                { pct: '40%', bg: '#EA580C', text: 'Weak' },
                { pct: '60%', bg: '#D97706', text: 'Fair' },
                { pct: '80%', bg: '#16A34A', text: 'Strong' },
                { pct: '100%', bg: '#15803D', text: 'Very strong' }
            ];
            var lvl = score > 0 ? levels[Math.min(score - 1, 4)] : { pct: '0%', bg: 'transparent', text: '' };
            bar.style.width      = lvl.pct;
            bar.style.background = lvl.bg;
            label.textContent    = lvl.text;
            label.style.color    = lvl.bg;
        }

        // ── Confirm match ──────────────────────────────────────────────
        function checkMatch() {
            var np  = document.getElementById('newPassword').value;
            var cp  = document.getElementById('confirmPassword').value;
            var err = document.getElementById('err-match');
            var btn = document.getElementById('submitBtn');
            var wrap = document.getElementById('wrap-confirm');
            if (cp && np !== cp) {
                err.classList.add('show');
                wrap.classList.add('err');
                btn.disabled = true;
            } else {
                err.classList.remove('show');
                wrap.classList.remove('err');
                btn.disabled = false;
            }
        }

        // ── Submit guard ───────────────────────────────────────────────
        document.getElementById('changePwdForm').addEventListener('submit', function (e) {
            var ok = true;
            var cur = document.getElementById('currentPassword').value;
            var np  = document.getElementById('newPassword').value;
            var cp  = document.getElementById('confirmPassword').value;

            if (!cur) {
                document.getElementById('err-current').classList.add('show');
                document.getElementById('wrap-current').classList.add('err');
                ok = false;
            } else {
                document.getElementById('err-current').classList.remove('show');
                document.getElementById('wrap-current').classList.remove('err');
            }
            if (np.length < 6) {
                document.getElementById('err-new').classList.add('show');
                document.getElementById('wrap-new').classList.add('err');
                ok = false;
            } else {
                document.getElementById('err-new').classList.remove('show');
                document.getElementById('wrap-new').classList.remove('err');
            }
            if (np !== cp) {
                document.getElementById('err-match').classList.add('show');
                document.getElementById('wrap-confirm').classList.add('err');
                ok = false;
            }
            if (!ok) e.preventDefault();
        });
    </script>
}