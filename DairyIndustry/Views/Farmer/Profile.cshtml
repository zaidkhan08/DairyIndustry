@model DairyIndustry.Models.FarmerModel.FarmerProfileModel

@{
    Layout = "_FarmerLayout";
    ViewData["Title"] = "My Profile";

    string initials = !string.IsNullOrEmpty(Model.FarmerName)
        ? string.Join("", Model.FarmerName.Split(' ').Select(x => x[0])).ToUpper()
        : "F";

    string maskedAccount = (!string.IsNullOrEmpty(Model.AccountNumber) && Model.AccountNumber.Length >= 4)
        ? "XXXX XXXX " + Model.AccountNumber[^4..]
        : "Not Available";

    string maskedAadhaar = (!string.IsNullOrEmpty(Model.AadhaarNumber) && Model.AadhaarNumber.Length >= 4)
        ? "XXXX-XXXX-" + Model.AadhaarNumber[^4..]
        : "Not Available";
}
<style>
    body {
        background: #f8fafc;
    }

    .container {
        max-width: 100%;
    }

    /* Cards */
    .card {
        border: 1px solid #eef2f7 !important;
        border-radius: 18px !important;
        transition: all .25s ease;
        background: #fff;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
        }

    /* Header Card */
    .card-body img {
        border-radius: 16px !important;
    }

    .bg-primary {
        background: linear-gradient(135deg,#2563eb,#3b82f6) !important;
    }

    h5 {
        font-weight: 700;
    }

    /* Card Headers */
    .card-header {
        background: #fff !important;
        border-bottom: 1px solid #edf2f7 !important;
        font-size: .95rem;
        color: #334155 !important;
        font-weight: 600;
    }

        .card-header i {
            color: #2563eb;
        }

    /* Labels */
    small.text-uppercase {
        display: block;
        margin-bottom: 4px;
        color: #94a3b8 !important;
        font-weight: 600 !important;
    }

    /* Values */
    .fw-medium,
    .fw-bold,
    .text-dark {
        color: #1e293b !important;
    }

    /* Status Badge */
    .badge {
        font-size: .78rem;
        font-weight: 600;
        padding: 8px 14px;
    }

    /* Bank Section */
    .font-monospace {
        letter-spacing: .5px;
    }

    /* Security Card */
    .btn-outline-primary {
        border-radius: 10px;
        font-weight: 600;
        transition: .25s;
    }

        .btn-outline-primary:hover {
            transform: translateY(-1px);
        }

    /* Responsive */
    @@media (max-width: 991px) {

        .container {
            padding-left: 12px;
            padding-right: 12px;
        }

        .card-body.d-flex.align-items-center.gap-3 {
            flex-wrap: wrap;
            text-align: center;
            justify-content: center;
        }

            .card-body.d-flex.align-items-center.gap-3 .flex-grow-1 {
                width: 100%;
            }
    }

    @@media (max-width: 768px) {

        .row > div {
            margin-bottom: 4px;
        }

        .card-body.d-flex.justify-content-between.align-items-center {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

            .card-body.d-flex.justify-content-between.align-items-center .btn {
                width: 100%;
            }

        .badge {
            margin-top: 5px;
        }
    }

    @@media (max-width: 576px) {

        .container.py-4 {
            padding-top: 15px !important;
            padding-bottom: 15px !important;
        }

        .card {
            border-radius: 14px !important;
        }

        .card-header {
            padding: 14px 16px !important;
        }

        .card-body {
            padding: 16px !important;
        }

        h5 {
            font-size: 1.1rem;
        }

        .fs-6 {
            font-size: 1rem !important;
        }

        img,
        .bg-primary {
            width: 65px !important;
            height: 65px !important;
        }
    }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-4" style="max-width:900px;">

    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body d-flex align-items-center gap-3 p-3">

            @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
            {
                <img src="@Model.ProfilePhoto" class="shadow-sm border border-light"
                     style="width:70px;height:70px;border-radius:12px;object-fit:cover;" alt="Profile">
            }
            else
            {
                <div class="bg-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm"
                     style="width:70px;height:70px;border-radius:12px;font-size:22px;">
                    @initials
                </div>
            }

            <div class="flex-grow-1">
                <h5 class="mb-1 fw-bold text-dark">@Model.FarmerName</h5>
                <div class="text-muted small font-monospace">ID: @Model.FarmerCode</div>
            </div>

            <div>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-1.5 rounded-pill">
                        Active
                    </span>
                }
                else
                {
                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle px-3 py-1.5 rounded-pill">
                        Inactive
                    </span>
                }
            </div>

        </div>
    </div>

    <div class="row g-3">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-header bg-white border-bottom fw-bold text-secondary py-3">
                    <i class="bi bi-person-vcard me-2"></i>Personal Info
                </div>
                <div class="card-body p-3">

                    <div class="mb-3">
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Phone Number</small>
                        <div class="fw-medium text-dark">@Model.Phone</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Email ID</small>
                        <div class="fw-medium text-dark">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Gender</small>
                            <div class="fw-medium text-dark">@Model.Gender</div>
                        </div>
                        <div class="col-6">
                            <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Date of Birth</small>
                            <div class="fw-medium text-dark">@Model.DateOfBirth.ToString("dd-MM-yyyy")</div>
                        </div>
                    </div>

                    <div>
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Identity Verification</small>
                        <div class="fw-medium text-dark font-monospace">@maskedAadhaar</div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-header bg-white border-bottom fw-bold text-secondary py-3">
                    <i class="bi bi-geo-alt me-2"></i>Address Details
                </div>
                <div class="card-body p-3">

                    <div class="mb-3">
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Village</small>
                        <div class="text-dark fw-medium">@Model.VillageName</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">City / Taluka</small>
                        <div class="text-dark fw-medium">@Model.CityName</div>
                    </div>

                    <div>
                        <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">State</small>
                        <div class="text-dark fw-medium">@Model.StateName</div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-header bg-white border-bottom fw-bold text-secondary py-3">
                    <i class="bi bi-building me-2"></i>Collection Assignment
                </div>
                <div class="card-body p-3">
                    <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Assigned Center</small>
                    <div class="fw-bold text-primary fs-6">@Model.CenterName</div>
                    <p class="text-muted small mb-0 mt-1">
                        All authorized milk history, receipts, and collection transactions are governed through this facility.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-3">
                <div class="card-header bg-white border-bottom fw-bold text-secondary py-3">
                    <i class="bi bi-bank me-2"></i>Settlement Account
                </div>
                <div class="card-body p-3">

                    @if (!string.IsNullOrEmpty(Model.BankName))
                    {
                        <div class="mb-2">
                            <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.05em;">Bank Name</small>
                            <div class="text-dark fw-medium">@Model.BankName</div>
                        </div>

                        <div class="mb-2">
                            <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.05em;">Account Number</small>
                            <div class="text-dark font-monospace fw-medium">@maskedAccount</div>
                        </div>

                        <div>
                            <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.05em;">IFSC Code</small>
                            <div class="text-dark font-monospace fw-medium">@Model.IFSCCode</div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-exclamation-circle d-block mb-1 fs-5"></i>
                            <span class="small">No bank layout linked to this profile.</span>
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm mt-4 rounded-3">
        <div class="card-body d-flex justify-content-between align-items-center p-3">
            <div>
                <div class="fw-bold text-dark">
                    <i class="bi bi-shield-lock me-2 text-secondary"></i>Account Security
                </div>
                <p class="text-muted small mb-0">Update security access parameters or update password keys.</p>
            </div>

            <a asp-action="ChangePassword" class="btn btn-sm btn-outline-primary px-3 rounded-2 fw-medium">
                Change Password
            </a>
        </div>
    </div>

</div>