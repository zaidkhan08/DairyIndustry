@model DairyIndustry.Models.FarmerModel.FarmerProfileModel

@{
    Layout = "_FarmerLayout";
}

<style>
    .profile-card {
        max-width: 900px;
        margin: auto;
        background: #fff;
        border-radius: 14px;
        padding: 25px;
        border: 1px solid #e5e5e5;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    .avatar {
        width: 80px;
        height: 80px;
        border-radius: 12px;
        background: #1b5e20;
        color: #fff;
        font-size: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .section-title {
        font-weight: 600;
        margin-top: 20px;
        margin-bottom: 10px;
        color: #1b5e20;
        font-size: 1rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 5px;
    }

    .info-row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .info-box {
        flex: 1;
        min-width: 200px;
    }

    .label {
        font-size: 12px;
        color: gray;
    }

    .value {
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 10px;
    }

    .badge-active {
        background: #e8f5e9;
        color: #1b5e20;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-edit {
        margin-top: 20px;
        float: right;
    }
</style>

<div class="container py-4">

    <div class="profile-card shadow-sm">

        <!-- HEADER -->
        <div class="profile-header">

            <div class="avatar">
                @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                {
                    <img src="@Model.ProfilePhoto"
                         style="width:100%; height:100%; object-fit:cover;">
                }
                else
                {
                    <span>@Model.FarmerName.Substring(0, 1)</span>
                }
            </div>

            <div>
                <h4 class="mb-0">@Model.FarmerName</h4>
                <small class="text-muted">#@Model.FarmerCode</small>
                <div class="mt-1">
                    @if (Model.IsActive)
                    {
                        <span class="badge-active">Active</span>
                    }
                    else
                    {
                        <span class="text-danger small">Inactive</span>
                    }
                </div>
            </div>

        </div>

        <!-- BASIC INFO -->
        <div class="section-title">Basic Details</div>

        <div class="info-row">
            <div class="info-box">
                <div class="label">Phone</div>
                <div class="value">@Model.Phone</div>
            </div>

            <div class="info-box">
                <div class="label">Center</div>
                <div class="value">@Model.CenterName</div>
            </div>
        </div>

        <!-- LOCATION -->
        <div class="section-title">Location</div>

        <div class="info-row">
            <div class="info-box">
                <div class="label">Village</div>
                <div class="value">@Model.VillageName</div>
            </div>

            <div class="info-box">
                <div class="label">City</div>
                <div class="value">@Model.CityName</div>
            </div>

            <div class="info-box">
                <div class="label">State</div>
                <div class="value">@Model.StateName</div>
            </div>
        </div>

        <!-- BANK -->
        <div class="section-title">Bank Details</div>

        <div class="info-row">
            <div class="info-box">
                <div class="label">Bank</div>
                <div class="value">@Model.BankName</div>
            </div>

            <div class="info-box">
                <div class="label">Account No</div>
                <div class="value">@Model.AccountNumber</div>
            </div>

            <div class="info-box">
                <div class="label">IFSC</div>
                <div class="value">@Model.IFSCCode</div>
            </div>
        </div>

 

    </div>

</div>