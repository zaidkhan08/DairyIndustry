@{
    ViewData["Title"] = "Registration Submitted";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center"
     style="background: linear-gradient(135deg, #1a2e4a 0%, #2d5a8e 100%);">

    <div style="max-width:480px; padding:2rem; width:100%;">
        <div class="card border-0 shadow-lg text-center p-5">
            <div style="font-size:4rem;" class="mb-3">✅</div>
            <h3 class="fw-bold mb-2">Registration Submitted!</h3>
            <p class="text-muted mb-4">
                Your application has been received and is pending review by our admin team.
                <br /><br />
                Once approved, you can log in using your chosen credentials via the
                <strong>common login page</strong> and view your orders.
            </p>
            <div class="d-grid">
                <a asp-controller="DistributorRegister" asp-action="Index"
                   class="btn btn-outline-secondary">
                    Register Another
                </a>
            </div>
        </div>
    </div>

</div>
