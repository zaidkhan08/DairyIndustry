@model List<DairyIndustry.Models.Admin.Distributor>
@{
    ViewData["Title"] = "Distributors";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex gap-2">

    <a asp-action="DownloadDistributorsPdf"
       class="btn btn-danger btn-sm">
        <i class="bi bi-file-earmark-pdf me-1"></i>
        Download PDF
    </a>

    <a asp-action="PendingDistributors"
       class="btn btn-outline-warning btn-sm">
        Pending Approvals
    </a>

    <a asp-action="RegisterDistributor"
       class="btn btn-primary btn-sm">
        + Add Distributor
    </a>

</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    @* <th>#</th> *@
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Location</th>
                    <th>GSTIN</th>
                    <th>Status</th>
                    <th>Registered</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        @* <td>@d.DistributorId</td> *@
                        <td>
                            <div class="fw-semibold">@d.DistributorName</div>
                            <small class="text-muted">@d.Email</small>
                        </td>
                        <td>@(d.ContactNumber ?? "—")</td>
                        <td>@(d.Location ?? "—")</td>
                        <td><code>@(d.GSTIN ?? "—")</code></td>
                        <td>
                            @{
                                var badge = d.Status switch
                                {
                                    "Approved" => "success",
                                    "Pending" => "warning",
                                    "Rejected" => "danger",
                                    "Suspended" => "secondary",
                                    _ => "light"
                                };
                            }
                            <span class="badge bg-@badge">@d.Status</span>
                        </td>
                        <td>@d.RegisteredOn.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (d.Status == "Approved")
                            {
                                <form asp-action="UpdateDistributorStatus" method="post"
                                      onsubmit="return confirm('Suspend @d.DistributorName?')">
                                    <input type="hidden" name="distributorId" value="@d.DistributorId" />
                                    <input type="hidden" name="status" value="Suspended" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        Suspend
                                    </button>
                                </form>
                            }
                            else if (d.Status == "Suspended")
                            {
                                <form asp-action="UpdateDistributorStatus" method="post">
                                    <input type="hidden" name="distributorId" value="@d.DistributorId" />
                                    <input type="hidden" name="status" value="Approved" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        Re-activate
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No distributors found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>