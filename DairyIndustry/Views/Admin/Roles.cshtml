@model List<DairyIndustry.Models.Admin.RoleModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@{
    ViewData["Title"] = "Manage Roles";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Roles</h3>
                <p class="text-muted mb-0">Create and view all system roles</p>
            </div>
            <a href="/Admin/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- Create Role Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-shield-plus me-1"></i> Create New Role
                </div>
                <div class="card-body p-4">

                    <form method="post" action="/Admin/CreateRole">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Role Name <span class="text-danger">*</span>
                            </label>
                            <input type="text"
                                   name="roleName"
                                   class="form-control"
                                   placeholder="e.g. Manager, Accountant"
                                   required />
                            <div class="form-text">
                                Role name must be unique
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Create Role
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>

        <!-- Roles List -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-shield me-1"></i> All Roles</span>
                    <span class="badge bg-primary">Total : @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    @* <th>Role ID</th> *@
                                    <th>Role Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No roles found. Create one.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    @foreach (var role in Model)
                                    {
                                        <tr>
                                            <td>@sr</td>
                                            @* <td>
                                                <span class="badge bg-secondary">
                                                    @role.RoleId
                                                </span>
                                            </td> *@
                                            <td>
                                                <i class="bi bi-shield-fill me-1 text-primary"></i>
                                                @role.RoleName
                                            </td>
                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                        </table>
                        <div class="d-flex justify-content-center mt-3">
                            <nav>
                                <ul class="pagination">

                                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)">Previous</a>
                                    </li>

                                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="?page=@i">@i</a>
                                        </li>
                                    }

                                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)">Next</a>
                                    </li>

                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer bg-white text-muted small">
                    @Model.Count role(s) available in the system
                </div>

            </div>
        </div>

    </div>

</div>