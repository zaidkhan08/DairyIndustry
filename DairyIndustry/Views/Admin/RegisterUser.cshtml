@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Register User";

    var staffList = ViewBag.StaffList as List<DairyIndustry.Models.Admin.StaffModel>
                   ?? new List<DairyIndustry.Models.Admin.StaffModel>();
}

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Register New User</h4>
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Users" class="text-decoration-none text-muted">Users</a></li>
                <li class="breadcrumb-item active text-muted">Register</li>
            </ol>
        </div>
        <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Users
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" asp-controller="Admin" asp-action="RegisterUser">
        <div class="row g-4">

            <!-- LEFT: Form Fields -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom px-4 py-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="bg-primary bg-opacity-10 rounded p-2 lh-1">
                                <i class="bi bi-person-lines-fill text-primary fs-5"></i>
                            </span>
                            <div>
                                <div class="fw-semibold">Account Information</div>
                                <div class="text-muted small">Assign login credentials to a staff member</div>
                            </div>
                        </div>
                    </div>
                    <div class="card-body px-4 py-4">

                        <div class="row g-4">

                            <!-- Staff -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Staff Member <span class="text-danger">*</span></label>
                                <select name="staffId" class="form-select" required onchange="fillRole(this)">
                                    <option value="">— Select staff member —</option>
                                    @foreach (var staff in staffList)
                                    {
                                        <option value="@staff.StaffId" data-role="@staff.RoleName">
                                            @staff.FullName — @staff.RoleName
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Role (auto-filled) -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Role</label>
                                <input type="text" id="roleDisplay"
                                       class="form-control bg-light text-muted"
                                       placeholder="Auto-filled from staff selection"
                                       readonly />
                            </div>

                            <!-- Username -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-at text-muted"></i>
                                    </span>
                                    <input type="text" name="username"
                                           class="form-control border-start-0"
                                           placeholder="Enter username"
                                           required autocomplete="off" />
                                </div>
                            </div>

                            <!-- Password -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="password" name="password" id="passwordInput"
                                           class="form-control border-start-0 border-end-0"
                                           placeholder="Min. 6 characters"
                                           required />
                                    <button type="button"
                                            class="btn btn-outline-secondary border-start-0"
                                            onclick="togglePassword()">
                                        <i class="bi bi-eye" id="eyeIcon"></i>
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Footer actions inside card -->
                    <div class="card-footer bg-white border-top px-4 py-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-5">
                            <i class="bi bi-person-plus me-2"></i>Register User
                        </button>
                        <a asp-controller="Admin" asp-action="Users"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Info Panel -->
            <div class="col-lg-4">
                @* <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom px-4 py-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="bg-warning bg-opacity-10 rounded p-2 lh-1">
                                <i class="bi bi-info-circle text-warning fs-5"></i>
                            </span>
                            <div class="fw-semibold">Guidelines</div>
                        </div>
                    </div>
                    <div class="card-body px-4 py-3">
                        <ul class="list-unstyled mb-0 small text-muted">
                            <li class="d-flex gap-2 mb-3">
                                <i class="bi bi-dot fs-5 text-primary mt-n1"></i>
                                <span>Only staff members <strong>without an existing login</strong> are shown in the dropdown.</span>
                            </li>
                            <li class="d-flex gap-2 mb-3">
                                <i class="bi bi-dot fs-5 text-primary mt-n1"></i>
                                <span>The <strong>role is automatically assigned</strong> based on the selected staff member's role.</span>
                            </li>
                            <li class="d-flex gap-2 mb-3">
                                <i class="bi bi-dot fs-5 text-primary mt-n1"></i>
                                <span>Username must be <strong>unique</strong> across all accounts.</span>
                            </li>
                            <li class="d-flex gap-2 mb-0">
                                <i class="bi bi-dot fs-5 text-primary mt-n1"></i>
                                <span>Password must be at least <strong>6 characters</strong> long.</span>
                            </li>
                        </ul>
                    </div>
                </div> *@

                <!-- Staff count info card -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body px-4 py-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">Available Staff</div>
                                <div class="fw-bold fs-4">@staffList.Count</div>
                                <div class="text-muted small">without a login account</div>
                            </div>
                            <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-people text-success fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </form>

</div>

@section Scripts {
    <script>
        function fillRole(select) {
            const option = select.options[select.selectedIndex];
            document.getElementById('roleDisplay').value = option.getAttribute('data-role') ?? '';
        }
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}