@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Register User";

    var staffList = ViewBag.StaffList as List<DairyIndustry.Models.Admin.StaffModel>
                   ?? new List<DairyIndustry.Models.Admin.StaffModel>();
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Register New User</h3>
                <p class="text-muted mb-0">Create a new login account for a staff member</p>
            </div>
            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Users
            </a>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-person-plus me-1 text-primary"></i> User Details
                </div>
                <div class="card-body p-4">

                    <form method="post" asp-controller="Admin" asp-action="RegisterUser">

                        <!-- Staff Dropdown — shows name, submits StaffId, role is auto-derived -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Staff Member <span class="text-danger">*</span>
                            </label>
                            <select name="staffId" class="form-select" required
                                    onchange="fillRole(this)">
                                <option value="">-- Select Staff --</option>
                                @foreach (var staff in staffList)
                                {
                                    <option value="@staff.StaffId"
                                            data-role="@staff.RoleName">
                                        @staff.FullName — @staff.RoleName
                                    </option>
                                }
                            </select>
                            <div class="form-text">
                                Only active staff without a login account are shown
                            </div>
                        </div>

                        <!-- Role — readonly, auto-filled when staff is selected -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Role</label>
                            <input type="text" id="roleDisplay" class="form-control bg-light"
                                   placeholder="Auto-filled from staff selection"
                                   readonly />
                            <div class="form-text">Role is taken from the selected staff member</div>
                        </div>

                        <!-- Username -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Username <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="username" class="form-control"
                                   placeholder="Enter username" required />
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Password <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="password" name="password" id="passwordInput"
                                       class="form-control" placeholder="Enter password"
                                       required />
                                <button type="button" class="btn btn-outline-secondary"
                                        onclick="togglePassword()">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                            <div class="form-text">Minimum 6 characters</div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-person-plus me-1"></i> Register User
                            </button>
                            <a asp-controller="Admin" asp-action="Users"
                               class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Auto-fill role display when staff is selected
        function fillRole(select) {
            const option = select.options[select.selectedIndex];
            const role   = option.getAttribute('data-role') ?? '';
            document.getElementById('roleDisplay').value = role;
        }

        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}
