@model List<DairyIndustry.Models.Admin.VillageModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Villages";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Villages</h3>
                <p class="text-muted mb-0">Add and view all villages</p>
            </div>
            <a href="/Admin/Cities" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Cities
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- Add Village Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-plus-circle me-1"></i> Add New Village
                </div>
                <div class="card-body p-4">
                    <form method="post" action="/Admin/AddVillage">

                        <!-- State Dropdown -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                State <span class="text-danger">*</span>
                            </label>
                            <select id="stateDropdown"
                                    class="form-select"
                                    required>
                                <option value="">-- Select State --</option>
                                @foreach (var state in ViewBag.States as List<DairyIndustry.Models.Admin.StateModel>)
                                {
                                    <option value="@state.StateId">@state.StateName</option>
                                }
                            </select>
                        </div>

                        <!-- City Dropdown (loaded via AJAX) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                City <span class="text-danger">*</span>
                            </label>
                            <select id="cityDropdown"
                                    name="cityId"
                                    class="form-select"
                                    required
                                    disabled>
                                <option value="">-- Select State First --</option>
                            </select>
                            <div class="form-text">Select a state to load cities</div>
                        </div>

                        <!-- Village Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Village Name <span class="text-danger">*</span>
                            </label>
                            <input type="text"
                                   name="villageName"
                                   class="form-control"
                                   placeholder="e.g. Bardoli, Olpad"
                                   required />
                            <div class="form-text">Village name must be unique within city</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Add Village
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- Villages List -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-map me-1"></i> All Villages</span>
                    <span class="badge bg-primary">Total : @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Village ID</th>
                                    <th>Village Name</th>
                                    <th>City</th>
                                    <th>State</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No villages found. Add one.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    @foreach (var village in Model)
                                    {
                                        <tr>
                                            <td>@sr</td>
                                            <td>
                                                <span class="badge bg-secondary">
                                                    @village.VillageId
                                                </span>
                                            </td>
                                            <td>
                                                <i class="bi bi-map me-1 text-success"></i>
                                                @village.VillageName
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">
                                                    @village.CityName
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">
                                                    @village.StateName
                                                </span>
                                            </td>
                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white text-muted small">
                    @Model.Count village(s) available in the system
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>

        // ── Cascading Dropdown ─────────────────────
        document.getElementById('stateDropdown').addEventListener('change', function () {

            const stateId      = this.value;
            const cityDropdown = document.getElementById('cityDropdown');

            // Reset city dropdown
            cityDropdown.innerHTML = '<option value="">-- Loading... --</option>';
            cityDropdown.disabled  = true;

            if (!stateId) {
                cityDropdown.innerHTML = '<option value="">-- Select State First --</option>';
                return;
            }

            // Fetch cities by state via AJAX
            fetch(`/Admin/GetCitiesByState?stateId=${stateId}`)
                .then(response => response.json())
                .then(data => {

                    cityDropdown.innerHTML = '<option value="">-- Select City --</option>';

                    if (data.length === 0) {
                        cityDropdown.innerHTML = '<option value="">No cities found for this state</option>';
                        return;
                    }

                    data.forEach(city => {
                        const option   = document.createElement('option');
                        option.value   = city.cityId;
                        option.text    = city.cityName;
                        cityDropdown.appendChild(option);
                    });

                    cityDropdown.disabled = false;
                })
                .catch(error => {
                    cityDropdown.innerHTML = '<option value="">Error loading cities</option>';
                    console.error('Error:', error);
                });
        });

    </script>
}