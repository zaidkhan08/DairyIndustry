@model List<DairyIndustry.Models.Admin.StaffModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Staff";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Staff</h3>
                <p class="text-muted mb-0">View and manage all staff members</p>
            </div>
            <a asp-controller="Admin" asp-action="AddStaff" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i> Add New Staff
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }

    <!-- Stats -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Total Staff</p>
                        <h4 class="fw-bold mb-0">@Model.Count</h4>
                    </div>
                    <i class="bi bi-people-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Active</p>
                        <h4 class="fw-bold mb-0">@Model.Count(s => s.IsActive)</h4>
                    </div>
                    <i class="bi bi-person-check-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Inactive</p>
                        <h4 class="fw-bold mb-0">@Model.Count(s => !s.IsActive)</h4>
                    </div>
                    <i class="bi bi-person-x-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people me-1"></i> All Staff Members</span>
            <span class="badge bg-primary">Total : @Model.Count</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Staff</th>
                            <th>Role</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Joining Date</th>
                            <th>Bank</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No staff members found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int sr = 1;
                            foreach (var staff in Model)
                            {
                                <tr>

                                    <td>@sr</td>

                                    <!-- Photo + Name -->
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(staff.ProfilePhoto))
                                            {
                                                <img src="@Url.Content("~/" + staff.ProfilePhoto.TrimStart('/'))"
                                                     class="rounded-circle border"
                                                     width="40" height="40"
                                                     style="object-fit:cover;"
                                                     alt="@staff.FullName" />
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                                                     style="width:40px; height:40px; flex-shrink:0;">
                                                    <span class="text-white fw-bold small">
                                                        @staff.FirstName[0]@staff.LastName[0]
                                                    </span>
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-semibold small">@staff.FullName</div>
                                                <div class="text-muted" style="font-size:11px;">ID: @staff.StaffId</div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Role — from Admin.Roles via JOIN -->
                                    <td>
                                        @{
                                            string badge = staff.RoleName?.ToLower() switch
                                            {
                                                "collection agent" => "bg-primary",
                                                "production manager" => "bg-warning text-dark",
                                                "finance manager" => "bg-success",
                                                "sales manager" => "bg-info text-dark",
                                                "hr manager" => "bg-secondary",
                                                "driver" => "bg-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badge">@staff.RoleName</span>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(staff.Phone))
                                        {
                                            <small><i class="bi bi-telephone me-1 text-muted"></i>@staff.Phone</small>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(staff.Email))
                                        {
                                            <small><i class="bi bi-envelope me-1 text-muted"></i>@staff.Email</small>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>

                                    <td>
                                        @if (staff.DOJ.HasValue)
                                        {
                                            <small><i class="bi bi-calendar3 me-1 text-muted"></i>@staff.DOJ.Value.ToString("dd MMM yyyy")</small>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(staff.BankName))
                                        {
                                            <div class="small fw-semibold">@staff.BankName</div>
                                            <div class="text-muted" style="font-size:11px;">@staff.AccountNumber</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Not Added</span>
                                        }
                                    </td>

                                    <td>
                                        @if (staff.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>

                                    <td>
                                        <form method="post" asp-controller="Admin" asp-action="ToggleStaffActive">
                                            <input type="hidden" name="staffId" value="@staff.StaffId" />
                                            <input type="hidden" name="isActive" value="@(!staff.IsActive).ToString().ToLower()" />
                                            @if (staff.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Deactivate @staff.FullName?')">
                                                    <i class="bi bi-person-x me-1"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success"
                                                        onclick="return confirm('Activate @staff.FullName?')">
                                                    <i class="bi bi-person-check me-1"></i> Activate
                                                </button>
                                            }
                                        </form>
                                    </td>

                                </tr>
                                sr++;
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white text-muted small d-flex justify-content-between">
            <span>Total: @Model.Count | Active: @Model.Count(s => s.IsActive) | Inactive: @Model.Count(s => !s.IsActive)</span>
            <span>Roles: @Model.Select(s => s.RoleId).Distinct().Count()</span>
        </div>

    </div>

</div>
