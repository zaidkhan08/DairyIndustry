@model List<DairyIndustry.Models.Admin.StaffModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Staff";

    // Standardize pagination variables
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="container mt-4">

    <!-- Page Title & Add Button -->
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h3 class="fw-bold mb-0">Manage Staff</h3>
            <p class="text-muted mb-0">View and manage all staff members</p>
        </div>
        <div class="col-auto">
            <a asp-controller="Admin" asp-action="AddStaff" class="btn btn-primary shadow-sm">
                <i class="bi bi-person-plus me-1"></i> Add New Staff
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small opacity-75">Total Staff</p>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalRecords</h4>
                    </div>
                    <i class="bi bi-people-fill fs-2 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small opacity-75">Active</p>
                        <h4 class="fw-bold mb-0">@Model.Count(s => s.IsActive)</h4>
                    </div>
                    <i class="bi bi-person-check-fill fs-2 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small opacity-75">Inactive</p>
                        <h4 class="fw-bold mb-0">@Model.Count(s => !s.IsActive)</h4>
                    </div>
                    <i class="bi bi-person-x-fill fs-2 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small opacity-75">Locations</p>
                        <h4 class="fw-bold mb-0">@(Model.Select(s => s.CenterName).Distinct().Count() + Model.Select(s => s.PlantName).Distinct().Count())</h4>
                    </div>
                    <i class="bi bi-geo-alt-fill fs-2 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Staff List</h6>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-primary rounded-pill">Total Records: @ViewBag.TotalStaff</span>
                <a href="/Admin/DownloadStaffPdf" class="btn btn-sm btn-success shadow-sm">
            <i class="bi bi-file-earmark-excel me-1"></i> Download PDF
        </a>
    </div>
</div>
        <br />
        <div class="card-body p-0">
            <div class="table-responsive">
                <div class="row p-3">

                    <div class="col-md-4">
                        <input type="text"
                               id="searchInput"
                               class="form-control"
                               placeholder="Search name, role or phone...">
                    </div>

                    <div class="col-md-3">
                        <select id="statusFilter" class="form-select">
                            <option value="">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>

                </div>
                <br />
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Staff Info</th>
                            <th>Role</th>
                            <th>Assignment</th>
                            <th>Contact</th>
                            <th>Salary</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="staffTable">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    No staff records available.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int sr = ((currentPage - 1) * 10) + 1;
                            foreach (var staff in Model)
                            {
                                <tr>
                                    <td class="ps-3 text-muted small">@sr</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(staff.ProfilePhoto))
                                            {
                                                <img src="@Url.Content("~/" + staff.ProfilePhoto.TrimStart('/'))"
                                                     class="rounded-circle border" width="38" height="38"
                                                     style="object-fit:cover;" alt="Profile" />
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-secondary-subtle text-secondary d-flex align-items-center justify-content-center fw-bold small"
                                                     style="width:38px; height:38px;">
                                                    @(staff.FirstName?[0])@(staff.LastName?[0])
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-bold small text-dark">@staff.FullName</div>
                                                <div class="text-muted tiny" style="font-size: 11px;">ID: @staff.StaffId</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @{
                                            string roleColor = staff.RoleName?.ToLower() switch
                                            {
                                                "administrator" => "danger",
                                                "production manager" => "warning text-dark",
                                                "collection agent" => "primary",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="badge bg-@roleColor-subtle text-@roleColor.Replace(" text-dark", "") border">@staff.RoleName</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(staff.CenterName))
                                        {
                                            <div class="small fw-semibold text-primary"><i class="bi bi-building me-1"></i>@staff.CenterName</div>
                                            <div class="text-muted tiny" style="font-size: 10px;">Collection Center</div>
                                        }
                                        else if (!string.IsNullOrEmpty(staff.PlantName))
                                        {
                                            <div class="small fw-semibold text-warning"><i class="bi bi-gear-wide-connected me-1"></i>@staff.PlantName</div>
                                            <div class="text-muted tiny" style="font-size: 10px;">Processing Plant</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Unassigned</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="small"><i class="bi bi-telephone me-1 text-muted"></i>@staff.Phone</div>
                                        <div class="text-muted small"><i class="bi bi-envelope me-1 text-muted"></i>@staff.Email</div>
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success">₹@staff.Salary.ToString("N0")</span>
                                    </td>
                                    <td>
                                        <span class="badge @(staff.IsActive ? "bg-success" : "bg-danger")">
                                            @(staff.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group">
                                            <a asp-action="GetStaffById" asp-route-id="@staff.StaffId" class="btn btn-sm btn-outline-secondary" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="EditStaff" asp-route-id="@staff.StaffId" class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form method="post" asp-action="ToggleStaffActive" class="d-inline">
                                                <input type="hidden" name="staffId" value="@staff.StaffId" />
                                                <input type="hidden" name="isActive" value="@(!staff.IsActive ? 1 : 0)" />
                                                <button type="submit" class="btn btn-sm @(staff.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                        onclick="return confirm('Change status for @staff.FullName?')">
                                                    <i class="bi @(staff.IsActive ? "bi-person-x" : "bi-person-check")"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination Footer -->
        <div class="card-footer bg-white py-3">
            <div class="row align-items-center">
                <div class="col-sm-6 text-center text-sm-start mb-3 mb-sm-0">
                    <span class="text-muted small">
                        Showing page <strong>@currentPage</strong> of <strong>@totalPages</strong>
                    </span>
                </div>
                <div class="col-sm-6">
                    <nav aria-label="Staff navigation">
                        <ul class="pagination pagination-sm justify-content-center justify-content-sm-end mb-0">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                            </li>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
    }

    .tiny {
        font-size: 0.7rem;
    }

    .btn-group .btn {
        padding: 0.25rem 0.5rem;
    }

    .badge {
        font-weight: 500;
    }
</style>
<script>

    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");

    function filterTable() {

        const search = searchInput.value.toLowerCase().trim();
        const status = statusFilter.value.toLowerCase().trim();

        const rows = document.querySelectorAll("#staffTable tr");

        rows.forEach(row => {

            const staffName =
                row.cells[1]?.innerText.toLowerCase() || "";

            const role =
                row.cells[2]?.innerText.toLowerCase() || "";

            const contact =
                row.cells[4]?.innerText.toLowerCase() || "";

            const currentStatus =
                row.cells[6]?.innerText.toLowerCase().trim() || "";

            const matchesSearch =
                staffName.includes(search) ||
                role.includes(search) ||
                contact.includes(search);

            const matchesStatus =
                status === "" ||
                currentStatus === status;

            if (matchesSearch && matchesStatus) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }

        });
    }

    searchInput.addEventListener("keyup", filterTable);
    statusFilter.addEventListener("change", filterTable);

</script>