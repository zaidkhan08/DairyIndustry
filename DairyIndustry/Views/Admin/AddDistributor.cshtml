@model DairyIndustry.Models.Admin.Distributor
@{
    ViewData["Title"] = "Add Distributor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-action="Distributors" class="btn btn-outline-secondary btn-sm">← Back</a>
            <h5 class="mb-0">Add Distributor</h5>
        </div>

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success">@TempData["success"]</div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="AddDistributor" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="DistributorName" class="form-label fw-semibold">
                            Distributor Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="DistributorName" class="form-control"
                               placeholder="e.g. Surat Dairy Distributors" />
                        <span asp-validation-for="DistributorName" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                            <input asp-for="ContactNumber" class="form-control"
                                   placeholder="9265431001" maxlength="15" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email"
                                   placeholder="distributor@example.com" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control"
                               placeholder="Ring Road, Surat" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Full Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2"
                                  placeholder="Shop No., Street, City, PIN"></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="GSTIN" class="form-label">GSTIN</label>
                        <input asp-for="GSTIN" class="form-control"
                               placeholder="22AAAAA0000A1Z5" maxlength="20" />
                        <div class="form-text">Leave blank if not applicable.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Add Distributor
                        </button>
                        <a asp-action="Distributors" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}