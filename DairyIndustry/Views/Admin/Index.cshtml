@model DairyIndustry.Models.Admin.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    var username = Context.Session.GetString("Username") ?? "Admin";

    int totalUsers = Model.Users.Count;
    int activeUsers = Model.Users.Count(u => u.IsActive);
    int totalStaff = Model.Staff.Count;
    int activeStaff = Model.Staff.Count(s => s.IsActive);
    int totalPlants = Model.Plants.Count;
    int activePlants = Model.Plants.Count(p => p.IsActive);
    int totalCenters = Model.Centers.Count;
    int activeCenters = Model.Centers.Count(c => c.IsActive);
    int totalProducts = Model.Products.Count;
    int activeProducts = Model.Products.Count(p => p.IsActive);

    // JSON helpers for chart data
    string JsonLabels(IEnumerable<DairyIndustry.Models.Admin.ChartPoint> pts)
        => "[" + string.Join(",", pts.Select(p => $"\"{p.Label}\"")) + "]";

    string JsonValues(IEnumerable<DairyIndustry.Models.Admin.ChartPoint> pts)
        => "[" + string.Join(",", pts.Select(p => p.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))) + "]";
}

@* ── Inline page styles ─────────────────────────────────────────── *@
<style>
    .dash-section-title {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #8b949e;
        margin: 0 0 14px;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(160px,1fr));
        gap: 14px;
        margin-bottom: 26px;
    }

    .kpi-card {
        background: #fff;
        border: 1px solid #e8eaed;
        border-radius: 12px;
        padding: 16px 18px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        position: relative;
        overflow: hidden;
        transition: box-shadow .18s,transform .18s;
    }

        .kpi-card:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,.07);
            transform: translateY(-1px);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: 12px 12px 0 0;
        }

        .kpi-card.blue::before {
            background: #2563eb;
        }

        .kpi-card.green::before {
            background: #059669;
        }

        .kpi-card.amber::before {
            background: #d97706;
        }

        .kpi-card.red::before {
            background: #dc2626;
        }

        .kpi-card.purple::before {
            background: #7c3aed;
        }

        .kpi-card.teal::before {
            background: #0d9488;
        }

    .kpi-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 6px;
    }

    .kpi-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }

        .kpi-icon.blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .kpi-icon.green {
            background: #f0fdf4;
            color: #059669;
        }

        .kpi-icon.amber {
            background: #fffbeb;
            color: #d97706;
        }

        .kpi-icon.red {
            background: #fef2f2;
            color: #dc2626;
        }

        .kpi-icon.purple {
            background: #f5f3ff;
            color: #7c3aed;
        }

        .kpi-icon.teal {
            background: #f0fdfa;
            color: #0d9488;
        }

    .kpi-badge {
        font-size: 10.5px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 5px;
        font-family: 'DM Mono',monospace;
    }

        .kpi-badge.ok {
            background: #f0fdf4;
            color: #166534;
        }

        .kpi-badge.warn {
            background: #fffbeb;
            color: #92400e;
        }

    .kpi-value {
        font-size: 26px;
        font-weight: 600;
        color: #0d1117;
        line-height: 1;
        letter-spacing: -.025em;
        font-family: 'DM Mono',monospace;
    }

    .kpi-label {
        font-size: 12px;
        color: #8b949e;
        font-weight: 500;
        margin-top: 3px;
    }

    .kpi-sub {
        font-size: 11px;
        color: #b0b8c4;
        margin-top: 1px;
    }

    .kpi-link {
        font-size: 11.5px;
        color: #2563eb;
        text-decoration: none;
        margin-top: 8px;
        display: inline-block;
    }

        .kpi-link:hover {
            text-decoration: underline;
        }

    .chart-grid {
        display: grid;
        gap: 16px;
        margin-bottom: 26px;
    }

    .chart-grid-2 {
        grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
    }

    .chart-grid-3 {
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
    }

    .chart-card {
        background: #fff;
        border: 1px solid #e8eaed;
        border-radius: 12px;
        padding: 18px 20px;
    }

    .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .chart-card-title {
        font-size: 13px;
        font-weight: 600;
        color: #0d1117;
        letter-spacing: -.01em;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .chart-card-title i {
            font-size: 15px;
        }

    .chart-badge {
        font-size: 10.5px;
        padding: 2px 8px;
        border-radius: 5px;
        font-family: 'DM Mono',monospace;
    }

    .chart-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        margin-bottom: 10px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: #57606a;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        flex-shrink: 0;
    }

    .table-card {
        background: #fff;
        border: 1px solid #e8eaed;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .table-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid #f0f2f5;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .table-card-title {
        font-size: 13px;
        font-weight: 600;
        color: #0d1117;
    }

    .dms-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .dms-tbl th {
            padding: 9px 14px;
            font-size: 10.5px;
            color: #8b949e;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .07em;
            background: #fafbfc;
            border-bottom: 1px solid #f0f2f5;
            white-space: nowrap;
        }

        .dms-tbl td {
            padding: 10px 14px;
            font-size: 13px;
            color: #57606a;
            border-bottom: 1px solid #f7f8fa;
            vertical-align: middle;
        }

        .dms-tbl tr:last-child td {
            border-bottom: none;
        }

        .dms-tbl tr:hover td {
            background: #fafbfc;
        }

    .pill {
        display: inline-flex;
        align-items: center;
        padding: 2px 9px;
        border-radius: 5px;
        font-size: 11px;
        font-weight: 500;
        font-family: 'DM Mono',monospace;
    }

    .pill-ok {
        background: #f0fdf4;
        color: #166534;
    }

    .pill-warn {
        background: #fffbeb;
        color: #92400e;
    }

    .pill-info {
        background: #eff6ff;
        color: #1e40af;
    }

    .pill-err {
        background: #fef2f2;
        color: #991b1b;
    }

    .pill-muted {
        background: #f4f6f9;
        color: #374151;
    }

    .pill-purple {
        background: #faf5ff;
        color: #6b21a8;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
    }

    .qa-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 14px 8px;
        border: 1px solid #e8eaed;
        border-radius: 10px;
        text-decoration: none;
        color: #57606a;
        font-size: 12px;
        font-weight: 500;
        transition: all .15s;
        background: #fff;
    }

        .qa-btn i {
            font-size: 20px;
        }

        .qa-btn:hover {
            background: #f4f6f9;
            border-color: #d0d4da;
            color: #0d1117;
        }

        .qa-btn.blue:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #1d4ed8;
        }

        .qa-btn.green:hover {
            background: #f0fdf4;
            border-color: #bbf7d0;
            color: #166534;
        }

        .qa-btn.amber:hover {
            background: #fffbeb;
            border-color: #fde68a;
            color: #92400e;
        }

        .qa-btn.red:hover {
            background: #fef2f2;
            border-color: #fecaca;
            color: #991b1b;
        }

        .qa-btn.purple:hover {
            background: #faf5ff;
            border-color: #e9d5ff;
            color: #6b21a8;
        }

        .qa-btn.teal:hover {
            background: #f0fdfa;
            border-color: #99f6e4;
            color: #0f766e;
        }

    .loss-bar-wrap {
        height: 7px;
        background: #f0f2f5;
        border-radius: 4px;
        overflow: hidden;
        margin-top: 6px;
    }

    .loss-bar {
        height: 100%;
        border-radius: 4px;
        transition: width .6s ease;
    }

    .summary-row {
        display: flex;
        gap: 8px;
        align-items: center;
        padding: 7px 0;
        border-bottom: 1px solid #f4f6f9;
    }

        .summary-row:last-child {
            border-bottom: none;
        }

    .summary-row-label {
        font-size: 12.5px;
        color: #57606a;
        flex: 1;
    }

    .summary-row-val {
        font-size: 13px;
        font-weight: 600;
        color: #0d1117;
        font-family: 'DM Mono',monospace;
    }

    .summary-row-badge {
        margin-left: 6px;
    }
</style>

<div style="padding: 0 0 24px;">

    @* ── Page header ───────────────────────────────────────────────── *@
    <div class="page-header" style="margin-bottom:22px;">
        <div class="page-header-left">
            <h1>Dashboard</h1>
            <p>Welcome back, <strong>@username</strong> — @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
        </div>
        <div class="page-header-actions">
            <a asp-controller="Admin" asp-action="RegisterUser" class="btn-dms-primary">
                <i class="bi bi-person-plus-fill"></i> New User
            </a>
            <a asp-controller="Admin" asp-action="AddStaff" class="btn-dms-secondary">
                <i class="bi bi-plus-circle"></i> Add Staff
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="dms-alert dms-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @* ── KPI cards — row 1 ─────────────────────────────────────────── *@
    <p class="dash-section-title">Overview</p>
    <div class="kpi-grid">

        <div class="kpi-card blue">
            <div class="kpi-top">
                <div class="kpi-icon blue"><i class="bi bi-people-fill"></i></div>
                <span class="kpi-badge ok">@activeUsers active</span>
            </div>
            <div class="kpi-value">@totalUsers</div>
            <div class="kpi-label">Total Users</div>
            <a asp-controller="Admin" asp-action="Users" class="kpi-link">View all →</a>
        </div>

        <div class="kpi-card green">
            <div class="kpi-top">
                <div class="kpi-icon green"><i class="bi bi-briefcase-fill"></i></div>
                <span class="kpi-badge ok">@activeStaff active</span>
            </div>
            <div class="kpi-value">@totalStaff</div>
            <div class="kpi-label">Staff Members</div>
            <a asp-controller="Admin" asp-action="Staff" class="kpi-link">View all →</a>
        </div>

        <div class="kpi-card teal">
            <div class="kpi-top">
                <div class="kpi-icon teal"><i class="bi bi-person-badge-fill"></i></div>
                <span class="kpi-badge ok">@Model.Collection.ActiveFarmers active</span>
            </div>
            <div class="kpi-value">@Model.Collection.TotalFarmers</div>
            <div class="kpi-label">Registered Farmers</div>
            <a asp-controller="Farmer" asp-action="Index" class="kpi-link">View all →</a>
        </div>

        <div class="kpi-card amber">
            <div class="kpi-top">
                <div class="kpi-icon amber"><i class="bi bi-building-fill"></i></div>
                <span class="kpi-badge ok">@activePlants active</span>
            </div>
            <div class="kpi-value">@totalPlants</div>
            <div class="kpi-label">Processing Plants</div>
            <a asp-controller="Admin" asp-action="GetAllPlants" class="kpi-link">View all →</a>
        </div>

        <div class="kpi-card purple">
            <div class="kpi-top">
                <div class="kpi-icon purple"><i class="bi bi-bucket-fill"></i></div>
                <span class="kpi-badge ok">@activeCenters active</span>
            </div>
            <div class="kpi-value">@totalCenters</div>
            <div class="kpi-label">Collection Centers</div>
            <a asp-controller="Admin" asp-action="GetAllCollection" class="kpi-link">View all →</a>
        </div>

        <div class="kpi-card red">
            <div class="kpi-top">
                <div class="kpi-icon red"><i class="bi bi-box-seam-fill"></i></div>
                <span class="kpi-badge ok">@activeProducts active</span>
            </div>
            <div class="kpi-value">@totalProducts</div>
            <div class="kpi-label">Products</div>
            <a asp-controller="Admin" asp-action="Products" class="kpi-link">View all →</a>
        </div>

    </div>

    @* ── KPI cards — row 2: operational ────────────────────────────── *@
    <div class="kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">

        <div class="kpi-card teal">
            <div class="kpi-top">
                <div class="kpi-icon teal"><i class="bi bi-droplet-fill"></i></div>
                <span class="kpi-badge ok">today</span>
            </div>
            <div class="kpi-value">@Model.Collection.TodayMilkCollected.ToString("N0") <small style="font-size:14px;color:#8b949e;">L</small></div>
            <div class="kpi-label">Today's Collection</div>
            <div class="kpi-sub">Total: @Model.Collection.TotalMilkCollected.ToString("N0") L</div>
        </div>

        <div class="kpi-card green">
            <div class="kpi-top">
                <div class="kpi-icon green"><i class="bi bi-check-circle-fill"></i></div>
                <span class="kpi-badge ok">@Model.Production.Completed done</span>
            </div>
            <div class="kpi-value">@Model.Batches.Count</div>
            <div class="kpi-label">Production Batches</div>
            <div class="kpi-sub">@Model.Production.InProgress in progress</div>
        </div>

        <div class="kpi-card amber">
            <div class="kpi-top">
                <div class="kpi-icon amber"><i class="bi bi-truck-front-fill"></i></div>
                <span class="kpi-badge warn">@Model.Transfer.PendingCount pending</span>
            </div>
            <div class="kpi-value">@Model.Transfers.Count</div>
            <div class="kpi-label">Milk Transfers</div>
            <div class="kpi-sub">Loss: @Model.Transfer.LossPercent%</div>
        </div>

        <div class="kpi-card blue">
            <div class="kpi-top">
                <div class="kpi-icon blue"><i class="bi bi-currency-rupee"></i></div>
                <span class="kpi-badge ok">revenue</span>
            </div>
            <div class="kpi-value">₹@((Model.Finance.TotalSalesRevenue / 100000m).ToString("F1"))L</div>
            <div class="kpi-label">Sales Revenue</div>
            <div class="kpi-sub">Pending: ₹@((Model.Finance.TotalFarmerPending + Model.Finance.TotalStaffPending + Model.Finance.TotalCenterPending).ToString("N0"))</div>
        </div>

        <div class="kpi-card red">
            <div class="kpi-top">
                <div class="kpi-icon red"><i class="bi bi-exclamation-triangle-fill"></i></div>
                @if (Model.Production.QCFailed > 0)
                {
                    <span class="kpi-badge warn">@Model.Production.QCFailed failed</span>
                }
                else
                {
                    <span class="kpi-badge ok">all clear</span>
                }
            </div>
            <div class="kpi-value">@Model.Collection.OpenBatches</div>
            <div class="kpi-label">Open Batches</div>
            <div class="kpi-sub">QC Failed: @Model.Production.QCFailed</div>
        </div>

    </div>

    @* ── Charts row 1: Milk collection trend + Batch status ────────── *@
    <p class="dash-section-title">Analytics</p>
    <div class="chart-grid chart-grid-2">

        @* Milk collection — line chart *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-graph-up-arrow" style="color:#2563eb;"></i>
                    Milk collection — last 7 days
                </div>
                <span class="chart-badge pill-info">Litres</span>
            </div>
            <div style="position:relative;height:220px;">
                <canvas id="chartMilk"
                        role="img"
                        aria-label="Line chart showing daily milk collection in litres for the last 7 days">
                    @string.Join(", ", Model.MilkLast7Days.Select(p => $"{p.Label}: {p.Value}L"))
                </canvas>
            </div>
        </div>

        @* Batch status — doughnut *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-pie-chart-fill" style="color:#7c3aed;"></i>
                    Production batch status
                </div>
            </div>
            <div class="chart-legend">
                <span class="legend-item"><span class="legend-dot" style="background:#059669;"></span>Completed (@Model.Production.Completed)</span>
                <span class="legend-item"><span class="legend-dot" style="background:#d97706;"></span>In Progress (@Model.Production.InProgress)</span>
                <span class="legend-item"><span class="legend-dot" style="background:#dc2626;"></span>QC Failed (@Model.Production.QCFailed)</span>
                <span class="legend-item"><span class="legend-dot" style="background:#9ca3af;"></span>Cancelled (@Model.Production.Cancelled)</span>
            </div>
            <div style="position:relative;height:180px;">
                <canvas id="chartBatch"
                        role="img"
                        aria-label="Doughnut chart showing production batch status distribution">
                    Completed: @Model.Production.Completed, In Progress: @Model.Production.InProgress,
                    QC Failed: @Model.Production.QCFailed, Cancelled: @Model.Production.Cancelled
                </canvas>
            </div>
        </div>

    </div>

    @* ── Charts row 2: Transfer overview + Payments + Top products ─── *@
    <div class="chart-grid chart-grid-3">

        @* Transfer dispatch vs received — bar *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-truck" style="color:#0d9488;"></i>
                    Transfer volumes
                </div>
            </div>
            <div class="chart-legend">
                <span class="legend-item"><span class="legend-dot" style="background:#2563eb;"></span>Dispatched</span>
                <span class="legend-item"><span class="legend-dot" style="background:#059669;"></span>Received</span>
                <span class="legend-item"><span class="legend-dot" style="background:#dc2626;"></span>Loss</span>
            </div>
            <div style="position:relative;height:200px;">
                <canvas id="chartTransfer"
                        role="img"
                        aria-label="Grouped bar chart comparing dispatched, received and loss quantities for recent transfers">
                    @foreach (var t in Model.TransferDispatchSeries)
                    {
                        <span>@t.Label: @t.Value L</span>
                    }
                </canvas>
            </div>
        </div>

        @* Payments paid vs pending — horizontal bar *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-wallet2" style="color:#d97706;"></i>
                    Payment status
                </div>
            </div>
            <div class="chart-legend">
                <span class="legend-item"><span class="legend-dot" style="background:#059669;"></span>Processed</span>
                <span class="legend-item"><span class="legend-dot" style="background:#fbbf24;"></span>Pending</span>
            </div>
            <div style="position:relative;height:@(Model.PaymentPaidSeries.Count * 52 + 40)px;">
                <canvas id="chartPayments"
                        role="img"
                        aria-label="Horizontal bar chart showing processed and pending payments by category">
                    Farmers paid ₹@Model.Finance.TotalFarmerPaid, pending ₹@Model.Finance.TotalFarmerPending.
                    Staff paid ₹@Model.Finance.TotalStaffPaid, pending ₹@Model.Finance.TotalStaffPending.
                    Centers paid ₹@Model.Finance.TotalCenterPaid, pending ₹@Model.Finance.TotalCenterPending.
                </canvas>
            </div>
        </div>

        @* Top products by milk used — horizontal bar *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-bar-chart-fill" style="color:#7c3aed;"></i>
                    Top products by milk used
                </div>
            </div>
            <div style="position:relative;height:@(Math.Max(Model.TopProductsByMilkUsed.Count * 42 + 40, 160))px;">
                <canvas id="chartTopProducts"
                        role="img"
                        aria-label="Horizontal bar chart showing top 5 products by total milk used in production">
                    @foreach (var p in Model.TopProductsByMilkUsed)
                    {
                        <span>@p.Label: @p.Value L</span>
                    }
                </canvas>
            </div>
        </div>

    </div>

    @* ── Charts row 3: Orders by status + Transfer KPIs + Quick actions *@
    <div class="chart-grid" style="grid-template-columns: 1fr 1fr 1fr; gap:16px; margin-bottom:26px;">

        @* Orders by status — doughnut *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-cart-check-fill" style="color:#2563eb;"></i>
                    Sales orders
                </div>
            </div>
            <div class="chart-legend" id="orderLegend"></div>
            <div style="position:relative;height:160px;">
                <canvas id="chartOrders"
                        role="img"
                        aria-label="Doughnut chart showing sales order distribution by status">
                    @foreach (var o in Model.OrdersByStatus)
                    {
                        <span>@o.Label: @((int)o.Value)</span>
                    }
                </canvas>
            </div>
        </div>

        @* Transfer KPI summary panel *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-speedometer2" style="color:#0d9488;"></i>
                    Transfer summary
                </div>
            </div>
            <div>
                <div class="summary-row">
                    <span class="summary-row-label">Total dispatched</span>
                    <span class="summary-row-val">@Model.Transfer.TotalDispatched.ToString("N0") L</span>
                </div>
                <div class="summary-row">
                    <span class="summary-row-label">Total received</span>
                    <span class="summary-row-val">@Model.Transfer.TotalReceived.ToString("N0") L</span>
                </div>
                <div class="summary-row">
                    <span class="summary-row-label">Total loss</span>
                    <span class="summary-row-val" style="color:#dc2626;">@Model.Transfer.TotalLoss.ToString("N2") L</span>
                </div>
                <div class="summary-row">
                    <span class="summary-row-label">Loss percentage</span>
                    <span class="summary-row-val" style="color:@(Model.Transfer.LossPercent > 5 ? "#dc2626" : "#059669");">
                        @Model.Transfer.LossPercent%
                    </span>
                </div>
                <div style="margin-top:12px;">
                    <div style="display:flex;justify-content:space-between;font-size:11.5px;color:#8b949e;margin-bottom:4px;">
                        <span>Transfer completion</span>
                        <span>@(Model.Transfers.Count > 0 ? Math.Round(((decimal)Model.Transfer.ReceivedCount / Model.Transfers.Count) * 100, 0) : 0)%</span>
                    </div>
                    <div class="loss-bar-wrap">
                        @{
                            var pct = Model.Transfers.Count > 0
                            ? (int)Math.Round(((decimal)Model.Transfer.ReceivedCount / Model.Transfers.Count) * 100)
                            : 0;
                        }
                        <div class="loss-bar" style="width:@pct%;background:#059669;"></div>
                    </div>
                </div>
                <div style="margin-top:10px;">
                    <div style="display:flex;justify-content:space-between;font-size:11.5px;color:#8b949e;margin-bottom:4px;">
                        <span>Loss rate (lower is better)</span>
                        <span>@Model.Transfer.LossPercent%</span>
                    </div>
                    <div class="loss-bar-wrap">
                        <div class="loss-bar" style="width:@Math.Min((double)Model.Transfer.LossPercent * 10, 100)%;background:@(Model.Transfer.LossPercent > 5 ? "#dc2626" : "#d97706");"></div>
                    </div>
                </div>
            </div>
        </div>

        @* Quick actions *@
        <div class="chart-card">
            <div class="chart-card-header">
                <div class="chart-card-title">
                    <i class="bi bi-lightning-fill" style="color:#d97706;"></i>
                    Quick actions
                </div>
            </div>
            <div class="quick-actions">
                <a asp-controller="Admin" asp-action="AddStaff" class="qa-btn green">
                    <i class="bi bi-person-plus-fill"></i>
                    <span>Add Staff</span>
                </a>
                <a asp-controller="Admin" asp-action="AddPlant" class="qa-btn amber">
                    <i class="bi bi-building-add"></i>
                    <span>Add Plant</span>
                </a>
                <a asp-controller="Admin" asp-action="AddCollection" class="qa-btn blue">
                    <i class="bi bi-house-add"></i>
                    <span>Add Center</span>
                </a>
                <a asp-controller="Admin" asp-action="AddProduct" class="qa-btn red">
                    <i class="bi bi-box-seam"></i>
                    <span>Add Product</span>
                </a>
                <a asp-controller="Admin" asp-action="RateChart" class="qa-btn teal">
                    <i class="bi bi-currency-rupee"></i>
                    <span>Rate Chart</span>
                </a>
                <a asp-controller="Admin" asp-action="AuditLogs" class="qa-btn purple">
                    <i class="bi bi-clock-history"></i>
                    <span>Audit Logs</span>
                </a>
            </div>
        </div>

    </div>

    @* ── Recent tables ──────────────────────────────────────────────── *@
    <p class="dash-section-title">Recent activity</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">

        @* Recent users *@
        <div class="table-card">
            <div class="table-card-header">
                <span class="table-card-title"><i class="bi bi-people me-2" style="color:#2563eb;"></i>Recent users</span>
                <a asp-controller="Admin" asp-action="Users" class="btn-dms-secondary" style="padding:5px 12px;font-size:12px;">View all</a>
            </div>
            <table class="dms-tbl">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentUsers.Any())
                    {
                        <tr><td colspan="4" class="text-center" style="color:#8b949e;padding:20px;">No users yet.</td></tr>
                    }
                    @foreach (var u in Model.RecentUsers)
                    {
                        <tr>
                            <td style="font-weight:600;color:#0d1117;">@u.Username</td>
                            <td><span class="pill pill-info">@u.RoleName</span></td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px;">@u.CreatedDate.ToString("dd MMM yy")</td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="pill pill-ok">Active</span>
                                }
                                else
                                {
                                    <span class="pill pill-err">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Recent batches *@
        <div class="table-card">
            <div class="table-card-header">
                <span class="table-card-title"><i class="bi bi-gear me-2" style="color:#7c3aed;"></i>Recent batches</span>
                <a asp-controller="Admin" asp-action="ProductionBatches" class="btn-dms-secondary" style="padding:5px 12px;font-size:12px;">View all</a>
            </div>
            <table class="dms-tbl">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Plant</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentBatches.Any())
                    {
                        <tr><td colspan="4" class="text-center" style="color:#8b949e;padding:20px;">No batches yet.</td></tr>
                    }
                    @foreach (var b in Model.RecentBatches)
                    {
                        var badgeCls = b.BatchStatus switch
                        {
                            "Completed" => "pill-ok",
                            "InProgress" => "pill-warn",
                            "QCFailed" => "pill-err",
                            "Cancelled" => "pill-muted",
                            _ => "pill-muted"
                        };
                        <tr>
                            <td style="font-weight:600;color:#0d1117;">@b.ProductName</td>
                            <td style="color:#8b949e;font-size:12px;">@b.PlantName</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px;">@b.ProductionDate.ToString("dd MMM yy")</td>
                            <td><span class="pill @badgeCls">@b.BatchStatus</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    @* Recent transfers — full width *@
    <div class="table-card">
        <div class="table-card-header">
            <span class="table-card-title"><i class="bi bi-truck me-2" style="color:#0d9488;"></i>Recent milk transfers</span>
            <a asp-controller="Admin" asp-action="MilkTransfers" class="btn-dms-secondary" style="padding:5px 12px;font-size:12px;">View all</a>
        </div>
        <div style="overflow-x:auto;">
            <table class="dms-tbl" style="min-width:700px;">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Route</th>
                        <th>Driver / Vehicle</th>
                        <th style="text-align:right;">Dispatch (L)</th>
                        <th style="text-align:right;">Received (L)</th>
                        <th style="text-align:right;">Loss (L)</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentTransfers.Any())
                    {
                        <tr><td colspan="8" class="text-center" style="color:#8b949e;padding:20px;">No transfers yet.</td></tr>
                    }
                    @{
                        int sr = 1;
                    }
                    @foreach (var t in Model.RecentTransfers)
                    {
                        <tr>
                            <td style="color:#b0b8c4;font-family:'DM Mono',monospace;font-size:12px;">@sr</td>
                            <td>
                                <span style="font-weight:600;color:#0d1117;">@t.CenterName</span>
                                <i class="bi bi-arrow-right" style="color:#b0b8c4;margin:0 4px;font-size:11px;"></i>
                                <span style="color:#57606a;font-size:12px;">@t.PlantName</span>
                            </td>
                            <td>
                                <div style="font-size:13px;color:#0d1117;">@(t.DriverName ?? "—")</div>
                                @if (!string.IsNullOrEmpty(t.VehicleNumber))
                                {
                                    <span class="pill pill-muted" style="font-size:10px;">@t.VehicleNumber</span>
                                }
                            </td>
                            <td style="text-align:right;font-family:'DM Mono',monospace;">@t.DispatchQty.ToString("N0")</td>
                            <td style="text-align:right;font-family:'DM Mono',monospace;">@(t.ReceivedQty.HasValue? t.ReceivedQty.Value.ToString("N0") : "—")</td>
                            <td style="text-align:right;font-family:'DM Mono',monospace;color:#dc2626;">@(t.LossQty.HasValue? t.LossQty.Value.ToString("N2") : "—")</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px;">@t.DispatchDate.ToString("dd MMM yy")</td>
                            <td>
                                @if (t.TransferStatus == "Received")
                                {
                                    <span class="pill pill-ok">Received</span>
                                }
                                else
                                {
                                    <span class="pill pill-warn">Pending</span>
                                }
                            </td>
                        </tr>
                        sr++;
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            Chart.defaults.font.family = "'DM Sans', sans-serif";
            Chart.defaults.font.size   = 12;
            Chart.defaults.color       = '#8b949e';

            var milkLabels    = @Html.Raw(JsonLabels(Model.MilkLast7Days));
            var milkValues    = @Html.Raw(JsonValues(Model.MilkLast7Days));

            var batchLabels   = @Html.Raw(JsonLabels(Model.BatchByStatus));
            var batchValues   = @Html.Raw(JsonValues(Model.BatchByStatus));

            var tDisLabels  = @Html.Raw(JsonLabels(Model.TransferDispatchSeries));
            var tDisValues  = @Html.Raw(JsonValues(Model.TransferDispatchSeries));
            var tRecValues  = @Html.Raw(JsonValues(Model.TransferReceivedSeries));
            var tLosValues  = @Html.Raw(JsonValues(Model.TransferLossSeries));

            var payLabels   = @Html.Raw(JsonLabels(Model.PaymentPaidSeries));
            var payPaid     = @Html.Raw(JsonValues(Model.PaymentPaidSeries));
            var payPending  = @Html.Raw(JsonValues(Model.PaymentPendingSeries));

            var prodLabels  = @Html.Raw(JsonLabels(Model.TopProductsByMilkUsed));
            var prodValues  = @Html.Raw(JsonValues(Model.TopProductsByMilkUsed));

            var ordLabels   = @Html.Raw(JsonLabels(Model.OrdersByStatus));
            var ordValues   = @Html.Raw(JsonValues(Model.OrdersByStatus));

            // ── 1. Milk collection line chart ──────────────────────────
            new Chart(document.getElementById('chartMilk'), {
                type: 'line',
                data: {
                    labels: milkLabels,
                    datasets: [{
                        label: 'Litres',
                        data: milkValues,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37,99,235,0.08)',
                        borderWidth: 2,
                        pointBackgroundColor: '#2563eb',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.35,
                        fill: true,
                        borderDash: [],
                        pointStyle: 'circle'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => ' ' + Number(ctx.parsed.y).toLocaleString('en-IN') + ' L'
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, border: { display: false } },
                        y: {
                            grid: { color: '#f0f2f5' },
                            border: { display: false },
                            ticks: { callback: v => Number(v).toLocaleString('en-IN') }
                        }
                    }
                }
            });

            // ── 2. Batch status doughnut ───────────────────────────────
            new Chart(document.getElementById('chartBatch'), {
                type: 'doughnut',
                data: {
                    labels: batchLabels,
                    datasets: [{
                        data: batchValues,
                        backgroundColor: ['#059669','#d97706','#dc2626','#9ca3af'],
                        borderColor: '#ffffff',
                        borderWidth: 3,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '72%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => ' ' + ctx.label + ': ' + ctx.parsed
                            }
                        }
                    }
                }
            });

            // ── 3. Transfer grouped bar ────────────────────────────────
            new Chart(document.getElementById('chartTransfer'), {
                type: 'bar',
                data: {
                    labels: tDisLabels,
                    datasets: [
                        {
                            label: 'Dispatched',
                            data: tDisValues,
                            backgroundColor: '#2563eb',
                            borderRadius: 4,
                            borderSkipped: false
                        },
                        {
                            label: 'Received',
                            data: tRecValues,
                            backgroundColor: '#059669',
                            borderRadius: 4,
                            borderSkipped: false
                        },
                        {
                            label: 'Loss',
                            data: tLosValues,
                            backgroundColor: '#fca5a5',
                            borderRadius: 4,
                            borderSkipped: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, border: { display: false } },
                        y: {
                            grid: { color: '#f0f2f5' },
                            border: { display: false },
                            ticks: { callback: v => Number(v).toLocaleString('en-IN') + ' L' }
                        }
                    }
                }
            });

            // ── 4. Payments horizontal bar ─────────────────────────────
            new Chart(document.getElementById('chartPayments'), {
                type: 'bar',
                data: {
                    labels: payLabels,
                    datasets: [
                        {
                            label: 'Processed',
                            data: payPaid,
                            backgroundColor: '#059669',
                            borderRadius: 4,
                            borderSkipped: false
                        },
                        {
                            label: 'Pending',
                            data: payPending,
                            backgroundColor: '#fbbf24',
                            borderRadius: 4,
                            borderSkipped: false
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { color: '#f0f2f5' },
                            border: { display: false },
                            ticks: { callback: v => '₹' + (v >= 1000 ? (v/1000).toFixed(0)+'K' : v) }
                        },
                        y: { grid: { display: false }, border: { display: false } }
                    }
                }
            });

            // ── 5. Top products horizontal bar ─────────────────────────
            new Chart(document.getElementById('chartTopProducts'), {
                type: 'bar',
                data: {
                    labels: prodLabels,
                    datasets: [{
                        label: 'Milk used (L)',
                        data: prodValues,
                        backgroundColor: ['#7c3aed','#9c5fe6','#b882ea','#d0a5ee','#e8c9f3'],
                        borderRadius: 4,
                        borderSkipped: false
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { color: '#f0f2f5' },
                            border: { display: false },
                            ticks: { callback: v => Number(v).toLocaleString('en-IN') + ' L' }
                        },
                        y: { grid: { display: false }, border: { display: false } }
                    }
                }
            });

            // ── 6. Orders by status doughnut ───────────────────────────
            var ordColors = {
                'Pending'   : '#fbbf24',
                'Confirmed' : '#2563eb',
                'Dispatched': '#0d9488',
                'Delivered' : '#059669',
                'Cancelled' : '#9ca3af'
            };
            var ordBg = ordLabels.map(l => ordColors[l] || '#c4b5fd');

            var ordChart = new Chart(document.getElementById('chartOrders'), {
                type: 'doughnut',
                data: {
                    labels: ordLabels,
                    datasets: [{
                        data: ordValues,
                        backgroundColor: ordBg,
                        borderColor: '#ffffff',
                        borderWidth: 3,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '68%',
                    plugins: { legend: { display: false } }
                }
            });

            // Build legend for orders chart
            var legendEl = document.getElementById('orderLegend');
            if(legendEl) {
                ordLabels.forEach(function(lbl, i) {
                    var span = document.createElement('span');
                    span.className = 'legend-item';
                    span.innerHTML = '<span class="legend-dot" style="background:' + ordBg[i] + ';"></span>'
                                   + lbl + ' (' + Math.round(ordValues[i]) + ')';
                    legendEl.appendChild(span);
                });
            }

        })();
    </script>
}