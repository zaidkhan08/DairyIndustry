@model List<DairyIndustry.Models.Reports.WastageModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Wastage Summary";

    var plants = ViewBag.Plants as List<DairyIndustry.Models.Admin.PlantModel>
                 ?? new List<DairyIndustry.Models.Admin.PlantModel>();

    var productWastage = Model.Where(w => w.WastageCategory == "ProductWastage").ToList();
    var milkWastage = Model.Where(w => w.WastageCategory == "MilkWastage").ToList();
}

<div class="container mt-4">

    <!-- Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Wastage Summary</h3>
                <p class="text-muted mb-0">Product and milk process wastage overview</p>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Total Records</p>
                        <h4 class="fw-bold mb-0">@Model.Count</h4>
                    </div>
                    <i class="bi bi-trash-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Product Wastage</p>
                        <h4 class="fw-bold mb-0">@productWastage.Sum(w => w.TotalWastage).ToString("0.00")</h4>
                    </div>
                    <i class="bi bi-box-seam fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Milk Wastage (Ltr)</p>
                        <h4 class="fw-bold mb-0">@milkWastage.Sum(w => w.TotalWastage).ToString("0.00")</h4>
                    </div>
                    <i class="bi bi-droplet-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-controller="Admin" asp-action="WastageSummary"
                  class="row g-3 align-items-end">

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Plant</label>
                    <select name="plantId" class="form-select">
                        <option value="">All Plants</option>
                        @foreach (var plant in plants)
                        {
                            <option value="@plant.PlantId"
                                    selected="@(ViewBag.PlantId?.ToString() == plant.PlantId.ToString() ? "selected" : null)">
                                @plant.PlantName
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">From Date</label>
                    <input type="date" name="fromDate" class="form-control"
                           value="@ViewBag.FromDate" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">To Date</label>
                    <input type="date" name="toDate" class="form-control"
                           value="@ViewBag.ToDate" />
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                    <a asp-controller="Admin" asp-action="WastageSummary"
                       class="btn btn-outline-secondary">Clear</a>
                </div>

            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> No wastage records found for the selected filters.
        </div>
    }
    else
    {
        <!-- Product Wastage Table -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-box-seam me-1 text-warning"></i> Product Wastage</span>
                <span class="badge bg-warning text-dark">@productWastage.Count records</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Plant</th>
                                <th>Product</th>
                                <th>Total Wastage</th>
                                <th>Unit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!productWastage.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox d-block mb-1"></i> No product wastage found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int sr = 1;
                                foreach (var w in productWastage)
                                {
                                    <tr>
                                        <td>@sr</td>
                                        <td><small><i class="bi bi-building me-1 text-muted"></i>@w.PlantName</small></td>
                                        <td><span class="fw-semibold small">@w.Item</span></td>
                                        <td><span class="text-danger fw-semibold">@w.TotalWastage.ToString("0.00")</span></td>
                                        <td><small>@w.Unit</small></td>
                                    </tr>
                                    sr++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-muted small">
                Total Product Wastage: <strong>@productWastage.Sum(w => w.TotalWastage).ToString("0.00")</strong>
            </div>
        </div>

        <!-- Milk Wastage Table -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-droplet me-1 text-info"></i> Milk Process Wastage</span>
                <span class="badge bg-info text-white">@milkWastage.Count records</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Plant</th>
                                <th>Milk Type</th>
                                <th>Wastage Type</th>
                                <th>Total Wastage</th>
                                <th>Unit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!milkWastage.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox d-block mb-1"></i> No milk wastage found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int sr = 1;
                                foreach (var w in milkWastage)
                                {
                                    <tr>
                                        <td>@sr</td>
                                        <td><small><i class="bi bi-building me-1 text-muted"></i>@w.PlantName</small></td>
                                        <td><span class="fw-semibold small">@w.Item</span></td>
                                        <td>
                                            @{
                                                string wasteBadge = w.WastageType?.ToLower() switch
                                                {
                                                    "evaporation" => "bg-info text-dark",
                                                    "spillage" => "bg-warning text-dark",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @wasteBadge">@w.WastageType</span>
                                        </td>
                                        <td><span class="text-danger fw-semibold">@w.TotalWastage.ToString("0.00")</span></td>
                                        <td><small>@w.Unit</small></td>
                                    </tr>
                                    sr++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-muted small">
                Total Milk Wastage: <strong>@milkWastage.Sum(w => w.TotalWastage).ToString("0.00") Ltr</strong>
            </div>
        </div>
    }

</div>