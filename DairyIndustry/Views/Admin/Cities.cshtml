@model List<DairyIndustry.Models.Admin.CityModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Cities";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Cities</h3>
                <p class="text-muted mb-0">Add and view all cities</p>
            </div>
            <a href="/Admin/States" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to States
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- Add City Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-plus-circle me-1"></i> Add New City
                </div>
                <div class="card-body p-4">
                    <form method="post" action="/Admin/AddCity">

                        <!-- State Dropdown -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                State <span class="text-danger">*</span>
                            </label>
                            <select name="stateId"
                                    class="form-select"
                                    required>
                                <option value="">-- Select State --</option>
                                @foreach (var state in ViewBag.States as List<DairyIndustry.Models.Admin.StateModel>)
                                {
                                    <option value="@state.StateId">@state.StateName</option>
                                }
                            </select>
                        </div>

                        <!-- City Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                City Name <span class="text-danger">*</span>
                            </label>
                            <input type="text"
                                   name="cityName"
                                   class="form-control"
                                   placeholder="e.g. Surat, Pune"
                                   required />
                            <div class="form-text">City name must be unique within state</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Add City
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- Cities List -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-building me-1"></i> All Cities</span>
                    <span class="badge bg-primary">Total : @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>City ID</th>
                                    <th>City Name</th>
                                    <th>State</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No cities found. Add one.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    @foreach (var city in Model)
                                    {
                                        <tr>
                                            <td>@sr</td>
                                            <td>
                                                <span class="badge bg-secondary">@city.CityId</span>
                                            </td>
                                            <td>
                                                <i class="bi bi-building me-1 text-primary"></i>
                                                @city.CityName
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">
                                                    @city.StateName
                                                </span>
                                            </td>
                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white text-muted small">
                    @Model.Count city/cities available in the system
                </div>
            </div>
        </div>

    </div>
</div>