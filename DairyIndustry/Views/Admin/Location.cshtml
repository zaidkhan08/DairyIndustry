@{
    ViewData["Title"] = "Manage Location";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var states = ViewBag.States as List<DairyIndustry.Models.Admin.StateModel>;
    var cities = ViewBag.Cities as List<DairyIndustry.Models.Admin.CityModel>;
    var villages = ViewBag.Villages as List<DairyIndustry.Models.Admin.VillageModel>;

    string activeTab = TempData["ActiveTab"]?.ToString() ?? "state";
}

<div class="bg-primary text-white py-4 px-4 mb-4 shadow-sm">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-geo-alt-fill me-2"></i>Location Management
            </h4>
            <p class="mb-0 opacity-75 small">
                Manage States, Cities and Villages from one place.
            </p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-light text-primary fw-semibold px-3 py-2">
                <i class="bi bi-geo me-1"></i>States: @states.Count
            </span>
            <span class="badge bg-light text-primary fw-semibold px-3 py-2">
                <i class="bi bi-building me-1"></i>Cities: @cities.Count
            </span>
            <span class="badge bg-light text-primary fw-semibold px-3 py-2">
                <i class="bi bi-map me-1"></i>Villages: @villages.Count
            </span>
        </div>
    </div>
</div>

<div class="container-fluid px-4 pb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabs -->
    <ul class="nav nav-tabs border-bottom mb-4" id="locationTabs">
        <li class="nav-item">
            <a class="nav-link fw-semibold @(activeTab == "state" ? "active" : "")"
               id="state-tab" href="#statePanel"
               data-bs-toggle="tab" role="tab">
                <i class="bi bi-geo-alt-fill me-1 text-primary"></i>States
                <span class="badge bg-primary ms-1">@states.Count</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link fw-semibold @(activeTab == "city" ? "active" : "")"
               id="city-tab" href="#cityPanel"
               data-bs-toggle="tab" role="tab">
                <i class="bi bi-building me-1 text-success"></i>Cities
                <span class="badge bg-success ms-1">@cities.Count</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link fw-semibold @(activeTab == "village" ? "active" : "")"
               id="village-tab" href="#villagePanel"
               data-bs-toggle="tab" role="tab">
                <i class="bi bi-map me-1 text-warning"></i>Villages
                <span class="badge bg-warning text-dark ms-1">@villages.Count</span>
            </a>
        </li>
    </ul>

    <div class="tab-content" id="locationTabContent">

        <!-- ════════════════════════════════════
             STATE TAB
        ════════════════════════════════════ -->
        <div class="tab-pane fade @(activeTab == "state" ? "show active" : "")"
             id="statePanel" role="tabpanel">
            <div class="row g-4">

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-circle text-primary"></i>
                            <span class="fw-semibold">Add New State</span>
                        </div>
                        <div class="card-body p-4">
                            <form method="post" action="/Admin/AddState">
                                <div class="mb-4">
                                    <label class="form-label fw-medium">
                                        State Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-geo-alt text-primary"></i>
                                        </span>
                                        <input type="text" name="stateName"
                                               class="form-control border-start-0 ps-0"
                                               placeholder="e.g. Gujarat, Maharashtra"
                                               required />
                                    </div>
                                    <div class="form-text ms-1">State name must be unique.</div>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary fw-semibold">
                                        <i class="bi bi-plus-circle me-2"></i>Add State
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-table text-primary"></i>
                                <span class="fw-semibold">All States</span>
                            </div>
                            <span class="badge bg-primary px-3">Total: @states.Count</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                                            <th class="py-3 text-muted fw-semibold small">State ID</th>
                                            <th class="py-3 text-muted fw-semibold small">State Name</th>
                                            <th class="py-3 text-muted fw-semibold small">Cities</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!states.Any())
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center text-muted py-5">
                                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                                    No states added yet.
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            int sr = 1;
                                            foreach (var state in states)
                                            {
                                                int cityCount = cities.Count(c => c.StateId == state.StateId);
                                                <tr>
                                                    <td class="px-4 text-muted small">@sr</td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border">
                                                            #@state.StateId
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <i class="bi bi-geo-alt-fill me-2 text-primary"></i>
                                                        <span class="fw-semibold">@state.StateName</span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                                                            @cityCount cities
                                                        </span>
                                                    </td>
                                                </tr>
                                                sr++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- ════════════════════════════════════
             CITY TAB
        ════════════════════════════════════ -->
        <div class="tab-pane fade @(activeTab == "city" ? "show active" : "")"
             id="cityPanel" role="tabpanel">
            <div class="row g-4">

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-circle text-success"></i>
                            <span class="fw-semibold">Add New City</span>
                        </div>
                        <div class="card-body p-4">
                            <form method="post" action="/Admin/AddCity">
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        State <span class="text-danger">*</span>
                                    </label>
                                    <select name="stateId" class="form-select" required>
                                        <option value="">-- Select State --</option>
                                        @foreach (var state in states)
                                        {
                                            <option value="@state.StateId">@state.StateName</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-medium">
                                        City Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-building text-success"></i>
                                        </span>
                                        <input type="text" name="cityName"
                                               class="form-control border-start-0 ps-0"
                                               placeholder="e.g. Surat, Pune"
                                               required />
                                    </div>
                                    <div class="form-text ms-1">Must be unique within the state.</div>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-success fw-semibold">
                                        <i class="bi bi-plus-circle me-2"></i>Add City
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-table text-success"></i>
                                <span class="fw-semibold">All Cities</span>
                            </div>
                            <span class="badge bg-success px-3">Total: @cities.Count</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                                            <th class="py-3 text-muted fw-semibold small">City ID</th>
                                            <th class="py-3 text-muted fw-semibold small">City Name</th>
                                            <th class="py-3 text-muted fw-semibold small">State</th>
                                            <th class="py-3 text-muted fw-semibold small">Villages</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!cities.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-5">
                                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                                    No cities added yet.
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            int sr = 1;
                                            foreach (var city in cities)
                                            {
                                                int villageCount = villages.Count(v => v.CityId == city.CityId);
                                                <tr>
                                                    <td class="px-4 text-muted small">@sr</td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border">
                                                            #@city.CityId
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <i class="bi bi-building me-2 text-success"></i>
                                                        <span class="fw-semibold">@city.CityName</span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                                                            @city.StateName
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-success bg-opacity-10 text-success fw-semibold">
                                                            @villageCount villages
                                                        </span>
                                                    </td>
                                                </tr>
                                                sr++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- ════════════════════════════════════
             VILLAGE TAB
        ════════════════════════════════════ -->
        <div class="tab-pane fade @(activeTab == "village" ? "show active" : "")"
             id="villagePanel" role="tabpanel">
            <div class="row g-4">

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-circle text-warning"></i>
                            <span class="fw-semibold">Add New Village</span>
                        </div>
                        <div class="card-body p-4">
                            <form method="post" action="/Admin/AddVillage">
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        State <span class="text-danger">*</span>
                                    </label>
                                    <select id="stateDropdown" class="form-select" required>
                                        <option value="">-- Select State --</option>
                                        @foreach (var state in states)
                                        {
                                            <option value="@state.StateId">@state.StateName</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        City <span class="text-danger">*</span>
                                    </label>
                                    <select id="cityDropdown" name="cityId"
                                            class="form-select" required disabled>
                                        <option value="">-- Select State First --</option>
                                    </select>
                                    <div class="form-text ms-1">Select state to load cities.</div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-medium">
                                        Village Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-map text-warning"></i>
                                        </span>
                                        <input type="text" name="villageName"
                                               class="form-control border-start-0 ps-0"
                                               placeholder="e.g. Bardoli, Olpad"
                                               required />
                                    </div>
                                    <div class="form-text ms-1">Must be unique within the city.</div>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-warning fw-semibold">
                                        <i class="bi bi-plus-circle me-2"></i>Add Village
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-table text-warning"></i>
                                <span class="fw-semibold">All Villages</span>
                            </div>
                            <span class="badge bg-warning text-dark px-3">Total: @villages.Count</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                                            <th class="py-3 text-muted fw-semibold small">Village ID</th>
                                            <th class="py-3 text-muted fw-semibold small">Village Name</th>
                                            <th class="py-3 text-muted fw-semibold small">City</th>
                                            <th class="py-3 text-muted fw-semibold small">State</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!villages.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-5">
                                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                                    No villages added yet.
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            int sr = 1;
                                            foreach (var village in villages)
                                            {
                                                <tr>
                                                    <td class="px-4 text-muted small">@sr</td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border">
                                                            #@village.VillageId
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <i class="bi bi-map me-2 text-warning"></i>
                                                        <span class="fw-semibold">@village.VillageName</span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-success bg-opacity-10 text-success fw-semibold">
                                                            @village.CityName
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                                                            @village.StateName
                                                        </span>
                                                    </td>
                                                </tr>
                                                sr++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('stateDropdown').addEventListener('change', function () {
            const stateId      = this.value;
            const cityDropdown = document.getElementById('cityDropdown');

            cityDropdown.innerHTML = '<option value="">-- Loading... --</option>';
            cityDropdown.disabled  = true;

            if (!stateId) {
                cityDropdown.innerHTML = '<option value="">-- Select State First --</option>';
                return;
            }

            fetch(`/Admin/GetCitiesByState?stateId=${stateId}`)
                .then(response => response.json())
                .then(data => {
                    cityDropdown.innerHTML = '<option value="">-- Select City --</option>';

                    if (data.length === 0) {
                        cityDropdown.innerHTML = '<option value="">No cities found</option>';
                        return;
                    }

                    data.forEach(city => {
                        const option = document.createElement('option');
                        option.value = city.cityId;
                        option.text  = city.cityName;
                        cityDropdown.appendChild(option);
                    });

                    cityDropdown.disabled = false;
                })
                .catch(() => {
                    cityDropdown.innerHTML = '<option value="">Error loading cities</option>';
                });
        });
    </script>
}