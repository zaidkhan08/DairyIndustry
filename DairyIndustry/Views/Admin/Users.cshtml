@model List<DairyIndustry.Models.Admin.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Users";

    // Capture current page from ViewBag or Query
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="container mt-4">

    <!-- Page Title Section -->
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h3 class="fw-bold mb-0">Manage Users</h3>
            <p class="text-muted mb-0">All registered users in the system</p>
        </div>
        <div class="col-auto d-flex gap-2">

            <a href="/Admin/DownloadUsersPdf"
               class="btn btn-danger shadow-sm">
                <i class="bi bi-file-earmark-pdf me-1"></i>
                Download PDF
            </a>

            <a href="/Admin/RegisterUser"
               class="btn btn-primary shadow-sm">
                <i class="bi bi-person-plus me-1"></i>
                Register New User
            </a>

        </div>
    </div>

    <!-- Users Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Users List</h6>
            <span class="badge bg-primary rounded-pill">Total Records: @ViewBag.TotalRecords</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3" style="width: 50px;">#</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Staff Linked</th>
                            <th>Created Date</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-person-exclamation fs-2 d-block mb-2"></i>
                                    No users found in the system.
                                </td>
                            </tr>
                        }
                        else
                        {
                            // Calculate Serial Number based on pagination
                            int sr = ((currentPage - 1) * 10) + 1;
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="ps-3 text-muted">@sr</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle me-2 text-secondary fs-5"></i>
                                            <span class="fw-medium">@user.Username</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2">
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.StaffId.HasValue)
                                        {
                                            <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">
                                                <i class="bi bi-link-45deg"></i> ID: @user.StaffId
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Not Linked</span>
                                        }
                                    </td>
                                    <td class="small">@user.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <form method="post" action="/Admin/UpdateUserStatus" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <input type="hidden" name="isActive" value="@(user.IsActive ? "false" : "true")" />

                                            @if (user.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Deactivate account for @user.Username?')">
                                                    <i class="bi bi-person-x"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success"
                                                        onclick="return confirm('Activate account for @user.Username?')">
                                                    <i class="bi bi-person-check"></i> Activate
                                                </button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- FIXED FOOTER WITH PAGINATION -->
        <div class="card-footer bg-white py-3">
            <div class="row align-items-center">
                <div class="col-sm-6 text-center text-sm-start mb-3 mb-sm-0">
                    <span class="text-muted small">
                        Showing page <strong>@currentPage</strong> of <strong>@totalPages</strong> —
                        <span class="text-success">Active: @Model.Count(u => u.IsActive)</span> |
                        <span class="text-danger">Inactive: @Model.Count(u => !u.IsActive)</span>
                    </span>
                </div>
                <div class="col-sm-6">
                    <nav aria-label="User navigation">
                        <ul class="pagination pagination-sm justify-content-center justify-content-sm-end mb-0">

                            @* Previous *@
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @* Numbers *@
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i">@i</a>
                                </li>
                            }

                            @* Next *@
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling to match the Audit Log style */
    .table thead th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: #495057;
    }

    .btn-sm {
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
    }

    .pagination .page-link {
        padding: 0.4rem 0.75rem;
        color: #6c757d;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    .italic {
        font-style: italic;
    }
</style>