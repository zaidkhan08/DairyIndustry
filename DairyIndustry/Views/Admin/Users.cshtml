@model List<DairyIndustry.Models.Admin.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Users</h3>
                <p class="text-muted mb-0">All registered users in the system</p>
            </div>
            <a href="/Admin/RegisterUser" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i> Register New User
            </a>
        </div>
    </div>

    <!-- Users Table -->
    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span>Users List</span>
                    <span class="badge bg-primary">Total : @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th>Staff Linked</th>
                                    <th>Created Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.UserId</td>
                                        <td>
                                            <i class="bi bi-person-circle me-1 text-secondary"></i>
                                            @user.Username
                                        </td>
                                        <td>
                                            <span class="badge bg-primary">@user.RoleName</span>
                                        </td>
                                        <td>
                                            @if (user.StaffId.HasValue)
                                            {
                                                <span class="badge bg-info text-dark">
                                                    Staff ID : @user.StaffId
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Not Linked</span>
                                            }
                                        </td>
                                        <td>@user.CreatedDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <form method="post" action="/Admin/UpdateUserStatus">
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <input type="hidden" name="isActive" value="false" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Deactivate @user.Username ?')">
                                                        <i class="bi bi-person-x me-1"></i> Deactivate
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" action="/Admin/UpdateUserStatus">
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <input type="hidden" name="isActive" value="true" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-success"
                                                            onclick="return confirm('Activate @user.Username ?')">
                                                        <i class="bi bi-person-check me-1"></i> Activate
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer Count -->
                <div class="card-footer bg-white text-muted small">
                    Showing @Model.Count user(s) —
                    Active : @Model.Count(u => u.IsActive) |
                    Inactive : @Model.Count(u => !u.IsActive)
                </div>

            </div>
        </div>
    </div>

</div>