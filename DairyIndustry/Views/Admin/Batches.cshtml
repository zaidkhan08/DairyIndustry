@model List<DairyIndustry.Models.Admin.BatchModel>

@{
    ViewData["Title"] = "Batch Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- ── PAGE HEADER ─────────────────────────────────────── -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-semibold text-dark">
            <i class="bi bi-collection me-2 text-primary"></i>Batch Management
        </h4>
        <small class="text-muted">
            Oversee collection batch open/close across all centers
        </small>
    </div>

    <button class="btn btn-primary btn-sm px-3"
            data-bs-toggle="modal"
            data-bs-target="#openBatchModal">
        <i class="bi bi-plus-lg me-1"></i>
        Open New Batch
    </button>
</div>

<!-- ── ALERTS ─────────────────────────────────────────── -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 py-2"
         role="alert">
        <i class="bi bi-check-circle-fill"></i>

        <span>@TempData["Success"]</span>

        <button type="button"
                class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 py-2"
         role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>

        <span>@TempData["Error"]</span>

        <button type="button"
                class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- ── SUMMARY CARDS ───────────────────────────────────── -->
<div class="row g-3 mb-4">

    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">

                <div class="rounded-3 p-2" style="background:#e8f5e9;">
                    <i class="bi bi-circle-fill text-success fs-5"></i>
                </div>

                <div>
                    <div class="fw-bold fs-4 lh-1">
                        @ViewBag.OpenCount
                    </div>

                    <small class="text-muted">Open</small>
                </div>

            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">

                <div class="rounded-3 p-2" style="background:#fff3e0;">
                    <i class="bi bi-lock-fill text-warning fs-5"></i>
                </div>

                <div>
                    <div class="fw-bold fs-4 lh-1">
                        @ViewBag.ClosedCount
                    </div>

                    <small class="text-muted">Closed</small>
                </div>

            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">

                <div class="rounded-3 p-2" style="background:#e3f2fd;">
                    <i class="bi bi-truck text-primary fs-5"></i>
                </div>

                <div>
                    <div class="fw-bold fs-4 lh-1">
                        @ViewBag.DispatchedCount
                    </div>

                    <small class="text-muted">Dispatched</small>
                </div>

            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 py-3">

                <div class="rounded-3 p-2" style="background:#f3e5f5;">
                    <i class="bi bi-layers-fill fs-5"
                       style="color:#9c27b0;"></i>
                </div>

                <div>
                    <div class="fw-bold fs-4 lh-1">
                        @Model.Count
                    </div>

                    <small class="text-muted">Total</small>
                </div>

            </div>
        </div>
    </div>

</div>

<!-- ── FILTER CARD ─────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">

    <div class="card-body py-3">

        <form method="get"
              action="@Url.Action("Batches", "Admin")"
              id="filterForm">

            <div class="row g-2 align-items-end">

                <div class="col-12 col-md-3">
                    <label class="form-label small text-muted mb-1">
                        Collection Center
                    </label>

                    <select name="centerId"
                            class="form-select form-select-sm">

                        <option value="">All Centers</option>

                        @foreach (var c in (List<DairyIndustry.Models.Admin.CollectionCenterModel>)ViewBag.Centers)
                        {
                            if (ViewBag.CenterId != null &&
                            (int)ViewBag.CenterId == c.CenterId)
                            {
                                <option value="@c.CenterId" selected>
                                    @c.CenterName
                                </option>
                            }
                            else
                            {
                                <option value="@c.CenterId">
                                    @c.CenterName
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small text-muted mb-1">
                        Status
                    </label>

                    <select name="status"
                            class="form-select form-select-sm">

                        <option value="">All Status</option>

                        @foreach (var s in new[] { "Open", "Closed", "Dispatched", "Cancelled" })
                        {
                            if (ViewBag.Status?.ToString() == s)
                            {
                                <option value="@s" selected>
                                    @s
                                </option>
                            }
                            else
                            {
                                <option value="@s">
                                    @s
                                </option>
                            }
                        }

                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small text-muted mb-1">
                        From Date
                    </label>

                    <input type="date"
                           name="fromDate"
                           class="form-control form-control-sm"
                           value="@ViewBag.FromDate"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small text-muted mb-1">
                        To Date
                    </label>

                    <input type="date"
                           name="toDate"
                           class="form-control form-control-sm"
                           value="@ViewBag.ToDate"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-6 col-md-3 d-flex gap-2">

                    <button type="submit"
                            class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-funnel me-1"></i>
                        Filter
                    </button>

                    <a href="@Url.Action("Batches", "Admin")"
                       class="btn btn-outline-secondary btn-sm px-3">
                        <i class="bi bi-x-lg"></i>
                    </a>

                </div>

            </div>

        </form>

    </div>

</div>

<!-- ── BATCHES TABLE ───────────────────────────────────── -->
<div class="card border-0 shadow-sm">

    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">

        <span class="fw-semibold text-dark">
            <i class="bi bi-table me-2 text-muted"></i>

            Batches

            <span class="badge bg-light text-dark border ms-1">
                @Model.Count
            </span>
        </span>

        <small class="text-muted d-none d-md-inline">
            Click a row to view collections
        </small>

    </div>

    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">

            <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>

            <p class="mt-3 text-muted mb-0">
                No batches found for the selected filters.
            </p>

            <a href="@Url.Action("Batches", "Admin")"
               class="btn btn-sm btn-outline-primary mt-3">
                Clear Filters
            </a>

        </div>
    }
    else
    {
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0"
                   id="batchTable">

                <thead class="table-light">
                    <tr>
                        <th class="ps-3" style="width:70px;">#</th>
                        <th>Center</th>
                        <th>Shift</th>
                        <th>Date</th>
                        <th class="text-end">Total Qty (L)</th>
                        <th class="text-center">Avg Fat</th>
                        <th class="text-center">Avg CLR</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var batch in Model)
                    {
                        <tr class="batch-row"
                            role="button"
                            onclick="window.location='@Url.Action("BatchDetail", "Admin", new { id = batch.BatchId })'">

                            <td class="ps-3 text-muted small">
                                @batch.BatchId
                            </td>

                            <td>
                                <span class="fw-medium">
                                    @batch.CenterName
                                </span>
                            </td>

                            <td>

                                @{
                                    string shiftClass = "bg-dark";
                                    string shiftIcon = "bi-moon-stars";

                                    if (batch.Shift == "Morning")
                                    {
                                        shiftClass = "bg-warning text-dark";
                                        shiftIcon = "bi-sunrise";
                                    }
                                    else if (batch.Shift == "Evening")
                                    {
                                        shiftClass = "bg-info text-dark";
                                        shiftIcon = "bi-sunset";
                                    }
                                }

                                <span class="badge rounded-pill @shiftClass">
                                    <i class="bi @shiftIcon me-1"></i>
                                    @batch.Shift
                                </span>

                            </td>

                            <td class="text-muted small">
                                @batch.BatchDate.ToString("dd MMM yyyy")
                            </td>

                            <td class="text-end fw-medium">

                                @if (batch.TotalQuantity.HasValue)
                                {
                                    @batch.TotalQuantity.Value.ToString("N1")
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }

                            </td>

                            <td class="text-center small">
                                @(batch.AvgFat.HasValue
                                    ? batch.AvgFat.Value.ToString("F2")
                                    : "—")
                            </td>

                            <td class="text-center small">
                                @(batch.AvgCLR.HasValue
                                    ? batch.AvgCLR.Value.ToString("F2")
                                    : "—")
                            </td>

                            <td class="text-center">

                                @{
                                    string bg = "secondary";
                                    string icon = "bi-question-circle";

                                    switch (batch.Status)
                                    {
                                        case "Open":
                                            bg = "success";
                                            icon = "bi-circle-fill";
                                            break;

                                        case "Closed":
                                            bg = "warning";
                                            icon = "bi-lock-fill";
                                            break;

                                        case "Dispatched":
                                            bg = "primary";
                                            icon = "bi-truck";
                                            break;

                                        case "Cancelled":
                                            bg = "danger";
                                            icon = "bi-x-circle-fill";
                                            break;
                                    }
                                }

                                <span class="badge bg-@bg-subtle text-@bg border border-@bg-subtle px-2 py-1">
                                    <i class="bi @icon me-1"
                                       style="font-size:0.6rem;"></i>

                                    @batch.Status
                                </span>

                            </td>

                            <td class="text-center pe-3"
                                onclick="event.stopPropagation()">

                                <div class="d-flex justify-content-center gap-1">

                                    <a href="@Url.Action("BatchDetail", "Admin", new { id = batch.BatchId })"
                                       class="btn btn-outline-secondary btn-sm"
                                       title="View Detail">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (batch.Status == "Open")
                                    {
                                        <button type="button"
                                                class="btn btn-outline-warning btn-sm"
                                                title="Close Batch"
                                                onclick="confirmClose(
                                                    @batch.BatchId,
                                                    '@batch.CenterName',
                                                    '@batch.Shift',
                                                    '@batch.BatchDate.ToString("dd MMM yyyy")'
                                                )">
                                            <i class="bi bi-lock"></i>
                                        </button>
                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>

@section Scripts {

    <script>

        // ── Open Batch Form Validation ───────────────────────
        document
            .getElementById('openBatchForm')
            .addEventListener('submit', function (e) {

                let valid = true;

                const center = document.getElementById('ob_centerId');
                const date = document.getElementById('ob_batchDate');
                const shift = document.querySelector('input[name="shift"]:checked');
                const shiftErr = document.getElementById('shiftError');

                center.classList.toggle('is-invalid', !center.value);
                date.classList.toggle('is-invalid', !date.value);

                if (!center.value || !date.value) {
                    valid = false;
                }

                if (!shift) {
                    shiftErr.classList.remove('d-none');
                    valid = false;
                }
                else {
                    shiftErr.classList.add('d-none');
                }

                if (!valid) {
                    e.preventDefault();
                }
            });

        // ── Filter Date Validation ───────────────────────────
        document
            .getElementById('filterForm')
            .addEventListener('submit', function (e) {

                const from = document.querySelector('[name="fromDate"]').value;
                const to = document.querySelector('[name="toDate"]').value;

                if (from && to && from > to) {
                    alert('From Date cannot be after To Date.');
                    e.preventDefault();
                }
            });

        // ── Close Batch Modal ────────────────────────────────
        function confirmClose(batchId, center, shift, date) {

            document.getElementById('closeBatchId').value = batchId;

            document.getElementById('closeBatchInfo').textContent =
                center + ' · ' + shift + ' · ' + date;

            new bootstrap.Modal(
                document.getElementById('closeBatchModal')
            ).show();
        }

        // ── Pointer Cursor ───────────────────────────────────
        document.querySelectorAll('.batch-row').forEach(row => {
            row.style.cursor = 'pointer';
        });

    </script>
}