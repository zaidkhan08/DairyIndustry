@{
    Layout = null;
    ViewData["Title"] = "Verify OTP";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DMS | Verify OTP</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-bg {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
}

        .input-focus:focus {
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
}

        .btn-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.3);
}

        .transition-all {
            transition: all 0.3s ease;
        }

        .floating {
            animation: floating 3s ease-in-out infinite;
        }

        @@keyframes floating {
            0%

        {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }

        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 0.5rem;
            padding: 0.6rem 0.9rem;
            font-size: 0.85rem;
        }

        .email-badge {
            display: inline-block;
            background: #eff6ff;
            color: #2563eb;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
        }

        .otp-input {
            width: 48px;
            height: 56px;
            text-align: center;
            font-size: 1.4rem;
            font-weight: 700;
            color: #1f2937;
            border: 1.5px solid #d1d5db;
            border-radius: 0.5rem;
            background: #f8fafc;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .otp-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
                background: #fff;
            }

        #countdown {
            font-weight: 700;
            color: #2563eb;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <main class="w-full">
        <div class="max-w-6xl w-full mx-auto bg-white rounded-xl shadow-xl overflow-hidden flex flex-col md:flex-row">

            <!-- Left Side - Branding -->
            <div class="w-full md:w-1/2 gradient-bg text-white p-10 flex flex-col justify-center items-center">
                <div class="text-center mb-8">
                    <h1 class="text-4xl font-bold mb-2">Verify OTP</h1>
                    <p class="text-white/80">Enter the code we sent you to continue to DMS.</p>
                </div>
                <div class="relative w-full max-w-xs">
                    <img src="~/uploads/Logo/bookcover.png" alt="OTP Illustration" class="w-full h-auto floating" />
                </div>
            </div>

            <!-- Right Side - OTP Form -->
            <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">
                <div class="text-center mb-8">
                    <div class="mb-4 flex justify-center">
                        <img alt="logo" src="~/uploads/Logo/logo.png" class="h-12" />
                    </div>
                    <h1 class="text-3xl font-bold text-gray-800 mb-2">Verify OTP</h1>
                    <p class="text-sm text-gray-500 mb-2">OTP sent to</p>
                    <span class="email-badge">@ViewBag.MaskedEmail</span>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert-danger mb-4 text-center">@ViewBag.Error</div>
                }

                <form method="post" action="/Admin/VerifyOtp" id="otpForm" class="space-y-6">
                    <input type="hidden" name="otpCode" id="otpCode" />

                    <div class="flex justify-center gap-2">
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                        <input type="text" maxlength="1" class="otp-input" inputmode="numeric" pattern="[0-9]" autocomplete="off" />
                    </div>

                    <div class="flex items-center justify-center gap-2 text-sm text-gray-500">
                        <input type="checkbox" name="rememberDevice" id="rememberDevice" value="true" class="accent-[#2563eb] w-4 h-4 cursor-pointer" />
                        <label for="rememberDevice" class="cursor-pointer">Trust this device for 30 days</label>
                    </div>

                    <div>
                        <button type="submit"
                                class="w-full gradient-bg text-white py-3 px-4 rounded-lg font-medium hover:opacity-90 btn-hover transition-all">
                            VERIFY
                        </button>
                    </div>
                </form>

                <div class="mt-6 text-center text-sm text-gray-500">
                    OTP expires in <span id="countdown">10:00</span> &nbsp;|&nbsp;
                    <a href="/Admin/ResendOtp" class="text-[#2563eb] font-semibold hover:underline">Resend OTP</a>
                </div>

                <div class="mt-4 text-center">
                    <a href="/Admin/Login" class="text-sm text-gray-500 hover:text-[#2563eb]">← Back to login</a>
                </div>
            </div>
        </div>
    </main>

    <script>
        // ── Auto-focus next box on input ──
        const inputs = document.querySelectorAll('.otp-input');

        inputs.forEach((input, i) => {
            input.addEventListener('input', () => {
                input.value = input.value.replace(/[^0-9]/g, '');
                if (input.value && i < inputs.length - 1)
                    inputs[i + 1].focus();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !input.value && i > 0)
                    inputs[i - 1].focus();
            });

            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pasted = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
                [...pasted].slice(0, 6).forEach((char, j) => {
                    if (inputs[j]) inputs[j].value = char;
                });
                const next = Math.min(pasted.length, 5);
                inputs[next].focus();
            });
        });

        // ── On submit: join 6 boxes into hidden input ──
        document.getElementById('otpForm').addEventListener('submit', (e) => {
            const joined = [...inputs].map(i => i.value).join('');
            if (joined.length < 6) {
                e.preventDefault();
                alert('Please enter all 6 digits.');
                return;
            }
            document.getElementById('otpCode').value = joined;
        });

        // ── Countdown timer (10 min) ──
        let total = 10 * 60;
        const el = document.getElementById('countdown');

        const timer = setInterval(() => {
            total--;
            const m = String(Math.floor(total / 60)).padStart(2, '0');
            const s = String(total % 60).padStart(2, '0');
            el.textContent = `${m}:${s}`;
            if (total <= 0) {
                clearInterval(timer);
                el.textContent = 'Expired';
                el.style.color = '#dc2626';
            }
        }, 1000);

        // ── Focus first box on load ──
        inputs[0].focus();
    </script>
</body>
</html>