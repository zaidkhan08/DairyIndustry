@model DairyIndustry.Models.Admin.UserProfileVM

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h3 class="fw-bold mb-0">My Profile</h3>
            <p class="text-muted mb-0">View your personal information</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <div class="row g-4">

                <!-- LEFT SIDE -->
                <div class="col-md-4 text-center border-end">

                    <!-- Profile Image -->
                    @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                    {
                        <img src="@Url.Content("~/" + Model.ProfilePhoto.TrimStart('/'))"
                             class="rounded-circle border shadow"
                             width="140" height="140"
                             style="object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto shadow"
                             style="width:140px; height:140px;">
                            <span class="text-white fs-2 fw-bold">
                                @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName[0])
                            </span>
                        </div>
                    }

                    <h4 class="mt-3 mb-0">@Model.FullName</h4>
                    <span class="badge bg-primary mt-1">@Model.RoleName</span>

                    <div class="mt-3">
                        <span class="badge bg-success px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i> Active
                        </span>
                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-md-8">

                    <h5 class="fw-semibold mb-3 border-bottom pb-2">
                        <i class="bi bi-person me-1"></i> Profile Details
                    </h5>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Username</div>
                        <div class="col-sm-8 fw-semibold">@Model.Username</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Email</div>
                        <div class="col-sm-8">
                            <i class="bi bi-envelope me-1 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Phone</div>
                        <div class="col-sm-8">
                            <i class="bi bi-telephone me-1 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)
                        </div>
                    </div>

                    <!-- ✅ FIXED HERE -->
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Joining Date</div>
                        <div class="col-sm-8">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>
                            @(Model.DOJ != null ? Model.DOJ.Value.ToString("dd MMM yyyy") : "—")
                        </div>
                    </div>

                    <!-- Salary -->
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Salary</div>
                        <div class="col-sm-8 fw-semibold text-success">
                            @(Model.Salary != null ? "₹ " + Model.Salary.Value.ToString("N0") : "—")
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="mt-4 d-flex gap-2">

                        <a href="#" class="btn btn-primary">
                            <i class="bi bi-pencil-square me-1"></i> Edit Profile
                        </a>

                        <a href="#" class="btn btn-outline-secondary">
                            <i class="bi bi-key me-1"></i> Change Password
                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>