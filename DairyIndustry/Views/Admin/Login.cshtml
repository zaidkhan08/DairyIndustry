@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DMS | Login Page</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        }
        .input-focus:focus {
            box-shadow: 0 0 0 3px rgba(150, 45, 144, 0.3);
        }

        .btn-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.3);
        }

        .transition-all {
            transition: all 0.3s ease;
        }

        .floating {
            animation: floating 3s ease-in-out infinite;
        }

        @@keyframes floating {
            0%
            {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-15px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 0.5rem;
            padding: 0.6rem 0.9rem;
            font-size: 0.85rem;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <main class="w-full">
        <div class="max-w-6xl w-full mx-auto bg-white rounded-xl shadow-xl overflow-hidden flex flex-col md:flex-row">

            <!-- Left Side - Branding -->
            <div class="w-full md:w-1/2 gradient-bg text-white p-10 flex flex-col justify-center items-center">
                <div class="text-center mb-8">
                    <h1 class="text-4xl font-bold mb-2">Welcome to DMS</h1>
                    <p class="text-white/80">A product designed to manage the farm's daily operations and dairy production.</p>
                </div>
                <div class="relative w-full max-w-xs">
                    <img src="~/uploads/Logo/bookcover.png" alt="Login Illustration" class="w-full h-auto floating" />
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">
                <div class="text-center mb-8">
                    <div class="mb-4 flex justify-center">
                        <img alt="logo" src="~/uploads/Logo/logo.png" class="h-12" />
                    </div>
                    <h1 class="text-3xl font-bold text-gray-800 mb-2">Sign In To DMS</h1>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert-danger mb-4 text-center">@ViewBag.Error</div>
                }

                <form class="space-y-6" method="post" action="/Admin/Login">

                    <div class="space-y-1">
                        <label for="username" class="block text-sm font-medium text-gray-700">Username</label>
                        <input class="form-control w-full border border-gray-300 rounded-lg px-4 py-3 outline-none transition-all input-focus"
                               type="text" placeholder="Username" name="username" autocomplete="off" required />
                    </div>

                    <div class="space-y-1">
                        <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
                        <input class="form-control w-full border border-gray-300 rounded-lg px-4 py-3 outline-none transition-all input-focus"
                               type="password" placeholder="Password" name="password" required />
                    </div>

                    <div>
                        <button id="m_login_signin_submit" type="submit"
                                class="w-full gradient-bg text-white py-3 px-4 rounded-lg font-medium hover:opacity-90 btn-hover transition-all">
                            Sign In
                        </button>
                    </div>
                </form>

                <div class="mt-8">
                    <div class="relative">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-gray-300"></div>
                        </div>
                        <div class="relative flex justify-center text-sm">
                            <span class="px-2 bg-white text-gray-500">Connect with us as</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <a asp-area="" asp-controller="Logistics" asp-action="RegisterDriver" class="text-sm text-gray-500 hover:text-[#2563eb]">
                        <i class="bi bi-people"></i> Driver ||
                    </a>
                    <a asp-area="" asp-controller="DistributorRegister" asp-action="Index" class="text-sm text-gray-500 hover:text-[#2563eb]">
                        <i class="bi bi-people"></i> Distributor ||
                    </a>
                    <a asp-area="" asp-controller="Farmer" asp-action="FarmerSelfRegistration" class="text-sm text-gray-500 hover:text-[#2563eb]">
                        <i class="bi bi-people"></i> Farmer
                    </a>
                </div>
            </div>
        </div>
    </main>

</body>
</html>