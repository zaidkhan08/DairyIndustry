@model List<DairyIndustry.Models.Admin.PlantModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Processing Plants";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Processing Plants</h3>
                <p class="text-muted mb-0">View and manage all milk processing plants</p>
            </div>
            <a asp-controller="Admin" asp-action="AddPlant" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Add New Plant
            </a>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Total Plants</p>
                            <h4 class="fw-bold mb-0">@Model.Count</h4>
                        </div>
                        <i class="bi bi-building-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Active Plants</p>
                            <h4 class="fw-bold mb-0">@Model.Count</h4>
                        </div>
                        <i class="bi bi-check-circle-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Locations Covered</p>
                            <h4 class="fw-bold mb-0">
                                @Model.Select(p => p.Location).Distinct().Count()
                            </h4>
                        </div>
                        <i class="bi bi-geo-alt-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Plants Table -->
    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-building me-1"></i> All Processing Plants
                    </span>
                    <span class="badge bg-primary">Total: @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>Plant ID</th>
                                    <th>Plant Name</th>
                                    <th>Location</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                                            <span class="fw-semibold">No processing plants found.</span><br />
                                            <small>Click "Add New Plant" to register one.</small>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    @foreach (var plant in Model)
                                    {
                                        <tr>
                                            <!-- Serial -->
                                            <td class="ps-3 text-muted small">@sr</td>

                                            <!-- Plant ID Badge -->
                                            <td>
                                                <span class="badge bg-secondary">
                                                    #@plant.PlantId
                                                </span>
                                            </td>

                                            <!-- Plant Name with Icon -->
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div style="width:36px; height:36px;
                                                                        border-radius:8px;
                                                                        background:#eff6ff;
                                                                        display:flex;
                                                                        align-items:center;
                                                                        justify-content:center;
                                                                        flex-shrink:0;">
                                                        <i class="bi bi-building-fill text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold small">@plant.PlantName</div>
                                                        <div class="text-muted" style="font-size:11px;">
                                                            Processing Plant
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>

                                            <!-- Location -->
                                            <td>
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                                    @plant.Location
                                                </span>
                                            </td>

                                            <!-- Actions -->
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center gap-2">

                                                    <!-- Edit Button -->
                                                    <a asp-controller="Admin"
                                                       asp-action="EditPlant"
                                                       asp-route-id="@plant.PlantId"
                                                       class="btn btn-sm btn-outline-warning"
                                                       title="Edit Plant">
                                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                                    </a>

                                                    <!-- Delete Button -->
                                                    @* <form asp-controller="Admin"
                                                          asp-action="DeletePlant"
                                                          asp-route-id="@plant.PlantId"
                                                          method="post"
                                                          class="d-inline"
                                                          onsubmit="return confirm('Are you sure you want to delete @plant.PlantName?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-danger"
                                                                title="Delete Plant">
                                                            <i class="bi bi-trash me-1"></i> Delete
                                                        </button>
                                                    </form> *@

                                                </div>
                                            </td>

                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer bg-white text-muted small d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-info-circle me-1"></i>
                        @Model.Count plant(s) registered in the system
                    </span>
                    <a asp-controller="Admin"
                       asp-action="AddPlant"
                       class="text-primary text-decoration-none small">
                        <i class="bi bi-plus-circle me-1"></i> Add New Plant
                    </a>
                </div>

            </div>
        </div>
    </div>

</div>