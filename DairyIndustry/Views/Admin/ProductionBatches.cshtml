@model List<DairyIndustry.Models.Admin.ProductionBatchModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Production Batches";

    var plants = ViewBag.Plants as List<DairyIndustry.Models.Admin.PlantModel> ?? new List<DairyIndustry.Models.Admin.PlantModel>();
    var products = ViewBag.Products as List<DairyIndustry.Models.Admin.ProductModel> ?? new List<DairyIndustry.Models.Admin.ProductModel>();
}

<div class="container mt-4">

    <!-- Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Production Batches</h3>
                <p class="text-muted mb-0">Track all production batch activity</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }

    <!-- Stats -->
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Total Batches</p>
                        <h4 class="fw-bold mb-0">@Model.Count</h4>
                    </div>
                    <i class="bi bi-layers-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">In Progress</p>
                        <h4 class="fw-bold mb-0">@Model.Count(b => b.BatchStatus == "InProgress")</h4>
                    </div>
                    <i class="bi bi-hourglass-split fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">Completed</p>
                        <h4 class="fw-bold mb-0">@Model.Count(b => b.BatchStatus == "Completed")</h4>
                    </div>
                    <i class="bi bi-check-circle-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 small">QC Failed / Cancelled</p>
                        <h4 class="fw-bold mb-0">@Model.Count(b => b.BatchStatus == "QCFailed" || b.BatchStatus == "Cancelled")</h4>
                    </div>
                    <i class="bi bi-x-circle-fill fs-2 opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-controller="Admin" asp-action="ProductionBatches"
                  class="row g-3 align-items-end">

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Plant</label>
                    <select name="plantId" class="form-select">
                        <option value="">All Plants</option>
                        @foreach (var plant in plants)
                        {
                            <option value="@plant.PlantId"
                                    selected="@(ViewBag.PlantId?.ToString() == plant.PlantId.ToString() ? "selected" : null)">
                                @plant.PlantName
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Product</label>
                    <select name="productId" class="form-select">
                        <option value="">All Products</option>
                        @foreach (var product in products)
                        {
                            <option value="@product.ProductId"
                                    selected="@(ViewBag.ProductId?.ToString() == product.ProductId.ToString() ? "selected" : null)">
                                @product.ProductName
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="batchStatus" class="form-select">
                        <option value="" selected="@(ViewBag.BatchStatus == null ? "selected" : null)">All</option>
                        <option value="InProgress" selected="@(ViewBag.BatchStatus == "InProgress" ? "selected" : null)">In Progress</option>
                        <option value="Completed" selected="@(ViewBag.BatchStatus == "Completed" ? "selected" : null)">Completed</option>
                        <option value="QCFailed" selected="@(ViewBag.BatchStatus == "QCFailed" ? "selected" : null)">QC Failed</option>
                        <option value="Cancelled" selected="@(ViewBag.BatchStatus == "Cancelled" ? "selected" : null)">Cancelled</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">From Date</label>
                    <input type="date" name="fromDate" class="form-control"
                           value="@ViewBag.FromDate" />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">To Date</label>
                    <input type="date" name="toDate" class="form-control"
                           value="@ViewBag.ToDate" />
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                    <a asp-controller="Admin" asp-action="ProductionBatches"
                       class="btn btn-outline-secondary">Clear</a>
                </div>

            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-layers me-1"></i> All Production Batches</span>
            <span class="badge bg-primary">Total : @Model.Count</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Batch ID</th>
                            <th>Product</th>
                            <th>Plant</th>
                            <th>Milk Used</th>
                            <th>Production Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No production batches found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int sr = 1;
                            foreach (var b in Model)
                            {
                                <tr>
                                    <td>@sr</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            #@b.ProductionBatchId
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">@b.ProductName</div>
                                        <div class="text-muted" style="font-size:11px;">@b.ProductType — @b.Unit</div>
                                    </td>
                                    <td>
                                        <small><i class="bi bi-building me-1 text-muted"></i>@b.PlantName</small>
                                    </td>
                                    <td>
                                        <small><i class="bi bi-droplet me-1 text-muted"></i>@b.MilkUsedQuantity.ToString("0.00") L</small>
                                    </td>
                                    <td>
                                        <small><i class="bi bi-calendar3 me-1 text-muted"></i>@b.ProductionDate.ToString("dd MMM yyyy")</small>
                                    </td>
                                    <td>
                                        @{
                                            string statusBadge = b.BatchStatus switch
                                            {
                                                "InProgress" => "bg-warning text-dark",
                                                "Completed" => "bg-success",
                                                "QCFailed" => "bg-danger",
                                                "Cancelled" => "bg-secondary",
                                                _ => "bg-light text-dark"
                                            };
                                        }
                                        <span class="badge @statusBadge">@b.BatchStatus</span>
                                    </td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white text-muted small d-flex justify-content-between">
            <span>
                Total: @Model.Count |
                In Progress: @Model.Count(b => b.BatchStatus == "InProgress") |
                Completed: @Model.Count(b => b.BatchStatus == "Completed") |
                Failed/Cancelled: @Model.Count(b => b.BatchStatus == "QCFailed" || b.BatchStatus == "Cancelled")
            </span>
            <span>Milk Used: @Model.Sum(b => b.MilkUsedQuantity).ToString("0.00") L</span>
        </div>
    </div>

</div>