@model DairyIndustry.Models.Finance.CenterPaymentModel
@{
    ViewData["Title"] = $"Payment Details — CP-{Model.CenterPaymentId:D4}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Using Admin as per previous context, change to Production if required

    bool isPending = Model.PaymentStatus == "Pending";
    bool isProcessed = Model.PaymentStatus == "Processed";
    bool isFailed = Model.PaymentStatus == "Failed";
    bool isCancelled = Model.PaymentStatus == "Cancelled";

    string statusPill = Model.PaymentStatus switch
    {
        "Processed" => "bg-success-subtle text-success border-success-subtle",
        "Pending" => "bg-warning-subtle text-warning border-warning-subtle",
        "Failed" => "bg-danger-subtle text-danger border-danger-subtle",
        _ => "bg-secondary-subtle text-secondary border-secondary-subtle"
    };
}

<div class="container-fluid p-4">

    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-action="CenterPayments" class="text-decoration-none fw-medium">Center Payments</a></li>
            <li class="breadcrumb-item active font-monospace">CP-@Model.CenterPaymentId.ToString("D4")</li>
        </ol>
    </nav>

    <div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold text-dark mb-1" style="letter-spacing: -0.5px;">Voucher CP-@Model.CenterPaymentId.ToString("D4")</h4>
            <p class="text-muted small mb-0">
                @Model.CenterName <i class="bi bi-dot"></i> @Model.PlantName <i class="bi bi-dot"></i> @Model.PaymentDate.ToString("dd MMM yyyy")
            </p>
        </div>
        <div class="badge rounded-pill border px-3 py-2 d-flex align-items-center gap-2 @statusPill">
            <i class="bi bi-circle-fill" style="font-size: 6px;"></i>
            <span class="fw-bold text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">@Model.PaymentStatus</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-light border-0 py-3 px-4 d-flex align-items-center gap-2">
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3" style="line-height: 1;">
                        <i class="bi bi-building"></i>
                    </div>
                    <h6 class="mb-0 fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Transfer & Center Details</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-6">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 10px;">Transfer Reference</small>
                            <span class="fw-bold font-monospace text-dark">@Model.BatchRef</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 10px;">Payment Date</small>
                            <span class="fw-semibold text-dark">@Model.PaymentDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 10px;">Collection Center</small>
                            <span class="fw-semibold text-dark">@Model.CenterName</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 10px;">Processing Plant</small>
                            <span class="fw-semibold text-dark">@Model.PlantName</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-light border-0 py-3 px-4 d-flex align-items-center gap-2">
                    <div class="bg-info bg-opacity-10 text-info p-2 rounded-3" style="line-height: 1;">
                        <i class="bi bi-droplet-half"></i>
                    </div>
                    <h6 class="mb-0 fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Quality & Rate</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="p-3 bg-primary bg-opacity-10 rounded-3 text-center border border-primary border-opacity-10">
                                <small class="text-primary text-uppercase fw-bold d-block mb-2" style="font-size: 10px;">Received Qty</small>
                                <h4 class="fw-bold mb-0 font-monospace">@Model.ReceivedQty.ToString("N1")</h4>
                                <small class="text-muted" style="font-size: 10px;">Litres</small>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 bg-light rounded-3 text-center border">
                                <small class="text-muted text-uppercase fw-bold d-block mb-2" style="font-size: 10px;">Tested Fat</small>
                                <h4 class="fw-bold mb-0 font-monospace">@(Model.TestedFat?.ToString("N2") ?? "—")</h4>
                                <small class="text-muted" style="font-size: 10px;">% Content</small>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 bg-light rounded-3 text-center border">
                                <small class="text-muted text-uppercase fw-bold d-block mb-2" style="font-size: 10px;">Tested CLR</small>
                                <h4 class="fw-bold mb-0 font-monospace">@(Model.TestedCLR?.ToString("N2") ?? "—")</h4>
                                <small class="text-muted" style="font-size: 10px;">Reading</small>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 bg-success bg-opacity-10 rounded-3 text-center border border-success border-opacity-10">
                                <small class="text-success text-uppercase fw-bold d-block mb-2" style="font-size: 10px;">Rate / L</small>
                                <h4 class="fw-bold mb-0 font-monospace text-success">₹@Model.RatePerLiter.ToString("N2")</h4>
                                <small class="text-muted" style="font-size: 10px;">Applied</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4 text-white" style="background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-white text-opacity-75 text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 1px;">Net Payable Amount</small>
                        <div class="small text-white text-opacity-50 mt-1">@Model.ReceivedQty.ToString("N2") L × ₹@Model.RatePerLiter.ToString("N2")/L</div>
                    </div>
                    <div class="text-end">
                        <h2 class="fw-bold mb-0 font-monospace">₹@Model.TotalAmount.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            @if (Model.BankStatus != null)
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-0 py-3 px-4 d-flex align-items-center gap-2">
                        <div class="bg-success bg-opacity-10 text-success p-2 rounded-3" style="line-height: 1;">
                            <i class="bi bi-bank"></i>
                        </div>
                        <h6 class="mb-0 fw-bold small text-uppercase">Payment Gateway Details</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item d-flex justify-content-between px-4 py-3">
                                <span class="text-muted fw-medium">Gateway Status</span>
                                <span class="fw-bold @(Model.BankStatus == "Success" ? "text-success" : "text-danger")">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Model.BankStatus
                                </span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-4 py-3">
                                <span class="text-muted fw-medium">Stripe Reference</span>
                                <span class="fw-bold font-monospace text-dark text-break ps-5 text-end">@Model.TransactionReference</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-4 py-3">
                                <span class="text-muted fw-medium">Service Provider</span>
                                <span class="fw-bold text-dark">Stripe Payments</span>
                            </li>
                        </ul>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="sticky-top" style="top: 1.5rem; z-index: 10;">
                <div class="card border-0 shadow-md rounded-4 overflow-hidden">
                    <div class="card-header bg-dark border-0 py-3 px-4">
                        <h6 class="mb-0 fw-bold text-white small text-uppercase"><i class="bi bi-lightning-charge me-2"></i>Available Actions</h6>
                    </div>
                    <div class="card-body p-4 text-center">

                        @if (isPending || isFailed)
                        {
                            <i class="bi @(isPending ? "bi-hourglass-split text-warning" : "bi-exclamation-octagon text-danger") display-4 mb-3"></i>
                            <h5 class="fw-bold text-dark">@(isPending ? "Ready for Payment" : "Transaction Failed")</h5>
                            <p class="text-muted small mb-4">Click below to securely process this transfer payment via Stripe gateway.</p>

                            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 text-start mb-4 border border-primary border-opacity-10">
                                <div class="d-flex gap-2">
                                    <i class="bi bi-shield-lock-fill"></i>
                                    <span class="small fw-medium">Secured by Stripe. Status updates automatically upon confirmation.</span>
                                </div>
                            </div>

                            <form asp-action="CreateCenterCheckoutSession" method="post" class="d-grid gap-2">
                                <input type="hidden" name="centerPaymentId" value="@Model.CenterPaymentId" />
                                <input type="hidden" name="totalAmount" value="@Model.TotalAmount" />
                                <input type="hidden" name="centerName" value="@Model.CenterName" />
                                <button type="submit" class="btn btn-success py-3 fw-bold shadow-sm rounded-3">
                                    <i class="bi bi-stripe me-2"></i> Pay ₹@Model.TotalAmount.ToString("N2")
                                </button>
                            </form>
                        }
                        else if (isProcessed)
                        {
                            <i class="bi bi-check-circle-fill text-success display-4 mb-3"></i>
                            <h5 class="fw-bold text-dark">Voucher Settled</h5>
                            <p class="text-muted small mb-4">This payment was completed successfully and the batch is closed for settlement.</p>
                        }
                        else if (isCancelled)
                        {
                            <i class="bi bi-slash-circle text-secondary display-4 mb-3"></i>
                            <h5 class="fw-bold text-dark">Voucher Void</h5>
                            <p class="text-muted small mb-4">This record has been cancelled and is no longer eligible for checkout.</p>
                        }

                        <hr class="my-4" />

                        <div class="d-grid gap-2">
                            <button class="btn btn-light border py-2 fw-semibold small" onclick="window.print()">
                                <i class="bi bi-printer me-2"></i> Print Invoice
                            </button>
                            <a asp-action="CenterPayments" class="btn btn-link text-decoration-none text-muted small py-2">
                                <i class="bi bi-arrow-left me-1"></i> Back to Payments List
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>