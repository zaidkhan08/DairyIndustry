@model List<DairyIndustry.Models.Finance.CenterPaymentModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Center Payments";

    // Summary logic
    int total = Model.Count;
    int processed = Model.Count(p => p.PaymentStatus == "Processed");
    int pending = Model.Count(p => p.PaymentStatus == "Pending");
    int cancelled = Model.Count(p => p.PaymentStatus == "Cancelled");
    decimal totalAmt = Model.Where(p => p.PaymentStatus != "Cancelled").Sum(p => p.TotalAmount);
}

<div class="container-fluid p-4">

    <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold text-dark mb-1" style="letter-spacing: -0.5px;">Center Payments</h4>
            <p class="text-muted small mb-0">Milk transfer payments to collection centers</p>
        </div>
        @* <a asp-action="CreateCenterPayment" class="btn btn-primary px-4 shadow-sm border-0 fw-semibold">
            <i class="bi bi-plus-lg me-1"></i> New Payment
        </a> *@
    </div>

    <div class="row g-3 mb-4">
        <div class="col">
            <div class="card border-0 shadow-sm border-top border-primary border-3">
                <div class="card-body p-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Total Records</small>
                    <h4 class="mb-0 fw-bold font-monospace">@total</h4>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm border-top border-success border-3">
                <div class="card-body p-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Processed</small>
                    <h4 class="mb-0 fw-bold font-monospace text-success">@processed</h4>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm border-top border-warning border-3">
                <div class="card-body p-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Pending</small>
                    <h4 class="mb-0 fw-bold font-monospace text-warning">@pending</h4>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm border-top border-secondary border-3">
                <div class="card-body p-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Cancelled</small>
                    <h4 class="mb-0 fw-bold font-monospace text-muted">@cancelled</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-top border-info border-3 bg-light">
                <div class="card-body p-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">Total Paid</small>
                    <h4 class="mb-0 fw-bold font-monospace text-primary">₹@totalAmt.ToString("N0")</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-3 px-4">
            <div class="row align-items-center g-3">
                <div class="col-md-3">
                    <h6 class="mb-0 fw-bold">All Payments <span class="badge bg-light text-dark border ms-2" id="visibleCount">@total</span></h6>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-1 overflow-auto pb-1" id="filterContainer">
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3 active" onclick="filterStatus('all', this)">All</button>
                        <button class="btn btn-sm btn-outline-success rounded-pill px-3" onclick="filterStatus('Processed', this)">Processed</button>
                        <button class="btn btn-sm btn-outline-warning rounded-pill px-3" onclick="filterStatus('Pending', this)">Pending</button>
                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="filterStatus('Failed', this)">Failed</button>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" id="cpSearch" class="form-control border-start-0 ps-1" placeholder="Search..." oninput="filterTable()">
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="border-0 ps-4">ID</th>
                            <th class="border-0">Transfer</th>
                            <th class="border-0">Center / Plant</th>
                            <th class="border-0 text-end">Qty (L)</th>
                            <th class="border-0 text-end">Rate</th>
                            <th class="border-0 text-end">Total (₹)</th>
                            <th class="border-0">Date</th>
                            <th class="border-0">Status</th>
                            <th class="border-0 text-center pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="cpTbody">
                        @foreach (var p in Model)
                        {
                            string statusClass = p.PaymentStatus switch
                            {
                                "Processed" => "bg-success",
                                "Pending" => "bg-warning text-dark",
                                "Failed" => "bg-danger",
                                "Cancelled" => "bg-secondary",
                                _ => "bg-light"
                            };

                            <tr data-status="@p.PaymentStatus" class="@(p.PaymentStatus == "Cancelled" ? "opacity-50" : "")">
                                <td class="ps-4 text-muted font-monospace">#@p.CenterPaymentId.ToString("D4")</td>
                                <td><span class="badge bg-light text-dark border font-monospace">@p.BatchRef</span></td>
                                <td>
                                    <div class="fw-bold">@p.CenterName</div>
                                    <div class="text-muted x-small">@p.PlantName</div>
                                </td>
                                <td class="text-end fw-semibold">@p.ReceivedQty.ToString("N1")</td>
                                <td class="text-end text-muted">₹@p.RatePerLiter.ToString("N2")</td>
                                <td class="text-end fw-bold text-primary">₹@p.TotalAmount.ToString("N0")</td>
                                <td><small class="text-muted">@p.PaymentDate.ToString("dd MMM yy")</small></td>
                                <td>
                                    <span class="badge rounded-pill @statusClass px-2 py-1" style="font-size: 10px;">
                                        @p.PaymentStatus
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="CenterPaymentDetail" asp-route-id="@p.CenterPaymentId" class="btn btn-sm btn-light border p-1" style="width: 28px;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @* @if (p.PaymentStatus == "Cancelled")
                                        {
                                            <button class="btn btn-sm btn-outline-primary py-0 px-2 fw-bold" style="font-size: 11px;" onclick="openRepay(@p.CenterPaymentId, '@p.BatchRef', @p.RatePerLiter, '@p.CenterName')">
                                                Re-pay
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger p-1" style="width: 28px;" onclick="openCancel(@p.CenterPaymentId, '@p.BatchRef', '@p.CenterName')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        } *@
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-exclamation-octagon fs-2"></i>
                </div>
                <h5 class="fw-bold mb-2">Cancel Payment?</h5>
                <p class="text-muted small" id="confirmMsg"></p>

                <form asp-action="CancelCenterPayment" method="post" class="mt-4">
                    <input type="hidden" name="centerPaymentId" id="cancelId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger py-2 fw-bold shadow-sm">Yes, Cancel Payment</button>
                        <button type="button" class="btn btn-light border py-2" data-bs-dismiss="modal">Keep It</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="repayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4">
                <div class="text-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-arrow-clockwise fs-2"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Re-activate Payment</h5>
                    <p class="text-muted small" id="repayMsg"></p>
                </div>

                <form asp-action="ReactivateCenterPayment" method="post" class="mt-3">
                    <input type="hidden" name="centerPaymentId" id="repayId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Adjust Rate (₹)</label>
                        <input type="number" name="ratePerLiter" id="repayRate" class="form-control form-control-lg fw-bold" step="0.01" />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary py-2 fw-bold shadow-sm">Confirm & Process</button>
                        <button type="button" class="btn btn-light border py-2" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const cancelModal = new bootstrap.Modal(document.getElementById('cancelModal'));
        const repayModal = new bootstrap.Modal(document.getElementById('repayModal'));

        function filterStatus(status, btn) {
            document.querySelectorAll('#filterContainer .btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const rows = document.querySelectorAll('#cpTbody tr');
            let count = 0;
            rows.forEach(r => {
                const match = (status === 'all' || r.dataset.status === status);
                r.style.display = match ? '' : 'none';
                if(match) count++;
            });
            document.getElementById('visibleCount').textContent = count;
        }

        function filterTable() {
            const q = document.getElementById('cpSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#cpTbody tr');
            rows.forEach(r => {
                const text = r.textContent.toLowerCase();
                r.style.display = text.includes(q) ? '' : 'none';
            });
        }

        function openCancel(id, ref, center) {
            document.getElementById('cancelId').value = id;
            document.getElementById('confirmMsg').textContent = `Are you sure you want to cancel the payment for ${center} (Batch: ${ref})?`;
            cancelModal.show();
        }

        function openRepay(id, ref, rate, center) {
            document.getElementById('repayId').value = id;
            document.getElementById('repayRate').value = rate;
            document.getElementById('repayMsg').textContent = `Re-processing payment for ${center}. You can update the rate below.`;
            repayModal.show();
        }
    </script>
}