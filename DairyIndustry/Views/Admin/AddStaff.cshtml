@model List<DairyIndustry.Models.Admin.RoleModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Staff";

    // ONLY these 4 roles are staff AND need login
    var loginRoles = new[] { "Administrator", "Plant Manager", "Collection Agent", "HR Manager" };
    var loginRolesJson = System.Text.Json.JsonSerializer.Serialize(loginRoles);

    // Roles that MUST be assigned to a Plant
    var plantRoles = new[] { "Plant Manager" };
    var plantRolesJson = System.Text.Json.JsonSerializer.Serialize(plantRoles);

    // Roles that MUST be assigned to a Center
    var centerRoles = new[] { "Collection Agent" };
    var centerRolesJson = System.Text.Json.JsonSerializer.Serialize(centerRoles);
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Add New Staff</h3>
                <p class="text-muted mb-0">Drivers, Farmers, and Distributors have separate registration</p>
            </div>
            <a asp-controller="Admin" asp-action="Staff" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Staff
            </a>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }

    <form method="post" asp-controller="Admin" asp-action="AddStaff" enctype="multipart/form-data">

        <div class="row g-4">

            <!-- ── PERSONAL DETAILS ─────────────────────────── -->
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-person me-1 text-primary"></i> Personal Details
                    </div>
                    <div class="card-body p-4">

                        <div class="mb-4 text-center">
                            <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center mx-auto mb-2 overflow-hidden"
                                 style="width:100px;height:100px;">
                                <img id="photoPreview" src="#" alt="Preview"
                                     class="w-100 h-100" style="object-fit:cover;display:none;" />
                                <i id="photoPlaceholder" class="bi bi-person-fill text-secondary fs-1"></i>
                            </div>
                            <label class="form-label fw-semibold d-block">
                                Profile Photo
                                <span class="text-muted fw-normal small">(Optional)</span>
                            </label>
                            <input type="file" name="profilePhoto" id="profilePhotoInput"
                                   class="form-control" accept=".jpg,.jpeg,.png"
                                   onchange="previewPhoto(this)" />
                            <div class="form-text">JPG or PNG — Max 2 MB</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                First Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="firstName" class="form-control"
                                   placeholder="Enter first name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Last Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="lastName" class="form-control"
                                   placeholder="Enter last name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Phone</label>
                            <input type="text" name="phone" class="form-control"
                                   placeholder="Enter phone number" maxlength="15" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Email
                                <span id="emailRequiredBadge" class="text-danger" style="display:none;">*</span>
                                <span id="emailOptionalBadge" class="text-muted fw-normal small">(Optional)</span>
                            </label>
                            <input type="email" name="email" id="emailInput"
                                   class="form-control" placeholder="Enter email address" />
                            <div id="emailHint" class="form-text" style="display:none;">
                                <i class="bi bi-info-circle me-1"></i>
                                OTP for 2-factor login will be sent to this email.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Role <span class="text-danger">*</span>
                            </label>
                            <select name="roleId" id="roleSelect" class="form-select"
                                    required onchange="onRoleChange()">
                                <option value="">-- Select Role --</option>
                                @foreach (var role in Model)
                                {
                                    <option value="@role.RoleId" data-name="@role.RoleName">
                                        @role.RoleName
                                    </option>
                                }
                            </select>
                            <!-- Role hint shown below dropdown -->
                            <div id="roleHintBox" class="mt-2" style="display:none;">
                                <span id="roleHintText" class="badge fs-6 px-3 py-2"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Date of Joining</label>
                            <input type="date" name="doj" class="form-control" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── BANK + SALARY ────────────────────────────── -->
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-bank me-1 text-success"></i> Bank Details
                        <span class="text-muted fw-normal small ms-1">(Optional)</span>
                    </div>
                    <div class="card-body p-4">

                        <div class="alert alert-info small mb-4">
                            <i class="bi bi-info-circle me-1"></i>
                            Bank details are needed for salary payments. You can add them later.
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Bank Name</label>
                            <input type="text" name="bankName" class="form-control"
                                   placeholder="e.g. SBI, HDFC, ICICI" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Account Number</label>
                            <input type="text" name="accountNumber" class="form-control"
                                   placeholder="Enter account number" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">IFSC Code</label>
                            <input type="text" name="ifscCode" class="form-control"
                                   placeholder="e.g. SBIN0001001" maxlength="20" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Salary (₹) <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="Salary" class="form-control"
                                   step="0.01" min="0" required placeholder="0.00" />
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- ── WORK ASSIGNMENT ─────────────────────────────── -->
        <div class="row g-4 mt-0">
            <div class="col-12">
                <div class="card shadow-sm border-0" id="assignmentCard">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-geo-alt me-1 text-warning"></i> Work Assignment
                    </div>
                    <div class="card-body p-4">

                        <!-- Shown when role FORCES a specific assignment -->
                        <div id="forcedAssignmentNote" class="alert alert-warning small mb-3" style="display:none;">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            <span id="forcedAssignmentText"></span>
                        </div>

                        <!-- Radio only shown for roles that have a choice -->
                        <div id="assignRadioGroup" class="mb-3">
                            <label class="form-label fw-semibold">Assign To</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="assignType"
                                           id="assignNone" value="none" checked
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label" for="assignNone">Not Assigned</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="assignType"
                                           id="assignCenter" value="center"
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label" for="assignCenter">Collection Center</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="assignType"
                                           id="assignPlant" value="plant"
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label" for="assignPlant">Plant</label>
                                </div>
                            </div>
                        </div>

                        <!-- Center dropdown -->
                        <div id="centerSection" style="display:none;" class="mb-3">
                            <label class="form-label fw-semibold">
                                Select Collection Center <span id="centerRequired" class="text-danger" style="display:none;">*</span>
                            </label>
                            <select name="centerId" id="centerSelect" class="form-select">
                                <option value="">-- Select Center --</option>
                                @if (ViewBag.Centers != null)
                                {
                                    foreach (var c in (ViewBag.Centers as List<DairyIndustry.Models.Admin.CollectionCenterModel>)!)
                                    {
                                        <option value="@c.CenterId">@c.CenterName</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Plant dropdown -->
                        <div id="plantSection" style="display:none;" class="mb-3">
                            <label class="form-label fw-semibold">
                                Select Plant <span id="plantRequired" class="text-danger" style="display:none;">*</span>
                            </label>
                            <select name="plantId" id="plantSelect" class="form-select">
                                <option value="">-- Select Plant --</option>
                                @if (ViewBag.Plants != null)
                                {
                                    foreach (var p in (ViewBag.Plants as List<DairyIndustry.Models.Admin.PlantModel>)!)
                                    {
                                        <option value="@p.PlantId">@p.PlantName</option>
                                    }
                                }
                            </select>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- ── LOGIN ACCOUNT ───────────────────────────────── -->
        <div class="row g-4 mt-0">
            <div class="col-12">
                <div id="userAccountSection" style="display:none;">
                    <div class="card shadow-sm border-0 border-start border-4 border-primary">
                        <div class="card-header bg-white fw-semibold border-bottom">
                            <i class="bi bi-shield-lock me-1 text-primary"></i> Login Account
                            <span class="badge bg-primary ms-2 small">Required for this role</span>
                        </div>
                        <div class="card-body p-4">

                            <div class="alert alert-warning small mb-4">
                                <i class="bi bi-info-circle me-1"></i>
                                <span id="loginAccountHint"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        Username <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" name="username" id="usernameInput"
                                           class="form-control" placeholder="e.g. rajesh.patel"
                                           autocomplete="off" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        Password <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input type="password" name="password" id="passwordInput"
                                               class="form-control" placeholder="Min 3 characters"
                                               autocomplete="new-password" minlength="3" />
                                        <button class="btn btn-outline-secondary" type="button"
                                                onclick="togglePasswordVisibility()">
                                            <i class="bi bi-eye" id="eyeIcon"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── SUBMIT ──────────────────────────────────────── -->
        <div class="row mt-4 mb-5">
            <div class="col">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-person-plus me-1"></i> Add Staff Member
                        </button>
                        <a asp-controller="Admin" asp-action="Staff"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        const LOGIN_ROLES  = @Html.Raw(loginRolesJson);   // roles that need login
        const PLANT_ROLES  = @Html.Raw(plantRolesJson);   // roles forced to plant
        const CENTER_ROLES = @Html.Raw(centerRolesJson);  // roles forced to center

        const ROLE_HINTS = {
            'Administrator':    'Admins can access all system features. They will log in with these credentials.',
            'Plant Manager':    'Plant Managers log in to manage production, transfers, and raw milk inventory at their assigned plant.',
            'Collection Agent': 'Collection Agents log in to record milk entries and manage batches at their assigned center.',
            'HR Manager':       'HR Managers log in to manage staff records, attendance, and payroll.'
        };

        function onRoleChange() {
            const select      = document.getElementById('roleSelect');
            const selectedOpt = select.options[select.selectedIndex];
            const roleName    = selectedOpt ? (selectedOpt.dataset.name || '').trim() : '';

            const needsLogin  = LOGIN_ROLES.includes(roleName);
            const forcePlant  = PLANT_ROLES.includes(roleName);
            const forceCenter = CENTER_ROLES.includes(roleName);

            // ── Login section ────────────────────────────────────
            const loginSection  = document.getElementById('userAccountSection');
            const usernameInput = document.getElementById('usernameInput');
            const passwordInput = document.getElementById('passwordInput');
            const hintEl        = document.getElementById('loginAccountHint');

            loginSection.style.display  = needsLogin ? 'block' : 'none';
            usernameInput.required       = needsLogin;
            passwordInput.required       = needsLogin;

            if (!needsLogin) {
                usernameInput.value = '';
                passwordInput.value = '';
            }

            hintEl.textContent = ROLE_HINTS[roleName] || '';

            // ── Email hint (login roles need email for OTP) ──────
            const emailHint         = document.getElementById('emailHint');
            const emailRequiredBadge = document.getElementById('emailRequiredBadge');
            const emailOptionalBadge = document.getElementById('emailOptionalBadge');

            emailHint.style.display          = needsLogin ? 'block' : 'none';
            emailRequiredBadge.style.display  = needsLogin ? 'inline' : 'none';
            emailOptionalBadge.style.display  = needsLogin ? 'none'   : 'inline';

            // ── Assignment section ───────────────────────────────
            const radioGroup      = document.getElementById('assignRadioGroup');
            const forcedNote      = document.getElementById('forcedAssignmentNote');
            const forcedText      = document.getElementById('forcedAssignmentText');
            const centerRequired  = document.getElementById('centerRequired');
            const plantRequired   = document.getElementById('plantRequired');

            if (forcePlant) {
                // Hide radio, auto-show Plant dropdown
                radioGroup.style.display = 'none';
                forcedNote.style.display = 'block';
                forcedText.textContent   = 'Plant Managers must be assigned to a Plant.';
                showSection('plant');
                plantRequired.style.display  = 'inline';
                centerRequired.style.display = 'none';
                document.getElementById('plantSelect').required  = true;
                document.getElementById('centerSelect').required = false;

            } else if (forceCenter) {
                // Hide radio, auto-show Center dropdown
                radioGroup.style.display = 'none';
                forcedNote.style.display = 'block';
                forcedText.textContent   = 'Collection Agents must be assigned to a Collection Center.';
                showSection('center');
                centerRequired.style.display = 'inline';
                plantRequired.style.display  = 'none';
                document.getElementById('centerSelect').required = true;
                document.getElementById('plantSelect').required  = false;

            } else {
                // Free choice
                radioGroup.style.display = 'block';
                forcedNote.style.display = 'none';
                centerRequired.style.display = 'none';
                plantRequired.style.display  = 'none';
                document.getElementById('centerSelect').required = false;
                document.getElementById('plantSelect').required  = false;

                // Reset to "Not Assigned"
                document.getElementById('assignNone').checked = true;
                toggleAssignment('none');
            }

            // ── Role hint badge ──────────────────────────────────
            const roleHintBox  = document.getElementById('roleHintBox');
            const roleHintText = document.getElementById('roleHintText');

            if (roleName === '') {
                roleHintBox.style.display = 'none';
            } else if (needsLogin) {
                roleHintBox.style.display   = 'block';
                roleHintText.className      = 'badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2';
                roleHintText.innerHTML      = '<i class="bi bi-shield-check me-1"></i> Needs login account';
            } else {
                roleHintBox.style.display   = 'block';
                roleHintText.className      = 'badge bg-secondary bg-opacity-10 text-secondary fs-6 px-3 py-2';
                roleHintText.innerHTML      = '<i class="bi bi-person-badge me-1"></i> Staff only — no login needed';
            }
        }

        function showSection(type) {
            document.getElementById('centerSection').style.display = type === 'center' ? 'block' : 'none';
            document.getElementById('plantSection').style.display  = type === 'plant'  ? 'block' : 'none';

            if (type !== 'center') document.getElementById('centerSelect').value = '';
            if (type !== 'plant')  document.getElementById('plantSelect').value  = '';
        }

        function toggleAssignment(value) {
            showSection(value === 'center' ? 'center' : value === 'plant' ? 'plant' : 'none');
        }

        function previewPhoto(input) {
            const preview     = document.getElementById('photoPreview');
            const placeholder = document.getElementById('photoPlaceholder');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src               = e.target.result;
                    preview.style.display     = 'block';
                    placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display     = 'none';
                placeholder.style.display = 'block';
            }
        }

        function togglePasswordVisibility() {
            const input   = document.getElementById('passwordInput');
            const eyeIcon = document.getElementById('eyeIcon');
            input.type        = input.type === 'password' ? 'text' : 'password';
            eyeIcon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
    </script>
}