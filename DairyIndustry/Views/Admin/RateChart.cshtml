@model List<DairyIndustry.Models.Admin.RateChartModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Rate Chart";
}

<div class="container mt-4">

    <!-- Page Title -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Manage Rate Chart</h3>
                <p class="text-muted mb-0">Set milk rates based on Fat and CLR ranges</p>
            </div>
            <a href="/Admin/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- Add Rate Chart Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-plus-circle me-1"></i> Add New Rate
                </div>
                <div class="card-body p-4">
                    <form method="post" action="/Admin/AddRateChart">

                        <!-- Milk Type -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Milk Type <span class="text-danger">*</span>
                            </label>
                            <select name="milkTypeId"
                                    class="form-select"
                                    required>
                                <option value="">-- Select Milk Type --</option>
                                @foreach (var milkType in ViewBag.MilkTypes as List<DairyIndustry.Models.Admin.MilkTypeModel>)
                                {
                                    <option value="@milkType.MilkTypeId">@milkType.MilkTypeName</option>
                                }
                            </select>
                        </div>

                        <!-- Fat Range -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Fat Range <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="number"
                                       name="fatFrom"
                                       class="form-control"
                                       placeholder="From"
                                       step="0.01"
                                       min="0"
                                       required />
                                <span class="input-group-text">to</span>
                                <input type="number"
                                       name="fatTo"
                                       class="form-control"
                                       placeholder="To"
                                       step="0.01"
                                       min="0"
                                       required />
                            </div>
                            <div class="form-text">Fat percentage range e.g. 3.50 to 4.50</div>
                        </div>

                        <!-- CLR Range -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                CLR Range <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="number"
                                       name="clrFrom"
                                       class="form-control"
                                       placeholder="From"
                                       step="0.01"
                                       min="0"
                                       required />
                                <span class="input-group-text">to</span>
                                <input type="number"
                                       name="clrTo"
                                       class="form-control"
                                       placeholder="To"
                                       step="0.01"
                                       min="0"
                                       required />
                            </div>
                            <div class="form-text">CLR range e.g. 26.00 to 28.00</div>
                        </div>

                        <!-- Rate Per Liter -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Rate Per Liter (₹) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input type="number"
                                       name="ratePerLiter"
                                       class="form-control"
                                       placeholder="e.g. 32.50"
                                       step="0.01"
                                       min="0"
                                       required />
                            </div>
                        </div>

                        <!-- Effective From -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Effective From <span class="text-danger">*</span>
                            </label>
                            <input type="date"
                                   name="effectiveFrom"
                                   class="form-control"
                                   required />
                            <div class="form-text">Date from which this rate is applicable</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Add Rate
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- Rate Chart List -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-cash-stack me-1"></i> All Rate Charts</span>
                    <span class="badge bg-primary">Total : @Model.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Milk Type</th>
                                    <th>Fat Range</th>
                                    <th>CLR Range</th>
                                    <th>Rate / Ltr</th>
                                    <th>Effective From</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No rate charts found. Add one.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    @foreach (var rate in Model)
                                    {
                                        <tr>
                                            <td>@sr</td>
                                            <td>
                                                <span class="badge bg-primary">
                                                    @rate.MilkTypeName
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-dark fw-semibold">
                                                    @rate.FatFrom
                                                </span>
                                                <span class="text-muted mx-1">—</span>
                                                <span class="text-dark fw-semibold">
                                                    @rate.FatTo
                                                </span>
                                                <small class="text-muted ms-1">%</small>
                                            </td>
                                            <td>
                                                <span class="text-dark fw-semibold">
                                                    @rate.CLRFrom
                                                </span>
                                                <span class="text-muted mx-1">—</span>
                                                <span class="text-dark fw-semibold">
                                                    @rate.CLRTo
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-success fs-6 px-3">
                                                    ₹ @rate.RatePerLiter
                                                </span>
                                            </td>
                                            <td>
                                                <small>
                                                    <i class="bi bi-calendar3 me-1 text-muted"></i>
                                                    @rate.EffectiveFrom.ToString("dd MMM yyyy")
                                                </small>
                                            </td>
                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white text-muted small d-flex justify-content-between">
                    <span>@Model.Count rate(s) configured in the system</span>
                    <span>Sorted by most recent effective date</span>
                </div>
            </div>
        </div>

    </div>
</div>