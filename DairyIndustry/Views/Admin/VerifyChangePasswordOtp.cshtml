@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Verify OTP";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-1" style="color:#1a1a2e;">Enter OTP</h5>
                    <p class="text-muted small mb-1">OTP sent to</p>
                    <span class="badge rounded-pill mb-4"
                          style="background:#eaf6fb;color:#4bbcd8;font-size:13px;
                                 font-weight:600;padding:6px 14px;">
                        @ViewBag.MaskedEmail
                    </span>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3 py-2 small">
                            @TempData["Success"]
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-3 py-2 small">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post" action="/Admin/VerifyChangePasswordOtp" id="cpOtpForm">
                        <input type="hidden" name="otpCode" id="cpOtpCode" />

                        <div class="d-flex gap-2 mb-4" id="cpOtpBoxes">
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                            <input type="text" maxlength="1" class="cp-otp-input"
                                   inputmode="numeric" pattern="[0-9]" autocomplete="off"
                                   style="width:48px;height:56px;text-align:center;font-size:22px;
                                          font-weight:700;border:1.5px solid #e2e8f0;border-radius:8px;
                                          background:#fafbfc;outline:none;font-family:'Nunito',sans-serif;" />
                        </div>

                        <button type="submit" class="btn w-100 fw-bold text-white rounded-3"
                                style="background:linear-gradient(135deg,#4bbcd8,#38a8c4);
                                       letter-spacing:1px;padding:11px;">
                            CONFIRM CHANGE
                        </button>
                    </form>

                    <div class="text-center mt-3" style="font-size:12px;color:#9aa5b4;">
                        Expires in <span id="cpCountdown" style="font-weight:700;color:#4bbcd8;">10:00</span>
                        &nbsp;|&nbsp;
                        <a href="/Admin/ResendChangePasswordOtp"
                           style="color:#4bbcd8;font-weight:600;text-decoration:none;">
                            Resend OTP
                        </a>
                    </div>

                    <div class="text-center mt-2">
                        <a href="/Admin/ChangePassword"
                           style="font-size:12px;color:#9aa5b4;text-decoration:none;">
                            ← Back
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const inputs = document.querySelectorAll('.cp-otp-input');

    inputs.forEach((input, i) => {
        input.addEventListener('focus', () => {
            input.style.borderColor = '#4bbcd8';
            input.style.boxShadow   = '0 0 0 3px rgba(75,188,216,0.12)';
            input.style.background  = '#fff';
        });
        input.addEventListener('blur', () => {
            input.style.borderColor = '#e2e8f0';
            input.style.boxShadow   = 'none';
            input.style.background  = '#fafbfc';
        });
        input.addEventListener('input', () => {
            input.value = input.value.replace(/[^0-9]/g, '');
            if (input.value && i < inputs.length - 1)
                inputs[i + 1].focus();
        });
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !input.value && i > 0)
                inputs[i - 1].focus();
        });
        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pasted = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
            [...pasted].slice(0, 6).forEach((char, j) => {
                if (inputs[j]) inputs[j].value = char;
            });
            inputs[Math.min(pasted.length, 5)].focus();
        });
    });

    document.getElementById('cpOtpForm').addEventListener('submit', (e) => {
        const joined = [...inputs].map(i => i.value).join('');
        if (joined.length < 6) {
            e.preventDefault();
            alert('Please enter all 6 digits.');
            return;
        }
        document.getElementById('cpOtpCode').value = joined;
    });

    // Countdown
    let total = 10 * 60;
    const el  = document.getElementById('cpCountdown');
    const timer = setInterval(() => {
        total--;
        const m = String(Math.floor(total / 60)).padStart(2, '0');
        const s = String(total % 60).padStart(2, '0');
        el.textContent = `${m}:${s}`;
        if (total <= 0) {
            clearInterval(timer);
            el.textContent    = 'Expired';
            el.style.color    = '#e05c5c';
        }
    }, 1000);

    inputs[0].focus();
</script>