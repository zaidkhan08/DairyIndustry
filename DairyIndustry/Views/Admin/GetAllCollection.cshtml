@model List<DairyIndustry.Models.Admin.CollectionCenterModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Collection Centers";
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Collection Centers</h3>
                <p class="text-muted mb-0">View and manage all milk collection centers</p>
            </div>
            <div class="d-flex gap-2">

                <a asp-controller="Admin"
                   asp-action="DownloadCollectionsPdf"
                   class="btn btn-danger">
                    <i class="bi bi-file-earmark-pdf me-1"></i>
                    Download PDF
                </a>

                <a asp-controller="Admin"
                   asp-action="AddCollection"
                   class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>
                    Add New Collection Center
                </a>

            </div>
        </div>
    </div>

    <div class="row mb-4 g-3">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Total Centers</p>
                            <h4 class="fw-bold mb-0">@Model.Count</h4>
                        </div>
                        <i class="bi bi-house-door-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Active Centers</p>
                            <h4 class="fw-bold mb-0">@Model.Count(c => c.IsActive)</h4>
                        </div>
                        <i class="bi bi-check-circle-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 small">Total Capacity (L)</p>
                            <h4 class="fw-bold mb-0">@Model.Sum(c => c.Capacity).ToString("N0")</h4>
                        </div>
                        <i class="bi bi-droplet-fill fs-2 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-house-door me-1"></i> All Collection Centers</span>
                    <span class="badge bg-primary">Total: @Model.Count</span>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    @* <th>Center ID</th> *@
                                    <th>Center Name</th>
                                    <th>Location</th>
                                    <th class="text-center">Capacity (L)</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>

                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                                            <span class="fw-semibold">No collection centers found.</span><br />
                                            <small>Click "Add New Collection Center" to register one.</small>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = 1;
                                    foreach (var center in Model)
                                    {
                                        <!-- FIX: apostrophe-safe confirm message via data attribute, handled in JS below -->
                                        <tr class="@(!center.IsActive ? "table-secondary" : "")">

                                            <td class="ps-3 text-muted small">@sr</td>

                                            @* <td>
                                                <span class="badge bg-secondary">#@center.CenterId</span>
                                            </td> *@

                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div style="width:36px;height:36px;border-radius:8px;
                                                                        background:#ecfdf5;display:flex;
                                                                        align-items:center;justify-content:center;
                                                                        flex-shrink:0;">
                                                        <i class="bi bi-house-door-fill text-success"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold small">@center.CenterName</div>
                                                        <div class="text-muted" style="font-size:11px;">Collection Center</div>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                                    @(string.IsNullOrEmpty(center.Location) ? "—" : center.Location)
                                                </span>
                                            </td>

                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    <i class="bi bi-droplet-fill text-primary me-1"></i>
                                                    @center.Capacity.ToString("N0") L
                                                </span>
                                            </td>

                                            <td class="text-center">
                                                @if (center.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactive</span>
                                                }
                                            </td>

                                            <td class="text-center">
                                                <div class="d-flex justify-content-center gap-2">

                                                    <a asp-controller="Admin"
                                                       asp-action="EditCollection"
                                                       asp-route-id="@center.CenterId"
                                                       class="btn btn-sm btn-outline-warning"
                                                       title="Edit">
                                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                                    </a>

                                                    @if (center.IsActive)
                                                    {
                                                        <!-- FIX: data-name avoids apostrophe breaking JS string -->
                                                        <form asp-controller="Admin"
                                                              asp-action="ToggleCollection"
                                                              method="post"
                                                              class="d-inline toggle-form"
                                                              data-name="@center.CenterName"
                                                              data-action="deactivate">
                                                            <input type="hidden" name="id" value="@center.CenterId" />
                                                            <input type="hidden" name="isActive" value="false" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="bi bi-x-circle me-1"></i> Deactivate
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form asp-controller="Admin"
                                                              asp-action="ToggleCollection"
                                                              method="post"
                                                              class="d-inline toggle-form"
                                                              data-name="@center.CenterName"
                                                              data-action="restore">
                                                            <input type="hidden" name="id" value="@center.CenterId" />
                                                            <input type="hidden" name="isActive" value="true" />
                                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                                <i class="bi bi-check-circle me-1"></i> Restore
                                                            </button>
                                                        </form>
                                                    }

                                                </div>
                                            </td>

                                        </tr>
                                        sr++;
                                    }
                                }

                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-white text-muted small d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-info-circle me-1"></i>
                        @Model.Count center(s) registered in the system
                    </span>
                    <a asp-controller="Admin" asp-action="AddCollection"
                       class="text-primary text-decoration-none small">
                        <i class="bi bi-plus-circle me-1"></i> Add New Collection Center
                    </a>
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // FIX: safe confirm using data attributes — no apostrophe issue
        document.querySelectorAll('.toggle-form').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                var name   = form.getAttribute('data-name');
                var action = form.getAttribute('data-action');
                var msg    = action === 'deactivate'
                    ? 'Are you sure you want to deactivate "' + name + '"?'
                    : 'Restore "' + name + '"?';
                if (!confirm(msg)) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
