@model List<DairyIndustry.Models.Admin.AuditLogModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Audit Logs";

    // Route data for pagination links
    var routeData = new Dictionary<string, string> {
        { "entityName", Context.Request.Query["entityName"] },
        { "fromDate", Context.Request.Query["fromDate"] },
        { "toDate", Context.Request.Query["toDate"] }
    };
}

<div class="container mt-4">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0 text-dark">Audit Logs</h3>
            <p class="text-muted mb-0">System activity tracking</p>
        </div>
        <a href="/Admin/Index" class="btn btn-sm btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" action="/Admin/AuditLogs" class="row g-2">
                <div class="col-md-3">
                    <input type="text" name="entityName" class="form-control form-control-sm" placeholder="Entity (e.g. Farmer)" value="@routeData["entityName"]" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="fromDate" class="form-control form-control-sm" value="@routeData["fromDate"]" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="toDate" class="form-control form-control-sm" value="@routeData["toDate"]" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary flex-grow-1">Search</button>
                    <a href="/Admin/AuditLogs" class="btn btn-sm btn-light border flex-grow-1">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Log Records</h6>
                <span class="badge rounded-pill bg-light text-dark border">Total: @ViewBag.TotalRecords</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3" style="width: 5%">#</th>
                        <th style="width: 20%">User</th>
                        <th style="width: 15%">Action</th>
                        <th style="width: 20%">Entity</th>
                        <th style="width: 25%">Timestamp</th>
                        <th class="text-end pe-3" style="width: 15%">ID</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">No records found.</td>
                        </tr>
                    }
                    else
                    {
                        int sr = ((ViewBag.CurrentPage - 1) * 10) + 1;
                        foreach (var log in Model)
                        {
                            <tr>
                                <td class="ps-3">@sr</td>
                                <td><strong>@log.Username</strong></td>
                                <td>
                                    @{
                                        string act = log.Action?.ToLower() ?? "";
                                        string color = act.Contains("add") || act.Contains("create") ? "success" :
                                        act.Contains("edit") || act.Contains("update") ? "warning" :
                                        act.Contains("delete") ? "danger" : "secondary";
                                    }
                                    <span class="badge bg-@color">@log.Action</span>
                                </td>
                                <td><span class="text-uppercase small fw-bold">@log.EntityName</span></td>
                                <td>
                                    <span class="d-block small">@log.ActionDate.ToString("yyyy-MM-dd")</span>
                                    <span class="text-muted tiny" style="font-size: 0.75rem;">@log.ActionDate.ToString("hh:mm:ss tt")</span>
                                </td>
                                <td class="text-end pe-3 text-muted">#@log.LogId</td>
                            </tr>
                            sr++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- FIXED PAGINATION FOOTER -->
        <div class="card-footer bg-white border-top-0 py-3">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <!-- Left Side: Status -->
                <div class="text-muted small mb-3 mb-md-0">
                    Showing page <b>@ViewBag.CurrentPage</b> of <b>@ViewBag.TotalPages</b>
                </div>

                <!-- Right Side: Pagination -->
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage - 1, entityName = routeData["entityName"], fromDate = routeData["fromDate"], toDate = routeData["toDate"] })">Previous</a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("AuditLogs", new { page = i, entityName = routeData["entityName"], fromDate = routeData["fromDate"], toDate = routeData["toDate"] })">@i</a>
                                </li>
                            }
                            else if (i == ViewBag.CurrentPage - 3 || i == ViewBag.CurrentPage + 3)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage + 1, entityName = routeData["entityName"], fromDate = routeData["fromDate"], toDate = routeData["toDate"] })">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
    /* Prevent table text wrapping and keep it clean */
    .table th {
        font-weight: 600;
        font-size: 0.8rem;
        color: #495057;
    }

    .table td {
        font-size: 0.9rem;
    }

    .pagination .page-link {
        padding: 0.4rem 0.75rem;
        border-radius: 4px;
        margin: 0 2px;
    }

    .badge {
        font-weight: 500;
        font-size: 0.75rem;
    }
</style>