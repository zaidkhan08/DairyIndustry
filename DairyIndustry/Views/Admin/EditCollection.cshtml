@model DairyIndustry.Models.Admin.CollectionCenterModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Collection Center";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Edit Collection Center</h3>
                <p class="text-muted mb-0">Update collection center details</p>
            </div>
            <a asp-controller="Admin" asp-action="GetAllCollection" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Collection
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-pencil-square me-1 text-warning"></i> Edit Details
                </div>
                <div class="card-body p-4">

                    <form method="post"
                          asp-controller="Admin"
                          asp-action="UpdateCollection">

                        <input type="hidden" name="CenterId" value="@Model.CenterId" />
                        <input type="hidden" name="IsActive" value="@Model.IsActive" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Center Name <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-building"></i>
                                </span>
                                <input type="text"
                                       name="CenterName"
                                       class="form-control"
                                       value="@Model.CenterName"
                                       maxlength="100"
                                       required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Location</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-geo-alt"></i>
                                </span>
                                <input type="text"
                                       name="Location"
                                       class="form-control"
                                       value="@Model.Location"
                                       maxlength="100" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Capacity (Litres) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-droplet"></i>
                                </span>
                                <input type="number"
                                       name="Capacity"
                                       class="form-control"
                                       value="@Model.Capacity"
                                       min="1"
                                       step="0.01"
                                       required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Village / Taluka <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-pin-map"></i>
                                </span>
                                <select class="form-select" name="VillageId">
                                    <option value="">— Select Village —</option>
                                    @foreach (var v in ViewBag.Villages)
                                    {
                                        <option value="@v.VillageId"
                                                selected="@(v.VillageId == Model.VillageId ? "selected" : null)">
                                            @v.VillageName
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-1"></i> Update
                            </button>
                            <a asp-controller="Admin"
                               asp-action="GetAllCollection"
                               class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>