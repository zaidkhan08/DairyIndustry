@model DairyIndustry.Models.Admin.AdminOrderModel
@{
    ViewData["Title"] = "Place Order";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Place Order (Admin)</h4>
        </div>
        <div class="card-body">

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success">@ViewBag.Message</div>
            }

            <form method="post" asp-action="AdminOrder" asp-controller="Admin">

                <div class="mb-3">
                    <label class="form-label">Select Distributor</label>
                    <select asp-for="DistributorId" class="form-select">
                        <option value="">-- Select Distributor --</option>
                        @foreach (var d in Model.DistributorList)
                        {
                            <option value="@d.DistributorId">@d.DistributorName</option>
                        }
                    </select>
                    <span asp-validation-for="DistributorId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Select Plant</label>
                    <select asp-for="PlantId" class="form-select">
                        <option value="">-- Select Plant --</option>
                        @foreach (var p in Model.PlantList)
                        {
                            <option value="@p.PlantId">@p.PlantName — @p.Location</option>
                        }
                    </select>
                    <span asp-validation-for="PlantId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Select Product</label>
                    <select asp-for="ProductId" class="form-select" id="productDropdown">
                        <option value="">-- Select Product --</option>
                        @foreach (var p in Model.ProductList)
                        {
                            <option value="@p.ProductId" data-price="@p.MRP">
                                @p.ProductName — ₹@p.MRP
                            </option>
                        }
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input asp-for="Quantity" type="number" step="0.01" class="form-control" placeholder="Enter quantity" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Unit Price (₹)</label>
                    <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" placeholder="Auto-filled from product" />
                    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Order Date</label>
                    <input asp-for="OrderDate" type="date" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success">Place Order</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById("productDropdown").addEventListener("change", function () {
            var price = this.options[this.selectedIndex].getAttribute("data-price");
            document.querySelector("input[name='UnitPrice']").value = price || '';
        });
    </script>
}