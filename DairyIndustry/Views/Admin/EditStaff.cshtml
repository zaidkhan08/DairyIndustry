@model DairyIndustry.Models.Admin.StaffModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Staff";

    var loginRoles = new[] { "Administrator", "Plant Manager", "Collection Agent", "HR Manager" };
    var loginRolesJson = System.Text.Json.JsonSerializer.Serialize(loginRoles);

    var plantRoles = new[] { "Plant Manager" };
    var plantRolesJson = System.Text.Json.JsonSerializer.Serialize(plantRoles);

    var centerRoles = new[] { "Collection Agent" };
    var centerRolesJson = System.Text.Json.JsonSerializer.Serialize(centerRoles);

    string currentAssign = "none";

    if (Model.CenterId.HasValue)
    {
        currentAssign = "center";
    }
    else if (Model.PlantId.HasValue)
    {
        currentAssign = "plant";
    }

    var roles = ViewBag.Roles as List<DairyIndustry.Models.Admin.RoleModel>;
    var currentRole = roles?.FirstOrDefault(r => r.RoleId == Model.RoleId);

    string currentRoleName = currentRole?.RoleName ?? "";

    bool isLoginRole = loginRoles.Contains(currentRoleName);
    bool isForcePlant = plantRoles.Contains(currentRoleName);
    bool isForceCenter = centerRoles.Contains(currentRoleName);
}

<div class="container mt-4">

    <!-- Header -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-0">Edit Staff</h3>
                <p class="text-muted mb-0">
                    Update details for @Model.FirstName @Model.LastName
                </p>
            </div>

            <a asp-controller="Admin"
               asp-action="Staff"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>
                Back to Staff
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-circle me-1"></i>
            @ViewBag.Error
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Success"]
        </div>
    }

    <!-- Form -->
    <form method="post"
          asp-controller="Admin"
          asp-action="EditStaff"
          enctype="multipart/form-data">

        <input type="hidden" name="staffId" value="@Model.StaffId" />
        <input type="hidden" name="existingPhoto" value="@Model.ProfilePhoto" />

        <div class="row g-4">

            <!-- PERSONAL DETAILS -->
            <div class="col-md-6">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-person me-1 text-primary"></i>
                        Personal Details
                    </div>

                    <div class="card-body p-4">

                        <!-- Photo -->
                        <div class="mb-4 text-center">

                            <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center mx-auto mb-2 overflow-hidden"
                                 style="width:100px;height:100px;">

                                @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                                {
                                    <img id="photoPreview"
                                         src="@Model.ProfilePhoto"
                                         alt="Preview"
                                         class="w-100 h-100"
                                         style="object-fit:cover;" />

                                    <i id="photoPlaceholder"
                                       class="bi bi-person-fill text-secondary fs-1"
                                       style="display:none;"></i>
                                }
                                else
                                {
                                    <img id="photoPreview"
                                         src="#"
                                         alt="Preview"
                                         class="w-100 h-100"
                                         style="object-fit:cover;display:none;" />

                                    <i id="photoPlaceholder"
                                       class="bi bi-person-fill text-secondary fs-1"></i>
                                }

                            </div>

                            <label class="form-label fw-semibold d-block">
                                Profile Photo
                                <span class="text-muted fw-normal small">(Optional)</span>
                            </label>

                            <input type="file"
                                   name="photoFile"
                                   id="profilePhotoInput"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png"
                                   onchange="previewPhoto(this)" />

                            <div class="form-text">
                                JPG or PNG — Max 2 MB
                            </div>

                        </div>

                        <!-- First Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                First Name
                                <span class="text-danger">*</span>
                            </label>

                            <input type="text"
                                   name="firstName"
                                   class="form-control"
                                   value="@Model.FirstName"
                                   placeholder="Enter first name"
                                   required />
                        </div>

                        <!-- Last Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Last Name
                                <span class="text-danger">*</span>
                            </label>

                            <input type="text"
                                   name="lastName"
                                   class="form-control"
                                   value="@Model.LastName"
                                   placeholder="Enter last name"
                                   required />
                        </div>

                        <!-- Phone -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Phone
                            </label>

                            <input type="text"
                                   name="phone"
                                   class="form-control"
                                   value="@Model.Phone"
                                   placeholder="Enter phone number"
                                   maxlength="15" />
                        </div>

                        <!-- Email -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Email

                                <span id="emailRequiredBadge"
                                      class="text-danger"
                                      style="display:@(isLoginRole ? "inline" : "none");">
                                    *
                                </span>

                                <span id="emailOptionalBadge"
                                      class="text-muted fw-normal small"
                                      style="display:@(isLoginRole ? "none" : "inline");">
                                    (Optional)
                                </span>
                            </label>

                            <input type="email"
                                   name="email"
                                   id="emailInput"
                                   class="form-control"
                                   value="@Model.Email"
                                   placeholder="Enter email address" />

                            <div id="emailHint"
                                 class="form-text"
                                 style="display:@(isLoginRole ? "block" : "none");">
                                <i class="bi bi-info-circle me-1"></i>
                                OTP for 2-factor login will be sent to this email.
                            </div>

                        </div>

                        <!-- Role -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Role
                                <span class="text-danger">*</span>
                            </label>

                            <select name="roleId"
                                    id="roleSelect"
                                    class="form-select"
                                    required
                                    onchange="onRoleChange()">

                                <option value="">-- Select Role --</option>

                                @if (roles != null)
                                {
                                    foreach (var role in roles)
                                    {
                                        <option value="@role.RoleId"
                                                data-name="@role.RoleName"
                                                selected="@(role.RoleId == Model.RoleId)">
                                            @role.RoleName
                                        </option>
                                    }
                                }

                            </select>

                            <div id="roleHintBox"
                                 class="mt-2"
                                 style="display:@(!string.IsNullOrEmpty(currentRoleName) ? "block" : "none");">

                                @if (isLoginRole)
                                {
                                    <span id="roleHintText"
                                          class="badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2">
                                        <i class="bi bi-shield-check me-1"></i>
                                        Needs login account
                                    </span>
                                }
                                else if (!string.IsNullOrEmpty(currentRoleName))
                                {
                                    <span id="roleHintText"
                                          class="badge bg-secondary bg-opacity-10 text-secondary fs-6 px-3 py-2">
                                        <i class="bi bi-person-badge me-1"></i>
                                        Staff only — no login needed
                                    </span>
                                }
                                else
                                {
                                    <span id="roleHintText"
                                          class="badge fs-6 px-3 py-2"></span>
                                }

                            </div>

                        </div>

                        <!-- DOJ -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Date of Joining
                            </label>

                            <input type="date"
                                   name="doj"
                                   class="form-control"
                                   value="@(Model.DOJ?.ToString("yyyy-MM-dd"))" />

                            <div class="form-text">
                                Leave blank if not confirmed yet
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- BANK DETAILS -->
            <div class="col-md-6">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-bank me-1 text-success"></i>
                        Bank Details
                        <span class="text-muted fw-normal small ms-1">
                            (Optional)
                        </span>
                    </div>

                    <div class="card-body p-4">

                        <div class="alert alert-info small mb-4">
                            <i class="bi bi-info-circle me-1"></i>
                            Bank details are required for salary payments.
                            You can update them later.
                        </div>

                        <!-- Bank Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Bank Name
                            </label>

                            <input type="text"
                                   name="bankName"
                                   class="form-control"
                                   value="@Model.BankName"
                                   placeholder="e.g. SBI, HDFC, ICICI" />
                        </div>

                        <!-- Account Number -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Account Number
                            </label>

                            <input type="text"
                                   name="accountNumber"
                                   class="form-control"
                                   value="@Model.AccountNumber"
                                   placeholder="Enter account number" />
                        </div>

                        <!-- IFSC -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                IFSC Code
                            </label>

                            <input type="text"
                                   name="ifscCode"
                                   class="form-control"
                                   value="@Model.IFSCCode"
                                   placeholder="e.g. SBIN0001001"
                                   maxlength="20" />

                            <div class="form-text">
                                11 character code found on your cheque book
                            </div>
                        </div>

                        <!-- Salary -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Salary (₹)
                                <span class="text-danger">*</span>
                            </label>

                            <input type="number"
                                   name="salary"
                                   class="form-control"
                                   value="@Model.Salary"
                                   step="0.01"
                                   min="0"
                                   required
                                   placeholder="0.00" />

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- WORK ASSIGNMENT -->
        <div class="row g-4 mt-0">

            <div class="col-12">

                <div class="card shadow-sm border-0">

                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-geo-alt me-1 text-warning"></i>
                        Work Assignment
                    </div>

                    <div class="card-body p-4">

                        <!-- Forced Assignment -->
                        <div id="forcedAssignmentNote"
                             class="alert alert-warning small mb-3"
                             style="display:@((isForcePlant || isForceCenter) ? "block" : "none");">

                            <i class="bi bi-exclamation-triangle me-1"></i>

                            <span id="forcedAssignmentText">

                                @if (isForcePlant)
                                {
                                    @:Plant Managers must be assigned to a Plant.
                                }

                                @if (isForceCenter)
                                {
                                    @:Collection Agents must be assigned to a Collection Center.
                                }

                            </span>

                        </div>

                        <!-- Radio Group -->
                        <div id="assignRadioGroup"
                             class="mb-3"
                             style="display:@((isForcePlant || isForceCenter) ? "none" : "block");">

                            <label class="form-label fw-semibold">
                                Assign To
                            </label>

                            <div class="d-flex gap-4">

                                <!-- None -->
                                <div class="form-check">

                                    <input class="form-check-input"
                                           type="radio"
                                           name="assignType"
                                           id="assignNone"
                                           value="none"
                                           checked="@(currentAssign == "none")"
                                           onchange="toggleAssignment(this.value)" />

                                    <label class="form-check-label" for="assignNone">
                                        Not Assigned
                                    </label>

                                </div>

                                <!-- Center -->
                                <div class="form-check">

                                    <input class="form-check-input"
                                           type="radio"
                                           name="assignType"
                                           id="assignCenter"
                                           value="center"
                                           checked="@(currentAssign == "center")"
                                           onchange="toggleAssignment(this.value)" />

                                    <label class="form-check-label" for="assignCenter">
                                        Collection Center
                                    </label>

                                </div>

                                <!-- Plant -->
                                <div class="form-check">

                                    <input class="form-check-input"
                                           type="radio"
                                           name="assignType"
                                           id="assignPlant"
                                           value="plant"
                                           checked="@(currentAssign == "plant")"
                                           onchange="toggleAssignment(this.value)" />

                                    <label class="form-check-label" for="assignPlant">
                                        Plant
                                    </label>

                                </div>

                            </div>

                        </div>

                        <!-- Center Section -->
                        <div id="centerSection"
                             class="mb-3"
                             style="display:@(currentAssign == "center" ? "block" : "none");">

                            <label class="form-label fw-semibold">
                                Select Collection Center

                                <span id="centerRequired"
                                      class="text-danger"
                                      style="display:@(isForceCenter ? "inline" : "none");">
                                    *
                                </span>
                            </label>

                            <select name="centerId"
                                    id="centerSelect"
                                    class="form-select"
                                    @(isForceCenter ? "required" : "")>

                                <option value="">-- Select Center --</option>

                                @foreach (var c in (ViewBag.Centers as List<DairyIndustry.Models.Admin.CollectionCenterModel>) ?? new())
                                {
                                    <option value="@c.CenterId"
                                            selected="@(Model.CenterId == c.CenterId)">
                                        @c.CenterName
                                    </option>
                                }

                            </select>

                        </div>

                        <!-- Plant Section -->
                        <div id="plantSection"
                             class="mb-3"
                             style="display:@(currentAssign == "plant" ? "block" : "none");">

                            <label class="form-label fw-semibold">
                                Select Plant

                                <span id="plantRequired"
                                      class="text-danger"
                                      style="display:@(isForcePlant ? "inline" : "none");">
                                    *
                                </span>
                            </label>

                            <select name="plantId"
                                    id="plantSelect"
                                    class="form-select"
                                    @(isForcePlant ? "required" : "")>

                                <option value="">-- Select Plant --</option>

                                @foreach (var p in (ViewBag.Plants as List<DairyIndustry.Models.Admin.PlantModel>) ?? new())
                                {
                                    <option value="@p.PlantId"
                                            selected="@(Model.PlantId == p.PlantId)">
                                        @p.PlantName
                                    </option>
                                }

                            </select>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Submit -->
        <div class="row mt-4 mb-5">

            <div class="col">

                <div class="card shadow-sm border-0">

                    <div class="card-body d-flex gap-2">

                        <button type="submit"
                                class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>
                            Save Changes
                        </button>

                        <a asp-controller="Admin"
                           asp-action="Staff"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </form>

</div>

@section Scripts {

    <script>

        const LOGIN_ROLES = @Html.Raw(loginRolesJson);
        const PLANT_ROLES = @Html.Raw(plantRolesJson);
        const CENTER_ROLES = @Html.Raw(centerRolesJson);

        const ROLE_HINTS = {
            'Administrator': 'Admins can access all system features.',
            'Plant Manager': 'Plant Managers manage production and inventory.',
            'Collection Agent': 'Collection Agents manage milk entries.',
            'HR Manager': 'HR Managers manage staff and payroll.'
        };

        function onRoleChange() {

            const select = document.getElementById('roleSelect');

            const selectedOption =
                select.options[select.selectedIndex];

            const roleName =
                selectedOption
                    ? (selectedOption.dataset.name || '').trim()
                    : '';

            const needsLogin =
                LOGIN_ROLES.includes(roleName);

            const forcePlant =
                PLANT_ROLES.includes(roleName);

            const forceCenter =
                CENTER_ROLES.includes(roleName);

            // Email
            document.getElementById('emailHint').style.display =
                needsLogin ? 'block' : 'none';

            document.getElementById('emailRequiredBadge').style.display =
                needsLogin ? 'inline' : 'none';

            document.getElementById('emailOptionalBadge').style.display =
                needsLogin ? 'none' : 'inline';

            // Assignment
            const radioGroup =
                document.getElementById('assignRadioGroup');

            const forcedNote =
                document.getElementById('forcedAssignmentNote');

            const forcedText =
                document.getElementById('forcedAssignmentText');

            const centerRequired =
                document.getElementById('centerRequired');

            const plantRequired =
                document.getElementById('plantRequired');

            const centerSelect =
                document.getElementById('centerSelect');

            const plantSelect =
                document.getElementById('plantSelect');

            if (forcePlant) {

                radioGroup.style.display = 'none';

                forcedNote.style.display = 'block';

                forcedText.textContent =
                    'Plant Managers must be assigned to a Plant.';

                showSection('plant');

                plantRequired.style.display = 'inline';
                centerRequired.style.display = 'none';

                plantSelect.required = true;
                centerSelect.required = false;

            }
            else if (forceCenter) {

                radioGroup.style.display = 'none';

                forcedNote.style.display = 'block';

                forcedText.textContent =
                    'Collection Agents must be assigned to a Collection Center.';

                showSection('center');

                centerRequired.style.display = 'inline';
                plantRequired.style.display = 'none';

                centerSelect.required = true;
                plantSelect.required = false;

            }
            else {

                radioGroup.style.display = 'block';

                forcedNote.style.display = 'none';

                centerRequired.style.display = 'none';
                plantRequired.style.display = 'none';

                centerSelect.required = false;
                plantSelect.required = false;

                document.getElementById('assignNone').checked = true;

                toggleAssignment('none');
            }

            // Role Hint
            const roleHintBox =
                document.getElementById('roleHintBox');

            const roleHintText =
                document.getElementById('roleHintText');

            if (roleName === '') {

                roleHintBox.style.display = 'none';

            }
            else if (needsLogin) {

                roleHintBox.style.display = 'block';

                roleHintText.className =
                    'badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2';

                roleHintText.innerHTML =
                    '<i class="bi bi-shield-check me-1"></i> Needs login account';

            }
            else {

                roleHintBox.style.display = 'block';

                roleHintText.className =
                    'badge bg-secondary bg-opacity-10 text-secondary fs-6 px-3 py-2';

                roleHintText.innerHTML =
                    '<i class="bi bi-person-badge me-1"></i> Staff only — no login needed';
            }
        }

        function showSection(type) {

            const centerSection =
                document.getElementById('centerSection');

            const plantSection =
                document.getElementById('plantSection');

            centerSection.style.display =
                type === 'center' ? 'block' : 'none';

            plantSection.style.display =
                type === 'plant' ? 'block' : 'none';

            if (type !== 'center') {
                document.getElementById('centerSelect').value = '';
            }

            if (type !== 'plant') {
                document.getElementById('plantSelect').value = '';
            }
        }

        function toggleAssignment(value) {

            if (value === 'center') {
                showSection('center');
            }
            else if (value === 'plant') {
                showSection('plant');
            }
            else {
                showSection('none');
            }
        }

        function previewPhoto(input) {

            const preview =
                document.getElementById('photoPreview');

            const placeholder =
                document.getElementById('photoPlaceholder');

            if (input.files && input.files[0]) {

                const reader = new FileReader();

                reader.onload = function (e) {

                    preview.src = e.target.result;

                    preview.style.display = 'block';

                    placeholder.style.display = 'none';
                };

                reader.readAsDataURL(input.files[0]);

            }
            else {

                preview.style.display = 'none';

                placeholder.style.display = 'block';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            onRoleChange();
        });

    </script>

}