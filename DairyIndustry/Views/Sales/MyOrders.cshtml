@model List<DairyIndustry.Models.SalesOrderModel>
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">My Orders</h4>
        <small class="text-muted">Welcome, <strong>@ViewBag.DistributorName</strong></small>
    </div>
</div>

@if (Model.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center" style="border-top:3px solid #0d6efd!important;">
                <div class="card-body py-3">
                    <div class="text-muted small">Total Orders</div>
                    <div class="fs-3 fw-bold text-primary">@Model.Count</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center" style="border-top:3px solid #198754!important;">
                <div class="card-body py-3">
                    <div class="text-muted small">Delivered</div>
                    <div class="fs-3 fw-bold text-success">@Model.Count(o => o.OrderStatus == "Delivered")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center" style="border-top:3px solid #ffc107!important;">
                <div class="card-body py-3">
                    <div class="text-muted small">Pending</div>
                    <div class="fs-3 fw-bold text-warning">@Model.Count(o => o.OrderStatus == "Pending")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center" style="border-top:3px solid #198754!important;">
                <div class="card-body py-3">
                    <div class="text-muted small">Total Value</div>
                    <div class="fs-3 fw-bold text-success">₹@Model.Sum(o => o.TotalAmount).ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background:#1a2e4a; color:#fff;">
                        <tr>
                            <th>#</th>
                            <th>Order Date</th>
                            <th class="text-end">Amount (₹)</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="text-muted small">#@o.OrderId</td>
                                <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end fw-semibold">₹@o.TotalAmount.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge bg-@o.StatusBadgeClass">@o.OrderStatus</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@o.OrderId"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-3 py-2 border-top bg-light text-muted small">
                @Model.Count order(s)
            </div>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="text-center text-muted py-5">
            <div style="font-size:3rem;">📋</div>
            <div class="fs-5 mt-2">No orders yet.</div>
            <p class="text-muted small mt-1">
                Your orders will appear here once they are created by the sales team.
            </p>
        </div>
    </div>
}
