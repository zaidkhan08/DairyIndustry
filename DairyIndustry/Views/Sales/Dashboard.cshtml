@model DairyIndustry.Models.SalesDashboardViewModel
@{
    ViewData["Title"] = "Sales Dashboard";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
}

<div class="page-header">
    <div>
        <h4 class="fw-bold mb-1">Sales Dashboard</h4>
        <small class="text-muted">@DateTime.Today.ToString("dddd, dd MMM yyyy")</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">➕ New Order</a>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100" style="border-left:4px solid #0d6efd!important;">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-muted small">Total Orders</div>
                        <div class="fs-2 fw-bold text-primary">@Model.Summary.TotalOrders</div>
                        <small class="text-muted">all time</small>
                    </div>
                    <span style="font-size:2rem;opacity:.25;">📋</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100" style="border-left:4px solid #198754!important;">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-muted small">Total Revenue</div>
                        <div class="fs-2 fw-bold text-success">₹@Model.Summary.TotalRevenue.ToString("N0")</div>
                        <small class="text-muted">Today: ₹@Model.Summary.TodayRevenue.ToString("N0")</small>
                    </div>
                    <span style="font-size:2rem;opacity:.25;">💰</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100"
             style="border-left:4px solid @(Model.Summary.PendingOrders > 0 ? "#ffc107" : "#0d6efd")!important;">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-muted small">Pending Orders</div>
                        <div class="fs-2 fw-bold @(Model.Summary.PendingOrders > 0 ? "text-warning" : "text-primary")">
                            @Model.Summary.PendingOrders
                        </div>
                        <small class="text-muted">awaiting confirmation</small>
                    </div>
                    <span style="font-size:2rem;opacity:.25;">⏳</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100" style="border-left:4px solid #6f42c1!important;">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-muted small">Distributors</div>
                        <div class="fs-2 fw-bold" style="color:#6f42c1;">@Model.Summary.TotalDistributors</div>
                        <small class="text-muted">registered</small>
                    </div>
                    <span style="font-size:2rem;opacity:.25;">🏪</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Status Breakdown + Top Distributors -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom fw-semibold text-primary">Orders by Status</div>
            <div class="card-body p-0">
                @if (Model.OrdersByStatus.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var s in Model.OrdersByStatus)
                        {
                            var bc = s.OrderStatus switch
                            {
                                "Pending" => "warning",
                                "Confirmed" => "info",
                                "Dispatched" => "primary",
                                "Delivered" => "success",
                                "Cancelled" => "danger",
                                _ => "secondary"
                            };
                            <li class="list-group-item d-flex justify-content-between align-items-center px-3">
                                <div>
                                    <span class="badge bg-@bc me-2">@s.OrderStatus</span>
                                    <small class="text-muted">₹@s.TotalAmount.ToString("N0")</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@s.Count</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-4">No orders yet.</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom d-flex justify-content-between">
                <span class="fw-semibold text-primary">Top Distributors</span>
                <a asp-action="Distributors" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.TopDistributors.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Distributor</th>
                                    <th class="text-center">Orders</th>
                                    <th class="text-end">Revenue</th>
                                    <th class="text-center">Delivered</th>
                                    <th class="text-center">Pending</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.TopDistributors)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@d.DistributorName</div>
                                            <small class="text-muted">@d.Location</small>
                                        </td>
                                        <td class="text-center">@d.TotalOrders</td>
                                        <td class="text-end text-success fw-semibold">₹@d.TotalRevenue.ToString("N2")</td>
                                        <td class="text-center"><span class="badge bg-success">@d.DeliveredOrders</span></td>
                                        <td class="text-center"><span class="badge bg-warning text-dark">@d.PendingOrders</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">No data yet.</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card">
    <div class="card-header bg-white border-bottom d-flex justify-content-between">
        <span class="fw-semibold text-primary">Recent Orders</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (Model.RecentOrders.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Distributor</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th class="text-center">Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders)
                        {
                            <tr>
                                <td class="text-muted small">#@o.OrderId</td>
                                <td>
                                    <div class="fw-semibold">@o.DistributorName</div>
                                    <small class="text-muted">@o.Location</small>
                                </td>
                                <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end fw-semibold">₹@o.TotalAmount.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge bg-@o.StatusBadgeClass">@o.OrderStatus</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@o.OrderId"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                No orders yet.
                <a asp-action="Create" class="btn btn-primary btn-sm ms-2">Create First Order</a>
            </div>
        }
    </div>
</div>
