@model DairyIndustry.Models.DistributorAnalyticsModel
@{
    ViewData["Title"] = "My Analytics";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
    string distName = Context.Session.GetString("DistributorName") ?? "Distributor";
}

<div class="page-header">
    <div>
        <h1 class="page-title">My Analytics</h1>
        <p class="page-subtitle">Order insights for <strong>@distName</strong></p>
    </div>
    <div style="display:flex;gap:8px;">
        <a asp-action="ExportOrders" class="btn btn-outline-success btn-sm">⬇️ Export CSV</a>
        <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm">← My Orders</a>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card" style="background:linear-gradient(135deg,#eff6ff,#dbeafe); border-color:#bfdbfe!important;">
            <div class="stat-card-value" style="color:#1d4ed8;">@Model.TotalOrders</div>
            <div class="stat-card-label" style="color:#1d4ed8;">Total Orders</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7); border-color:#bbf7d0!important;">
            <div class="stat-card-value" style="color:#15803d;">@Model.CompletionRate%</div>
            <div class="stat-card-label" style="color:#15803d;">Completion Rate</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card" style="background:linear-gradient(135deg,#eff6ff,#dbeafe); border-color:#bfdbfe!important;">
            <div class="stat-card-value" style="color:#1d4ed8; font-size:22px;">₹@Model.TotalSpent.ToString("N0")</div>
            <div class="stat-card-label" style="color:#1d4ed8;">Total Spent</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card"
             style="background:@(Model.MonthOnMonthChange >= 0 ? "linear-gradient(135deg,#f0fdf4,#dcfce7)" : "linear-gradient(135deg,#fef2f2,#fee2e2)");
                    border-color:@(Model.MonthOnMonthChange >= 0 ? "#bbf7d0" : "#fecaca")!important;">
            <div class="stat-card-value" style="color:@(Model.MonthOnMonthChange >= 0 ? "#15803d" : "#991b1b");">
                @(Model.MonthOnMonthChange >= 0 ? "▲" : "▼") @Math.Abs(Model.MonthOnMonthChange)%
            </div>
            <div class="stat-card-label" style="color:@(Model.MonthOnMonthChange >= 0 ? "#15803d" : "#991b1b");">vs Last Month</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Monthly Spend Chart -->
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">
                📈 Monthly Spend — Last 6 Months
            </div>
            <div class="card-body">
                @if (!Model.MonthlyTrend.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📊</div>
                        <div class="empty-state-title">No order data yet</div>
                    </div>
                }
                else
                {
                    <canvas id="monthlyChart" height="120"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- Status Breakdown Chart -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">
                🥧 Status Breakdown
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (!Model.StatusBreakdown.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📊</div>
                        <div class="empty-state-title">No data yet</div>
                    </div>
                }
                else
                {
                    <canvas id="statusChart" height="180"></canvas>
                }
            </div>
        </div>
    </div>
</div>

<!-- This Month / Last Month / Cancelled -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">💰 This Month</div>
            <div class="card-body" style="text-align:center;">
                <div style="font-size:28px; font-weight:800; color:#1d4ed8; letter-spacing:-.5px;">₹@Model.ThisMonthSpent.ToString("N0")</div>
                <div style="font-size:12.5px; margin-top:6px;">
                    @{
                        string trend = Model.MonthOnMonthChange == 0 ? "Same as last month" :
                                       Model.MonthOnMonthChange > 0
                                       ? $"▲ {Model.MonthOnMonthChange}% vs last month"
                                       : $"▼ {Math.Abs(Model.MonthOnMonthChange)}% vs last month";
                    }
                    <span style="color:@(Model.MonthOnMonthChange >= 0 ? "#16a34a" : "#dc2626"); font-weight:600;">@trend</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">📅 Last Month</div>
            <div class="card-body" style="text-align:center;">
                <div style="font-size:28px; font-weight:800; color:#64748b; letter-spacing:-.5px;">₹@Model.LastMonthSpent.ToString("N0")</div>
                <div style="font-size:12.5px; color:#94a3b8; margin-top:6px;">Previous month total</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">❌ Cancelled Orders</div>
            <div class="card-body" style="text-align:center;">
                <div style="font-size:28px; font-weight:800; color:#dc2626; letter-spacing:-.5px;">@Model.CancelledOrders</div>
                <div style="font-size:12.5px; color:#94a3b8; margin-top:6px;">
                    @(Model.TotalOrders == 0 ? "0" : Math.Round((decimal)Model.CancelledOrders / Model.TotalOrders * 100, 1).ToString())% of all orders
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Top Products -->
@if (Model.TopProducts.Any())
{
    <div class="card">
        <div class="card-header" style="background:#fff; font-weight:700; color:#0f172a; font-size:13.5px;">
            🏆 Top 5 Most Ordered Products
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark-head">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Unit</th>
                            <th class="text-end">Total Qty Ordered</th>
                            <th class="text-end">Total Spent (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var p in Model.TopProducts)
                        {
                            <tr>
                                <td>
                                    @if (rank == 1)      { <span class="badge badge-pending">🥇 1</span> }
                                    else if (rank == 2)  { <span class="badge" style="background:#e2e8f0;color:#475569;">🥈 2</span> }
                                    else if (rank == 3)  { <span class="badge" style="background:#fef3c7;color:#92400e;">🥉 3</span> }
                                    else                 { <span style="color:#94a3b8; font-size:13px;">@rank</span> }
                                </td>
                                <td style="font-weight:600; color:#0f172a;">@p.ProductName</td>
                                <td style="font-size:12px; color:#64748b;">@p.Unit</td>
                                <td class="text-end" style="font-weight:600;">@p.TotalQty.ToString("N2")</td>
                                <td class="text-end" style="font-weight:700; color:#1d4ed8;">₹@p.TotalSpent.ToString("N2")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <script>
        @if (Model.MonthlyTrend.Any())
        {
            <text>
            const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
            new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.MonthlyTrend.Select(m => $"'{m.Label}'")))],
                    datasets: [{
                        label: 'Amount Spent (₹)',
                        data: [@Html.Raw(string.Join(",", Model.MonthlyTrend.Select(m => m.Amount)))],
                        backgroundColor: 'rgba(59,130,246,0.7)',
                        borderColor: '#1d4ed8',
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: ctx => '₹' + ctx.raw.toLocaleString('en-IN') } }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f1f5f9' },
                            ticks: { callback: val => '₹' + val.toLocaleString('en-IN'), font: { size: 11 } }
                        },
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                    }
                }
            });
            </text>
        }

        @if (Model.StatusBreakdown.Any())
        {
            var colorMap = new Dictionary<string, string> {
                ["Pending"]    = "#f59e0b",
                ["Confirmed"]  = "#3b82f6",
                ["Dispatched"] = "#8b5cf6",
                ["Delivered"]  = "#10b981",
                ["Received"]   = "#06b6d4",
                ["Cancelled"]  = "#ef4444"
            };
            <text>
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => $"'{s.Status}'")))],
                    datasets: [{
                        data: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => s.Count)))],
                        backgroundColor: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => {
                            colorMap.TryGetValue(s.Status, out var c);
                            return $"'{c ?? "#94a3b8"}'";
                        })))],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 10 } }
                    }
                }
            });
            </text>
        }
    </script>
}
