@model DairyIndustry.Models.DistributorAnalyticsModel
@{
    ViewData["Title"] = "My Analytics";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
    string distName = Context.Session.GetString("DistributorName") ?? "Distributor";
}

<div class="page-header">
    <div>
        <h4 class="fw-bold mb-1">My Analytics</h4>
        <small class="text-muted">Order insights for <strong>@distName</strong></small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportOrders" class="btn btn-outline-success btn-sm">⬇️ Export CSV</a>
        <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm">← My Orders</a>
    </div>
</div>

<!-- ── Summary Cards ── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card text-center">
            <div class="fs-3 fw-bold text-primary">@Model.TotalOrders</div>
            <div class="small text-muted">Total Orders</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center">
            <div class="fs-3 fw-bold text-success">@Model.CompletionRate%</div>
            <div class="small text-muted">Completion Rate</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center">
            <div class="fs-3 fw-bold text-primary">₹@Model.TotalSpent.ToString("N0")</div>
            <div class="small text-muted">Total Spent</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center">
            <div class="fs-3 fw-bold @(Model.MonthOnMonthChange >= 0 ? "text-success" : "text-danger")">
                @(Model.MonthOnMonthChange >= 0 ? "▲" : "▼") @Math.Abs(Model.MonthOnMonthChange)%
            </div>
            <div class="small text-muted">vs Last Month</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">

    <!-- ── Monthly Spend Trend ── -->
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-semibold" style="background:#f8fafc;">
                📈 Monthly Spend — Last 6 Months
            </div>
            <div class="card-body">
                @if (!Model.MonthlyTrend.Any())
                {
                    <div class="text-center text-muted py-4">No order data yet.</div>
                }
                else
                {
                    <canvas id="monthlyChart" height="120"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- ── Order Status Breakdown ── -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold" style="background:#f8fafc;">
                🥧 Order Status Breakdown
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (!Model.StatusBreakdown.Any())
                {
                    <div class="text-center text-muted">No data yet.</div>
                }
                else
                {
                    <canvas id="statusChart" height="180"></canvas>
                }
            </div>
        </div>
    </div>

</div>

<!-- ── This Month vs Last Month ── -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold" style="background:#f8fafc;">
                💰 This Month
            </div>
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-primary">₹@Model.ThisMonthSpent.ToString("N0")</div>
                <div class="small text-muted mt-1">
                    @{
                        var thisMonthOrders = Model.StatusBreakdown.Sum(s => 0); // placeholder
                        string trend = Model.MonthOnMonthChange == 0 ? "Same as last month" :
                                       Model.MonthOnMonthChange > 0
                                       ? $"▲ {Model.MonthOnMonthChange}% vs last month"
                                       : $"▼ {Math.Abs(Model.MonthOnMonthChange)}% vs last month";
                    }
                    <span class="@(Model.MonthOnMonthChange >= 0 ? "text-success" : "text-danger")">
                        @trend
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold" style="background:#f8fafc;">
                📅 Last Month
            </div>
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-secondary">₹@Model.LastMonthSpent.ToString("N0")</div>
                <div class="small text-muted mt-1">Previous month total</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold" style="background:#f8fafc;">
                ❌ Cancelled Orders
            </div>
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-danger">@Model.CancelledOrders</div>
                <div class="small text-muted mt-1">
                    @(Model.TotalOrders == 0 ? "0" :
                      Math.Round((decimal)Model.CancelledOrders / Model.TotalOrders * 100, 1).ToString())% of all orders
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Top Products ── -->
@if (Model.TopProducts.Any())
{
    <div class="card">
        <div class="card-header fw-semibold" style="background:#f8fafc;">
            🏆 Top 5 Most Ordered Products
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Unit</th>
                        <th class="text-end">Total Qty Ordered</th>
                        <th class="text-end">Total Spent (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var p in Model.TopProducts)
                    {
                        <tr>
                            <td>
                                @if (rank == 1) { <span class="badge bg-warning text-dark">🥇 1</span> }
                                else if (rank == 2) { <span class="badge bg-secondary">🥈 2</span> }
                                else if (rank == 3) { <span class="badge bg-warning-subtle text-dark">🥉 3</span> }
                                else { <span class="text-muted">@rank</span> }
                            </td>
                            <td class="fw-semibold">@p.ProductName</td>
                            <td class="text-muted small">@p.Unit</td>
                            <td class="text-end">@p.TotalQty.ToString("N2")</td>
                            <td class="text-end fw-semibold text-primary">₹@p.TotalSpent.ToString("N2")</td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <script>
        // ── Monthly Spend Bar Chart ───────────────────────────────────────
        @if (Model.MonthlyTrend.Any())
        {
            <text>
            const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
            new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.MonthlyTrend.Select(m => $"'{m.Label}'")))],
                    datasets: [{
                        label: 'Amount Spent (₹)',
                        data: [@Html.Raw(string.Join(",", Model.MonthlyTrend.Select(m => m.Amount)))],
                        backgroundColor: 'rgba(74,158,218,0.7)',
                        borderColor: '#1a2e4a',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => '₹' + ctx.raw.toLocaleString('en-IN')
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: val => '₹' + val.toLocaleString('en-IN')
                            }
                        }
                    }
                }
            });
            </text>
        }

        // ── Status Doughnut Chart ─────────────────────────────────────────
        @if (Model.StatusBreakdown.Any())
        {
            var colorMap = new Dictionary<string, string> {
                ["Pending"]    = "#ffc107",
                ["Confirmed"]  = "#0dcaf0",
                ["Dispatched"] = "#0d6efd",
                ["Delivered"]  = "#198754",
                ["Received"]   = "#20c997",
                ["Cancelled"]  = "#dc3545"
            };
            <text>
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => $"'{s.Status}'")))],
                    datasets: [{
                        data: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => s.Count)))],
                        backgroundColor: [@Html.Raw(string.Join(",", Model.StatusBreakdown.Select(s => {
                            colorMap.TryGetValue(s.Status, out var c);
                            return $"'{c ?? "#adb5bd"}'";
                        })))],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { font: { size: 11 }, padding: 10 }
                        }
                    }
                }
            });
            </text>
        }
    </script>
}
