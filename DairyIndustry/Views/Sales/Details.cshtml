@model DairyIndustry.Models.SalesOrderModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
    string role = Context.Session.GetString("RoleName") ?? "";
    bool isAdmin = role == "Admin";
    bool isDist = role == "Distributor";

    // Timeline steps in order
    var steps = new[] { "Pending", "Confirmed", "Dispatched", "Delivered", "Received" };
    bool isCancelled = Model.OrderStatus == "Cancelled";
    int currentStep = Array.IndexOf(steps, Model.OrderStatus);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Order #@Model.OrderId</h4>
        <small class="text-muted">@Model.DistributorName — @Model.OrderDate.ToString("dd MMM yyyy")</small>
    </div>
    <div class="d-flex gap-2">
        @if (isDist && Model.OrderStatus == "Delivered")
        {
            <form asp-action="ConfirmReceipt" method="post" class="m-0"
                  onsubmit="return confirm('Confirm that you have received this order?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <button type="submit" class="btn btn-success btn-sm">
                    ✅ Confirm Receipt
                </button>
            </form>
            <a asp-action="Reorder" asp-route-id="@Model.OrderId"
               class="btn btn-outline-success btn-sm"
               onclick="return confirm('Reorder the same items from this order?')">
                🔁 Reorder
            </a>
        }
        @if (isDist && Model.OrderStatus == "Received")
        {
            <a asp-action="Reorder" asp-route-id="@Model.OrderId"
               class="btn btn-outline-success btn-sm"
               onclick="return confirm('Reorder the same items from this order?')">
                🔁 Reorder
            </a>
        }
        <button class="btn btn-outline-secondary btn-sm" onclick="printInvoice()">
            🖨️ Print Invoice
        </button>
        @if (isAdmin)
        {
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Orders</a>
        }
        else
        {
            <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm">← My Orders</a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        ❌ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ── Order Status Timeline ── -->
@if (isCancelled)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4 py-2">
        ❌ <strong>This order was cancelled.</strong>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center justify-content-between position-relative">
                <!-- connecting line -->
                <div style="position:absolute; top:18px; left:10%; right:10%;
                                             height:3px; background:#dee2e6; z-index:0;"></div>
                <div style="position:absolute; top:18px; left:10%;
                                             height:3px; background:#0d6efd; z-index:1;
                                             width:@(currentStep < 0 ? 0 : (currentStep * 100 / (steps.Length - 1)))%;
                                             transition:width .4s;"></div>

                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i < currentStep;
                    bool current = i == currentStep;
                    string circleStyle = done ? "background:#0d6efd; border-color:#0d6efd; color:#fff;" :
                    current ? "background:#0d6efd; border-color:#0d6efd; color:#fff; box-shadow:0 0 0 4px rgba(13,110,253,.2);" :
                    "background:#fff; border-color:#dee2e6; color:#adb5bd;";
                    <div class="d-flex flex-column align-items-center" style="z-index:2; flex:1;">
                        <div style="width:36px; height:36px; border-radius:50%; border:2px solid;
                                                                    display:flex; align-items:center; justify-content:center;
                                                                    font-size:.8rem; font-weight:700; @circleStyle">
                            @if (done)
                            {
                                <span>✓</span>
                            }
                            else
                            {

                                <span>@(i + 1)</span>
                            }
                        </div>
                        <div class="mt-1 small @(current ? "fw-bold text-primary" : done ? "text-muted" : "text-muted")"
                             style="font-size:.72rem;">
                            @steps[i]
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-3">

    <!-- ── Order Info Card ── -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header text-white d-flex justify-content-between align-items-center"
                 style="background:#1a2e4a;">
                <span class="fw-semibold">Order Info</span>
                <span class="badge bg-@Model.StatusBadgeClass">@Model.OrderStatus</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Order ID</dt>
                    <dd class="col-7">#@Model.OrderId</dd>

                    <dt class="col-5 text-muted">Distributor</dt>
                    <dd class="col-7 fw-semibold">@Model.DistributorName</dd>

                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <dt class="col-5 text-muted">Location</dt>
                        <dd class="col-7">@Model.Location</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.ContactNumber))
                    {
                        <dt class="col-5 text-muted">Contact</dt>
                        <dd class="col-7">@Model.ContactNumber</dd>
                    }

                    <dt class="col-5 text-muted">Plant</dt>
                    <dd class="col-7">
                        @if (!string.IsNullOrEmpty(Model.PlantName))
                        {
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle">
                                🏭 @Model.PlantName
                            </span>
                        }
                        else
                        {

                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-5 text-muted">Order Date</dt>
                    <dd class="col-7">@Model.OrderDate.ToString("dd MMM yyyy")</dd>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <dt class="col-5 text-muted">Order Note</dt>
                        <dd class="col-7">
                            <span class="badge bg-light text-dark border">📝 @Model.Notes</span>
                        </dd>
                    }

                    <dt class="col-5 text-muted">Total Amount</dt>
                    <dd class="col-7 fw-bold text-primary fs-5">₹@Model.TotalAmount.ToString("N2")</dd>
                </dl>
            </div>

            <div class="card-footer bg-white">
                <div class="d-grid gap-2">

                    @if (isAdmin)
                    {
                        <!-- Admin: advance status -->
                        @if (Model.NextStatus != null)
                        {
                            <form asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="newStatus" value="@Model.NextStatus" />
                                <button type="submit" class="btn btn-primary w-100">
                                    Mark as @Model.NextStatus
                                </button>
                            </form>
                        }
                        @if (Model.CanCancel)
                        {
                            <form asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="newStatus" value="Cancelled" />
                                <button type="submit" class="btn btn-outline-danger w-100"
                                        onclick="return confirm('Cancel this order?')">
                                    Cancel Order
                                </button>
                            </form>
                        }
                        @if (Model.OrderStatus == "Delivered")
                        {
                            <div class="text-center text-success fw-semibold py-1">✅ Order Delivered — Awaiting distributor confirmation</div>
                        }
                        @if (Model.OrderStatus == "Received")
                        {
                            <div class="text-center text-success fw-semibold py-1">✅ Receipt Confirmed by Distributor</div>
                        }
                        @if (isCancelled)
                        {
                            <div class="text-center text-danger fw-semibold py-1">❌ Order Cancelled</div>
                        }
                    }

                    @if (isDist)
                    {
                        <!-- Distributor: can only cancel Pending orders themselves -->
                        @if (Model.OrderStatus == "Pending")
                        {
                            <form asp-action="CancelOrder" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <button type="submit" class="btn btn-outline-danger w-100"
                                        onclick="return confirm('Are you sure you want to cancel this order?')">
                                    Cancel Order
                                </button>
                            </form>
                        }
                        @if (Model.OrderStatus == "Delivered")
                        {
                            <form asp-action="ConfirmReceipt" method="post"
                                  onsubmit="return confirm('Confirm that you have received this order?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <button type="submit" class="btn btn-success w-100">
                                    ✅ Confirm Receipt
                                </button>
                            </form>
                            <a asp-action="Reorder" asp-route-id="@Model.OrderId"
                               class="btn btn-outline-success w-100 mt-1"
                               onclick="return confirm('Reorder the same items from this order?')">
                                🔁 Reorder This Order
                            </a>
                        }
                        @if (Model.OrderStatus == "Received")
                        {
                            <div class="text-center text-success fw-semibold py-1">
                                ✅ You confirmed receipt of this order
                            </div>
                            <a asp-action="Reorder" asp-route-id="@Model.OrderId"
                               class="btn btn-outline-success w-100 mt-1"
                               onclick="return confirm('Reorder the same items from this order?')">
                                🔁 Reorder This Order
                            </a>
                        }
                        @if (isCancelled)
                        {
                            <div class="text-center text-danger fw-semibold py-1">❌ Order Cancelled</div>
                        }
                        @if (Model.OrderStatus is "Confirmed" or "Dispatched")
                        {
                            <div class="text-center text-muted small py-1">
                                Order is being processed — contact admin to make changes.
                            </div>
                        }
                    }

                </div>
            </div>
        </div>
    </div>

    <!-- ── Line Items + Add Product ── -->
    <div class="col-md-8">

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                <span class="fw-semibold text-primary">Order Items</span>
                @if (Model.OrderDetails.Any())
                {
                    <span class="badge bg-primary">@Model.OrderDetails.Count</span>
                }
            </div>
            <div class="card-body p-0">
                @if (Model.OrderDetails.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Product Name</th>
                                    <th>Type</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price (₹)</th>
                                    <th class="text-end">Total (₹)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rowNum = 1;
                                }
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="text-muted small">@(rowNum++)</td>
                                        <td class="fw-semibold">@item.ProductName</td>
                                        <td><small class="text-muted">@item.ProductType</small></td>
                                        <td class="text-center">
                                            @item.Quantity.ToString("N2")
                                            <small class="text-muted">@item.Unit</small>
                                        </td>
                                        <td class="text-end">₹@item.UnitPrice.ToString("N2")</td>
                                        <td class="text-end fw-semibold text-success">
                                            ₹@item.LineTotal.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="5" class="text-end fw-bold">Order Total</td>
                                    <td class="text-end fw-bold text-primary fs-6">
                                        ₹@Model.TotalAmount.ToString("N2")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        No products added yet.
                        @if (!Model.CanAddItems)
                        {
                            <span class="small">(Order must be Pending to add items)</span>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Add Product Form — Pending orders only, Admin + Distributor -->
        @if (Model.CanAddItems)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom fw-semibold text-primary">
                    ➕ Add Product to Order
                </div>
                <div class="card-body">
                    <form asp-action="AddOrderDetail" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="OrderId" value="@Model.OrderId" />
                        <input type="hidden" name="UnitPrice" id="unitPriceHidden" value="0" />

                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label fw-semibold small">Product</label>
                                <select name="ProductId" class="form-select" required
                                        onchange="setMRP(this)">
                                    <option value="">— Select Product —</option>
                                    @foreach (SelectListItem item in (SelectList)ViewBag.Products)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Quantity</label>
                                <input type="number" name="Quantity" id="qty"
                                       class="form-control" step="0.01" min="0.01"
                                       placeholder="0.00" required oninput="calcTotal()" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Unit Price / MRP (₹)</label>
                                <div class="form-control bg-light text-muted" id="mrpDisplay"
                                     style="cursor:not-allowed;">
                                    Select a product
                                </div>
                            </div>
                            <div class="col-md-1">
                                <label class="form-label fw-semibold small">Total</label>
                                <input type="text" id="lineTotal"
                                       class="form-control bg-light fw-bold text-success"
                                       value="0.00" readonly />
                            </div>
                            <div class="col-md-1">
                                <button type="submit" class="btn btn-primary w-100" title="Add">➕</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const mrpMap = {};
        @if (ViewBag.ProductList != null)
        {
                            foreach (var p in (List<DairyIndustry.Models.ProductSalesModel>)ViewBag.ProductList)
                            {
                                                @Html.Raw($"mrpMap['{p.ProductId}'] = {{ mrp: {p.MRP}, unit: '{p.Unit}' }};")
                            }
        }

        function setMRP(sel) {
            const data    = mrpMap[sel.value];
            const display = document.getElementById('mrpDisplay');
            const hidden  = document.getElementById('unitPriceHidden');
            if (data) {
                display.textContent = '₹' + parseFloat(data.mrp).toFixed(2) + ' / ' + data.unit;
                hidden.value = data.mrp;
            } else {
                display.textContent = 'Select a product';
                hidden.value = '0';
            }
            calcTotal();
        }

        function calcTotal() {
            const q = parseFloat(document.getElementById('qty').value)             || 0;
            const p = parseFloat(document.getElementById('unitPriceHidden').value) || 0;
            document.getElementById('lineTotal').value = (q * p).toFixed(2);
        }

        function printInvoice() {
            document.body.classList.add('printing-invoice');
            window.print();
            document.body.classList.remove('printing-invoice');
        }
    </script>

    <style>
        /* ── Screen: invoice invisible ── */
        #invoice-template {
            display: none !important;
        }

        @@media print {
            /* 1. Hide the navbar, sidebar, overlay */
            .navbar,
            #sales-sidebar,
            #sidebar-overlay {
                display: none !important;
            }
            /* 2. Reset page-content so it has no offset/padding */
            #page-content {
                margin: 0 !important;
                padding: 0 !important;
                background: #fff !important;
                min-height: unset !important;
            }
                /* 3. Hide everything directly inside page-content EXCEPT the invoice */
                #page-content > *:not(#invoice-template) {
                    display: none !important;
                }
            /* 4. Show the invoice */
            #invoice-template {
                display: block !important;
            }
            /* 5. Clean page margins, remove browser URL/date headers */
            @@page {
                margin: 12mm 15mm 12mm 15mm;
                size: A4 portrait;
            }
            /* 6. Ensure colours print */
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
}

<!-- ── Invoice Template (print only) ── -->
<div id="invoice-template">
    <style>
        #invoice-template {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 13px;
            color: #1a1a1a;
            background: #fff;
            width: 100%;
        }

            /* ── Header ── */
            #invoice-template .inv-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                border-bottom: 3px solid #1a2e4a;
                padding-bottom: 16px;
                margin-bottom: 24px;
            }

            #invoice-template .inv-logo {
                font-size: 24px;
                font-weight: 800;
                color: #1a2e4a;
                line-height: 1.2;
            }

                #invoice-template .inv-logo span {
                    color: #4a9eda;
                }

                #invoice-template .inv-logo small {
                    display: block;
                    font-size: 11px;
                    font-weight: 400;
                    color: #666;
                    margin-top: 3px;
                }

            #invoice-template .inv-title {
                text-align: right;
            }

                #invoice-template .inv-title h2 {
                    font-size: 26px;
                    font-weight: 700;
                    color: #1a2e4a;
                    letter-spacing: .05em;
                    margin: 0 0 4px;
                }

                #invoice-template .inv-title .inv-number {
                    font-size: 14px;
                    color: #555;
                }

                #invoice-template .inv-title .inv-status {
                    display: inline-block;
                    margin-top: 6px;
                    padding: 3px 12px;
                    border-radius: 20px;
                    font-size: 11px;
                    font-weight: 600;
                    background: #e8f4fd;
                    color: #1a2e4a;
                    border: 1px solid #bee3f8;
                }

            /* ── Parties ── */
            #invoice-template .inv-parties {
                display: flex;
                gap: 0;
                margin-bottom: 28px;
                border: 1px solid #e0e7ef;
                border-radius: 6px;
                overflow: hidden;
            }

            #invoice-template .inv-party {
                flex: 1;
                padding: 14px 18px;
            }

                #invoice-template .inv-party:first-child {
                    border-right: 1px solid #e0e7ef;
                    background: #f8fafc;
                }

            #invoice-template .inv-party-label {
                font-size: 9px;
                text-transform: uppercase;
                letter-spacing: .12em;
                color: #4a9eda;
                font-weight: 700;
                margin-bottom: 8px;
            }

            #invoice-template .inv-party-name {
                font-size: 15px;
                font-weight: 700;
                color: #1a2e4a;
                margin-bottom: 4px;
            }

            #invoice-template .inv-party-detail {
                font-size: 12px;
                color: #555;
                line-height: 1.7;
            }

            /* ── Meta row (date / order info) ── */
            #invoice-template .inv-meta-row {
                display: flex;
                gap: 20px;
                margin-bottom: 24px;
            }

            #invoice-template .inv-meta-item {
                flex: 1;
                background: #f8fafc;
                border: 1px solid #e0e7ef;
                border-radius: 6px;
                padding: 10px 14px;
            }

                #invoice-template .inv-meta-item label {
                    font-size: 9px;
                    text-transform: uppercase;
                    letter-spacing: .1em;
                    color: #888;
                    display: block;
                    margin-bottom: 3px;
                }

                #invoice-template .inv-meta-item span {
                    font-size: 13px;
                    font-weight: 600;
                    color: #1a2e4a;
                }

            /* ── Items table ── */
            #invoice-template table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 0;
                font-size: 12.5px;
            }

            #invoice-template thead tr {
                background: #1a2e4a;
                color: #fff;
            }

            #invoice-template thead th {
                padding: 10px 12px;
                font-size: 11px;
                font-weight: 600;
                letter-spacing: .04em;
                text-align: left;
                border: none;
            }

                #invoice-template thead th:nth-child(n+5) {
                    text-align: right;
                }

            #invoice-template tbody tr:nth-child(even) {
                background: #f8fafc;
            }

            #invoice-template tbody td {
                padding: 9px 12px;
                border-bottom: 1px solid #eaecef;
                vertical-align: middle;
            }

                #invoice-template tbody td:nth-child(n+5) {
                    text-align: right;
                }

            #invoice-template tfoot tr {
                background: #eef3f8;
            }

            #invoice-template tfoot td {
                padding: 12px 12px;
                font-weight: 700;
                border-top: 2px solid #1a2e4a;
                font-size: 14px;
                text-align: right;
                color: #1a2e4a;
            }

                #invoice-template tfoot td:first-child {
                    text-align: left;
                    font-size: 13px;
                }

            /* ── Footer ── */
            #invoice-template .inv-note {
                margin-top: 24px;
                padding: 10px 16px;
                background: #f8fafc;
                border-left: 4px solid #4a9eda;
                font-size: 11.5px;
                color: #555;
                border-radius: 0 4px 4px 0;
            }

            #invoice-template .inv-footer {
                margin-top: 28px;
                padding-top: 14px;
                border-top: 1px solid #ddd;
                display: flex;
                justify-content: space-between;
                font-size: 10.5px;
                color: #999;
            }

            #invoice-template .inv-stamp {
                text-align: right;
                margin-top: 40px;
                padding-top: 10px;
                border-top: 1px dashed #bbb;
                font-size: 11px;
                color: #888;
                width: 180px;
                margin-left: auto;
            }
    </style>

    <!-- Header -->
    <div class="inv-header">
        <div class="inv-logo">
            🥛 <span>DMS</span>
            <small>Dairy Industry Pvt. Ltd. — Sales Division</small>
        </div>
        <div class="inv-title">
            <h2>TAX INVOICE</h2>
            <div class="inv-number">Invoice No: <strong>INV-@Model.OrderId.ToString("D5")</strong></div>
            <div><span class="inv-status">@Model.OrderStatus</span></div>
        </div>
    </div>

    <!-- Meta row -->
    <div class="inv-meta-row">
        <div class="inv-meta-item">
            <label>Order ID</label>
            <span>#@Model.OrderId</span>
        </div>
        <div class="inv-meta-item">
            <label>Order Date</label>
            <span>@Model.OrderDate.ToString("dd MMM yyyy")</span>
        </div>
        <div class="inv-meta-item">
            <label>Processing Plant</label>
            <span>@(Model.PlantName ?? "—")</span>
        </div>
        <div class="inv-meta-item">
            <label>Invoice Generated</label>
            <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </div>

    <!-- Parties -->
    <div class="inv-parties">
        <div class="inv-party">
            <div class="inv-party-label">Bill From</div>
            <div class="inv-party-name">Dairy Industry Pvt. Ltd.</div>
            <div class="inv-party-detail">
                @(Model.PlantName ?? "Processing Plant")<br />
                Gujarat, India<br />
                GSTIN: 24XXXXX0000X1ZX
            </div>
        </div>
        <div class="inv-party">
            <div class="inv-party-label">Bill To</div>
            <div class="inv-party-name">@Model.DistributorName</div>
            <div class="inv-party-detail">
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    @Model.Location

                    <br />
                }
                @if (!string.IsNullOrEmpty(Model.ContactNumber))
                {
                    @:Phone: @Model.ContactNumber
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <div style="margin-bottom:16px; padding:10px 14px; background:#fffbea;
                        border-left:4px solid #f39c12; border-radius:0 4px 4px 0; font-size:12px;">
            <strong>Order Note:</strong> @Model.Notes
        </div>
    }

    <!-- Items table -->
    <table>
        <thead>
            <tr>
                <th style="width:30px">#</th>
                <th>Product Name</th>
                <th>Type</th>
                <th>Unit</th>
                <th>Qty</th>
                <th>Unit Price (₹)</th>
                <th>Amount (₹)</th>
            </tr>
        </thead>
        <tbody>
            @{
                int inv_row = 1;
            }
            @foreach (var item in Model.OrderDetails)
            {
                <tr>
                    <td>@(inv_row++)</td>
                    <td><strong>@item.ProductName</strong></td>
                    <td>@item.ProductType</td>
                    <td>@item.Unit</td>
                    <td>@item.Quantity.ToString("N2")</td>
                    <td>₹@item.UnitPrice.ToString("N2")</td>
                    <td>₹@item.LineTotal.ToString("N2")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="6">Grand Total</td>
                <td>₹@Model.TotalAmount.ToString("N2")</td>
            </tr>
        </tfoot>
    </table>

    <!-- Note -->
    <div class="inv-note">
        ✅ This is a computer-generated invoice and does not require a physical signature.
    </div>

    <!-- Stamp / Signature area -->
    <div class="inv-stamp">
        Authorised Signatory<br />
        Dairy Industry Pvt. Ltd.
    </div>

    <!-- Footer -->
    <div class="inv-footer">
        <span>Generated: @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</span>
        <span>DMS — Dairy Management System</span>
    </div>
</div>

