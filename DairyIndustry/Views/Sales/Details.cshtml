@model DairyIndustry.Models.SalesOrderModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_SalesLayout.cshtml";
    string role = Context.Session.GetString("RoleName") ?? "";
    bool isAdmin = role == "Admin";
    var productList = ViewBag.ProductList as List<DairyIndustry.Models.ProductSalesModel> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Order #@Model.OrderId</h4>
        <small class="text-muted">@Model.OrderDate.ToString("dd MMM yyyy") — @Model.DistributorName</small>
    </div>
    @if (isAdmin)
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← All Orders</a>
    }
    else
    {
        <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm">← My Orders</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- ── Order Summary Card ── -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-semibold text-white" style="background:#1a2e4a;">📋 Order Info</div>
            <div class="card-body">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted">Distributor</td><td><strong>@Model.DistributorName</strong></td></tr>
                    <tr><td class="text-muted">Location</td><td>@(Model.Location ?? "—")</td></tr>
                    <tr><td class="text-muted">Contact</td><td>@(Model.ContactNumber ?? "—")</td></tr>
                    <tr><td class="text-muted">Plant</td><td>@(Model.PlantName ?? "—")</td></tr>
                    <tr><td class="text-muted">Order Date</td><td>@Model.OrderDate.ToString("dd MMM yyyy")</td></tr>
                    <tr>
                        <td class="text-muted">Status</td>
                        <td>
                            @{
                                string badge = Model.OrderStatus switch
                                {
                                    "Pending" => "warning text-dark",
                                    "Confirmed" => "primary",
                                    "Dispatched" => "info text-dark",
                                    "Delivered" => "success",
                                    "Cancelled" => "danger",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@badge">@Model.OrderStatus</span>
                        </td>
                    </tr>
                    <tr><td class="text-muted">Total Amount</td><td><strong>₹@Model.TotalAmount.ToString("N2")</strong></td></tr>
                </table>
            </div>
        </div>
    </div>

    @if (isAdmin)
    {
        <!-- Admin: update status -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header fw-semibold text-white" style="background:#1a2e4a;">🔄 Update Status</div>
                <div class="card-body d-flex flex-column justify-content-center gap-2">
                    @foreach (var s in new[] { "Pending", "Confirmed", "Dispatched", "Delivered", "Cancelled" })
                    {
                        if (s != Model.OrderStatus)
                        {
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="newStatus" value="@s" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                    Mark as @s
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- ── Order Items Table ── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-semibold" style="background:#f8f9fa;">
        📦 Order Items (@(Model.OrderDetails?.Count ?? 0) product@(Model.OrderDetails?.Count == 1 ? "" : "s"))
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Type</th>
                    <th>Unit</th>
                    <th class="text-end">Qty</th>
                    <th class="text-end">Unit Price (MRP)</th>
                    <th class="text-end">Line Total</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.OrderDetails == null || !Model.OrderDetails.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No products added yet.</td></tr>
                }
                else
                {
                    @foreach (var d in Model.OrderDetails)
                    {
                        <tr>
                            <td><strong>@d.ProductName</strong></td>
                            <td><span class="badge bg-light text-dark border">@d.ProductType</span></td>
                            <td>@d.Unit</td>
                            <td class="text-end">@d.Quantity.ToString("N2")</td>
                            <td class="text-end">₹@d.UnitPrice.ToString("N2")</td>
                            <td class="text-end"><strong>₹@d.LineTotal.ToString("N2")</strong></td>
                        </tr>
                    }
                    <tr class="table-light fw-bold">
                        <td colspan="5" class="text-end">Total</td>
                        <td class="text-end">₹@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── Add Product Form (only for Pending orders) ── -->
@if (Model.OrderStatus == "Pending")
{
    <div class="card border-0 shadow-sm">
        <div class="card-header fw-semibold text-white" style="background:#1a2e4a;">
            ➕ Add Product to Order
        </div>
        <div class="card-body p-4">
            <p class="text-muted small mb-3">
                Unit price is set automatically from the current product rate (MRP).
                @if (!isAdmin)
                {
                    <span>Adding the same product again will <strong>increase the existing quantity</strong> — no duplicate row will be created.</span>
                }
                else
                {
                    <span>Adding the same product again will <strong>merge quantities</strong> — no duplicate row will be created.</span>
                }
            </p>
            <form asp-action="AddOrderDetail" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="OrderId" value="@Model.OrderId" />
                {{!-- UnitPrice is intentionally NOT shown — controller fetches MRP automatically --}}

                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Product</label>
                        <select name="ProductId" id="detailProductSelect" class="form-select" required>
                            <option value="">— Select Product —</option>
                            @foreach (var p in productList)
                            {
                                <option value="@p.ProductId" data-mrp="@p.MRP" data-unit="@p.Unit">
                                    @p.ProductName (@p.ProductType)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Quantity</label>
                        <input name="Quantity" type="number" step="0.01" min="0.01"
                               class="form-control" placeholder="e.g. 10" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Unit Price (MRP)</label>
                        <div class="form-control bg-light text-muted" id="mrpDisplay" style="cursor:not-allowed;">
                            Select a product
                        </div>
                        {{!-- Hidden field satisfies model binding if UnitPrice is required --}}
                        <input type="hidden" name="UnitPrice" id="unitPriceHidden" value="0" />
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-success w-100">Add</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('detailProductSelect')?.addEventListener('change', function () {
            const opt  = this.options[this.selectedIndex];
            const mrp  = opt.getAttribute('data-mrp');
            const unit = opt.getAttribute('data-unit');
            const display = document.getElementById('mrpDisplay');
            const hidden  = document.getElementById('unitPriceHidden');
            if (mrp) {
                display.textContent = '₹' + parseFloat(mrp).toFixed(2) + ' / ' + (unit || 'unit');
                hidden.value = mrp;
            } else {
                display.textContent = 'Select a product';
                hidden.value = '0';
            }
        });
    </script>
}
