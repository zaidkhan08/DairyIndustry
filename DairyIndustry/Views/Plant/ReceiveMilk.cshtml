@model DairyIndustry.Models.Production.ReceiveMilkViewModel

@{
    ViewData["Title"] = "Receive Milk";
    Layout = "_CollectionCenterLayout";
}

<div class="container mt-4" style="max-width:600px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Receive Milk</h4>
        <a asp-action="IncomingTransfers"
           class="btn btn-outline-secondary btn-sm">
            &larr; Back
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- TRANSFER INFO — readonly display -->
    <div class="card border-0 bg-light mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">Transfer Details</h6>
            <div class="row g-2 text-center">
                <div class="col-6">
                    <small class="text-muted d-block">From Center</small>
                    <strong>@Model.CenterName</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Milk Type</small>
                    <strong>@Model.MilkTypeName</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Vehicle</small>
                    <strong>@Model.VehicleNumber</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Driver</small>
                    <strong>@(Model.DriverName ?? "-")</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Dispatch Date</small>
                    <strong>@Model.DispatchDate.ToString("dd MMM yyyy")</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Dispatched Qty</small>
                    <strong class="text-primary">
                        @Model.DispatchQty.ToString("F2") L
                    </strong>
                </div>
            </div>
        </div>
    </div>

    <!-- RECEIVE FORM -->
    <div class="card shadow-sm">
        <div class="card-header fw-semibold bg-success text-white">
            Enter Received Details
        </div>
        <div class="card-body">
            <form asp-action="ReceiveMilk" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="TransferId" />
                <input type="hidden" asp-for="CenterName" />
                <input type="hidden" asp-for="MilkTypeName" />
                <input type="hidden" asp-for="VehicleNumber" />
                <input type="hidden" asp-for="DriverName" />
                <input type="hidden" asp-for="DispatchQty" />
                <input type="hidden" asp-for="DispatchDate" />

                <!-- RECEIVED QTY -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Received Quantity (L)
                        <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ReceivedQty"
                           type="number"
                           step="0.01"
                           class="form-control"
                           max="@Model.DispatchQty"
                           placeholder="e.g. 218.00" />
                    <small class="text-muted">
                        Max: @Model.DispatchQty.ToString("F2") L
                    </small>
                    <span asp-validation-for="ReceivedQty"
                          class="text-danger small"></span>
                </div>

                <!-- RECEIVED DATE -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Received Date
                        <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ReceivedDate"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="ReceivedDate"
                          class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100">
                    ✅ Confirm Receipt
                </button>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}