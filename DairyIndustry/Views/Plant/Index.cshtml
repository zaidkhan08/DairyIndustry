@model DairyIndustry.Models.Production.PlantStaffModel


@{
    ViewData["Title"] = "Plant Dashboard";
    Layout = "_CollectionCenterLayout";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h4 class="fw-bold">
            Welcome, @Context.Session.GetString("StaffName")
        </h4>
        <p class="text-muted">
            @ViewBag.PlantName
        </p>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="row g-3">

        <div class="col-md-4">
            <a asp-action="IncomingTransfers"
               asp-controller="Plant"
               class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center py-4">
                    <div class="fs-1">🚛</div>
                    <h6 class="mt-2 fw-semibold">Incoming Transfers</h6>
                    <small class="text-muted">
                        Receive milk from centers
                    </small>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="RawMilkInventory"
               asp-controller="Plant"
               class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center py-4">
                    <div class="fs-1">🥛</div>
                    <h6 class="mt-2 fw-semibold">Raw Milk Inventory</h6>
                    <small class="text-muted">
                        View available raw milk
                    </small>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="Logout"
               asp-controller="Auth"
               class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center py-4">
                    <div class="fs-1">🚪</div>
                    <h6 class="mt-2 fw-semibold">Logout</h6>
                    <small class="text-muted">
                        Sign out
                    </small>
                </div>
            </a>
        </div>

    </div>
</div>