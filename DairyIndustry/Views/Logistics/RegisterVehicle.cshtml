@{
    ViewData["Title"] = "Register Vehicle";
    Layout = "~/Views/Shared/_LogisticsLayout.cshtml";
}

<div class="container-fluid p-4">

    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-10">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                        <div>@TempData["Success"]</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="bg-primary" style="height:4px;"></div>

                <div class="card-header bg-white border-0 py-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px;height:48px;">
                            <i class="bi bi-truck text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">Register a Vehicle</h5>
                            <p class="text-muted small mb-0">Add a transport vehicle to your fleet. Admin will verify before use.</p>
                        </div>
                    </div>
                </div>

                <div class="card-body px-4 pb-4 pt-2">

                    <form method="post" asp-action="RegisterVehicle" asp-controller="Logistics"
                          id="registerVehicleForm" novalidate>

                        <!-- Vehicle Number -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Vehicle Number <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="bi bi-truck-flatbed"></i>
                                </span>
                                <input type="text" name="vehicleNumber" id="vehicleNumber"
                                       class="form-control border-start-0 ps-1 text-uppercase"
                                       placeholder="e.g. GJ05AB1234"
                                       maxlength="20" required
                                       oninput="this.value = this.value.toUpperCase()" />
                                <div class="invalid-feedback">Vehicle number is required.</div>
                            </div>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Enter the registered vehicle plate number (e.g. GJ05AB1234).
                            </div>
                        </div>

                        <!-- Capacity -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Milk Capacity (Litres) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="bi bi-droplet-fill text-info"></i>
                                </span>
                                <input type="number" name="capacity" id="capacity"
                                       class="form-control border-start-0 ps-1"
                                       placeholder="e.g. 500"
                                       min="50" max="50000" step="10" required />
                                <span class="input-group-text bg-light text-muted">Ltr</span>
                                <div class="invalid-feedback">Please enter a valid capacity (50–50,000 Ltr).</div>
                            </div>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Maximum milk load this vehicle can carry in a single trip.
                            </div>
                        </div>

                        <!-- Info alert -->
                        <div class="alert alert-info border-0 small d-flex align-items-start gap-2 mb-4">
                            <i class="bi bi-shield-check text-info flex-shrink-0 mt-1"></i>
                            <div>
                                Your vehicle will appear as <strong>Pending</strong> until an administrator verifies it.
                                Only <strong>Approved</strong> vehicles can be used in logistics shifts.
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i> Register Vehicle
                            </button>
                            <a asp-action="MyVehicles" class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bootstrap validation
        document.getElementById('registerVehicleForm').addEventListener('submit', function (e) {
            if (!this.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            }
            this.classList.add('was-validated');
        });
    </script>
}
