@model List<DairyIndustry.Models.Logistics.VehiclesModel>
@{
    ViewData["Title"] = "All Vehicles";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-dark text-white py-4 px-4 mb-4 shadow-sm">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-truck me-2"></i>All Vehicles
            </h4>
            <p class="mb-0 opacity-75 small">
                Review and approve vehicle registrations submitted by drivers.
            </p>
        </div>
        <span class="badge bg-light text-dark fw-semibold px-3 py-2">
            <i class="bi bi-truck me-1"></i>Total: @Model.Count
        </span>
    </div>
</div>

<div class="container-fluid px-4 pb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-hourglass-split text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(v => v.Status == "Pending")
                        </div>
                        <small class="text-muted">Pending</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-success bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-check-circle text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(v => v.Status == "Approved")
                        </div>
                        <small class="text-muted">Approved</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-danger bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-x-circle text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(v => v.Status == "Rejected")
                        </div>
                        <small class="text-muted">Rejected</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicles Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
            <i class="bi bi-table text-dark"></i>
            <span class="fw-semibold">Vehicle Records</span>
        </div>
        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-truck display-4 d-block mb-3"></i>
                    <h6 class="fw-semibold">No vehicles registered yet</h6>
                    <p class="small">Vehicle registrations will appear here once drivers submit them.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                                <th class="py-3 text-muted fw-semibold small">Vehicle</th>
                                <th class="py-3 text-muted fw-semibold small">Capacity</th>
                                <th class="py-3 text-muted fw-semibold small">Driver</th>
                                <th class="py-3 text-muted fw-semibold small">Driver Status</th>
                                <th class="py-3 text-muted fw-semibold small">Registered On</th>
                                <th class="py-3 text-muted fw-semibold small">Status</th>
                                <th class="py-3 text-muted fw-semibold small text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vehicle in Model)
                            {
                                string vehicleBadge = vehicle.Status switch
                                {
                                    "Approved" => "success",
                                    "Pending" => "warning",
                                    "Rejected" => "danger",
                                    _ => "secondary"
                                };

                                string driverBadge = vehicle.DriverStatus switch
                                {
                                    "Active" => "success",
                                    "Pending" => "warning",
                                    "Inactive" => "secondary",
                                    "Suspended" => "danger",
                                    _ => "secondary"
                                };

                                <tr>
                                    <td class="px-4 text-muted small">#@vehicle.VehicleId</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-dark text-white rounded-3 d-flex align-items-center
                                                                justify-content-center flex-shrink-0"
                                                 style="width:38px; height:38px;">
                                                <i class="bi bi-truck"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold small">@vehicle.VehicleNumber</div>
                                                <div class="text-muted" style="font-size:.75rem;">
                                                    ID: #@vehicle.VehicleId
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small fw-semibold">
                                        @vehicle.Capacity.ToString("F0") Ltr
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">@vehicle.DriverName</div>
                                        <div class="text-muted" style="font-size:.75rem;">
                                            @(string.IsNullOrEmpty(vehicle.Phone) ? "—" : vehicle.Phone)
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-@driverBadge">
                                            @vehicle.DriverStatus
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        @vehicle.RegisteredOn.ToString("dd MMM yyyy")
                                    </td>
                                    <td>
                                        <span class="badge bg-@vehicleBadge">@vehicle.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1 flex-wrap">

                                            @if (vehicle.Status == "Pending" || vehicle.Status == "Rejected")
                                            {
                                                <form method="post" action="/Logistics/UpdateVehicleStatus">
                                                    <input type="hidden" name="vehicleId" value="@vehicle.VehicleId" />
                                                    <input type="hidden" name="status" value="Approved" />
                                                    <button type="submit" class="btn btn-success btn-sm fw-semibold">
                                                        <i class="bi bi-check-circle me-1"></i>Approve
                                                    </button>
                                                </form>
                                            }

                                            @if (vehicle.Status == "Pending" || vehicle.Status == "Approved")
                                            {
                                                <form method="post" action="/Logistics/UpdateVehicleStatus">
                                                    <input type="hidden" name="vehicleId" value="@vehicle.VehicleId" />
                                                    <input type="hidden" name="status" value="Rejected" />
                                                    <button type="submit" class="btn btn-danger btn-sm fw-semibold">
                                                        <i class="bi bi-x-circle me-1"></i>Reject
                                                    </button>
                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>

</div>