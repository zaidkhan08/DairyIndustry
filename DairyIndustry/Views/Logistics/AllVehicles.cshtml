@model List<DairyIndustry.Models.Logistics.VehiclesModel>
@{
    ViewData["Title"] = "All Vehicles";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Badge Helper
    string GetStatusClass(string s) => s switch
    {
        "Approved" or "Active" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Rejected" or "Suspended" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container-fluid p-4">

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex">
                    <div class="bg-warning d-flex align-items-center justify-content-center px-4">
                        <i class="bi bi-clock-history text-white fs-3"></i>
                    </div>
                    <div class="p-3">
                        <h4 class="mb-0 fw-bold">@Model.Count(v => v.Status == "Pending")</h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px;">Awaiting Review</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex">
                    <div class="bg-success d-flex align-items-center justify-content-center px-4">
                        <i class="bi bi-patch-check text-white fs-3"></i>
                    </div>
                    <div class="p-3">
                        <h4 class="mb-0 fw-bold">@Model.Count(v => v.Status == "Approved")</h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px;">Active Fleet</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex">
                    <div class="bg-dark d-flex align-items-center justify-content-center px-4">
                        <i class="bi bi-truck text-white fs-3"></i>
                    </div>
                    <div class="p-3">
                        <h4 class="mb-0 fw-bold">@Model.Count</h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px;">Total Registered</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="alert @(TempData["Success"] != null ? "alert-success" : "alert-danger") border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi @(TempData["Success"] != null ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @(TempData["Success"] ?? TempData["Error"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 fw-bold"><i class="bi bi-list-stars me-2 text-primary"></i>Vehicle Registry</h6>
            <div class="dropdown">
                <button class="btn btn-light btn-sm border dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-filter me-1"></i> Filter Status
                </button>
                <ul class="dropdown-menu shadow border-0">
                    <li><a class="dropdown-item" href="#">All</a></li>
                    <li><a class="dropdown-item" href="#">Approved</a></li>
                    <li><a class="dropdown-item" href="#">Pending</a></li>
                </ul>
            </div>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-truck-front display-1 text-light"></i>
                    <p class="text-muted mt-3">No vehicle submissions to display.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="border-0 px-4">Vehicle Detail</th>
                                <th class="border-0">Volume (Ltr)</th>
                                <th class="border-0">Assigned Driver</th>
                                <th class="border-0 text-center">Registration</th>
                                <th class="border-0 text-center">Status</th>
                                <th class="border-0 text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded p-2 me-3">
                                                <i class="bi bi-truck text-dark fs-5"></i>
                                            </div>
                                            <div>
                                                <span class="fw-bold d-block text-dark">@v.VehicleNumber</span>
                                                <small class="text-muted">ID: #@v.VehicleId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="fw-semibold">@v.Capacity.ToString("N0")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div>
                                                <span class="d-block fw-medium small">@v.DriverName</span>
                                                <span class="badge @GetStatusClass(v.DriverStatus)" style="font-size: 9px;">
                                                    Driver @v.DriverStatus
                                                </span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <small class="text-muted">@v.RegisteredOn.ToString("dd MMM yyyy")</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetStatusClass(v.Status) px-3 py-2 rounded-pill">
                                            @v.Status
                                        </span>
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            @if (v.Status != "Approved")
                                            {
                                                <form method="post" asp-action="UpdateVehicleStatus" asp-controller="Logistics">
                                                    <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                    <input type="hidden" name="status" value="Approved" />
                                                    <button type="submit" class="btn btn-sm btn-success px-3 shadow-sm">Approve</button>
                                                </form>
                                            }
                                            @if (v.Status != "Rejected")
                                            {
                                                <form method="post" asp-action="UpdateVehicleStatus" asp-controller="Logistics">
                                                    <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                    <input type="hidden" name="status" value="Rejected" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3">Reject</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>