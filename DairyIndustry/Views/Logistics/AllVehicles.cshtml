@model List<DairyIndustry.Models.Logistics.VehiclesModel>
@{
    ViewBag.Title = "All Vehicles";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Header -->
<div class="bg-primary text-white py-3 mb-4 shadow-sm">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-truck fs-4"></i>
                <div>
                    <h4 class="mb-0 fw-bold">All Vehicles</h4>
                    <small class="opacity-75">Review and manage vehicle registrations</small>
                </div>
            </div>
            <span class="badge bg-white text-primary fs-6 fw-bold px-3 py-2">
                @Model.Count Total
            </span>
        </div>
    </div>
</div>

<div class="container-fluid mb-5">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2" style="background:#e8f0fe;">
                        <i class="bi bi-truck text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">@Model.Count</div>
                        <small class="text-muted">Total Vehicles</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2" style="background:#d1fae5;">
                        <i class="bi bi-check-circle-fill text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">@Model.Count(v => v.Status == "Approved")</div>
                        <small class="text-muted">Approved</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2" style="background:#fef9c3;">
                        <i class="bi bi-hourglass-split text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">@Model.Count(v => v.Status == "Pending")</div>
                        <small class="text-muted">Pending</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2" style="background:#fee2e2;">
                        <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">@Model.Count(v => v.Status == "Rejected")</div>
                        <small class="text-muted">Rejected</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-pills mb-3" id="vehicleTabs">
        <li class="nav-item">
            <button class="nav-link active" onclick="filterTable('All')">
                All
                <span class="badge bg-primary ms-1">@Model.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Pending')">
                <i class="bi bi-hourglass-split me-1"></i>Pending
                <span class="badge bg-warning text-dark ms-1">
                    @Model.Count(v => v.Status == "Pending")
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Approved')">
                <i class="bi bi-check-circle me-1"></i>Approved
                <span class="badge bg-success ms-1">
                    @Model.Count(v => v.Status == "Approved")
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Rejected')">
                <i class="bi bi-x-circle me-1"></i>Rejected
                <span class="badge bg-danger ms-1">
                    @Model.Count(v => v.Status == "Rejected")
                </span>
            </button>
        </li>
    </ul>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="vehiclesTable">
                    <thead style="background:#e8f0fe;">
                        <tr>
                            <th class="ps-3 text-primary">#</th>
                            <th class="text-primary">Vehicle</th>
                            <th class="text-primary">Capacity</th>
                            <th class="text-primary">Driver</th>
                            <th class="text-primary">Driver Status</th>
                            <th class="text-primary">Vehicle RC</th>
                            <th class="text-primary">Phone</th>
                            <th class="text-primary">Registered</th>
                            <th class="text-primary">Status</th>
                            <th class="text-primary pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-truck fs-1 d-block mb-2 opacity-50"></i>
                                    No vehicles registered yet.
                                </td>
                            </tr>
                        }

                        @foreach (var v in Model)
                        {
                            <tr data-status="@v.Status">
                                <td class="ps-3 text-muted small">@v.VehicleId</td>

                                <!-- Vehicle Number + Capacity pill -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-3 d-flex align-items-center
                                                        justify-content-center bg-primary bg-opacity-10"
                                             style="width:38px;height:38px;flex-shrink:0;">
                                            <i class="bi bi-truck text-primary"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold font-monospace">@v.VehicleNumber</div>
                                            <small class="text-muted">ID: @v.VehicleId</small>
                                        </div>
                                    </div>
                                </td>

                                <!-- Capacity -->
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-droplet me-1 text-primary"></i>
                                        @v.Capacity.ToString("N0") L
                                    </span>
                                </td>

                                <!-- Driver info -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-secondary bg-opacity-25
                                                        text-dark d-flex align-items-center
                                                        justify-content-center fw-bold"
                                             style="width:32px;height:32px;font-size:.8rem;flex-shrink:0;">
                                            @v.DriverName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-medium">@v.DriverName</div>
                                            @if (!string.IsNullOrEmpty(v.Phone))
                                            {
                                                <small class="text-muted">@v.Phone</small>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <!-- Driver Status -->
                                <td>
                                    @if (v.DriverStatus == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2">
                                            <i class="bi bi-check-circle me-1"></i>Active
                                        </span>
                                    }
                                    else if (v.DriverStatus == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2">
                                            <i class="bi bi-hourglass-split me-1"></i>Pending
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2">
                                            <i class="bi bi-x-circle me-1"></i>@v.DriverStatus
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(v.VehicleRCPath))
                                    {
                                        <a href="@v.VehicleRCPath" target="_blank"
                                           class="btn btn-sm btn-outline-primary px-2 py-1">
                                            <i class="bi bi-file-earmark-text me-1"></i>View DL
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-25 text-secondary">
                                            Not uploaded
                                        </span>
                                    }
                                </td>

                                <!-- Phone -->
                                <td class="small text-muted">
                                    @(string.IsNullOrEmpty(v.Phone) ? "—" : v.Phone)
                                </td>

                                <!-- Registered On -->
                                <td class="small text-muted">
                                    @v.RegisteredOn.ToString("dd MMM yyyy")
                                    <br />
                                    <span style="font-size:.75rem;">
                                        @v.RegisteredOn.ToString("hh:mm tt")
                                    </span>
                                </td>

                                <!-- Vehicle Status Badge -->
                                <td>
                                    @if (v.Status == "Approved")
                                    {
                                        <span class="badge bg-success px-2 py-1">
                                            <i class="bi bi-check-circle me-1"></i>Approved
                                        </span>
                                    }
                                    else if (v.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1">
                                            <i class="bi bi-hourglass-split me-1"></i>Pending
                                        </span>
                                    }
                                    else if (v.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger px-2 py-1">
                                            <i class="bi bi-x-circle me-1"></i>Rejected
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1">@v.Status</span>
                                    }
                                </td>

                                <!-- Actions -->
                                <td class="pe-3">
                                    <div class="d-flex gap-1 flex-wrap">

                                        @if (v.Status == "Pending")
                                        {
                                            <!-- Approve -->
                                            <form asp-controller="Logistics"
                                                  asp-action="UpdateVehicleStatus"
                                                  method="post" class="m-0">
                                                <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-success px-2 py-1"
                                                        title="Approve vehicle"
                                                        onclick="return confirm('Approve vehicle @v.VehicleNumber for @v.DriverName?')">
                                                    <i class="bi bi-check-lg me-1"></i>Approve
                                                </button>
                                            </form>

                                            <!-- Reject -->
                                            <form asp-controller="Logistics"
                                                  asp-action="UpdateVehicleStatus"
                                                  method="post" class="m-0">
                                                <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger px-2 py-1"
                                                        title="Reject vehicle"
                                                        onclick="return confirm('Reject vehicle @v.VehicleNumber?')">
                                                    <i class="bi bi-x-lg me-1"></i>Reject
                                                </button>
                                            </form>
                                        }

                                        else if (v.Status == "Approved")
                                        {
                                            <!-- Revoke -->
                                            <form asp-controller="Logistics"
                                                  asp-action="UpdateVehicleStatus"
                                                  method="post" class="m-0">
                                                <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger px-2 py-1"
                                                        title="Revoke vehicle approval"
                                                        onclick="return confirm('Revoke approval for @v.VehicleNumber? The driver will be notified.')">
                                                    <i class="bi bi-slash-circle me-1"></i>Revoke
                                                </button>
                                            </form>
                                        }

                                        else if (v.Status == "Rejected")
                                        {
                                            <!-- Re-review -->
                                            <form asp-controller="Logistics"
                                                  asp-action="UpdateVehicleStatus"
                                                  method="post" class="m-0">
                                                <input type="hidden" name="vehicleId" value="@v.VehicleId" />
                                                <input type="hidden" name="status" value="Pending" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-secondary px-2 py-1"
                                                        title="Reset to Pending for re-review">
                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Re-review
                                                </button>
                                            </form>
                                        }

                                        <!-- Driver inactive warning -->
                                        @if (v.DriverStatus != "Active" && v.Status == "Approved")
                                        {
                                            <span class="badge bg-warning text-dark ms-1"
                                                  title="Vehicle is approved but driver is not active">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Driver inactive
                                            </span>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Approved but Driver Inactive Warning Banner -->
    @{
        int mismatchCount = Model.Count(v => v.Status == "Approved" && v.DriverStatus != "Active");
    }
    @if (mismatchCount > 0)
    {
        <div class="alert alert-warning d-flex gap-2 align-items-start mt-3 mb-0">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <div>
                <strong>@mismatchCount vehicle(s)</strong> are approved but assigned to
                <strong>inactive or pending drivers</strong>.
                These vehicles cannot be used for transfers until the driver is also approved.
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        function filterTable(status) {
            const rows = document.querySelectorAll('#vehiclesTable tbody tr[data-status]');
            rows.forEach(row => {
                row.style.display =
                    (status === 'All' || row.dataset.status === status) ? '' : 'none';
            });

            document.querySelectorAll('#vehicleTabs .nav-link').forEach(btn => {
                const text = btn.textContent.trim();
                const matches =
                    status === 'All'      ? text.startsWith('All')      :
                    status === 'Approved' ? text.startsWith('Approved') :
                    status === 'Pending'  ? text.startsWith('Pending')  :
                    status === 'Rejected' ? text.startsWith('Rejected') : false;
                btn.classList.toggle('active', matches);
            });
        }
    </script>
}
