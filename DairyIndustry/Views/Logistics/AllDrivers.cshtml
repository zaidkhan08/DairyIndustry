@model List<DairyIndustry.Models.Logistics.DriversModel>
@{
    ViewData["Title"] = "All Drivers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Status Helper
    string GetStatusBadge(string status) => status switch
    {
        "Active" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Suspended" => "bg-danger",
        "Inactive" => "bg-secondary",
        _ => "bg-dark"
    };
}

<div class="container-fluid p-4">

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-white-50 d-block mb-1 text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Total Fleet</small>
                        <h3 class="mb-0 fw-bold">@Model.Count</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        
        @{
            var stats = new[] { 
                new { Label = "Pending", Count = Model.Count(d => d.Status == "Pending"), Color = "warning", Icon = "bi-clock-history" },
                new { Label = "Active", Count = Model.Count(d => d.Status == "Active"), Color = "success", Icon = "bi-check-all" },
                new { Label = "Suspended", Count = Model.Count(d => d.Status == "Suspended"), Color = "danger", Icon = "bi-exlamation-octagon" }
            };
        }

        @foreach (var stat in stats)
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3 d-flex align-items-center">
                        <div class="bg-@stat.Color bg-opacity-10 text-@stat.Color rounded-3 p-2 me-3">
                            <i class="@stat.Icon fs-4"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">@stat.Label</small>
                            <h4 class="mb-0 fw-bold text-dark">@stat.Count</h4>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        var isSuccess = TempData["Success"] != null;
        <div class="alert @(isSuccess ? "alert-success" : "alert-danger") border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi @(isSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @(isSuccess ? TempData["Success"] : TempData["Error"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3 border-0 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-person-badge me-2 text-primary"></i>Driver Directory</h6>
            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm border" onclick="window.print()"><i class="bi bi-printer me-1"></i> Export</button>
            </div>
        </div>
        
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-light"></i>
                    <p class="text-muted mt-3">No driver records found in the system.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="border-0 px-4">Driver Profile</th>
                                <th class="border-0">Credentials</th>
                                <th class="border-0 text-center">Vehicle Info</th>
                                <th class="border-0 text-center">Status</th>
                                <th class="border-0 text-end px-4">Management</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var driver in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" style="width: 42px; height: 42px;">
                                                @driver.DriverName[0].ToString().ToUpper()
                                            </div>
                                            <div>
                                                <span class="fw-bold d-block text-dark">@driver.DriverName</span>
                                                <small class="text-muted d-flex align-items-center">
                                                    <i class="bi bi-calendar-event me-1"></i> Joined: @driver.RegisteredOn.ToString("dd MMM yy")
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">
                                            <div class="mb-1"><i class="bi bi-credit-card-2-front me-2 text-muted"></i>@driver.LicenseNo</div>
                                            <div><i class="bi bi-telephone me-2 text-muted"></i>@(driver.Phone ?? "N/A")</div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(driver.VehicleNumber))
                                        {
                                            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 border border-info border-opacity-25 rounded-pill">
                                                <i class="bi bi-truck me-1"></i>@driver.VehicleNumber
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Not Assigned</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetStatusBadge(driver.Status) px-3 py-2 rounded-pill shadow-sm">
                                            @driver.Status
                                        </span>
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="btn-group shadow-sm">
                                            @if (driver.Status != "Active")
                                            {
                                                <form method="post" asp-action="UpdateDriverStatus" asp-controller="Logistics" class="d-inline">
                                                    <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                    <input type="hidden" name="status" value="Active" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Approve Driver">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                            }
                                            @if (driver.Status == "Active")
                                            {
                                                <form method="post" asp-action="UpdateDriverStatus" asp-controller="Logistics" class="d-inline">
                                                    <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                    <input type="hidden" name="status" value="Inactive" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Deactivate">
                                                        <i class="bi bi-pause-fill"></i>
                                                    </button>
                                                </form>
                                            }
                                            <form method="post" asp-action="UpdateDriverStatus" asp-controller="Logistics" class="d-inline">
                                                <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                <input type="hidden" name="status" value="Suspended" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Suspend">
                                                    <i class="bi bi-slash-circle"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>