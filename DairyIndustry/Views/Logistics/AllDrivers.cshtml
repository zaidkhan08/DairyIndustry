@model List<DairyIndustry.Models.Logistics.DriversModel>
@{
    ViewData["Title"] = "All Drivers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-primary text-white py-4 px-4 mb-4 shadow-sm">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-people me-2"></i>All Drivers
            </h4>
            <p class="mb-0 opacity-75 small">
                Manage driver registrations — approve, suspend or deactivate accounts.
            </p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-light text-primary fw-semibold px-3 py-2">
                <i class="bi bi-people me-1"></i>
                Total: @Model.Count
            </span>
        </div>
    </div>
</div>

<div class="container-fluid px-4 pb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-hourglass-split text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(d => d.Status == "Pending")
                        </div>
                        <small class="text-muted">Pending</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-success bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-check-circle text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(d => d.Status == "Active")
                        </div>
                        <small class="text-muted">Active</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-secondary bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-pause-circle text-secondary fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(d => d.Status == "Inactive")
                        </div>
                        <small class="text-muted">Inactive</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="bg-danger bg-opacity-10 rounded-3 d-flex align-items-center
                                justify-content-center flex-shrink-0"
                         style="width:48px; height:48px;">
                        <i class="bi bi-slash-circle text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4 lh-1">
                            @Model.Count(d => d.Status == "Suspended")
                        </div>
                        <small class="text-muted">Suspended</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Drivers Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
            <i class="bi bi-table text-primary"></i>
            <span class="fw-semibold">Driver Records</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                    <h6 class="fw-semibold">No drivers registered yet</h6>
                    <p class="small">Driver registrations will appear here.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                                <th class="py-3 text-muted fw-semibold small">Driver</th>
                                <th class="py-3 text-muted fw-semibold small">License No</th>
                                <th class="py-3 text-muted fw-semibold small">Phone</th>
                                <th class="py-3 text-muted fw-semibold small">Vehicle</th>
                                <th class="py-3 text-muted fw-semibold small">Registered On</th>
                                <th class="py-3 text-muted fw-semibold small">Status</th>
                                <th class="py-3 text-muted fw-semibold small text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var driver in Model)
                            {
                                string badgeColor = driver.Status switch
                                {
                                    "Active" => "success",
                                    "Pending" => "warning",
                                    "Inactive" => "secondary",
                                    "Suspended" => "danger",
                                    _ => "secondary"
                                };

                                <tr>
                                    <td class="px-4 text-muted small">#@driver.DriverId</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-primary text-white rounded-circle d-flex
                                                                align-items-center justify-content-center fw-bold flex-shrink-0"
                                                 style="width:36px; height:36px; font-size:.85rem;">
                                                @driver.DriverName[0].ToString().ToUpper()
                                            </div>
                                            <div>
                                                <div class="fw-semibold small">@driver.DriverName</div>
                                                <div class="text-muted" style="font-size:.75rem;">
                                                    @@@driver.Username
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border fw-normal">
                                            @driver.LicenseNo
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        @(string.IsNullOrEmpty(driver.Phone) ? "—" : driver.Phone)
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(driver.VehicleNumber))
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success fw-semibold">
                                                <i class="bi bi-truck me-1"></i>@driver.VehicleNumber
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No vehicle</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @driver.RegisteredOn.ToString("dd MMM yyyy")
                                    </td>
                                    <td>
                                        <span class="badge bg-@badgeColor">@driver.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1 flex-wrap">

                                            @if (driver.Status == "Pending" || driver.Status == "Inactive" || driver.Status == "Suspended")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                    <input type="hidden" name="status" value="Active" />
                                                    <button type="submit" class="btn btn-success btn-sm fw-semibold">
                                                        <i class="bi bi-check-circle me-1"></i>Approve
                                                    </button>
                                                </form>
                                            }

                                            @if (driver.Status == "Active")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                    <input type="hidden" name="status" value="Inactive" />
                                                    <button type="submit" class="btn btn-secondary btn-sm fw-semibold">
                                                        <i class="bi bi-pause-circle me-1"></i>Deactivate
                                                    </button>
                                                </form>
                                            }

                                            @if (driver.Status != "Suspended")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                    <input type="hidden" name="status" value="Suspended" />
                                                    <button type="submit" class="btn btn-danger btn-sm fw-semibold">
                                                        <i class="bi bi-slash-circle me-1"></i>Suspend
                                                    </button>
                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>