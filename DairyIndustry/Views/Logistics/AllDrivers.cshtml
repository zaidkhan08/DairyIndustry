@model List<DairyIndustry.Models.Logistics.DriversModel>
@{
    ViewBag.Title = "All Drivers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Header -->
<div class="bg-primary text-white py-3 mb-4 shadow-sm">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-people-fill fs-4"></i>
                <div>
                    <h4 class="mb-0 fw-bold">All Drivers</h4>
                    <small class="opacity-75">Review and manage driver registrations</small>
                </div>
            </div>
            <span class="badge bg-white text-primary fs-6 fw-bold px-3 py-2">
                @Model.Count Total
            </span>
        </div>
    </div>
</div>

<div class="container-fluid mb-5">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Tabs — values match actual DB status values -->
    <ul class="nav nav-pills mb-3" id="driverTabs">
        <li class="nav-item">
            <button class="nav-link active" onclick="filterTable('All')">
                All <span class="badge bg-primary ms-1">@Model.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Pending')">
                <i class="bi bi-hourglass-split me-1"></i>Pending
                <span class="badge bg-warning text-dark ms-1">
                    @Model.Count(d => d.Status == "Pending")
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Active')">
                <i class="bi bi-check-circle me-1"></i>Approved
                <span class="badge bg-success ms-1">
                    @Model.Count(d => d.Status == "Active")
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterTable('Rejected')">
                <i class="bi bi-x-circle me-1"></i>Rejected
                <span class="badge bg-danger ms-1">
                    @Model.Count(d => d.Status == "Rejected")
                </span>
            </button>
        </li>
    </ul>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="driversTable">
                    <thead style="background:#e8f0fe;">
                        <tr>
                            <th class="ps-3 text-primary">#</th>
                            <th class="text-primary">Driver</th>
                            <th class="text-primary">Licence No</th>
                            <th class="text-primary">Phone</th>
                            <th class="text-primary">Email</th>
                            <th class="text-primary">DL Document</th>
                            <th class="text-primary">Vehicle</th>
                            <th class="text-primary">Registered</th>
                            <th class="text-primary">Status</th>
                            <th class="text-primary pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                    No drivers registered yet.
                                </td>
                            </tr>
                        }
                        @foreach (var d in Model)
                        {
                            <tr data-status="@d.Status">
                                <td class="ps-3 text-muted small">@d.DriverId</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary text-white d-flex
                                                        align-items-center justify-content-center fw-bold"
                                             style="width:36px;height:36px;font-size:.85rem;flex-shrink:0;">
                                            @d.DriverName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@d.DriverName</div>
                                            <small class="text-muted">@d.Username</small>
                                        </div>
                                    </div>
                                </td>
                                <td><code class="text-dark">@d.LicenseNo</code></td>
                                <td>@(d.Phone ?? "—")</td>
                                <td class="small">@(d.Email ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.DrivingLicensePath))
                                    {
                                        <a href="@d.DrivingLicensePath" target="_blank"
                                           class="btn btn-sm btn-outline-primary px-2 py-1">
                                            <i class="bi bi-file-earmark-text me-1"></i>View DL
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-25 text-secondary">
                                            Not uploaded
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.VehicleNumber))
                                    {
                                        <div>
                                            <span class="badge bg-light text-dark border">
                                                @d.VehicleNumber
                                            </span>
                                            @if (d.VehicleStatus == "Approved")
                                            {
                                                <span class="badge bg-success ms-1">Approved</span>
                                            }
                                            else if (d.VehicleStatus == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark ms-1">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger ms-1">@d.VehicleStatus</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No vehicle</span>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @d.RegisteredOn.ToString("dd MMM yyyy")
                                    <br /><span style="font-size:.75rem;">@d.RegisteredOn.ToString("hh:mm tt")</span>
                                </td>

                                <td>
                                    @if (d.Status == "Active")
                                    {
                                        <span class="badge bg-success px-2 py-1">
                                            <i class="bi bi-check-circle me-1"></i>Approved
                                        </span>
                                    }
                                    else if (d.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1">
                                            <i class="bi bi-hourglass-split me-1"></i>Pending
                                        </span>
                                    }
                                    else if (d.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger px-2 py-1">
                                            <i class="bi bi-x-circle me-1"></i>Rejected
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1">@d.Status</span>
                                    }
                                </td>

                           
                                <td class="pe-3">
                                    <div class="d-flex gap-1">

                                        @if (d.Status == "Pending")
                                        {
                                            <form asp-action="UpdateDriverStatus" method="post" class="m-0">
                                                <input type="hidden" name="driverId" value="@d.DriverId" />
                                                <input type="hidden" name="status" value="Active" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-success px-2 py-1"
                                                        title="Approve driver"
                                                        onclick="return confirm('Approve @d.DriverName as an active driver?')">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <form asp-action="UpdateDriverStatus" method="post" class="m-0">
                                                <input type="hidden" name="driverId" value="@d.DriverId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger px-2 py-1"
                                                        title="Reject driver"
                                                        onclick="return confirm('Reject @d.DriverName?')">
                                                    <i class="bi bi-x-lg"></i> Reject
                                                </button>
                                            </form>
                                        }
                                        else if (d.Status == "Active")
                                        {
                                            <form asp-action="UpdateDriverStatus" method="post" class="m-0">
                                                <input type="hidden" name="driverId" value="@d.DriverId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger px-2 py-1"
                                                        title="Revoke approval"
                                                        onclick="return confirm('Revoke approval for @d.DriverName? They will lose login access.')">
                                                    <i class="bi bi-slash-circle me-1"></i>Revoke
                                                </button>
                                            </form>
                                        }
                                        else if (d.Status == "Rejected")
                                        {
                                            <form asp-action="UpdateDriverStatus" method="post" class="m-0">
                                                <input type="hidden" name="driverId" value="@d.DriverId" />
                                                <input type="hidden" name="status" value="Pending" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-secondary px-2 py-1"
                                                        title="Reset to Pending for re-review">
                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Re-review
                                                </button>
                                            </form>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function filterTable(status) {
            const rows = document.querySelectorAll('#driversTable tbody tr[data-status]');
            rows.forEach(row => {
                row.style.display = (status === 'All' || row.dataset.status === status) ? '' : 'none';
            });
            // Update active tab highlight
            document.querySelectorAll('#driverTabs .nav-link').forEach(btn => {
                const matches =
                    status === 'All'      ? btn.textContent.trim().startsWith('All') :
                    status === 'Active'   ? btn.textContent.trim().startsWith('Approved') :
                    status === 'Pending'  ? btn.textContent.trim().startsWith('Pending') :
                    status === 'Rejected' ? btn.textContent.trim().startsWith('Rejected') : false;
                btn.classList.toggle('active', matches);
            });
        }
    </script>
}
