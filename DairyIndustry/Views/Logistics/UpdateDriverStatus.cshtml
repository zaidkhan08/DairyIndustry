@model List<DairyIndustry.Models.Logistics.DriversModel>
@{
    ViewData["Title"] = "Driver Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Helper to get status colors
    string GetStatusClass(string status) => status switch
    {
        "Active" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Suspended" => "bg-danger",
        "Inactive" => "bg-secondary",
        _ => "bg-dark"
    };
}

<div class="container-fluid p-4">

    <div class="row g-3 mb-4">
        @{
            var stats = new[] {
                new { Label = "Total Drivers", Count = Model.Count, Icon = "bi-people", Color = "primary" },
                new { Label = "Active", Count = Model.Count(d => d.Status == "Active"), Icon = "bi-check-circle", Color = "success" },
                new { Label = "Pending", Count = Model.Count(d => d.Status == "Pending"), Icon = "bi-hourglass-split", Color = "warning" },
                new { Label = "Suspended", Count = Model.Count(d => d.Status == "Suspended"), Icon = "bi-slash-circle", Color = "danger" }
                };
        }
        @foreach (var s in stats)
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-3 d-flex align-items-center">
                        <div class="bg-@s.Color bg-opacity-10 text-@s.Color rounded-3 d-flex align-items-center justify-content-center me-3"
                             style="width:48px; height:48px;">
                            <i class="bi @s.Icon fs-4"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">@s.Count</h4>
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 0.5px;">@s.Label</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="alert @(TempData["Success"] != null ? "alert-success" : "alert-danger") border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi @(TempData["Success"] != null ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @(TempData["Success"] ?? TempData["Error"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-white border-0 py-3 px-4 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-person-vcard me-2 text-primary"></i>Driver Records</h6>
            <div class="btn-group shadow-sm">
                <button class="btn btn-light btn-sm border" onclick="window.print()"><i class="bi bi-printer me-1"></i> Print</button>
            </div>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-x display-3 text-light"></i>
                    <p class="text-muted mt-2">No registered drivers found in the system.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="border-0 px-4">Driver Profile</th>
                                <th class="border-0">License & Contact</th>
                                <th class="border-0">Assigned Vehicle</th>
                                <th class="border-0">Joined Date</th>
                                <th class="border-0">Status</th>
                                <th class="border-0 text-center px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3"
                                                 style="width:38px; height:38px; font-size: 0.9rem;">
                                                @d.DriverName[0].ToString().ToUpper()
                                            </div>
                                            <div>
                                                <span class="fw-bold d-block text-dark">@d.DriverName</span>
                                                <small class="text-muted">@@@d.Username</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small fw-medium"><i class="bi bi-card-text me-2 text-muted"></i>@d.LicenseNo</div>
                                        <div class="small text-muted"><i class="bi bi-telephone me-2"></i>@(d.Phone ?? "N/A")</div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(d.VehicleNumber))
                                        {
                                            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill border border-info border-opacity-25">
                                                <i class="bi bi-truck me-1"></i> @d.VehicleNumber
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Not Assigned</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@d.RegisteredOn.ToString("dd MMM yyyy")</small>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusClass(d.Status) px-3 py-2 rounded-pill shadow-xs">
                                            @d.Status
                                        </span>
                                    </td>
                                    <td class="px-4">
                                        <div class="d-flex justify-content-center gap-1">
                                            @if (d.Status != "Active")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@d.DriverId" />
                                                    <input type="hidden" name="status" value="Active" />
                                                    <button type="submit" class="btn btn-sm btn-success px-3 rounded-pill shadow-sm">Approve</button>
                                                </form>
                                            }
                                            @if (d.Status == "Active")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@d.DriverId" />
                                                    <input type="hidden" name="status" value="Inactive" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary px-3 rounded-pill">Deactivate</button>
                                                </form>
                                            }
                                            @if (d.Status != "Suspended")
                                            {
                                                <form method="post" action="/Logistics/UpdateDriverStatus">
                                                    <input type="hidden" name="driverId" value="@d.DriverId" />
                                                    <input type="hidden" name="status" value="Suspended" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill">Suspend</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>