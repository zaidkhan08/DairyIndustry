@model List<DairyIndustry.Models.Admin.MilkTransferModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "My Transfers";

    var totalDispatched = Model.Sum(t => t.DispatchQty);
    var totalReceived = Model.Where(t => t.ReceivedQty.HasValue).Sum(t => t.ReceivedQty ?? 0);
    var totalLoss = Model.Where(t => t.LossQty.HasValue).Sum(t => t.LossQty ?? 0);
    var completedCount = Model.Count(t => t.TransferStatus == "Received");
    var pendingCount = Model.Count(t => t.TransferStatus != "Received");

    decimal lossPercent = totalDispatched > 0 ? (totalLoss / totalDispatched) * 100 : 0;

    string StatusClass(string s) => s switch
    {
        "Received" => "bg-success bg-opacity-10 text-success border border-success border-opacity-25",
        _ => "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25"
    };
}

<div class="container-fluid p-4">

    <!-- ── STAT CARDS ─────────────────────────────────── -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex align-items-stretch">
                    <div class="bg-primary px-3 py-4 text-white d-flex align-items-center">
                        <i class="bi bi-arrow-left-right fs-3"></i>
                    </div>
                    <div class="px-3 py-3">
                        <h4 class="mb-0 fw-bold">@Model.Count</h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size:10px;">Total Trips</small>
                        <div class="small mt-1">
                            <span class="text-success">@completedCount done</span>
                            @if (pendingCount > 0)
                            {
                                <span class="text-warning ms-1">· @pendingCount pending</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex align-items-stretch">
                    <div class="bg-success px-3 py-4 text-white d-flex align-items-center">
                        <i class="bi bi-box-arrow-up fs-3"></i>
                    </div>
                    <div class="px-3 py-3">
                        <h4 class="mb-0 fw-bold">@totalDispatched.ToString("N0") <small style="font-size:12px;" class="text-muted">L</small></h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size:10px;">Dispatched</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex align-items-stretch">
                    <div class="bg-info px-3 py-4 text-white d-flex align-items-center">
                        <i class="bi bi-box-arrow-in-down fs-3"></i>
                    </div>
                    <div class="px-3 py-3">
                        <h4 class="mb-0 fw-bold">@totalReceived.ToString("N0") <small style="font-size:12px;" class="text-muted">L</small></h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size:10px;">Received</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0 d-flex align-items-stretch">
                    <div class="bg-danger px-3 py-4 text-white d-flex align-items-center">
                        <i class="bi bi-droplet-half fs-3"></i>
                    </div>
                    <div class="px-3 py-3">
                        <h4 class="mb-0 fw-bold @(lossPercent > 2 ? "text-danger" : "")">
                            @totalLoss.ToString("N2") <small style="font-size:12px;" class="text-muted">L</small>
                        </h4>
                        <small class="text-muted text-uppercase fw-bold" style="font-size:10px;">Transit Loss</small>
                        <div class="small @(lossPercent > 2 ? "text-danger" : "text-success") mt-1 fw-semibold">@lossPercent.ToString("N2")%</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── FILTER BAR ──────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-3 px-4">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchInput" class="form-control border-start-0 ps-1"
                               placeholder="Search trip, route, vehicle..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        <option value="Received">Completed</option>
                        <option value="Pending">In Transit</option>
                    </select>
                </div>
                <div class="col-md-auto ms-auto">
                    <button class="btn btn-outline-secondary btn-sm px-3" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i> Print
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── TRANSFER TABLE ─────────────────────────────── -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 px-4">
            <h6 class="mb-0 fw-bold text-dark">
                <i class="bi bi-clock-history me-2 text-primary"></i>Detailed Transfer Logs
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="transferTable">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="border-0 px-4">Trip Details</th>
                            <th class="border-0">Route</th>
                            <th class="border-0">Dispatch Qty</th>
                            <th class="border-0">Arrival Qty</th>
                            <th class="border-0">Loss</th>
                            <th class="border-0 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody id="transferBody">
                        @if (!Model.Any())
                        {
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center py-5">
                                    <div class="bg-light d-inline-flex p-4 rounded-circle mb-3">
                                        <i class="bi bi-slash-circle display-4 text-muted"></i>
                                    </div>
                                    <p class="text-muted mt-2">No transfer records found for your account.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var t in Model)
                            {
                                <tr data-status="@t.TransferStatus"
                                    data-search="@($"#{t.TransferId} {t.CenterName} {t.PlantName} {t.VehicleNumber}".ToLower())">
                                    <td class="px-4">
                                        <div class="fw-bold text-dark small">#@t.TransferId</div>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar-event me-1"></i>@t.DispatchDate.ToString("dd MMM yyyy")
                                        </small>
                                        <div class="text-primary fw-medium" style="font-size:10px;">
                                            Batch: @t.BatchId &bull; @t.Shift
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1">
                                            <div class="small fw-semibold text-dark">
                                                <i class="bi bi-circle-fill text-success me-1" style="font-size:6px;"></i>@t.CenterName
                                            </div>
                                            <div class="ms-1 border-start border-2 ps-2 text-muted small py-1" style="font-size:10px;">
                                                via @t.VehicleNumber
                                            </div>
                                            <div class="small fw-semibold text-dark">
                                                <i class="bi bi-geo-alt-fill text-danger me-1" style="font-size:8px;"></i>@t.PlantName
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="fw-bold small">@t.DispatchQty.ToString("N1")</span>
                                        <small class="text-muted"> L</small>
                                        @if (t.BatchAvgFat.HasValue || t.BatchAvgCLR.HasValue)
                                        {
                                            <div class="text-muted" style="font-size:10px;">
                                                F: @t.BatchAvgFat?.ToString("N1") | C: @t.BatchAvgCLR?.ToString("N1")
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (t.ReceivedQty.HasValue)
                                        {
                                            <span class="fw-bold text-success small">@t.ReceivedQty.Value.ToString("N1")</span>
                                            <small class="text-muted"> L</small>
                                            <div class="text-muted" style="font-size:10px;">@t.ReceivedDate?.ToString("dd MMM")</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">In Transit...</span>
                                        }
                                    </td>
                                    <td>
                                        @if (t.LossQty.HasValue)
                                        {
                                            <div class="@(t.LossPercent > 2 ? "text-danger" : "text-warning")">
                                                <span class="fw-bold small">@t.LossQty.Value.ToString("N2") L</span>
                                                <div style="font-size:10px;">(@t.LossPercent.ToString("N2")%)</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @StatusClass(t.TransferStatus) rounded-pill px-3 py-2 small">
                                            @(t.TransferStatus == "Received" ? "Completed" : "In Transit")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- no-results row (hidden by default) -->
            <div id="noResults" class="text-center py-5" style="display:none;">
                <i class="bi bi-search display-4 text-muted"></i>
                <p class="text-muted mt-3">No transfers match your search.</p>
            </div>
        </div>

        <div class="card-footer bg-light border-0 py-3 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted fw-bold text-uppercase" style="font-size:10px;letter-spacing:1px;">End of Logs</small>
            <div class="small text-muted">
                Completed: <span class="text-success fw-bold">@completedCount</span> &nbsp;|&nbsp;
                In Transit: <span class="text-warning fw-bold">@pendingCount</span>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const searchInput  = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const rows         = document.querySelectorAll('#transferBody tr[data-status]');
        const noResults    = document.getElementById('noResults');

        function filterTable() {
            const query  = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            let visible  = 0;

            rows.forEach(row => {
                const matchSearch = !query  || row.dataset.search.includes(query);
                const matchStatus = !status || row.dataset.status === status;
                const show = matchSearch && matchStatus;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            noResults.style.display = visible === 0 ? 'block' : 'none';
        }

        searchInput.addEventListener('input',    filterTable);
        statusFilter.addEventListener('change',  filterTable);
    </script>
}
