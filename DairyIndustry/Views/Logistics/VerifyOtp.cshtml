@{
    Layout = null;
    ViewBag.Title = "Verify OTP";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DMS | Verify OTP</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        }

        .btn-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.3);
        }

        .transition-all {
            transition: all 0.3s ease;
        }

        .floating {
            animation: floating 3s ease-in-out infinite;
        }

        @@keyframes floating {
            0%

        {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }

        }

        .pill-step-active {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            color: #fff;
            font-weight: 700;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pill-step-done {
            background-color: #dcfce7;
            color: #15803d;
            font-weight: 700;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #10b981;
        }

        .pill-step-disabled {
            background-color: #ffffff;
            color: #9ca3af;
            font-weight: 600;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #e5e7eb;
        }

        .pill-badge-blue {
            background-color: #eff6ff;
            color: #1e40af;
            font-weight: 600;
            font-size: 0.82rem;
            padding: 6px 14px;
            border-radius: 6px;
            border: 1px solid #bfdbfe;
            display: inline-block;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
        }

        .alert-info {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            color: #1e40af;
        }

        .otp-input-box {
            letter-spacing: 10px;
            font-size: 1.6rem;
        }

            .otp-input-box:focus {
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
                border-color: #2563eb;
            }

        #countdown {
            font-weight: 700;
            color: #2563eb;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <main class="w-full">
        <div class="max-w-6xl w-full mx-auto bg-white rounded-xl shadow-xl overflow-hidden flex flex-col md:flex-row">

            <!-- Left Side - Branding -->
            <div class="w-full md:w-1/2 gradient-bg text-white p-10 flex flex-col justify-center items-center">
                <div class="text-center mb-8">
                    <h1 class="text-4xl font-bold mb-2">Verify OTP</h1>
                    <p class="text-white/80">Enter the code sent to your email to continue.</p>
                </div>
                <div class="relative w-full max-w-xs">
                    <img src="~/uploads/Logo/bookcover.png" alt="OTP Illustration" class="w-full h-auto floating" />
                </div>

                <div class="flex items-center justify-center mt-8 w-full max-w-xs">
                    <div class="pill-step-done"><i class="bi bi-check-lg"></i></div>
                    <div class="flex-grow border-t-2 border-white/40 mx-2"></div>
                    <div class="pill-step-active">2</div>
                    <div class="flex-grow border-t-2 border-white/40 mx-2"></div>
                    <div class="pill-step-disabled">3</div>
                </div>
            </div>

            <!-- Right Side - OTP Form -->
            <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">

                <div class="text-center mb-6">
                    <div class="mb-4 flex justify-center">
                        <img alt="logo" src="~/uploads/Logo/logo.png" class="h-12" />
                    </div>
                    <h1 class="text-2xl font-bold text-gray-800 mb-2">Verify OTP</h1>
                    <span class="pill-badge-blue font-monospace">
                        <i class="bi bi-envelope-open me-1"></i>@ViewBag.Email
                    </span>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert-danger rounded-lg shadow-sm mb-4 px-4 py-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    </div>
                }
                @if (TempData["Info"] != null)
                {
                    <div class="alert-info rounded-lg shadow-sm mb-4 px-4 py-3" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i> @TempData["Info"]
                    </div>
                }

                <form asp-action="VerifyOtp" asp-controller="Logistics" method="post" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-2 text-center">6-Digit Code</label>
                        <input type="text" name="otpCode"
                               class="otp-input-box w-full text-center font-bold rounded-lg border border-gray-300 outline-none transition-all mx-auto block font-monospace"
                               style="max-width: 280px; padding: 12px;" maxlength="6" inputmode="numeric" pattern="\d{6}"
                               placeholder="------" autocomplete="one-time-code" required />
                    </div>

                    <button type="submit" class="gradient-bg btn-hover transition-all w-full py-3 rounded-md text-white font-semibold tracking-wide">
                        <i class="bi bi-shield-check-fill me-1"></i> Verify OTP
                    </button>
                </form>

                <div class="text-center mt-6 text-sm text-gray-500">
                    Expires in <span id="countdown">10:00</span>
                </div>

                <div class="text-center mt-4 pt-4 border-t border-gray-100 text-sm">
                    <span class="text-gray-500">Didn't get the code?</span>
                    <a asp-action="RegisterDriver" asp-controller="Logistics" class="font-bold ml-1 hover:underline" style="color:#2563eb;">
                        ← Go back and resend
                    </a>
                </div>
            </div>
        </div>
    </main>

    @section Scripts {
        <script>
            let seconds = 600;
            const el = document.getElementById('countdown');
            const timer = setInterval(() => {
                seconds--;
                const m = String(Math.floor(seconds / 60)).padStart(2, '0');
                const s = String(seconds % 60).padStart(2, '0');
                el.textContent = m + ':' + s;
                if (seconds <= 60) {
                    el.style.color = '#ef4444';
                }
                if (seconds <= 0) {
                    clearInterval(timer);
                    el.textContent = 'Expired';
                    el.style.color = '#ef4444';
                }
            }, 1000);
        </script>
    }
</body>
</html>