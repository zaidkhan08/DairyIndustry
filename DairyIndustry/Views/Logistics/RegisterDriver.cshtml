@{
    ViewData["Title"] = "Driver Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Driver Registration</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="min-vh-100 d-flex justify-content-center align-items-center py-4">
        <div class="card shadow-sm border-0" style="max-width:520px; width:90%;">

            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-semibold">Driver Registration</h5>
            </div>

            <div class="card-body p-4">

                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success">
                        @ViewBag.Success
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" action="/Logistics/Register">

                    <h6 class="text-muted fw-semibold border-bottom pb-2 mb-3">
                        Personal Information
                    </h6>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            Full Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="driverName"
                               class="form-control" placeholder="Enter your full name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            License Number <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="licenseNo"
                               class="form-control" placeholder="e.g. GJ05 2024 001234" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium">Phone</label>
                        <input type="text" name="phone"
                               class="form-control" placeholder="Enter phone number" />
                    </div>

                    <h6 class="text-muted fw-semibold border-bottom pb-2 mb-3">
                        Login Credentials
                    </h6>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            Username <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="username"
                               class="form-control" placeholder="Choose a username" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium">
                            Password <span class="text-danger">*</span>
                        </label>
                        <input type="password" name="password"
                               class="form-control" placeholder="Choose a password" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" asp-action="RegisterDriver" asp-controller="Logistics" class="btn btn-primary px-4">
                            Register
                        </button>
                        <a href="/Admin/Login" class="btn btn-outline-secondary px-4">
                            Back to Login
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>

</body>
</html>