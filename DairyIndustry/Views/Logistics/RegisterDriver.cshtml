@{
    ViewBag.Title = "Driver Registration";
}

<!-- Page Header -->
<div class="bg-primary text-white py-3 mb-4 shadow-sm">
    <div class="container">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-person-plus-fill fs-4"></i>
            <div>
                <h4 class="mb-0 fw-bold">Driver Registration</h4>
                <small class="opacity-75">Step 1 of 3 — Verify your email address</small>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <!-- Step Indicator -->
            <div class="d-flex align-items-center mb-4">
                <div class="d-flex flex-column align-items-center">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center
                                justify-content-center fw-bold" style="width:36px;height:36px;">
                        1
                    </div>
                    <small class="text-primary fw-semibold mt-1" style="font-size:0.7rem;">Email</small>
                </div>
                <div class="flex-grow-1 border-top border-2 border-primary mx-2 mb-3"></div>
                <div class="d-flex flex-column align-items-center">
                    <div class="rounded-circle bg-white border border-2 border-secondary text-secondary
                                d-flex align-items-center justify-content-center fw-bold"
                         style="width:36px;height:36px;">
                        2
                    </div>
                    <small class="text-muted mt-1" style="font-size:0.7rem;">Verify OTP</small>
                </div>
                <div class="flex-grow-1 border-top border-2 border-secondary mx-2 mb-3"></div>
                <div class="d-flex flex-column align-items-center">
                    <div class="rounded-circle bg-white border border-2 border-secondary text-secondary
                                d-flex align-items-center justify-content-center fw-bold"
                         style="width:36px;height:36px;">
                        3
                    </div>
                    <small class="text-muted mt-1" style="font-size:0.7rem;">Details</small>
                </div>
            </div>

            <!-- Alerts -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>@TempData["Error"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@ViewBag.Success</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Card -->
            <div class="card border-0 shadow">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0 fw-semibold">
                        <i class="bi bi-envelope-fill me-2"></i>Enter Your Email to Get OTP
                    </h6>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">
                        We will send a 6-digit OTP to your email address to verify your identity
                        before completing the registration.
                    </p>
                    <form asp-action="SendOtp" asp-controller="Logistics" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">
                                Full Name <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white border-primary">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                                <input type="text" name="driverName" class="form-control border-start-0"
                                       style="border-color:#dee2e6;"
                                       placeholder="e.g. Ramesh Patel" required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-dark">
                                Email Address <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white border-primary">
                                    <i class="bi bi-envelope-fill"></i>
                                </span>
                                <input type="email" name="email" class="form-control border-start-0"
                                       style="border-color:#dee2e6;"
                                       placeholder="yourname@gmail.com" required />
                            </div>
                            <div class="form-text">OTP will be sent to this email. Make sure it is valid.</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                            <i class="bi bi-send-fill me-2"></i>Send OTP
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">
                        Already registered?
                        <a asp-action="Login" asp-controller="Admin"
                           class="text-primary fw-semibold text-decoration-none">Login here</a>
                    </small>
                </div>
            </div>

        </div>
    </div>
</div>