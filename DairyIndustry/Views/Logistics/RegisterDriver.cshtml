@{
    Layout = null;
    ViewBag.Title = "Driver Registration";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DMS | Driver Registration</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        }

        .input-focus:focus {
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
            border-color: #2563eb;
        }

        .btn-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.3);
        }

        .transition-all {
            transition: all 0.3s ease;
        }

        .floating {
            animation: floating 3s ease-in-out infinite;
        }

        @@keyframes floating {
            0%

        {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }

        }

        .pill-step-active {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            color: #fff;
            font-weight: 700;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pill-step-disabled {
            background-color: #ffffff;
            color: #9ca3af;
            font-weight: 600;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #e5e7eb;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
        }

        .alert-success {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #16a34a;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <main class="w-full">
        <div class="max-w-6xl w-full mx-auto bg-white rounded-xl shadow-xl overflow-hidden flex flex-col md:flex-row">

            <!-- Left Side - Branding -->
            <div class="w-full md:w-1/2 gradient-bg text-white p-10 flex flex-col justify-center items-center">
                <div class="text-center mb-8">
                    <h1 class="text-4xl font-bold mb-2">Driver Registration</h1>
                    <p class="text-white/80">Join the DMS logistics network in a few quick steps.</p>
                </div>
                <div class="relative w-full max-w-xs">
                    <img src="~/uploads/Logo/bookcover.png" alt="Registration Illustration" class="w-full h-auto floating" />
                </div>
            </div>

            <!-- Right Side - Form -->
            <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">

                <div class="text-center mb-6">
                    <div class="mb-4 flex justify-center">
                        <img alt="logo" src="~/uploads/Logo/logo.png" class="h-12" />
                    </div>
                    <h1 class="text-2xl font-bold text-gray-800">Email Verification</h1>
                </div>

                <div class="flex items-center justify-center mb-6">
                    <div class="flex flex-col items-center">
                        <div class="pill-step-active">1</div>
                    </div>
                    <div class="flex-grow border-t-2 border-gray-200 mx-2" style="max-width: 60px;"></div>
                    <div class="flex flex-col items-center">
                        <div class="pill-step-disabled">2</div>
                    </div>
                    <div class="flex-grow border-t-2 border-gray-200 mx-2" style="max-width: 60px;"></div>
                    <div class="flex flex-col items-center">
                        <div class="pill-step-disabled">3</div>
                    </div>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert-danger rounded-lg shadow-sm mb-4 px-4 py-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    </div>
                }
                @if (ViewBag.Success != null)
                {
                    <div class="alert-success rounded-lg shadow-sm mb-4 px-4 py-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                    </div>
                }

                <form method="post" asp-action="SendOtp" asp-controller="Logistics" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Full Name <span class="text-red-500">*</span></label>
                        <input type="text" name="driverName"
                               class="w-full border border-gray-300 rounded-md px-4 py-2.5 text-gray-800 outline-none transition-all input-focus"
                               placeholder="e.g. Ramesh Patel" required />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Email Address <span class="text-red-500">*</span></label>
                        <input type="email" name="email"
                               class="w-full border border-gray-300 rounded-md px-4 py-2.5 text-gray-800 outline-none transition-all input-focus"
                               placeholder="yourname@gmail.com" required />
                    </div>

                    <button type="submit" class="gradient-bg btn-hover transition-all w-full py-3 rounded-md text-white font-semibold tracking-wide">
                        <i class="bi bi-send-fill me-1"></i> Send Verification OTP
                    </button>
                </form>

                <div class="text-center mt-6 pt-4 border-t border-gray-100 text-sm">
                    <span class="text-gray-500">Already registered?</span>
                    <a asp-action="Login" asp-controller="Admin" class="font-bold ml-1 hover:underline" style="color:#2563eb;">
                        Login here
                    </a>
                </div>
            </div>
        </div>
    </main>

</body>
</html>