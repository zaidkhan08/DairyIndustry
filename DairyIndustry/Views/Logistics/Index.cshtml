@model DairyIndustry.Models.Logistics.DriversModel
@{
    ViewData["Title"] = "Driver Dashboard";
    Layout = "~/Views/Shared/_LogisticsLayout.cshtml";

    var vehicles = ViewBag.Vehicles as List<DairyIndustry.Models.Logistics.VehiclesModel>;

    // Local Helper for Status Badges
    string GetStatusClass(string status) => status switch
    {
        "Active" or "Approved" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Suspended" or "Rejected" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container-fluid p-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="bg-primary" style="height: 5px;"></div>

                <div class="card-body p-4">
                    @if (Model == null)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-exclamation-triangle text-warning display-4"></i>
                            <p class="mt-3 text-muted">Driver profile data is missing.</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mb-4">
                            <div class="position-relative d-inline-block">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm mx-auto"
                                     style="width: 80px; height: 80px; font-size: 2rem;">
                                    @Model.DriverName[0].ToString().ToUpper()
                                </div>
                                <span class="position-absolute bottom-0 end-0 p-2 @(Model.IsActive ? "bg-success" : "bg-danger") border border-2 border-white rounded-circle"></span>
                            </div>
                            <h5 class="mt-3 mb-0 fw-bold text-dark">@Model.DriverName</h5>
                            <p class="text-muted small">@("@" + Model.Username)</p>
                            <span class="badge rounded-pill @GetStatusClass(Model.Status) px-3 py-2">
                                @Model.Status.ToUpper()
                            </span>
                        </div>

                        <div class="border-top pt-3">
                            <h6 class="text-uppercase fw-bold text-muted small mb-3" style="letter-spacing: 1px;">Information</h6>

                            <div class="d-flex align-items-center mb-3">
                                <div class="topbar-icon-btn me-3 text-primary bg-primary bg-opacity-10">
                                    <i class="bi bi-card-text"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">License Number</small>
                                    <span class="fw-semibold">@Model.LicenseNo</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <div class="topbar-icon-btn me-3 text-success bg-success bg-opacity-10">
                                    <i class="bi bi-telephone"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Contact</small>
                                    <span class="fw-semibold">@(Model.Phone ?? "Not Provided")</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center">
                                <div class="topbar-icon-btn me-3 text-info bg-info bg-opacity-10">
                                    <i class="bi bi-calendar-check"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Member Since</small>
                                    <span class="fw-semibold">@Model.RegisteredOn.ToString("MMMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-truck me-2 text-primary"></i>My Registered Vehicles
                    </h6>
                    <a asp-action="RegisterVehicle" class="btn btn-primary btn-sm px-3 shadow-sm">
                        <i class="bi bi-plus-lg me-1"></i> Add Vehicle
                    </a>
                </div>

                <div class="card-body p-4">
                    @if (vehicles == null || !vehicles.Any())
                    {
                        <div class="text-center py-5">
                            <img src="https://cdn-icons-png.flaticon.com/512/2144/2144772.png" alt="Empty" style="width: 120px; opacity: 0.5;">
                            <h5 class="mt-4 fw-bold">No Vehicles Found</h5>
                            <p class="text-muted">You haven't registered any transport vehicles yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border-light">
                                <thead class="table-light">
                                    <tr class="small text-uppercase text-muted">
                                        <th class="border-0 px-4">Vehicle Details</th>
                                        <th class="border-0">Capacity</th>
                                        <th class="border-0">Status</th>
                                        @* <th class="border-0 text-end px-4">Actions</th> *@
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in vehicles)
                                    {
                                        <tr>
                                            <td class="px-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-3 bg-light p-2 me-3">
                                                        <i class="bi bi-truck-flatbed text-primary fs-4"></i>
                                                    </div>
                                                    <div>
                                                        <span class="fw-bold d-block text-dark">@v.VehicleNumber</span>
                                                        <small class="text-muted">ID: #@v.VehicleId</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border fw-medium">
                                                    <i class="bi bi-droplet-fill text-info me-1"></i>
                                                    @v.Capacity.ToString("N0") Ltr
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @GetStatusClass(v.Status) d-inline-flex align-items-center">
                                                    <i class="bi bi-circle-fill me-1" style="font-size: 6px;"></i>
                                                    @v.Status
                                                </span>
                                            </td>
                                            @* <td class="text-end px-4">
                                                <button class="btn btn-light btn-sm rounded-pill border" title="Details">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </td> *@
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @if (vehicles?.Count > 0)
                {
                    <div class="card-footer bg-light border-0 py-3 px-4">
                        <small class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Showing @vehicles.Count registered vehicle(s).
                        </small>
                    </div>
                }
            </div>
        </div>

    </div>
</div>