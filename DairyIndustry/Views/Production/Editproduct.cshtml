@model DairyIndustry.Models.Production.ProductModel
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<h4 class="mb-4">✏️ Edit Product</h4>

<div class="card shadow-sm" style="max-width: 500px;">
    <div class="card-header bg-primary text-white"><strong>Edit Product</strong></div>
    <div class="card-body">
        <form asp-action="EditProduct" method="post">

            <input type="hidden" name="ProductId" value="@Model.ProductId" />

            <div class="mb-2">
                <label class="form-label">Product Name</label>
                <input type="text" name="ProductName" class="form-control" value="@Model.ProductName" required />
            </div>

            <div class="mb-2">
                <label class="form-label">Product Type</label>
                <select name="ProductType" class="form-select" required>
                    @foreach (var t in new[] { "Milk", "Butter", "Ghee", "Paneer", "Curd", "Cheese", "Cream", "IceCream", "Other" })
                    {
                        <option value="@t" selected="@(Model.ProductType == t ? "selected" : null)">@t</option>
                    }
                </select>
            </div>

            <div class="mb-2">
                <label class="form-label">MRP (₹)</label>
                <input type="number" name="MRP" class="form-control" step="0.01" value="@Model.MRP" required />
            </div>

            <div class="mb-2">
                <label class="form-label">Unit</label>
                <select name="Unit" class="form-select" required>
                    @foreach (var u in new[] { "Ltr", "Kg", "Gm", "Pcs", "Ml" })
                    {
                        <option value="@u" selected="@(Model.Unit == u ? "selected" : null)">@u</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Shelf Life (Days)</label>
                <input type="number" name="ShelfLifeDays" class="form-control"
                       value="@Model.ShelfLifeDays" min="1" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Products" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>
