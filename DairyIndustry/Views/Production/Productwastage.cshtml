@model List<DairyIndustry.Models.Production.ProductWastageModel>
@{
    ViewData["Title"] = "Product Wastage";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">🗑️ Product Wastage</h4>
    <a asp-action="AddWastage" class="btn btn-danger">+ Record Wastage</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Summary *@
@if (Model.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body">
                    <p class="mb-1 small">Total Records</p>
                    <h4 class="fw-bold mb-0">@Model.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body">
                    <p class="mb-1 small">Total Wasted</p>
                    <h4 class="fw-bold mb-0">@Model.Sum(x => x.Quantity).ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body">
                    <p class="mb-1 small">Products Affected</p>
                    <h4 class="fw-bold mb-0">@Model.Select(x => x.ProductId).Distinct().Count()</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-secondary text-white">
                <div class="card-body">
                    <p class="mb-1 small">Batches Affected</p>
                    <h4 class="fw-bold mb-0">@Model.Select(x => x.BatchId).Distinct().Count()</h4>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Batch</th>
                    <th>Plant</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th>Qty Wasted</th>
                    <th>Reason</th>
                    <th>Recorded Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">No wastage records found.</td>
                    </tr>
                }
                @foreach (var w in Model)
                {
                    <tr>
                        <td>@w.WastageId</td>
                        <td><strong>PB-@w.BatchId</strong></td>
                        <td>@w.PlantName</td>
                        <td>@w.ProductName</td>
                        <td><span class="badge bg-info text-dark">@w.ProductType</span></td>
                        <td><span class="text-danger fw-bold">@w.Quantity.ToString("N2") @w.Unit</span></td>
                        <td>@(w.Reason ?? "—")</td>
                        <td>@w.RecordedDate.ToString("dd-MMM-yyyy")</td>
                        <td>
                            <a asp-action="WastageByBatch" asp-route-id="@w.BatchId"
                               class="btn btn-sm btn-outline-secondary">By Batch</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
