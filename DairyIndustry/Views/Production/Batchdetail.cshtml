@model DairyIndustry.Models.Production.ProductionBatchModel
@{
    ViewData["Title"] = $"Batch PB-{Model.ProductionBatchId}";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
    var milkTypes = ViewBag.MilkTypes as List<DairyIndustry.Models.Admin.MilkTypeModel>;
    bool canChangeStatus = Model.BatchStatus == "InProgress";
    bool canAddWastage = Model.BatchStatus == "InProgress";
}

<style>
    .bd-root {
        --ink: #202124;
        --ink-2: #3c4043;
        --ink-m: #5f6368;
        --ink-f: #9aa0a6;
        --surface: #fff;
        --bg: #f8f9fa;
        --bg-3: #f1f3f4;
        --border: #e0e0e0;
        --accent: #1a73e8;
        --accent-bg: #e8f0fe;
        --accent-dark: #185abc;
        --green: #1e8e3e;
        --green-bg: #e6f4ea;
        --green-mid: #ceead6;
        --red: #d93025;
        --red-bg: #fce8e6;
        --red-mid: #f5c6c2;
        --yellow: #f29900;
        --yellow-bg: #fef7e0;
        --yellow-mid: #fce8b2;
        --grey-bg: #f1f3f4;
        --grey-mid: #e8eaed;
        --shadow: 0 1px 2px rgba(60,64,67,.3),0 1px 3px 1px rgba(60,64,67,.15);
        --shadow-sm: 0 1px 2px rgba(60,64,67,.2);
        --r: 8px;
        --r-lg: 12px;
        font-family: 'Roboto',sans-serif;
        color: var(--ink);
        max-width: 960px;
    }

    .bd-bc {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--ink-f);
        margin-bottom: 6px;
    }

        .bd-bc a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }

            .bd-bc a:hover {
                text-decoration: underline;
            }

    .bd-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 4px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .bd-title {
        font-size: 22px;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 2px;
    }

    .bd-sub {
        font-size: 13px;
        color: var(--ink-m);
        margin: 0 0 20px;
    }

    .bd-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .bd-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 36px;
        padding: 0 16px;
        border-radius: 18px;
        font-size: 13px;
        font-weight: 500;
        font-family: 'Roboto',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid;
        transition: background .2s, box-shadow .2s, transform .1s;
        white-space: nowrap;
    }

        .bd-btn:active {
            transform: scale(.98);
        }

    .bd-btn-back {
        background: var(--surface);
        border-color: var(--border);
        color: var(--ink-2);
    }

        .bd-btn-back:hover {
            background: var(--bg-3);
            color: var(--ink);
            border-color: #bbb;
        }

    .bd-btn-warn {
        background: var(--yellow-bg);
        border-color: var(--yellow-mid);
        color: #b06000;
    }

        .bd-btn-warn:hover {
            background: #fde9a0;
            box-shadow: 0 1px 4px rgba(242,153,0,.3);
        }

    .bd-btn-ok {
        background: var(--green-bg);
        border-color: var(--green-mid);
        color: var(--green);
    }

        .bd-btn-ok:hover {
            background: #d2eeda;
            box-shadow: 0 1px 4px rgba(30,142,62,.2);
        }

    .bd-qc-alert {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 18px;
        border-radius: var(--r-lg);
        background: var(--red-bg);
        border: 1px solid var(--red-mid);
        color: var(--red);
        margin-bottom: 20px;
        font-size: 14px;
    }

        .bd-qc-alert i {
            font-size: 20px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .bd-qc-alert a {
            color: var(--red);
            font-weight: 500;
        }

    .bd-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 16px;
        border-radius: var(--r-lg);
        font-size: 13.5px;
        font-weight: 500;
        margin-bottom: 16px;
        border: 1px solid;
    }

    .bd-alert-success {
        background: var(--green-bg);
        border-color: var(--green-mid);
        color: var(--green);
    }

    .bd-alert-danger {
        background: var(--red-bg);
        border-color: var(--red-mid);
        color: var(--red);
    }

    .bd-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        font-size: 16px;
    }

        .bd-alert-close:hover {
            opacity: 1;
        }

    .bd-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 16px;
        margin-bottom: 16px;
    }

    @@media(max-width:768px) {
        .bd-grid {
            grid-template-columns: 1fr;
        }
    }

    .bd-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }

    .bd-card-hd {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        font-size: 14px;
        font-weight: 500;
        color: var(--ink-2);
    }

        .bd-card-hd i {
            color: var(--accent);
            font-size: 16px;
        }

    .bd-card-body {
        padding: 20px;
    }

    .bd-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .bd-info-row {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 10px 14px;
        background: var(--bg);
        border-radius: var(--r);
        border: 1px solid var(--border);
    }

        .bd-info-row.full {
            grid-column: 1/-1;
        }

    .bd-info-key {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--ink-f);
    }

    .bd-info-val {
        font-size: 14px;
        font-weight: 500;
        color: var(--ink);
    }

        .bd-info-val.mono {
            font-family: 'Roboto Mono','Courier New',monospace;
        }

        .bd-info-val.big {
            font-size: 18px;
            font-weight: 400;
            color: var(--accent);
        }

    .bd-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 500;
    }

    .bd-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    .bd-flow {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .bd-flow-step {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        position: relative;
    }

        .bd-flow-step:not(:last-child)::after {
            content: '';
            position: absolute;
            left: 27px;
            top: 100%;
            width: 2px;
            height: 10px;
            background: var(--border);
            z-index: 0;
        }

    .bd-flow-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        flex-shrink: 0;
        z-index: 1;
        border: 2px solid;
    }

    .bd-flow-step.inactive .bd-flow-icon {
        background: var(--bg);
        border-color: var(--border);
        color: var(--ink-f);
    }

    .bd-flow-name {
        font-size: 14px;
        font-weight: 400;
        color: var(--ink-m);
    }

    .bd-flow-step.current .bd-flow-name {
        font-weight: 500;
        color: var(--ink);
    }

    .bd-flow-badge {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 500;
    }

    .bd-qc-note {
        margin: 12px 16px;
        padding: 10px 14px;
        background: var(--yellow-bg);
        border: 1px solid var(--yellow-mid);
        border-radius: var(--r);
        font-size: 12px;
        color: #7a4f00;
    }

    .bd-links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .bd-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 36px;
        padding: 0 16px;
        border-radius: 18px;
        font-size: 13px;
        font-weight: 500;
        font-family: 'Roboto',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--ink-2);
        transition: background .2s, border-color .2s;
    }

        .bd-link-btn:hover {
            background: var(--bg-3);
            border-color: #bbb;
            color: var(--ink);
        }

        .bd-link-btn.danger {
            color: var(--red);
            border-color: var(--red-mid);
        }

            .bd-link-btn.danger:hover {
                background: var(--red-bg);
            }

    /* ── Offcanvas ── */
    .bd-oc-title {
        font-size: 16px;
        font-weight: 500;
        color: var(--ink);
    }

    .bd-form-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--ink-m);
        margin-bottom: 6px;
    }

    .bd-form-req {
        color: var(--red);
    }

    .bd-select, .bd-input, .bd-textarea {
        width: 100%;
        border: 1.5px solid var(--border);
        border-radius: var(--r);
        padding: 10px 14px;
        font-size: 14px;
        font-family: 'Roboto',sans-serif;
        color: var(--ink);
        background: var(--surface);
        outline: none;
        transition: border-color .2s, box-shadow .2s;
    }

    .bd-select {
        appearance: none;
        cursor: pointer;
    }

        .bd-select:focus, .bd-input:focus, .bd-textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(26,115,232,.1);
        }

    .bd-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .bd-form-hint {
        font-size: 12px;
        color: var(--ink-f);
        margin-top: 4px;
    }

    .bd-input-group {
        display: flex;
    }

        .bd-input-group .bd-input {
            border-radius: var(--r) 0 0 var(--r);
            flex: 1;
        }

    .bd-input-group-text {
        display: flex;
        align-items: center;
        padding: 0 14px;
        background: var(--bg-3);
        border: 1.5px solid var(--border);
        border-left: none;
        border-radius: 0 var(--r) var(--r) 0;
        font-size: 14px;
        color: var(--ink-m);
        font-weight: 500;
    }

    .bd-qc-warning {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 14px;
        border-radius: var(--r);
        background: var(--red-bg);
        border: 1px solid var(--red-mid);
        color: var(--red);
        font-size: 13px;
        margin-bottom: 12px;
    }

        .bd-qc-warning.hidden {
            display: none;
        }

    .bd-wastage-info {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 14px;
        border-radius: var(--r);
        background: var(--yellow-bg);
        border: 1px solid var(--yellow-mid);
        color: #7a4f00;
        font-size: 13px;
        margin-bottom: 12px;
    }

    /* ── Submit buttons — explicit solid colors, no CSS vars ── */
    .bd-btn-submit {
        width: 100%;
        height: 44px;
        border-radius: 22px;
        border: none;
        font-size: 14px;
        font-weight: 500;
        font-family: 'Roboto', sans-serif;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        letter-spacing: .3px;
        transition: box-shadow .2s, transform .1s;
    }

        .bd-btn-submit:active {
            transform: scale(.98);
        }

        .bd-btn-submit.primary {
            background-color: #1a73e8;
            color: #ffffff;
        }

            .bd-btn-submit.primary:hover {
                background-color: #1558b0;
                box-shadow: 0 2px 8px rgba(26,115,232,.45);
            }

        .bd-btn-submit.warning {
            background-color: #f29900;
            color: #ffffff;
        }

            .bd-btn-submit.warning:hover {
                background-color: #c97f00;
                box-shadow: 0 2px 8px rgba(242,153,0,.45);
            }

    .bd-mb {
        margin-bottom: 16px;
    }

    /* ── Offcanvas sticky footer layout ── */
    .bd-oc-flex {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .bd-oc-body {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
    }

    .bd-oc-footer {
        flex-shrink: 0;
        padding: 16px 20px;
        border-top: 1px solid #e0e0e0;
        background: #ffffff;
    }
</style>

<div class="bd-root">

    <!-- Breadcrumb -->
    <div class="bd-bc">
        <a asp-action="Batches">Batch Tracking</a>
        <i class="bi bi-chevron-right" style="font-size:10px;"></i>
        <span>PB-@Model.ProductionBatchId</span>
    </div>

    <!-- Header -->
    <div class="bd-header">
        <div>
            <h1 class="bd-title">Batch Detail &nbsp;<span style="color:var(--ink-m);font-weight:300;">PB-@Model.ProductionBatchId</span></h1>
            <p class="bd-sub">@Model.PlantName &nbsp;·&nbsp; @Model.ProductionDate.ToString("dd MMM yyyy")</p>
        </div>
        <div class="bd-actions">
            @if (canAddWastage)
            {
                <button class="bd-btn bd-btn-warn" data-bs-toggle="offcanvas" data-bs-target="#wastageDrawer">
                    <i class="bi bi-droplet-half"></i> Record Wastage
                </button>
            }
            @if (canChangeStatus)
            {
                <button class="bd-btn bd-btn-ok" data-bs-toggle="offcanvas" data-bs-target="#statusDrawer">
                    <i class="bi bi-pencil"></i> Update Status
                </button>
            }
            <a asp-action="Batches" class="bd-btn bd-btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="bd-alert bd-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="bd-alert-close" onclick="this.closest('.bd-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bd-alert bd-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="bd-alert-close" onclick="this.closest('.bd-alert').remove()">&times;</button>
        </div>
    }

    <!-- QC Failed banner -->
    @if (Model.BatchStatus == "QCFailed")
    {
        <div class="bd-qc-alert">
            <i class="bi bi-exclamation-octagon-fill"></i>
            <div>
                <strong>This batch failed QC.</strong><br>
                The full milk quantity of <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong>
                has been automatically written off and recorded in
                <a asp-action="MilkProcessWastage">Milk Process Wastage</a>.
            </div>
        </div>
    }

    <!-- Main grid -->
    <div class="bd-grid">

        <!-- Batch info -->
        <div class="bd-card">
            <div class="bd-card-hd"><i class="bi bi-info-circle-fill"></i> Batch Information</div>
            <div class="bd-card-body">
                <div class="bd-info-grid">
                    <div class="bd-info-row">
                        <span class="bd-info-key">Batch ID</span>
                        <span class="bd-info-val mono">PB-@Model.ProductionBatchId.ToString("D4")</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Status</span>
                        @{
                            string sc = Model.BatchStatus switch
                            {
                                "InProgress" => "background:var(--yellow-bg);color:var(--yellow);border:1px solid var(--yellow-mid);",
                                "Completed" => "background:var(--green-bg);color:var(--green);border:1px solid var(--green-mid);",
                                "QCFailed" => "background:var(--red-bg);color:var(--red);border:1px solid var(--red-mid);",
                                "Cancelled" => "background:var(--grey-bg);color:var(--ink-m);border:1px solid var(--grey-mid);",
                                _ => ""
                            };
                        }
                        <span class="bd-status" style="@sc">
                            <span class="bd-status-dot"></span>@Model.BatchStatus
                        </span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Plant</span>
                        <span class="bd-info-val">@Model.PlantName</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Production Date</span>
                        <span class="bd-info-val">@Model.ProductionDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Product</span>
                        <span class="bd-info-val">@Model.ProductName</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Product Type</span>
                        <span class="bd-info-val">@Model.ProductType</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Unit</span>
                        <span class="bd-info-val">@Model.Unit</span>
                    </div>
                    <div class="bd-info-row">
                        <span class="bd-info-key">Milk Used</span>
                        <span class="bd-info-val big">@Model.MilkUsedQuantity.ToString("N2") L</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status flow -->
        <div class="bd-card">
            <div class="bd-card-hd"><i class="bi bi-diagram-3-fill"></i> Status Flow</div>
            <div class="bd-card-body" style="padding:12px 0;">
                @{
                    var steps = new[] {
                                ("InProgress", "bi-hourglass-split",   "background:var(--yellow-bg);color:var(--yellow);border-color:var(--yellow);"),
                                ("Completed",  "bi-check-circle-fill", "background:var(--green-bg);color:var(--green);border-color:var(--green);"),
                                ("QCFailed",   "bi-x-circle-fill",     "background:var(--red-bg);color:var(--red);border-color:var(--red);"),
                                ("Cancelled",  "bi-dash-circle-fill",  "background:var(--grey-bg);color:var(--ink-m);border-color:var(--border);")
                                };
                }
                <div class="bd-flow">
                    @foreach (var (name, icon, style) in steps)
                    {
                        bool isCurrent = Model.BatchStatus == name;
                        <div class="bd-flow-step @(isCurrent ? "current" : "inactive")">
                            <div class="bd-flow-icon" style="@(isCurrent? style : "background:var(--bg);border-color:var(--border);color:var(--ink-f);")">
                                <i class="bi @icon"></i>
                            </div>
                            <span class="bd-flow-name">@name</span>
                            @if (isCurrent)
                            {
                                <span class="bd-flow-badge" style="@style">Current</span>
                            }
                            @if (name == "QCFailed" && isCurrent)
                            {
                                <span class="bd-flow-badge" style="background:var(--red-bg);color:var(--red);border:1px solid var(--red-mid);margin-left:4px;">
                                    <i class="bi bi-droplet-half"></i> Auto-logged
                                </span>
                            }
                        </div>
                    }
                </div>
                @if (canChangeStatus)
                {
                    <div class="bd-qc-note">
                        <i class="bi bi-info-circle me-1"></i>
                        Marking as <strong>QC Failed</strong> will automatically record
                        <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong> in Milk Process Wastage.
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Quick links -->
    <div class="bd-links">
        <a asp-action="WastageByBatch" asp-route-id="@Model.ProductionBatchId" class="bd-link-btn">
            <i class="bi bi-trash3"></i> Product Wastage for This Batch
        </a>
        <a asp-action="MilkProcessWastage" class="bd-link-btn danger">
            <i class="bi bi-droplet-half"></i> All Milk Process Wastage
        </a>
    </div>

</div>


<!-- ══════════════════════════════════════════
     OFFCANVAS — Update Status
══════════════════════════════════════════ -->
@if (canChangeStatus)
{
    <div class="offcanvas offcanvas-end" tabindex="-1" id="statusDrawer"
         style="width:380px; font-family:'Roboto',sans-serif;">

        <div class="bd-oc-flex">

            <div class="offcanvas-header" style="border-bottom:1px solid #e0e0e0; flex-shrink:0;">
                <h6 class="offcanvas-title bd-oc-title">
                    <i class="bi bi-pencil me-2" style="color:#1a73e8;"></i>Update Batch Status
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="bd-oc-body">
                <form asp-action="UpdateBatchStatus" method="post" id="statusForm">
                    <input type="hidden" name="productionBatchId" value="@Model.ProductionBatchId" />

                    <div class="bd-mb">
                        <label class="bd-form-label">New Status</label>
                        <select name="batchStatus" class="bd-select" id="statusSelect" onchange="showQCWarn(this.value)">
                            <option value="Completed">Completed</option>
                            <option value="QCFailed">QC Failed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>

                    <div class="bd-qc-warning hidden" id="qcWarning">
                        <i class="bi bi-exclamation-octagon-fill" style="flex-shrink:0;margin-top:1px;"></i>
                        <span>
                            <strong>Warning:</strong> Selecting QC Failed will automatically record
                            <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong> as wastage.
                            This cannot be undone.
                        </span>
                    </div>
                </form>
            </div>

            <!-- Sticky footer — always visible -->
            <div class="bd-oc-footer">
                <button type="submit" form="statusForm" class="bd-btn-submit primary">
                    <i class="bi bi-check-lg"></i> Confirm Status Update
                </button>
            </div>

        </div>
    </div>
}


<!-- ══════════════════════════════════════════
     OFFCANVAS — Record Process Wastage
══════════════════════════════════════════ -->
@if (canAddWastage)
{
    <div class="offcanvas offcanvas-end" tabindex="-1" id="wastageDrawer"
         style="width:420px; font-family:'Roboto',sans-serif;">

        <div class="bd-oc-flex">

            <div class="offcanvas-header" style="border-bottom:1px solid #e0e0e0; flex-shrink:0;">
                <h6 class="offcanvas-title bd-oc-title">
                    <i class="bi bi-droplet-half me-2" style="color:#f29900;"></i>Record Process Wastage
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="bd-oc-body">
                <p style="font-size:13px;color:#5f6368;margin-bottom:20px;">
                    Record raw milk lost during processing for batch <strong>PB-@Model.ProductionBatchId</strong>
                    (e.g. spillage, evaporation, equipment loss). This is separate from a full QC failure.
                </p>

                <form asp-action="AddMilkProcessWastage" method="post" id="wastageForm">
                    <input type="hidden" name="productionBatchId" value="@Model.ProductionBatchId" />

                    <div class="bd-mb">
                        <label class="bd-form-label">Milk Type <span class="bd-form-req">*</span></label>
                        <select name="milkTypeId" class="bd-select" required>
                            <option value="">— Select milk type —</option>
                            @if (milkTypes != null)
                            {
                                @foreach (var mt in milkTypes)
                                {
                                    <option value="@mt.MilkTypeId">@mt.MilkTypeName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="bd-mb">
                        <label class="bd-form-label">Wastage Quantity <span class="bd-form-req">*</span></label>
                        <div class="bd-input-group">
                            <input type="number" name="wastageQuantity" class="bd-input"
                                   step="0.01" min="0.01" max="@Model.MilkUsedQuantity"
                                   placeholder="e.g. 25.50" required />
                            <span class="bd-input-group-text">L</span>
                        </div>
                        <div class="bd-form-hint">Max: @Model.MilkUsedQuantity.ToString("N2") L (total milk used)</div>
                    </div>

                    <div class="bd-mb">
                        <label class="bd-form-label">Reason</label>
                        <textarea name="reason" class="bd-textarea" maxlength="200"
                              placeholder="e.g. Spillage during transfer, evaporation loss…"></textarea>
                    </div>

                    <div class="bd-wastage-info">
                        <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
                        <span>
                            This records a <strong>partial</strong> milk loss only.
                            To write off the entire batch, use <strong>Update Status &rarr; QC Failed</strong>.
                        </span>
                    </div>
                </form>
            </div>

            <!-- Sticky footer — always visible -->
            <div class="bd-oc-footer">
                <button type="submit" form="wastageForm" class="bd-btn-submit warning">
                    <i class="bi bi-droplet-half"></i> Record Wastage
                </button>
            </div>

        </div>
    </div>
}


@section Scripts {
    <script>
        function showQCWarn(val) {
            const w = document.getElementById('qcWarning');
            w.classList.toggle('hidden', val !== 'QCFailed');
        }
    </script>
}
