@model DairyIndustry.Models.Production.ProductionBatchModel
@{
    ViewData["Title"] = $"Batch PB-{Model.ProductionBatchId}";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";

    bool canChangeStatus = Model.BatchStatus == "InProgress";
    bool canAddWastage = Model.BatchStatus == "InProgress";

    string statusColor = Model.BatchStatus switch
    {
        "InProgress" => "#854F0B",
        "Completed" => "#3B6D11",
        "QCFailed" => "#A32D2D",
        "Cancelled" => "#5f6368",
        "Pending" => "#185FA5",
        _ => "#5f6368"
    };
    string statusBg = Model.BatchStatus switch
    {
        "InProgress" => "#FAEEDA",
        "Completed" => "#EAF3DE",
        "QCFailed" => "#FCEBEB",
        "Cancelled" => "#f1f3f4",
        "Pending" => "#E6F1FB",
        _ => "#f1f3f4"
    };
    string statusBorder = Model.BatchStatus switch
    {
        "InProgress" => "#FAC775",
        "Completed" => "#C0DD97",
        "QCFailed" => "#F7C1C1",
        "Cancelled" => "#e0e0e0",
        "Pending" => "#B5D4F4",
        _ => "#e0e0e0"
    };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .bd {
        --ink: #111827;
        --ink-2: #374151;
        --ink-3: #6b7280;
        --ink-4: #9ca3af;
        --surface: #ffffff;
        --bg: #f8f9fa;
        --border: #e2e5ea;
        --accent: #185FA5;
        --green: #3B6D11;
        --green-bg: #EAF3DE;
        --green-bd: #C0DD97;
        --red: #A32D2D;
        --red-bg: #FCEBEB;
        --red-bd: #F7C1C1;
        --amber: #854F0B;
        --amber-bg: #FAEEDA;
        --amber-bd: #FAC775;
        --blue-bg: #E6F1FB;
        --blue-bd: #B5D4F4;
        --r: 10px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        color: var(--ink);
        max-width: 1000px;
    }

    /* ── Breadcrumb ── */
    .bd-bc {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--ink-3);
        margin-bottom: 6px;
    }

        .bd-bc a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }

            .bd-bc a:hover {
                text-decoration: underline;
            }

    /* ── Page header ── */
    .bd-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 20px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .bd-title {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -0.5px;
        color: var(--ink);
        margin: 0 0 4px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .bd-title-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        letter-spacing: 0;
    }

    .bd-title-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .bd-sub {
        font-size: 13px;
        color: var(--ink-3);
        margin: 0;
    }

    /* ── Action buttons ── */
    .bd-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .bd-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 36px;
        padding: 0 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid;
        transition: all .15s;
        white-space: nowrap;
    }

    .bd-btn-back {
        background: var(--surface);
        border-color: var(--border);
        color: var(--ink-2);
    }

        .bd-btn-back:hover {
            background: #f3f4f6;
            border-color: #ccc;
            color: var(--ink);
            text-decoration: none;
        }

    .bd-btn-wastage {
        background: var(--amber-bg);
        border-color: var(--amber-bd);
        color: var(--amber);
    }

        .bd-btn-wastage:hover {
            background: #fde9a0;
        }

    .bd-btn-status {
        background: var(--green-bg);
        border-color: var(--green-bd);
        color: var(--green);
    }

        .bd-btn-status:hover {
            background: #d2eeda;
        }

    /* ── Alerts ── */
    .bd-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 16px;
        border-radius: var(--r);
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 16px;
        border: 1px solid;
    }

    .bd-alert-success {
        background: var(--green-bg);
        border-color: var(--green-bd);
        color: var(--green);
    }

    .bd-alert-danger {
        background: var(--red-bg);
        border-color: var(--red-bd);
        color: var(--red);
    }

    .bd-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        font-size: 16px;
        opacity: .6;
        line-height: 1;
    }

        .bd-alert-close:hover {
            opacity: 1;
        }

    /* ── QC Failed banner ── */
    .bd-qc-banner {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 18px;
        border-radius: var(--r);
        background: var(--red-bg);
        border: 1px solid var(--red-bd);
        color: var(--red);
        margin-bottom: 20px;
        font-size: 13.5px;
    }

        .bd-qc-banner a {
            color: var(--red);
            font-weight: 600;
        }

    /* ── Grid layout ── */
    .bd-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 16px;
        align-items: start;
    }

    @@media (max-width: 768px) {
        .bd-grid

    {
        grid-template-columns: 1fr;
    }

    }

    /* ── Cards ── */
    .bd-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r);
        overflow: hidden;
    }

    .bd-card-hd {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border-bottom: 1px solid var(--border);
        background: #fafbfc;
        font-size: 13px;
        font-weight: 600;
        color: var(--ink-2);
    }

        .bd-card-hd i {
            color: var(--accent);
            font-size: 15px;
        }

    .bd-card-body {
        padding: 18px;
    }

    /* ── Info grid (inside Batch Information card) ── */
    .bd-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .bd-info-cell {
        padding: 11px 14px;
        background: #fafbfc;
        border: 1px solid var(--border);
        border-radius: 8px;
    }

        .bd-info-cell.span2 {
            grid-column: 1 / -1;
        }

    .bd-info-label {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--ink-4);
        margin-bottom: 4px;
    }

    .bd-info-value {
        font-size: 14px;
        font-weight: 500;
        color: var(--ink);
    }

        .bd-info-value.mono {
            font-family: 'SF Mono', 'Consolas', monospace;
            color: var(--accent);
        }

        .bd-info-value.big {
            font-size: 20px;
            font-weight: 700;
            color: var(--accent);
            letter-spacing: -0.5px;
        }

    /* ── Status Flow card ── */
    .bd-flow {
        display: flex;
        flex-direction: column;
    }

    .bd-flow-step {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 18px;
        position: relative;
    }

        .bd-flow-step:not(:last-child) {
            border-bottom: 1px solid #f3f4f6;
        }

    .bd-flow-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        border: 2px solid;
    }

        .bd-flow-dot.active {
            background: currentColor;
        }

        .bd-flow-dot.inactive {
            background: transparent;
            border-color: #d1d5db;
            color: #d1d5db;
        }

    .bd-flow-label {
        font-size: 13px;
        font-weight: 400;
        color: var(--ink-3);
        flex: 1;
    }

        .bd-flow-label.active {
            font-weight: 600;
            color: var(--ink);
        }

    .bd-flow-badge {
        font-size: 10px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 10px;
        border: 1px solid;
        letter-spacing: 0.3px;
    }

    .bd-qc-note {
        margin: 0 14px 14px;
        padding: 10px 13px;
        background: var(--amber-bg);
        border: 1px solid var(--amber-bd);
        border-radius: 8px;
        font-size: 12px;
        color: var(--amber);
        line-height: 1.5;
    }

    /* ── Divider ── */
    .bd-divider {
        height: 1px;
        background: var(--border);
        margin: 16px 0;
    }

    /* ── Offcanvas / Drawer ── */
    .bd-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: 400px;
        max-width: 100vw;
        height: 100vh;
        background: var(--surface);
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform .3s cubic-bezier(.4,0,.2,1);
        z-index: 1050;
        box-shadow: -4px 0 24px rgba(0,0,0,.08);
    }

        .bd-drawer.open {
            transform: translateX(0);
        }

    .bd-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.2);
        opacity: 0;
        pointer-events: none;
        transition: opacity .3s;
        z-index: 1040;
    }

        .bd-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

    .bd-drawer-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .bd-drawer-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .bd-drawer-sub {
        font-size: 12px;
        color: var(--ink-3);
        margin: 2px 0 0;
    }

    .bd-drawer-close {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1px solid var(--border);
        background: #fafbfc;
        cursor: pointer;
        font-size: 16px;
        color: var(--ink-3);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .15s;
        flex-shrink: 0;
    }

        .bd-drawer-close:hover {
            background: #f0f0f0;
            color: var(--ink);
        }

    .bd-drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .bd-drawer-foot {
        padding: 14px 20px;
        border-top: 1px solid var(--border);
        background: #fafbfc;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    /* ── Frozen info pill inside drawer ── */
    .bd-frozen {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: var(--blue-bg);
        border: 1px solid var(--blue-bd);
        border-radius: 8px;
        font-size: 12px;
        color: var(--accent);
    }

        .bd-frozen strong {
            font-size: 13px;
        }

    /* ── Form fields ── */
    .bd-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .bd-field label {
            font-size: 12px;
            font-weight: 600;
            color: var(--ink-2);
        }

        .bd-field .req {
            color: var(--red);
        }

        .bd-field input,
        .bd-field select,
        .bd-field textarea {
            width: 100%;
            padding: 9px 12px;
            font-size: 13px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #fafbfc;
            color: var(--ink);
            outline: none;
            transition: border-color .15s, box-shadow .15s;
            font-family: inherit;
            box-sizing: border-box;
        }

            .bd-field input:focus,
            .bd-field select:focus,
            .bd-field textarea:focus {
                border-color: var(--accent);
                background: var(--surface);
                box-shadow: 0 0 0 3px rgba(24,95,165,.1);
            }

        .bd-field textarea {
            resize: vertical;
            min-height: 80px;
        }

    .bd-field-hint {
        font-size: 11px;
        color: var(--ink-4);
    }

    .bd-input-row {
        display: flex;
        gap: 0;
    }

        .bd-input-row input {
            border-radius: 8px 0 0 8px;
            flex: 1;
        }

    .bd-input-suffix {
        display: flex;
        align-items: center;
        padding: 0 13px;
        background: #f3f4f6;
        border: 1px solid var(--border);
        border-left: none;
        border-radius: 0 8px 8px 0;
        font-size: 13px;
        font-weight: 500;
        color: var(--ink-3);
    }

    /* ── Info box inside drawer ── */
    .bd-info-box {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 11px 13px;
        border-radius: 8px;
        font-size: 12px;
        line-height: 1.5;
    }

        .bd-info-box.amber {
            background: var(--amber-bg);
            border: 1px solid var(--amber-bd);
            color: var(--amber);
        }

        .bd-info-box.red {
            background: var(--red-bg);
            border: 1px solid var(--red-bd);
            color: var(--red);
        }

    /* ── QC warning in status drawer ── */
    .bd-qc-warn {
        display: none;
        gap: 10px;
        align-items: flex-start;
        padding: 11px 13px;
        border-radius: 8px;
        font-size: 12px;
        line-height: 1.5;
        background: var(--red-bg);
        border: 1px solid var(--red-bd);
        color: var(--red);
    }

        .bd-qc-warn.show {
            display: flex;
        }

    /* ── Submit buttons ── */
    .btn-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        height: 38px;
        padding: 0 20px;
        border-radius: 8px;
        border: none;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-submit.primary {
            background: var(--accent);
            color: #fff;
        }

            .btn-submit.primary:hover {
                background: #0C447C;
            }

        .btn-submit.warning {
            background: #d97706;
            color: #fff;
        }

            .btn-submit.warning:hover {
                background: #b45309;
            }

        .btn-submit.cancel {
            background: var(--surface);
            color: var(--ink-2);
            border: 1px solid var(--border);
        }

            .btn-submit.cancel:hover {
                background: #f3f4f6;
            }
</style>

<!-- Overlay -->
<div class="bd-overlay" id="bdOverlay"></div>

<div class="bd">

    <!-- Breadcrumb -->
    <div class="bd-bc">
        <a asp-action="Batches">Batch Tracking</a>
        <i class="bi bi-chevron-right" style="font-size:10px;"></i>
        <span>PB-@Model.ProductionBatchId</span>
    </div>

    <!-- Header -->
    <div class="bd-header">
        <div>
            <h1 class="bd-title">
                Batch <span style="font-family:'SF Mono','Consolas',monospace;font-weight:700;">PB-@Model.ProductionBatchId.ToString("D4")</span>
                <span class="bd-title-badge" style="background:@statusBg;color:@statusColor;border:1px solid @statusBorder;">
                    <span class="bd-title-dot"></span>@Model.BatchStatus
                </span>
            </h1>
            <p class="bd-sub">@Model.PlantName &nbsp;·&nbsp; @Model.ProductionDate.ToString("dd MMM yyyy")</p>
        </div>
        <div class="bd-actions">
            @if (canAddWastage)
            {
                <button class="bd-btn bd-btn-wastage" onclick="openDrawer('wastageDrawer')">
                    <i class="bi bi-droplet-half"></i> Record Wastage
                </button>
            }
            @if (canChangeStatus)
            {
                <button class="bd-btn bd-btn-status" onclick="openDrawer('statusDrawer')">
                    <i class="bi bi-pencil"></i> Update Status
                </button>
            }
            <a asp-action="Batches" class="bd-btn bd-btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="bd-alert bd-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="bd-alert-close" onclick="this.closest('.bd-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bd-alert bd-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="bd-alert-close" onclick="this.closest('.bd-alert').remove()">&times;</button>
        </div>
    }

    <!-- QC Failed Banner -->
    @if (Model.BatchStatus == "QCFailed")
    {
        <div class="bd-qc-banner">
            <i class="bi bi-exclamation-octagon-fill" style="font-size:20px;flex-shrink:0;margin-top:2px;"></i>
            <div>
                <strong>This batch failed QC.</strong> The full milk quantity of
                <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong> has been automatically
                written off and recorded in Milk Process Wastage.
            </div>
        </div>
    }

    <!-- Main 2-col grid -->
    <div class="bd-grid">

        <!-- LEFT: Batch Information -->
        <div class="bd-card">
            <div class="bd-card-hd">
                <i class="bi bi-info-circle-fill"></i> Batch Information
            </div>
            <div class="bd-card-body">
                <div class="bd-info-grid">
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Batch ID</div>
                        <div class="bd-info-value mono">PB-@Model.ProductionBatchId.ToString("D4")</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Status</div>
                        <div class="bd-info-value">
                            <span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;background:@statusBg;color:@statusColor;border:1px solid @statusBorder;">
                                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;"></span>
                                @Model.BatchStatus
                            </span>
                        </div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Plant</div>
                        <div class="bd-info-value">@Model.PlantName</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Production Date</div>
                        <div class="bd-info-value">@Model.ProductionDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Product</div>
                        <div class="bd-info-value">@Model.ProductName</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Product Type</div>
                        <div class="bd-info-value">@Model.ProductType</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Unit</div>
                        <div class="bd-info-value">@Model.Unit</div>
                    </div>
                    <div class="bd-info-cell">
                        <div class="bd-info-label">Milk Type</div>
                        <div class="bd-info-value">@(Model.MilkTypeName ?? "—")</div>
                    </div>
                    <div class="bd-info-cell span2">
                        <div class="bd-info-label">Milk Used</div>
                        <div class="bd-info-value big">@Model.MilkUsedQuantity.ToString("N2") <span style="font-size:14px;font-weight:500;color:var(--ink-3);">L</span></div>
                    </div>
                   
                </div>
            </div>
        </div>

        <!-- RIGHT: Status Flow -->
        <div class="bd-card">
            <div class="bd-card-hd">
                <i class="bi bi-diagram-3-fill"></i> Status Flow
            </div>
            <div class="bd-flow">
                @{
                    var flowSteps = new[]
                    {
                                ("Pending",    "bi-clock",               "#185FA5", "#E6F1FB", "#B5D4F4"),
                                ("InProgress", "bi-hourglass-split",     "#854F0B", "#FAEEDA", "#FAC775"),
                                ("Completed",  "bi-check-circle-fill",   "#3B6D11", "#EAF3DE", "#C0DD97"),
                                ("QCFailed",   "bi-x-circle-fill",       "#A32D2D", "#FCEBEB", "#F7C1C1"),
                                ("Cancelled",  "bi-dash-circle-fill",    "#6b7280", "#f1f3f4", "#e0e0e0"),
                                };
                }
                @foreach (var (name, icon, fc, fbg, fbd) in flowSteps)
                {
                    bool isCurrent = Model.BatchStatus == name;
                    <div class="bd-flow-step">
                        <span class="bd-flow-dot @(isCurrent ? "active" : "inactive")"
                              style="@(isCurrent ? $"color:{fc};border-color:{fc};" : "")"></span>
                        <span class="bd-flow-label @(isCurrent ? "active" : "")">@name</span>
                        @if (isCurrent)
                        {
                            <span class="bd-flow-badge"
                                  style="background:@fbg;color:@fc;border-color:@fbd;">
                                Current
                            </span>
                        }
                    </div>
                }
            </div>
            @if (canChangeStatus)
            {
                <div class="bd-qc-note" style="margin:12px;">
                    <i class="bi bi-info-circle me-1"></i>
                    Marking as <strong>QC Failed</strong> will automatically record
                    <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong> in Milk Process Wastage.
                </div>
            }
        </div>

    </div><!-- /bd-grid -->

</div><!-- /bd -->
<!-- ══════════════════════════════════════
     DRAWER — Record Wastage
══════════════════════════════════════ -->
@if (canAddWastage)
{
    <div class="bd-drawer" id="wastageDrawer">
        <div class="bd-drawer-hd">
            <div>
                <p class="bd-drawer-title"><i class="bi bi-droplet-half" style="color:#d97706;margin-right:7px;"></i>Record Process Wastage</p>
                <p class="bd-drawer-sub">Batch PB-@Model.ProductionBatchId.ToString("D4") · @Model.PlantName</p>
            </div>
            <button class="bd-drawer-close" onclick="closeDrawer('wastageDrawer')">&times;</button>
        </div>

        <div class="bd-drawer-body">

            <!-- Auto-filled milk type info pill -->
            <div class="bd-frozen">
                <i class="bi bi-lock-fill" style="font-size:15px;flex-shrink:0;"></i>
                <div>
                    <div style="font-size:11px;font-weight:500;margin-bottom:1px;">Milk Type (auto-filled from batch)</div>
                    <strong>@(Model.MilkTypeName ?? "—")</strong>
                </div>
            </div>

            <form asp-action="AddMilkProcessWastage" method="post" id="wastageForm">
                <input type="hidden" name="productionBatchId" value="@Model.ProductionBatchId" />
                <input type="hidden" name="milkTypeId" value="@Model.MilkTypeId" />

                <div class="bd-field">
                    <label>Wastage Quantity <span class="req">*</span></label>
                    <div class="bd-input-row">
                        <input type="number" name="wastageQuantity"
                               step="0.01" min="0.01" max="@Model.MilkUsedQuantity"
                               placeholder="e.g. 25.50" required />
                        <span class="bd-input-suffix">L</span>
                    </div>
                    <span class="bd-field-hint">Max allowed: @Model.MilkUsedQuantity.ToString("N2") L</span>
                </div>

                <div class="bd-field">
                    <label>Wastage Reason <span class="req">*</span></label>
                    <select name="reason" required>
                        <option value="">— Select reason —</option>
                        <option value="Spillage">Spillage</option>
                        <option value="Evaporation">Evaporation</option>
                        <option value="Equipment Loss">Equipment Loss</option>
                        <option value="Contamination">Contamination</option>
                        <option value="Transfer Loss">Transfer Loss</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="bd-field">
                    <label>Notes <span style="font-weight:400;color:var(--ink-4);">(optional)</span></label>
                    <textarea name="notes" placeholder="Any additional details about the wastage event…" maxlength="300"></textarea>
                </div>

                <div class="bd-info-box amber">
                    <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
                    <span>
                        This records a <strong>partial</strong> milk loss only.
                        To write off the entire batch, use <strong>Update Status → QC Failed</strong>.
                    </span>
                </div>

            </form>
        </div>

        <div class="bd-drawer-foot">
            <button type="button" class="btn-submit cancel" onclick="closeDrawer('wastageDrawer')">Cancel</button>
            <button type="submit" form="wastageForm" class="btn-submit warning">
                <i class="bi bi-droplet-half"></i> Record Wastage
            </button>
        </div>
    </div>
}


<!-- ══════════════════════════════════════
     DRAWER — Update Status
══════════════════════════════════════ -->
@if (canChangeStatus)
{
    <div class="bd-drawer" id="statusDrawer">
        <div class="bd-drawer-hd">
            <div>
                <p class="bd-drawer-title"><i class="bi bi-pencil" style="color:#185FA5;margin-right:7px;"></i>Update Batch Status</p>
                <p class="bd-drawer-sub">Batch PB-@Model.ProductionBatchId.ToString("D4") · currently <strong>@Model.BatchStatus</strong></p>
            </div>
            <button class="bd-drawer-close" onclick="closeDrawer('statusDrawer')">&times;</button>
        </div>

        <div class="bd-drawer-body">

            <form asp-action="UpdateBatchStatus" method="post" id="statusForm">
                <input type="hidden" name="productionBatchId" value="@Model.ProductionBatchId" />

                <div class="bd-field">
                    <label>New Status <span class="req">*</span></label>
                    <select name="batchStatus" id="statusSelect" onchange="toggleQCWarn(this.value)" required>
                        <option value="">— Select new status —</option>
                        <option value="Completed">Completed</option>
                        <option value="QCFailed">QC Failed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="bd-qc-warn" id="qcWarn">
                    <i class="bi bi-exclamation-octagon-fill" style="flex-shrink:0;margin-top:1px;font-size:15px;"></i>
                    <span>
                        <strong>Warning:</strong> Selecting QC Failed will automatically record
                        <strong>@Model.MilkUsedQuantity.ToString("N2") L</strong> as wastage in
                        Milk Process Wastage. <strong>This cannot be undone.</strong>
                    </span>
                </div>

            </form>
        </div>

        <div class="bd-drawer-foot">
            <button type="button" class="btn-submit cancel" onclick="closeDrawer('statusDrawer')">Cancel</button>
            <button type="submit" form="statusForm" class="btn-submit primary">
                <i class="bi bi-check-lg"></i> Confirm Update
            </button>
        </div>
    </div>
}

<script>
    const overlay = document.getElementById('bdOverlay');

    function openDrawer(id) {
        document.getElementById(id).classList.add('open');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeDrawer(id) {
        document.getElementById(id).classList.remove('open');
        overlay.classList.remove('open');
        document.body.style.overflow = '';
    }

    overlay.addEventListener('click', function () {
        document.querySelectorAll('.bd-drawer.open').forEach(d => d.classList.remove('open'));
        overlay.classList.remove('open');
        document.body.style.overflow = '';
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            document.querySelectorAll('.bd-drawer.open').forEach(d => d.classList.remove('open'));
            overlay.classList.remove('open');
            document.body.style.overflow = '';
        }
    });

    function toggleQCWarn(val) {
        const w = document.getElementById('qcWarn');
        if (w) w.classList.toggle('show', val === 'QCFailed');
    }
</script>
