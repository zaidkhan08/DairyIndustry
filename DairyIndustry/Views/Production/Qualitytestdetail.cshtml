@model DairyIndustry.Models.Production.QualityTestModel
@{
    ViewData["Title"] = $"Quality Test — T-{Model.TransferId}";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
    var fatDiff = (Model.TestedFat.HasValue && Model.BatchAvgFat.HasValue)
                    ? (Model.TestedFat.Value - Model.BatchAvgFat.Value) : (decimal?)null;
    var clrDiff = (Model.TestedCLR.HasValue && Model.BatchAvgCLR.HasValue)
                    ? (Model.TestedCLR.Value - Model.BatchAvgCLR.Value) : (decimal?)null;
    bool passed = Model.QualityResult == "Normal";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .qd {
        --c-surface: #ffffff;
        --c-bg: #f5f6f8;
        --c-bg2: #f0f1f4;
        --c-border: #e2e5ea;
        --c-border-lt: #eef0f3;
        --c-text: #111827;
        --c-text-2: #374151;
        --c-text-3: #6b7280;
        --c-text-4: #9ca3af;
        --c-accent: #2563eb;
        --c-green: #16a34a;
        --c-green-bg: #f0fdf4;
        --c-green-bd: #86efac;
        --c-red: #dc2626;
        --c-red-bg: #fef2f2;
        --c-red-bd: #fca5a5;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        color: var(--c-text);
        max-width: 860px;
    }

    .qd-bc {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.3px;
        color: var(--c-text-4);
        margin-bottom: 14px;
        text-transform: uppercase;
    }

        .qd-bc a {
            color: var(--c-accent);
            text-decoration: none;
        }

            .qd-bc a:hover {
                text-decoration: underline;
            }

        .qd-bc i {
            font-size: 9px;
        }

    .qd-titlerow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .qd-title {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.4px;
        color: var(--c-text);
        margin: 0 0 3px;
    }

    .qd-title-sub {
        font-size: 12px;
        color: var(--c-text-3);
    }

    .qd-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 500;
        color: var(--c-text-2);
        padding: 6px 14px;
        border: 1px solid var(--c-border);
        border-radius: 5px;
        background: var(--c-surface);
        text-decoration: none;
        transition: all .15s;
    }

        .qd-back:hover {
            background: var(--c-bg);
            border-color: #c9cdd4;
        }

    /* Two-col layout */
    .qd-layout {
        display: grid;
        grid-template-columns: 1fr 252px;
        gap: 14px;
        align-items: start;
    }

    /* Ledger */
    .qd-ledger {
        border: 1px solid var(--c-border);
        border-radius: 6px;
        overflow: hidden;
        background: var(--c-surface);
    }

    .qd-ledger-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 18px;
        background: var(--c-bg);
        border-bottom: 1px solid var(--c-border);
    }

        .qd-ledger-hd + .qd-section-gap {
            border-top: 1px solid var(--c-border);
        }

    .qd-ledger-hd-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.7px;
        text-transform: uppercase;
        color: var(--c-text-3);
    }

    .qd-ledger-hd-note {
        font-size: 11px;
        color: var(--c-text-4);
    }

    /* Metric rows (3 cols: label | batch avg | tested) */
    .qd-metric-row {
        display: grid;
        grid-template-columns: 180px 1fr 1fr;
        border-bottom: 1px solid var(--c-border-lt);
    }

        .qd-metric-row:hover {
            background: #f8f9fb;
        }

    .qd-metric-label {
        padding: 14px 18px;
        border-right: 1px solid var(--c-border-lt);
        background: #fafbfc;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 3px;
    }

    .qd-metric-label-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text-2);
    }

    .qd-metric-label-sub {
        font-size: 11px;
        color: var(--c-text-4);
    }

    .qd-metric-cell {
        padding: 14px 18px;
        border-right: 1px solid var(--c-border-lt);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .qd-metric-cell:last-child {
            border-right: none;
        }

    .qd-metric-cell-lbl {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--c-text-4);
        margin-bottom: 5px;
    }

    .qd-metric-val {
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.6px;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

        .qd-metric-val .u {
            font-size: 12px;
            font-weight: 400;
            color: var(--c-text-4);
            margin-left: 1px;
        }

        .qd-metric-val.avg {
            font-size: 20px;
            font-weight: 500;
            color: var(--c-text-3);
        }

        .qd-metric-val.ok {
            color: var(--c-green);
        }

        .qd-metric-val.dev {
            color: var(--c-red);
        }

    .qd-pill {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 3px;
        margin-top: 6px;
        width: fit-content;
    }

        .qd-pill.ok {
            background: var(--c-green-bg);
            color: var(--c-green);
        }

        .qd-pill.dev {
            background: var(--c-red-bg);
            color: var(--c-red);
        }

    .qd-flag {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        font-weight: 600;
        color: var(--c-red);
        margin-top: 4px;
    }

    /* Info rows (2 cols: label | value) */
    .qd-section-sep {
        border-top: 1px solid var(--c-border);
    }

    .qd-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        border-bottom: 1px solid var(--c-border-lt);
    }

        .qd-row:last-child {
            border-bottom: none;
        }

        .qd-row:hover {
            background: #f8f9fb;
        }

    .qd-row-lbl {
        padding: 10px 18px;
        font-size: 12px;
        font-weight: 500;
        color: var(--c-text-3);
        border-right: 1px solid var(--c-border-lt);
        background: #fafbfc;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .qd-row-lbl i {
            font-size: 11px;
            color: var(--c-text-4);
        }

    .qd-row-val {
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        color: var(--c-text);
        display: flex;
        align-items: center;
    }

        .qd-row-val.mono {
            font-family: 'SF Mono', 'Consolas', monospace;
            font-size: 12px;
            letter-spacing: 0.5px;
        }

    .qd-tid {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 12px;
        font-weight: 600;
        color: var(--c-accent);
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 3px 10px;
        border-radius: 4px;
    }

    /* RIGHT panel */
    .qd-panel {
        border: 1px solid var(--c-border);
        border-radius: 6px;
        overflow: hidden;
        background: var(--c-surface);
    }

    .qd-panel-stamp {
        padding: 24px 20px 20px;
        text-align: center;
        border-bottom: 1px solid var(--c-border);
    }

        .qd-panel-stamp.pass {
            background: var(--c-green-bg);
        }

        .qd-panel-stamp.fail {
            background: var(--c-red-bg);
        }

    .qd-stamp-icon {
        font-size: 38px;
        display: block;
        margin-bottom: 10px;
        line-height: 1;
    }

    .qd-panel-stamp.pass .qd-stamp-icon {
        color: var(--c-green);
    }

    .qd-panel-stamp.fail .qd-stamp-icon {
        color: var(--c-red);
    }

    .qd-stamp-eyebrow {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .qd-panel-stamp.pass .qd-stamp-eyebrow {
        color: var(--c-green);
    }

    .qd-panel-stamp.fail .qd-stamp-eyebrow {
        color: var(--c-red);
    }

    .qd-stamp-result {
        font-size: 19px;
        font-weight: 700;
        color: var(--c-text);
        letter-spacing: -0.3px;
    }

    .qd-panel-section {
        padding: 7px 16px 3px;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--c-text-4);
        background: var(--c-bg);
        border-top: 1px solid var(--c-border);
        border-bottom: 1px solid var(--c-border-lt);
    }

        .qd-panel-section:first-of-type {
            border-top: none;
        }

    .qd-pstat {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 16px;
        border-bottom: 1px solid var(--c-border-lt);
        font-size: 12px;
    }

        .qd-pstat:last-child {
            border-bottom: none;
        }

    .qd-pstat-lbl {
        color: var(--c-text-3);
        font-weight: 500;
    }

    .qd-pstat-val {
        font-weight: 600;
        color: var(--c-text);
        font-variant-numeric: tabular-nums;
    }

        .qd-pstat-val.ok {
            color: var(--c-green);
        }

        .qd-pstat-val.dev {
            color: var(--c-red);
        }

    @@media (max-width: 680px) {
        .qd-layout {
            grid-template-columns: 1fr;
        }

        .qd-metric-row {
            grid-template-columns: 140px 1fr 1fr;
        }

        .qd-row {
            grid-template-columns: 140px 1fr;
        }
    }
</style>

<div class="qd">

    <div class="qd-bc">
        <a asp-action="Qualitytests">Quality Tests</a>
        <i class="bi bi-chevron-right"></i>
        <span>Transfer #@Model.TransferId</span>
    </div>

    <div class="qd-titlerow">
        <div>
            <div class="qd-title">Quality Test — T-@Model.TransferId</div>
            <div class="qd-title-sub">@Model.TestDate.ToString("dd MMM yyyy") &nbsp;·&nbsp; @Model.CenterName → @Model.PlantName</div>
        </div>
        <a asp-action="Qualitytests" class="qd-back">
            <i class="bi bi-arrow-left"></i> Back to list
        </a>
    </div>

    <div class="qd-layout">

        <!-- LEFT: Ledger -->
        <div class="qd-ledger">

            <!-- Readings section -->
            <div class="qd-ledger-hd">
                <span class="qd-ledger-hd-label"><i class="bi bi-activity" style="margin-right:5px;"></i>Quality Readings</span>
                <span class="qd-ledger-hd-note">Tested vs Batch Average</span>
            </div>

            <div class="qd-metric-row">
                <div class="qd-metric-label">
                    <span class="qd-metric-label-name">Fat Content</span>
                    <span class="qd-metric-label-sub">Tolerance ±0.5%</span>
                </div>
                <div class="qd-metric-cell">
                    <div class="qd-metric-cell-lbl">Batch Average</div>
                    <div class="qd-metric-val avg">@(Model.BatchAvgFat?.ToString("F2") ?? "—")<span class="u">%</span></div>
                </div>
                <div class="qd-metric-cell">
                    <div class="qd-metric-cell-lbl">Tested Reading</div>
                    <div class="qd-metric-val @(Model.IsFatDeviated ? "dev" : "ok")">
                        @(Model.TestedFat?.ToString("F2") ?? "—")<span class="u">%</span>
                    </div>
                    @if (fatDiff.HasValue)
                    {
                        <div class="qd-pill @(Model.IsFatDeviated ? "dev" : "ok")">
                            <i class="bi @(fatDiff.Value >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                            @(fatDiff.Value >= 0 ? "+" : "")@fatDiff.Value.ToString("F2") var
                        </div>
                    }
                    @if (Model.IsFatDeviated)
                    {
                        <div class="qd-flag"><i class="bi bi-exclamation-triangle-fill"></i> Outside ±0.5% tolerance</div>
                    }
                </div>
            </div>

            <div class="qd-metric-row" style="border-bottom:none;">
                <div class="qd-metric-label">
                    <span class="qd-metric-label-name">CLR</span>
                    <span class="qd-metric-label-sub">Tolerance ±2</span>
                </div>
                <div class="qd-metric-cell">
                    <div class="qd-metric-cell-lbl">Batch Average</div>
                    <div class="qd-metric-val avg">@(Model.BatchAvgCLR?.ToString("F2") ?? "—")</div>
                </div>
                <div class="qd-metric-cell">
                    <div class="qd-metric-cell-lbl">Tested Reading</div>
                    <div class="qd-metric-val @(Model.IsCLRDeviated ? "dev" : "ok")">
                        @(Model.TestedCLR?.ToString("F2") ?? "—")
                    </div>
                    @if (clrDiff.HasValue)
                    {
                        <div class="qd-pill @(Model.IsCLRDeviated ? "dev" : "ok")">
                            <i class="bi @(clrDiff.Value >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                            @(clrDiff.Value >= 0 ? "+" : "")@clrDiff.Value.ToString("F2") var
                        </div>
                    }
                    @if (Model.IsCLRDeviated)
                    {
                        <div class="qd-flag"><i class="bi bi-exclamation-triangle-fill"></i> Outside ±2 tolerance</div>
                    }
                </div>
            </div>

            <!-- Transfer info section -->
            <div class="qd-ledger-hd qd-section-sep">
                <span class="qd-ledger-hd-label"><i class="bi bi-truck" style="margin-right:5px;"></i>Transfer Information</span>
            </div>

            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-hash"></i> Transfer ID</div>
                <div class="qd-row-val"><span class="qd-tid"><i class="bi bi-arrow-left-right"></i> T-@Model.TransferId</span></div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-calendar3"></i> Test Date</div>
                <div class="qd-row-val">@Model.TestDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-geo-alt"></i> From (Center)</div>
                <div class="qd-row-val">@Model.CenterName</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-building"></i> To (Plant)</div>
                <div class="qd-row-val">@Model.PlantName</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-truck"></i> Vehicle</div>
                <div class="qd-row-val mono">@Model.VehicleNumber</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-person"></i> Driver</div>
                <div class="qd-row-val">@Model.DriverName</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-calendar-check"></i> Dispatch Date</div>
                <div class="qd-row-val">@Model.DispatchDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-droplet"></i> Dispatched Qty</div>
                <div class="qd-row-val mono">@Model.DispatchQty.ToString("F2") L</div>
            </div>
            <div class="qd-row">
                <div class="qd-row-lbl"><i class="bi bi-droplet-fill"></i> Received Qty</div>
                <div class="qd-row-val mono">@(Model.ReceivedQty?.ToString("F2") ?? "—") L</div>
            </div>

        </div>

        <!-- RIGHT: Verdict panel -->
        <div class="qd-panel">

            <div class="qd-panel-stamp @(passed ? "pass" : "fail")">
                <i class="bi @(passed ? "bi-patch-check-fill" : "bi-patch-exclamation-fill") qd-stamp-icon"></i>
                <div class="qd-stamp-eyebrow">Official Result</div>
                <div class="qd-stamp-result">@Model.QualityResult</div>
            </div>

            <div class="qd-panel-section">Fat</div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Batch avg</span>
                <span class="qd-pstat-val">@(Model.BatchAvgFat?.ToString("F2") ?? "—")%</span>
            </div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Tested</span>
                <span class="qd-pstat-val @(Model.IsFatDeviated ? "dev" : "ok")">@(Model.TestedFat?.ToString("F2") ?? "—")%</span>
            </div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Status</span>
                <span class="qd-pstat-val @(Model.IsFatDeviated ? "dev" : "ok")">
                    @(Model.IsFatDeviated ? "⚠ Deviated" : "✓ Normal")
                </span>
            </div>

            <div class="qd-panel-section">CLR</div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Batch avg</span>
                <span class="qd-pstat-val">@(Model.BatchAvgCLR?.ToString("F2") ?? "—")</span>
            </div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Tested</span>
                <span class="qd-pstat-val @(Model.IsCLRDeviated ? "dev" : "ok")">@(Model.TestedCLR?.ToString("F2") ?? "—")</span>
            </div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Status</span>
                <span class="qd-pstat-val @(Model.IsCLRDeviated ? "dev" : "ok")">
                    @(Model.IsCLRDeviated ? "⚠ Deviated" : "✓ Normal")
                </span>
            </div>

            <div class="qd-panel-section">Transfer</div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Dispatched</span>
                <span class="qd-pstat-val">@Model.DispatchQty.ToString("F0") L</span>
            </div>
            <div class="qd-pstat">
                <span class="qd-pstat-lbl">Received</span>
                <span class="qd-pstat-val">@(Model.ReceivedQty?.ToString("F0") ?? "—") L</span>
            </div>
            @if (Model.ReceivedQty.HasValue)
            {
                var loss = Model.DispatchQty - Model.ReceivedQty.Value;
                <div class="qd-pstat">
                    <span class="qd-pstat-lbl">Loss</span>
                    <span class="qd-pstat-val @(loss > 0 ? "dev" : "ok")">@loss.ToString("F0") L</span>
                </div>
            }

        </div>

    </div>
</div>
