@model List<DairyIndustry.Models.Production.ProductionBatchModel>
@{
    ViewData["Title"] = "Production Batches";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">🏭 Production Batches</h4>
    <a asp-action="StartBatch" class="btn btn-primary">+ Start New Batch</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Batch #</th>
                    <th>Plant</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th>Milk Used (L)</th>
                    <th>Production Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No production batches found.</td></tr>
                }
                @foreach (var b in Model)
                {
                    <tr>
                        <td><strong>PB-@b.ProductionBatchId</strong></td>
                        <td>@b.PlantName</td>
                        <td>@b.ProductName</td>
                        <td><span class="badge bg-info text-dark">@b.ProductType</span></td>
                        <td>@b.MilkUsedQuantity.ToString("N2")</td>
                        <td>@b.ProductionDate.ToString("dd-MMM-yyyy")</td>
                        <td><span class="badge @b.StatusBadgeClass">@b.BatchStatus</span></td>
                        <td>
                            <a asp-action="BatchDetail" asp-route-id="@b.ProductionBatchId"
                               class="btn btn-sm btn-outline-secondary">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
