@model List<DairyIndustry.Models.Production.TransferLossLogModel>
@using DairyIndustry.Models.Production
@{
    ViewData["Title"] = "Transfer Loss Log";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";

    var summary = ViewBag.Summary as List<LossSummaryModel> ?? new List<LossSummaryModel>();

    decimal totalLoss = Model.Sum(x => x.LossQty);
    decimal totalDispatch = Model.Sum(x => x.DispatchQty);
    decimal totalReceived = Model.Sum(x => x.ReceivedQty);
    decimal overallPct = totalDispatch > 0 ? Math.Round((totalLoss / totalDispatch) * 100, 2) : 0;
    int severeCount = Model.Count(x => x.LossCategory == "Severe");
    int moderateCount = Model.Count(x => x.LossCategory == "Moderate");
    int minorCount = Model.Count(x => x.LossCategory == "Minor");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .tl {
        --c-surface: #fff;
        --c-bg: #f5f6f8;
        --c-border: #e2e5ea;
        --c-text: #111827;
        --c-text-2: #374151;
        --c-text-3: #6b7280;
        --c-text-4: #9ca3af;
        --c-accent: #2563eb;
        --c-accent-bg: #eff6ff;
        --c-green: #16a34a;
        --c-green-bg: #f0fdf4;
        --c-green-border: #86efac;
        --c-red: #dc2626;
        --c-red-bg: #fef2f2;
        --c-red-border: #fca5a5;
        --c-amber: #d97706;
        --c-amber-bg: #fffbeb;
        --c-amber-border: #fcd34d;
        --r: 8px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        color: var(--c-text);
    }

    /* ── Page Header ── */
    .tl-page-header {
        margin-bottom: 20px;
    }

    .tl-breadcrumb {
        font-size: 12px;
        color: var(--c-text-3);
        margin-bottom: 4px;
    }

    .tl-page-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--c-text);
        margin: 0 0 12px;
        letter-spacing: -0.5px;
    }

    /* ── Filter Tabs ── */
    .tl-tabs {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .tl-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 400;
        cursor: pointer;
        border: 1px solid var(--c-border);
        background: transparent;
        color: var(--c-text-3);
        transition: all .15s;
        text-decoration: none;
    }

        .tl-tab:hover {
            background: #f3f4f6;
            color: var(--c-text-2);
        }

        .tl-tab.active {
            background: #f3f4f6;
            color: var(--c-text);
            font-weight: 500;
            border-color: #d1d5db;
        }

    .tl-tab-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 10px;
    }

    .badge-all {
        background: #e5e7eb;
        color: var(--c-text-3);
    }

    .badge-severe {
        background: var(--c-red-bg);
        color: var(--c-red);
    }

    .badge-moderate {
        background: var(--c-amber-bg);
        color: var(--c-amber);
    }

    .badge-minor {
        background: var(--c-green-bg);
        color: var(--c-green);
    }

    /* ── Stats Row ── */
    .tl-stats {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .tl-stat {
        padding: 16px 20px;
        border-right: 1px solid var(--c-border);
    }

        .tl-stat:last-child {
            border-right: none;
        }

    .tl-stat-label {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--c-text-3);
        margin-bottom: 6px;
    }

    .tl-stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--c-text);
        letter-spacing: -0.5px;
        font-variant-numeric: tabular-nums;
    }

        .tl-stat-value .unit {
            font-size: 13px;
            font-weight: 400;
            color: var(--c-text-3);
            margin-left: 2px;
        }

    /* ── Table Card ── */
    .tl-card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r);
        overflow: hidden;
    }

    .tl-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        background: #fafbfc;
        border-bottom: 1px solid var(--c-border);
        flex-wrap: wrap;
        gap: 10px;
    }

    .tl-toolbar-left {
        font-size: 13px;
        color: var(--c-text-3);
    }

    .tl-search-wrap {
        position: relative;
    }

    .tl-search-icon {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 13px;
        color: var(--c-text-4);
        pointer-events: none;
    }

    .tl-search {
        height: 30px;
        padding: 0 10px 0 30px;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-surface);
        font-size: 13px;
        color: var(--c-text);
        outline: none;
        width: 220px;
        transition: border-color .15s, box-shadow .15s;
    }

        .tl-search:focus {
            border-color: var(--c-accent);
            box-shadow: 0 0 0 3px rgba(37,99,235,.08);
        }

    /* ── Table ── */
    .tl-scroll {
        overflow-x: auto;
        overflow-y: auto;
    }

        .tl-scroll::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        .tl-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .tl-scroll::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

    .tl-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 860px;
    }

        .tl-table thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--c-text-3);
            padding: 9px 16px;
            text-align: left;
            background: #fafbfc;
            border-bottom: 1px solid var(--c-border);
            white-space: nowrap;
        }

            .tl-table thead th.r {
                text-align: right;
            }

            .tl-table thead th.c {
                text-align: center;
            }

        .tl-table tbody td {
            padding: 12px 16px;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: middle;
            color: var(--c-text-2);
        }

        .tl-table tbody tr:last-child td {
            border-bottom: none;
        }

        .tl-table tbody tr:hover td {
            background: #f8faff;
        }

        .tl-table td.r {
            text-align: right;
        }

        .tl-table td.c {
            text-align: center;
        }

    /* ── Cell Styles ── */
    .tl-refid {
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 13px;
        font-weight: 600;
        color: var(--c-accent);
        text-decoration: none;
    }

        .tl-refid:hover {
            text-decoration: underline;
        }

    .tl-sub {
        font-size: 11px;
        color: var(--c-text-3);
        margin-top: 2px;
    }

    .tl-route-name {
        font-size: 13px;
        font-weight: 500;
        color: var(--c-text);
    }

    .tl-driver-name {
        font-size: 13px;
        color: var(--c-text-2);
    }

    .tl-date-val {
        font-size: 13px;
        font-weight: 500;
        color: var(--c-text-2);
        font-variant-numeric: tabular-nums;
    }

    .tl-shift-badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        color: var(--c-text-3);
        margin-top: 2px;
    }

    .tl-dispatch-val {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text);
        font-variant-numeric: tabular-nums;
    }

    .tl-received-val {
        font-size: 11px;
        color: var(--c-text-3);
        font-variant-numeric: tabular-nums;
        margin-top: 2px;
    }

    .tl-loss-val {
        font-size: 13px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

        .tl-loss-val.severe {
            color: var(--c-red);
        }

        .tl-loss-val.moderate {
            color: var(--c-amber);
        }

        .tl-loss-val.minor {
            color: var(--c-text-3);
        }

    .tl-loss-pct {
        font-size: 11px;
        color: inherit;
        margin-top: 2px;
        font-variant-numeric: tabular-nums;
    }

    /* ── Category Pill ── */
    .tl-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

    .tl-pill-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    .tl-pill.severe {
        background: var(--c-red-bg);
        color: var(--c-red);
        border: 1px solid var(--c-red-border);
    }

    .tl-pill.moderate {
        background: var(--c-amber-bg);
        color: var(--c-amber);
        border: 1px solid var(--c-amber-border);
    }

    .tl-pill.minor {
        background: var(--c-green-bg);
        color: var(--c-green);
        border: 1px solid var(--c-green-border);
    }

    /* ── Footer ── */
    .tl-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-top: 1px solid var(--c-border);
        background: #fafbfc;
        flex-wrap: wrap;
        gap: 8px;
        min-height: 48px;
    }

    .tl-record-count {
        font-size: 12px;
        color: var(--c-text-3);
    }

        .tl-record-count strong {
            color: var(--c-text-2);
        }

    .tl-foot-stats {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .tl-foot-stat {
        text-align: right;
    }

    .tl-foot-label {
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        color: var(--c-text-4);
        margin-bottom: 1px;
    }

    .tl-foot-value {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text-2);
        font-variant-numeric: tabular-nums;
    }

        .tl-foot-value.red {
            color: var(--c-red);
        }

    .tl-empty {
        padding: 60px 24px;
        text-align: center;
        color: var(--c-text-3);
        font-size: 13px;
    }

    /* ── Pagination ── */
    .tl-foot-center {
        flex: 1;
        display: flex;
        justify-content: center;
    }

    .tl-pagination {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .tl-pg-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 30px;
        height: 30px;
        padding: 0 6px;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-surface);
        font-size: 13px;
        font-weight: 400;
        color: var(--c-text-2);
        cursor: pointer;
        transition: all .15s;
        font-family: inherit;
    }

        .tl-pg-btn:hover:not(:disabled) {
            background: #f3f4f6;
            border-color: #d1d5db;
            color: var(--c-text);
        }

        .tl-pg-btn.active {
            background: var(--c-accent);
            border-color: var(--c-accent);
            color: #fff;
            font-weight: 600;
        }

        .tl-pg-btn:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

    .tl-pg-ellipsis {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 30px;
        height: 30px;
        font-size: 13px;
        color: var(--c-text-3);
        user-select: none;
    }

    @@media (max-width: 900px) {
        .tl-stats {
            grid-template-columns: repeat(3, 1fr);
        }

        .tl-stat:nth-child(3) {
            border-right: none;
        }

        .tl-stat:nth-child(4) {
            border-top: 1px solid var(--c-border);
        }

        .tl-stat:nth-child(5) {
            border-top: 1px solid var(--c-border);
            border-right: none;
        }
    }

    @@media (max-width: 600px) {
        .tl-stats {
            grid-template-columns: 1fr 1fr;
        }

        .tl-search {
            width: 160px;
        }
    }
</style>

<div class="tl">

    <!-- Page Header -->
    <div class="tl-page-header">
        <div class="tl-breadcrumb">Production › Transfer Loss Log</div>
        <h1 class="tl-page-title">Transfer Loss Log</h1>
        <div class="tl-tabs">
            <button class="tl-tab active" data-filter="all">
                <i class="bi bi-list-ul"></i>
                All
                <span class="tl-tab-badge badge-all">@Model.Count</span>
            </button>
            <button class="tl-tab" data-filter="Severe">
                <i class="bi bi-exclamation-circle"></i>
                Severe
                <span class="tl-tab-badge badge-severe">@severeCount</span>
            </button>
            <button class="tl-tab" data-filter="Moderate">
                <i class="bi bi-exclamation-triangle"></i>
                Moderate
                <span class="tl-tab-badge badge-moderate">@moderateCount</span>
            </button>
            <button class="tl-tab" data-filter="Minor">
                <i class="bi bi-check-circle"></i>
                Minor
                <span class="tl-tab-badge badge-minor">@minorCount</span>
            </button>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="tl-stats">
        <div class="tl-stat">
            <div class="tl-stat-label">Total Dispatched (L)</div>
            <div class="tl-stat-value">@totalDispatch.ToString("N0")</div>
        </div>
        <div class="tl-stat">
            <div class="tl-stat-label">Total Received (L)</div>
            <div class="tl-stat-value">@totalReceived.ToString("N0")</div>
        </div>
        <div class="tl-stat">
            <div class="tl-stat-label">Total Loss (L)</div>
            <div class="tl-stat-value" style="color:var(--c-red);">@totalLoss.ToString("N2")</div>
        </div>
        <div class="tl-stat">
            <div class="tl-stat-label">Variance Rate</div>
            <div class="tl-stat-value" style="color:@(overallPct >= 5 ? "var(--c-red)" : overallPct >= 2 ? "var(--c-amber)" : "var(--c-green)");">
                @overallPct.ToString("F2")<span class="unit">%</span>
            </div>
        </div>
        <div class="tl-stat">
            <div class="tl-stat-label">Critical Events</div>
            <div class="tl-stat-value" style="color:@(severeCount > 0 ? "var(--c-red)" : "var(--c-green)");">@severeCount</div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="tl-card">
        <div class="tl-toolbar">
            <span class="tl-toolbar-left">Plant transfer loss records</span>
            <div class="tl-search-wrap">
                <i class="bi bi-search tl-search-icon"></i>
                <input type="text" id="logSearch" class="tl-search" placeholder="Search ID, driver, center…">
            </div>
        </div>

        <div class="tl-scroll">
            <table class="tl-table" id="lossTable">
                <thead>
                    <tr>
                        <th style="width:120px;">Batch / Ref</th>
                        <th>Route</th>
                        <th style="width:150px;">Driver</th>
                        <th style="width:130px;">Date / Shift</th>
                        <th style="width:140px;" class="r">Dispatch (L)</th>
                        <th style="width:130px;" class="r">Loss (L)</th>
                        <th style="width:110px;" class="c">Category</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7">
                                <div class="tl-empty">
                                    <i class="bi bi-inbox" style="font-size:28px;display:block;margin-bottom:8px;"></i>
                                    No loss records found.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in Model)
                        {
                            string catClass = log.LossCategory == "Severe" ? "severe" :
                            log.LossCategory == "Moderate" ? "moderate" : "minor";

                            <tr class="searchable-row" data-category="@log.LossCategory">
                                <td>
                                    <a href="@Url.Action("Detail", new { id = log.TransferId })" class="tl-refid">T#@log.TransferId</a>
                                    <div class="tl-sub">@log.PlantName</div>
                                </td>
                                <td>
                                    <div class="tl-route-name">@log.CenterName</div>
                                    <div class="tl-sub">@log.VehicleNumber</div>
                                </td>
                                <td>
                                    <div class="tl-driver-name">@log.DriverName</div>
                                </td>
                                <td>
                                    <div class="tl-date-val">@log.DispatchDate.ToString("dd MMM yyyy")</div>
                                    <div class="tl-shift-badge">@log.Shift shift</div>
                                </td>
                                <td class="r">
                                    <div class="tl-dispatch-val">@log.DispatchQty.ToString("N0")</div>
                                    <div class="tl-received-val">Received: @log.ReceivedQty.ToString("N0")</div>
                                </td>
                                <td class="r">
                                    <div class="tl-loss-val @catClass">−@log.LossQty.ToString("N1")</div>
                                    <div class="tl-loss-pct @catClass">@log.LossPct.ToString("F2")%</div>
                                </td>
                                <td class="c">
                                    <span class="tl-pill @catClass">
                                        <span class="tl-pill-dot"></span>
                                        @log.LossCategory
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="tl-footer">
            <span class="tl-record-count" id="recordCount"></span>
            <div class="tl-foot-center">
                <div class="tl-pagination" id="pagination"></div>
            </div>
            <div class="tl-foot-stats">
                <div class="tl-foot-stat">
                    <div class="tl-foot-label">Gross Loss</div>
                    <div class="tl-foot-value red">@totalLoss.ToString("N1") L</div>
                </div>
                <div class="tl-foot-stat">
                    <div class="tl-foot-label">Variance</div>
                    <div class="tl-foot-value">@overallPct.ToString("F2")%</div>
                </div>
                <div class="tl-foot-stat">
                    <div class="tl-foot-label">Severe</div>
                    <div class="tl-foot-value @(severeCount > 0 ? "red" : "")">@severeCount</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const searchInput = document.getElementById('logSearch');
    const allRows = Array.from(document.querySelectorAll('.searchable-row'));
    const countEl  = document.getElementById('recordCount');
    const paginEl  = document.getElementById('pagination');
    const tabs     = document.querySelectorAll('.tl-tab');

    const PAGE_SIZE = 10;
    let activeFilter = 'all';
    let currentPage  = 1;
    let filteredRows = [];

    /* ── Filter + Search ── */
    function getFiltered() {
        const q = searchInput.value.trim().toUpperCase();
        return allRows.filter(row => {
            const catMatch    = activeFilter === 'all' || row.dataset.category === activeFilter;
            const searchMatch = !q || row.textContent.toUpperCase().includes(q);
            return catMatch && searchMatch;
        });
    }

    /* ── Render page ── */
    function render() {
        filteredRows = getFiltered();
        const total     = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * PAGE_SIZE;
        const end   = start + PAGE_SIZE;

        allRows.forEach(r => r.style.display = 'none');
        filteredRows.forEach((r, i) => {
            r.style.display = (i >= start && i < end) ? '' : 'none';
        });

        /* record count label */
        const from = total === 0 ? 0 : start + 1;
        const to   = Math.min(end, total);
        countEl.innerHTML = total === 0
            ? '<strong>0</strong> records'
            : `Showing <strong>${from}–${to}</strong> of <strong>${total}</strong> records`;

        /* pagination buttons */
        renderPagination(totalPages);
    }

    /* ── Build pagination controls ── */
    function renderPagination(totalPages) {
        paginEl.innerHTML = '';
        if (totalPages <= 1) return;

        const pages = getPageNumbers(currentPage, totalPages);

        /* Prev */
        paginEl.appendChild(makeBtn(
            '<i class="bi bi-chevron-left"></i>', currentPage === 1,
            () => { currentPage--; render(); }
        ));

        pages.forEach(p => {
            if (p === '…') {
                const el = document.createElement('span');
                el.className = 'tl-pg-ellipsis';
                el.textContent = '…';
                paginEl.appendChild(el);
            } else {
                paginEl.appendChild(makeBtn(p, false, () => { currentPage = p; render(); }, p === currentPage));
            }
        });

        /* Next */
        paginEl.appendChild(makeBtn(
            '<i class="bi bi-chevron-right"></i>', currentPage === totalPages,
            () => { currentPage++; render(); }
        ));
    }

    /* ── Smart page number list (always show first, last, current ±1) ── */
    function getPageNumbers(cur, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages = new Set([1, total, cur, cur - 1, cur + 1].filter(p => p >= 1 && p <= total));
        const sorted = Array.from(pages).sort((a, b) => a - b);
        const result = [];
        sorted.forEach((p, i) => {
            if (i > 0 && p - sorted[i - 1] > 1) result.push('…');
            result.push(p);
        });
        return result;
    }

    /* ── Button factory ── */
    function makeBtn(label, disabled, onClick, active = false) {
        const btn = document.createElement('button');
        btn.className = 'tl-pg-btn' + (active ? ' active' : '');
        btn.innerHTML = label;
        btn.disabled  = disabled;
        if (!disabled) btn.addEventListener('click', onClick);
        return btn;
    }

    /* ── Tab clicks ── */
    tabs.forEach(tab => {
        tab.addEventListener('click', function () {
            tabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            activeFilter = this.dataset.filter;
            currentPage  = 1;
            render();
        });
    });

    /* ── Search input ── */
    searchInput.addEventListener('input', () => { currentPage = 1; render(); });

    /* ── Init ── */
    render();
</script>
