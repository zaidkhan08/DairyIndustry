    </div>

    <!-- ═══ ROW 5 — Center Payments (Full Width) ════════ -->
    <div class="panel">
        <div class="panel-header">
            <div class="panel-title">
                <div class="panel-icon blue">
                    <svg><use href="#icon-card" /></svg>
                </div>
