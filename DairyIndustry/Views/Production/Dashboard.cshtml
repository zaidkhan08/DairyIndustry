@model DairyIndustry.Models.Production.ProductionDashboardViewModel
@{
    ViewData["Title"] = "Production Dashboard";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg: #f5f6fb;
        --surface: rgba(255,255,255,0.85);
        --surface-solid: #ffffff;
        --border: rgba(220,224,240,0.7);
        --border-light: rgba(220,224,240,0.4);
        --text: #0f172a;
        --text-mid: #334155;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --mint: #10b981;
        --mint-bg: #ecfdf5;
        --mint-text: #065f46;
        --aqua: #06b6d4;
        --aqua-bg: #ecfeff;
        --aqua-text: #155e75;
        --lavender: #8b5cf6;
        --lavender-bg: #f5f3ff;
        --lavender-text: #4c1d95;
        --amber: #f59e0b;
        --amber-bg: #fffbeb;
        --amber-text: #78350f;
        --blue: #3b82f6;
        --blue-bg: #eff6ff;
        --blue-text: #1e3a8a;
        --coral: #f43f5e;
        --coral-bg: #fff1f2;
        --coral-text: #881337;
        --shadow-card: 0 8px 32px rgba(15,23,42,0.05), 0 2px 8px rgba(15,23,42,0.03);
        --shadow-hover: 0 20px 48px rgba(15,23,42,0.10), 0 4px 16px rgba(15,23,42,0.06);
        --shadow-sm: 0 2px 8px rgba(15,23,42,0.04);
        --radius-xl: 24px;
        --radius-lg: 18px;
        --radius-md: 12px;
        --radius-sm: 8px;
        --radius-pill: 100px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text);
        font-size: 14px;
        min-height: 100vh;
    }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 800px 600px at 10% 20%, rgba(139,92,246,0.04) 0%, transparent 60%), radial-gradient(ellipse 600px 500px at 85% 80%, rgba(59,130,246,0.04) 0%, transparent 60%), radial-gradient(ellipse 500px 400px at 50% 50%, rgba(16,185,129,0.03) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

    /* ── Buttons ── */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(99,102,241,0.30);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.40);
            color: #fff;
        }

    .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--surface-solid);
        color: var(--text-mid);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-outline:hover {
            background: var(--bg);
            border-color: rgba(99,102,241,0.3);
            color: var(--lavender);
            transform: translateY(-1px);
        }

    /* ── Dash Body ── */
    .dash-body {
        position: relative;
        z-index: 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    /* ══════════════════════════════════════
           WELCOME TYPOGRAPHY
        ══════════════════════════════════════ */
    .welcome-block {
        padding: 0.25rem 0 0;
    }

    .welcome-date {
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 10px;
    }

    .welcome-title {
        font-size: 46px;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -1.5px;
        color: var(--text);
        margin: 0;
    }

    .welcome-name {
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .welcome-sub {
        font-size: 14px;
        color: var(--text-muted);
        margin-top: 10px;
        font-weight: 500;
    }

        .welcome-sub strong {
            color: var(--text-mid);
        }

    .welcome-actions {
        display: flex;
        gap: 10px;
        margin-top: 1.25rem;
    }

    /* ══════════════════════════════════════
           NEW FINANCIAL KPI CARDS
        ══════════════════════════════════════ */
    .fin-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 16px;
        align-items: stretch;
    }

    /* Base card */
    .fin-card {
        border-radius: var(--radius-xl);
        padding: 1.6rem 1.75rem;
        box-shadow: var(--shadow-card);
        display: flex;
        flex-direction: column;
        gap: 0;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        position: relative;
        overflow: hidden;
    }

        .fin-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        /* Card variants */
        .fin-card.card-dark {
            background: #0f172a;
            color: #fff;
        }

        .fin-card.card-white {
            background: var(--surface-solid);
            border: 1px solid var(--border);
            color: var(--text);
        }

        .fin-card.card-green {
            background: var(--surface-solid);
            border: 1px solid var(--border);
            color: var(--text);
        }

        .fin-card.card-red {
            background: var(--surface-solid);
            border: 1px solid var(--border);
            color: var(--text);
        }

    .icon-blue {
        background: #eff6ff;
        color: #2563eb;
    }

    .todo-card {
        min-height: 295px;
        width: 100%;
    }

    .todo-list {
        flex: 1;
    }

    .fin-card {
        height: 100%;
    }

    .todo-input-wrap {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        margin-bottom: 18px;
    }

    .todo-input {
        flex: 1;
        height: 44px;
        border-radius: 12px;
        border: 1px solid var(--border);
        padding: 0 14px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        background: #fff;
        transition: 0.2s ease;
    }

        .todo-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.08);
        }

    .todo-add-btn {
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg,#3b82f6,#6366f1);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s ease;
        flex-shrink: 0;
    }

        .todo-add-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(99,102,241,0.35);
        }

    .todo-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow-y: auto;
        max-height: 180px;
        padding-right: 4px;
    }

    .todo-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 12px 14px;
        transition: 0.2s ease;
    }

        .todo-item:hover {
            background: #f1f5f9;
        }

    .todo-text {
        flex: 1;
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.5;
    }

    .todo-actions {
        display: flex;
        gap: 8px;
    }

    .todo-btn {
        border: none;
        cursor: pointer;
        font-size: 11px;
        font-weight: 700;
        padding: 7px 10px;
        border-radius: 8px;
        transition: 0.2s ease;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .todo-edit {
        background: #eff6ff;
        color: #2563eb;
    }

    .todo-delete {
        background: #fef2f2;
        color: #dc2626;
    }

    .todo-btn:hover {
        transform: translateY(-1px);
    }

    .todo-empty {
        text-align: center;
        color: var(--text-muted);
        font-size: 13px;
        padding: 30px 10px;
    }


    /* Card header row */
    .fin-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.1rem;
    }

    .fin-card-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 700;
        color: inherit;
        opacity: 0.85;
    }

    .fin-card-label-icon {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .fin-card-label-icon svg {
            width: 14px;
            height: 14px;
        }

    /* Dark card icon */
    .icon-dark-blue {
        background: rgba(59,130,246,0.2);
        color: #60a5fa;
    }
    /* Green card icon */
    .icon-green {
        background: #dcfce7;
        color: #16a34a;
    }
    /* Red card icon */
    .icon-red {
        background: #ffe4e6;
        color: #e11d48;
    }

    .fin-pill {
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        white-space: nowrap;
    }

        .fin-pill.dark {
            background: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.7);
        }

        .fin-pill.green-pill {
            background: #dcfce7;
            color: #15803d;
        }

        .fin-pill.red-pill {
            background: #ffe4e6;
            color: #be123c;
        }

        .fin-pill.amber-pill {
            background: var(--amber-bg);
            color: #b45309;
        }

    /* Big value */
    .fin-value {
        font-size: 42px;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -1.5px;
        margin-bottom: 4px;
    }

    .fin-card.card-dark .fin-value {
        color: #fff;
    }

    .fin-card.card-white .fin-value,
    .fin-card.card-green .fin-value,
    .fin-card.card-red .fin-value {
        color: var(--text);
    }

    .fin-delta {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        margin-top: 6px;
    }

        .fin-delta.up {
            color: #16a34a;
        }

        .fin-delta.down {
            color: #e11d48;
        }

        .fin-delta.neutral {
            color: var(--text-muted);
        }

        .fin-delta svg {
            width: 13px;
            height: 13px;
            flex-shrink: 0;
        }

    /* Dark card action buttons */
    .fin-actions {
        display: flex;
        gap: 8px;
        margin-top: 1.5rem;
    }

    .fin-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 9px 10px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all 0.2s ease;
    }

        .fin-btn svg {
            width: 13px;
            height: 13px;
        }

        .fin-btn.solid {
            background: #3b82f6;
            color: #fff;
        }

            .fin-btn.solid:hover {
                background: #2563eb;
            }

        .fin-btn.ghost {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.8);
            border: 1px solid rgba(255,255,255,0.12);
        }

            .fin-btn.ghost:hover {
                background: rgba(255,255,255,0.14);
            }

    /* Divider rows inside card */
    .fin-divider {
        height: 1px;
        background: rgba(220,224,240,0.5);
        margin: 1rem 0;
    }

        .fin-divider.dark {
            background: rgba(255,255,255,0.08);
        }

    /* Sub rows (e.g. Salary / Freelance) */
    .fin-sub-row {
        display: flex;
        gap: 1.5rem;
        margin-top: 0.6rem;
    }

    .fin-sub-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .fin-sub-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .fin-sub-value {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        font-family: 'DM Mono', monospace;
    }

    /* Progress / mini bar */
    .fin-bar-wrap {
        margin-top: 1rem;
    }

    .fin-bar-labels {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

    .fin-bar-track {
        height: 7px;
        background: #f1f5f9;
        border-radius: 100px;
        overflow: hidden;
    }

    .fin-bar-fill {
        height: 100%;
        border-radius: 100px;
        transition: width 1s cubic-bezier(0.4,0,0.2,1);
    }

    .fill-blue {
        background: linear-gradient(90deg, #3b82f6, #6366f1);
    }

    .fill-green {
        background: linear-gradient(90deg, #10b981, #06b6d4);
    }

    .fill-red {
        background: linear-gradient(90deg, #f43f5e, #f97316);
    }

    /* Segment bar (expense breakdown) */
    .seg-bar {
        display: flex;
        height: 7px;
        border-radius: 100px;
        overflow: hidden;
        margin-top: 1rem;
        gap: 2px;
    }

    .seg-bar-chunk {
        border-radius: 100px;
    }

    .seg-legend {
        display: flex;
        gap: 12px;
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .seg-dot {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
    }

        .seg-dot::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .seg-dot.blue::before {
            background: #3b82f6;
        }

        .seg-dot.green::before {
            background: #10b981;
        }

        .seg-dot.amber::before {
            background: #f59e0b;
        }

    /* ── Panel (existing) ── */
    .panel {
        background: var(--surface);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.25s ease;
    }

        .panel:hover {
            box-shadow: 0 12px 40px rgba(15,23,42,0.07), 0 2px 12px rgba(15,23,42,0.04);
        }

    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem 1rem;
        border-bottom: 1px solid var(--border-light);
    }

    .panel-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: -0.2px;
    }

    .panel-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .panel-icon svg {
            width: 16px;
            height: 16px;
        }

        .panel-icon.amber {
            background: var(--amber-bg);
            color: var(--amber);
        }

        .panel-icon.mint {
            background: var(--mint-bg);
            color: var(--mint);
        }

        .panel-icon.blue {
            background: var(--blue-bg);
            color: var(--blue);
        }

        .panel-icon.coral {
            background: var(--coral-bg);
            color: var(--coral);
        }

        .panel-icon.lavender {
            background: var(--lavender-bg);
            color: var(--lavender);
        }

        .panel-icon.aqua {
            background: var(--aqua-bg);
            color: var(--aqua);
        }

    .panel-view-all {
        font-size: 12px;
        font-weight: 600;
        color: var(--blue);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        opacity: 0.8;
        transition: opacity 0.15s;
    }

        .panel-view-all:hover {
            opacity: 1;
        }

    .panel-body {
        padding: 1.25rem 1.5rem;
        flex: 1;
    }

    .panel-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-light);
    }

    /* ── Batch Grid ── */
    .batch-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .batch-cell {
        border-radius: var(--radius-lg);
        padding: 1.25rem 1rem 1rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease;
    }

        .batch-cell:hover {
            transform: scale(1.02);
        }

        .batch-cell::after {
            content: '';
            position: absolute;
            bottom: -10px;
            right: -10px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            opacity: 0.15;
        }

        .batch-cell.amber-bg {
            background: linear-gradient(145deg,#fffbeb,#fef3c7);
        }

            .batch-cell.amber-bg::after {
                background: var(--amber);
            }

        .batch-cell.teal-bg {
            background: linear-gradient(145deg,#ecfdf5,#d1fae5);
        }

            .batch-cell.teal-bg::after {
                background: var(--mint);
            }

        .batch-cell.red-bg {
            background: linear-gradient(145deg,#fff1f2,#ffe4e6);
        }

            .batch-cell.red-bg::after {
                background: var(--coral);
            }

        .batch-cell.gray-bg {
            background: linear-gradient(145deg,#f8fafc,#f1f5f9);
        }

            .batch-cell.gray-bg::after {
                background: #94a3b8;
            }

    .batch-num {
        font-size: 38px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 6px;
        letter-spacing: -1.5px;
    }

        .batch-num.amber {
            color: #d97706;
        }

        .batch-num.teal {
            color: var(--mint);
        }

        .batch-num.red {
            color: var(--coral);
        }

        .batch-num.gray {
            color: #94a3b8;
        }

    .batch-lbl {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text-muted);
    }

    .view-all-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 10px;
        background: transparent;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 600;
        color: var(--text-mid);
        text-decoration: none;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: all 0.2s ease;
    }

        .view-all-btn:hover {
            background: var(--bg);
            transform: translateY(-1px);
        }

        .view-all-btn.amber-btn {
            border-color: rgba(245,158,11,0.4);
            color: #d97706;
        }

            .view-all-btn.amber-btn:hover {
                background: var(--amber-bg);
                border-color: var(--amber);
            }

    /* ── Transfer rows ── */
    .transfer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 11px 0;
        border-bottom: 1px solid var(--border-light);
        font-size: 13px;
    }

        .transfer-row:last-of-type {
            border-bottom: none;
        }

        .transfer-row .t-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .transfer-row .t-value {
            font-weight: 700;
            color: var(--text);
            font-family: 'DM Mono', monospace;
            font-size: 13px;
        }

            .transfer-row .t-value.red {
                color: var(--coral);
            }

    .progress-wrap {
        margin-top: 16px;
    }

    .progress-track {
        height: 8px;
        background: #f1f5f9;
        border-radius: var(--radius-pill);
        overflow: hidden;
        margin-bottom: 8px;
    }

    .progress-fill {
        height: 100%;
        border-radius: var(--radius-pill);
        background: linear-gradient(90deg, var(--mint), var(--aqua));
        transition: width 1s cubic-bezier(0.4,0,0.2,1);
        position: relative;
    }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 20px;
            height: 100%;
            background: rgba(255,255,255,0.4);
            border-radius: var(--radius-pill);
            animation: shimmer 2s infinite;
        }

    @@keyframes shimmer {
        0% {
            opacity: 0
        }

        50% {
            opacity: 1
        }

        100% {
            opacity: 0
        }
    }

    .progress-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* ── Tables ── */
    .dash-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .dash-table thead {
            background: #f8fafc;
        }

        .dash-table th {
            font-size: 10.5px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 10px 1.5rem;
            text-align: left;
            border-bottom: 1px solid var(--border-light);
        }

        .dash-table td {
            padding: 13px 1.5rem;
            color: var(--text-mid);
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
            font-weight: 500;
        }

        .dash-table tr:last-child td {
            border-bottom: none;
        }

        .dash-table tbody tr {
            transition: background 0.15s ease;
        }

            .dash-table tbody tr:hover td {
                background: rgba(59,130,246,0.03);
            }

    /* ── Pills ── */
    .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 11px;
        border-radius: var(--radius-pill);
        white-space: nowrap;
        letter-spacing: 0.2px;
    }

    .pill-active {
        background: #dcfce7;
        color: #166534;
    }

    .pill-inactive {
        background: var(--coral-bg);
        color: var(--coral-text);
    }

    .pill-inprogress {
        background: #fef9c3;
        color: #713f12;
    }

    .pill-completed {
        background: #dcfce7;
        color: #166534;
    }

    .pill-failed {
        background: var(--coral-bg);
        color: var(--coral-text);
    }

    .pill-cancelled {
        background: #f1f5f9;
        color: #64748b;
    }

    .pill-pending {
        background: var(--amber-bg);
        color: var(--amber-text);
    }

    .panel-action-bar {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-light);
        display: flex;
        gap: 10px;
        background: #fafbfc;
    }

    /* ── Grid layouts ── */
    .mid-grid, .bottom-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    /* Todo list */

    .ops-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 8px;
    }

    .ops-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        transition: 0.2s ease;
    }

        .ops-item:hover {
            background: #f1f5f9;
            transform: translateY(-1px);
        }

    .ops-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .ops-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

        .ops-icon.blue {
            background: #dbeafe;
        }

        .ops-icon.green {
            background: #dcfce7;
        }

        .ops-icon.red {
            background: #fee2e2;
        }

        .ops-icon.amber {
            background: #fef3c7;
        }

    .ops-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    .ops-sub {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .ops-badge {
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

        .ops-badge.warning {
            background: #fef3c7;
            color: #92400e;
        }

        .ops-badge.success {
            background: #dcfce7;
            color: #166534;
        }

        .ops-badge.danger {
            background: #fee2e2;
            color: #b91c1c;
        }

        .ops-badge.info {
            background: #dbeafe;
            color: #1d4ed8;
        }

    @@media (max-width: 1200px) {
        .fin-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 1024px) {
        .fin-grid {
            grid-template-columns: 1fr;
        }

        .mid-grid, .bottom-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .dash-body {
            padding: 1.25rem;
        }

        .welcome-title {
            font-size: 32px;
        }

        .fin-value {
            font-size: 30px;
        }

        .batch-grid {
            grid-template-columns: 1fr 1fr;
        }


    }
</style>

<!-- ═══ SVG DEFS ═══ -->
