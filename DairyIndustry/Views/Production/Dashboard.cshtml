    <symbol id="icon-trend-down" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="23 18 13.5 8.5 8.5 13.5 1 6" /><polyline points="17 18 23 18 23 12" />
    </symbol>
    <symbol id="icon-arrow-right" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
    </symbol>
    <symbol id="icon-list" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" />
        <line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" />
    </symbol>
    <symbol id="icon-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
    </symbol>
</svg>

<!-- ═══════════════════════════════════════
     PAGE HEADER
═══════════════════════════════════════ -->
<div class="page-header">
    <div>
        <h1 class="page-title">Production Dashboard</h1>
        <p class="page-subtitle">
            Welcome back, <strong>@User.Identity?.Name?.Split('\\').Last()</strong>
            &nbsp;&mdash;&nbsp; @DateTime.Now.ToString("dddd, dd MMMM yyyy")
        </p>
    </div>
    <div class="header-actions">
        <a href="@Url.Action("StartBatch", "Production")" class="btn-primary">
            <svg width="14" height="14"><use href="#icon-plus" /></svg>
            Start Batch
        </a>
        <a href="@Url.Action("Index", "Production")" class="btn-outline">
            <svg width="14" height="14"><use href="#icon-list" /></svg>
            All Records
        </a>
    </div>
</div>

<div class="dash-body">

    <!-- ═══ ROW 1 — 6 KPI Cards ══════════════════════ -->
    <div class="summary-grid">

        <!-- Milk Transfers -->
        <div class="sum-card c-aqua">
            <div class="sum-card-top">
                <div class="sum-icon aqua">
                    <svg><use href="#icon-truck" /></svg>
                </div>
                @if (Model.PendingTransfers > 0)
                {
                    <span class="sum-badge badge-amber">@Model.PendingTransfers Pending</span>
                }
                else
                {
                    <span class="sum-badge badge-mint">All Clear</span>
                }
            </div>
            <div>
                <div class="sum-value" data-target="@Model.TotalTransfers">@Model.TotalTransfers</div>
                <div class="sum-label">Milk Transfers</div>
            </div>
            <a href="@Url.Action("Index", "Production")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

        <!-- Production Batches -->
        <div class="sum-card c-amber">
            <div class="sum-card-top">
                <div class="sum-icon amber">
                    <svg><use href="#icon-factory" /></svg>
                </div>
                @if (Model.InProgressBatches > 0)
                {
                    <span class="sum-badge badge-amber">@Model.InProgressBatches Active</span>
                }
                else
                {
                    <span class="sum-badge badge-gray">0 Active</span>
                }
            </div>
            <div>
                <div class="sum-value" data-target="@Model.TotalBatches">@Model.TotalBatches</div>
                <div class="sum-label">Production Batches</div>
            </div>
            <a href="@Url.Action("Batches", "Production")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

        <!-- Raw Milk Stock -->
        <div class="sum-card c-mint">
            <div class="sum-card-top">
                <div class="sum-icon mint">
                    <svg><use href="#icon-droplet" /></svg>
                </div>
                @if (Model.LowStockCount > 0)
                {
                    <span class="sum-badge badge-amber">@Model.LowStockCount Low</span>
                }
                else
                {
                    <span class="sum-badge badge-mint">Stocked</span>
                }
            </div>
            <div>
                <div class="sum-value">@((Model.TotalRawMilkStock / 1000).ToString("F1"))k</div>
                <div class="sum-label">Raw Milk Stock (L)</div>
            </div>
            <a href="@Url.Action("RawMilkInventory", "Production")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

        <!-- Quality Tests -->
        <div class="sum-card c-coral">
            <div class="sum-card-top">
                <div class="sum-icon coral">
                    <svg><use href="#icon-flask" /></svg>
                </div>
                @if (Model.DeviatedTests > 0)
                {
                    <span class="sum-badge badge-coral">@Model.DeviatedTests Deviated</span>
                }
                else
                {
                    <span class="sum-badge badge-mint">All Normal</span>
                }
            </div>
            <div>
                <div class="sum-value" data-target="@Model.TotalQualityTests">@Model.TotalQualityTests</div>
                <div class="sum-label">Quality Tests</div>
            </div>
            <a href="@Url.Action("QualityTests", "Production")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

        <!-- Center Payments -->
        <div class="sum-card c-blue">
            <div class="sum-card-top">
                <div class="sum-icon blue">
                    <svg><use href="#icon-card" /></svg>
                </div>
                @if (Model.PendingCenterPayments > 0)
                {
                    <span class="sum-badge badge-amber">@Model.PendingCenterPayments Pending</span>
                }
                else
                {
                    <span class="sum-badge badge-mint">All Settled</span>
                }
            </div>
            <div>
                <div class="sum-value">₹@((Model.TotalPaidToCenters / 100000).ToString("F1"))L</div>
                <div class="sum-label">Center Payments</div>
            </div>
            <a href="@Url.Action("CenterPayments", "Finance")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

        <!-- Wastage -->
        <div class="sum-card c-lavender">
            <div class="sum-card-top">
                <div class="sum-icon lavender">
                    <svg><use href="#icon-box" /></svg>
                </div>
                <span class="sum-badge badge-lavender">@Model.TotalProductWastage Logged</span>
            </div>
            <div>
                <div class="sum-value">@Model.TotalMilkProcessWastage.ToString("N0")</div>
                <div class="sum-label">Process Wastage (L)</div>
            </div>
            <a href="@Url.Action("WastageLog", "Production")" class="sum-link">
                View all
                <svg width="12" height="12"><use href="#icon-arrow-right" /></svg>
            </a>
        </div>

    </div>

    <!-- ═══ ROW 2 — Batch Stats | Transfer Overview ════ -->
    <div class="mid-grid">

        <!-- Production Batches Panel -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon amber">
                        <svg><use href="#icon-factory" /></svg>
                    </div>
                    Production Batches
                </div>
            </div>
            <div class="panel-body">
                <div class="batch-grid">
                    <div class="batch-cell amber-bg">
                        <div class="batch-num amber">@Model.InProgressBatches</div>
                        <div class="batch-lbl">In Progress</div>
                    </div>
                    <div class="batch-cell teal-bg">
                        <div class="batch-num teal">@Model.CompletedBatches</div>
                        <div class="batch-lbl">Completed</div>
                    </div>
                    <div class="batch-cell red-bg">
                        <div class="batch-num red">@Model.QCFailedBatches</div>
                        <div class="batch-lbl">QC Failed</div>
                    </div>
                    <div class="batch-cell gray-bg">
                        <div class="batch-num gray">@(Model.TotalBatches - Model.InProgressBatches - Model.CompletedBatches - Model.QCFailedBatches)</div>
                        <div class="batch-lbl">Cancelled</div>
                    </div>
                </div>
            </div>
            <div class="panel-footer">
                <a href="@Url.Action("Batches", "Production")" class="view-all-btn amber-btn">
                    <svg width="14" height="14"><use href="#icon-list" /></svg>
                    View All Batches
                </a>
            </div>
        </div>

        <!-- Transfer Overview Panel -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon aqua">
                        <svg><use href="#icon-truck" /></svg>
                    </div>
                    Transfer Overview
                </div>
            </div>
            <div class="panel-body">
                @{
                    var totalDispatched = Model.RecentTransfers.Sum(t => t.DispatchQty);
                    var receivedQty = Model.RecentTransfers.Where(t => t.Status == "Received").Sum(t => t.DispatchQty);
                    var receivedPct = totalDispatched > 0 ? (int)Math.Round(receivedQty / totalDispatched * 100) : 0;
                }
                <div class="transfer-row">
                    <span class="t-label">Total Dispatched</span>
                    <span class="t-value">@totalDispatched.ToString("N0") L</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Total Loss</span>
                    <span class="t-value red">@Model.TotalLossLitres.ToString("N1") L</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Loss %</span>
                    <span class="t-value red">@Model.AvgLossPct.ToString("F2")%</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Pending Receipt</span>
                    <span class="t-value">
                        @if (Model.PendingTransfers == 0)
                        {
                            <span class="pill pill-active">0</span>
                        }
                        else
                        {
                            <span class="pill pill-pending">@Model.PendingTransfers</span>
                        }
                    </span>
                </div>
                <div class="progress-wrap">
                    <div class="progress-track">
                        <div class="progress-fill" style="width:@receivedPct%"></div>
                    </div>
                    <p class="progress-label">@receivedPct% transfers received</p>
                </div>
            </div>
            <div class="panel-footer">
                <a href="@Url.Action("Index", "Production")" class="view-all-btn">
                    <svg width="14" height="14"><use href="#icon-list" /></svg>
                    View All Transfers
                </a>
            </div>
        </div>

    </div>

    <!-- ═══ ROW 3 — Recent Transfers | Recent Batches ══ -->
    <div class="bottom-grid">

        <!-- Recent Transfers -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon aqua">
                        <svg><use href="#icon-truck" /></svg>
                    </div>
                    Recent Transfers
                </div>
                <a href="@Url.Action("Index", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentTransfers.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Batch Ref</th>
                            <th>Center</th>
                            <th>Dispatched</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.RecentTransfers.Take(6))
                        {
                            <tr>
                                <td style="font-weight:700;font-size:12px;font-family:'DM Mono',monospace;color:var(--text)">@t.BatchRef</td>
                                <td>@t.CenterName</td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-muted)">@t.DispatchDate.ToString("dd MMM yy")</td>
                                <td>
                                    @if (t.Status == "Received")
                                    {
                                        <span class="pill pill-completed">Received</span>
                                    }
                                    else
                                    {
                                        <span class="pill pill-pending">Dispatched</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No transfers recorded yet.</div>
            }
        </div>

        <!-- Recent Batches -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon amber">
                        <svg><use href="#icon-factory" /></svg>
                    </div>
                    Recent Batches
                </div>
                <a href="@Url.Action("Batches", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentBatches.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Plant</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.RecentBatches.Take(6))
                        {
                            <tr>
                                <td style="font-weight:600;color:var(--text)">@b.ProductName</td>
                                <td style="color:var(--text-muted)">@b.PlantName</td>
                                <td style="font-size:12px;font-family:'DM Mono',monospace;color:var(--text-muted)">@b.ProductionDate.ToString("dd MMM yy")</td>
                                <td>
                                    @switch (b.BatchStatus)
                                    {
                                        case "InProgress":
                                            <span class="pill pill-inprogress">In Progress</span>
                                            break;
                                        case "Completed":
                                            <span class="pill pill-completed">Completed</span>
                                            break;
                                        case "QCFailed":
                                            <span class="pill pill-failed">QC Failed</span>
                                            break;
                                        case "Cancelled":
                                            <span class="pill pill-cancelled">Cancelled</span>
                                            break;
                                        default:
                                            <span class="pill pill-cancelled">@b.BatchStatus</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No production batches found.</div>
            }
        </div>

    </div>

    <!-- ═══ ROW 4 — Raw Milk Inventory | Transfer Loss ══ -->
    <div class="bottom-grid">

        <!-- Raw Milk Inventory -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon mint">
                        <svg><use href="#icon-droplet" /></svg>
                    </div>
                    Raw Milk Inventory
                </div>
                <a href="@Url.Action("RawMilkInventory", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.Inventory.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Plant</th>
                            <th>Milk Type</th>
                            <th>Quantity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Inventory.Take(7))
                        {
                            <tr>
                                <td style="font-size:12px;font-weight:600;color:var(--text)">@inv.PlantName</td>
                                <td style="font-size:12px;color:var(--text-muted)">@inv.MilkTypeName</td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600">@inv.Quantity.ToString("N0") L</td>
                                <td>
                                    @switch (inv.StockLabel)
                                    {
                                        case "Available":
                                            <span class="pill pill-active">Available</span>
                                            break;
                                        case "Low":
                                            <span class="pill pill-inprogress">Low</span>
                                            break;
                                        default:
                                            <span class="pill pill-failed">Empty</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No inventory data found.</div>
            }
        </div>

        <!-- Transfer Loss Log -->
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon coral">
                        <svg><use href="#icon-trend-down" /></svg>
                    </div>
                    Transfer Loss Log
                </div>
                <a href="@Url.Action("TransferLossLog", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentLosses.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Route</th>
                            <th>Loss (L)</th>
                            <th>Loss %</th>
                            <th>Category</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model.RecentLosses.Take(6))
                        {
                            <tr>
                                <td>
