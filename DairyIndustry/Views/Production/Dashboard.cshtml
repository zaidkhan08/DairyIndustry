        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" />
    </symbol>
</svg>

@{
    var totalDispatched = Model.RecentTransfers.Sum(t => t.DispatchQty);
    var receivedQty = Model.RecentTransfers.Where(t => t.Status == "Received").Sum(t => t.DispatchQty);
    var receivedPct = totalDispatched > 0 ? (int)Math.Round(receivedQty / totalDispatched * 100) : 0;
    var totalCenterPaid = Model.TotalPaidToCenters;
    var pendingCenterAmt = Model.RecentCenterPayments.Where(x => x.PaymentStatus == "Pending").Sum(x => x.TotalAmount);
    var processedAmt = Model.RecentCenterPayments.Where(x => x.PaymentStatus == "Processed").Sum(x => x.TotalAmount);

    // Expense segment %
    var totalWaste = (double)(Model.TotalMilkProcessWastage + Model.TotalProductWastage);
    var totalLoss = (double)Model.TotalLossLitres;
    var totalStock = (double)Model.TotalRawMilkStock;
    var grandOps = totalWaste + totalLoss + totalStock;
    var wastePct = grandOps > 0 ? (int)(totalWaste / grandOps * 100) : 33;
    var lossPct2 = grandOps > 0 ? (int)(totalLoss / grandOps * 100) : 33;
    var stockPct = 100 - wastePct - lossPct2;
}

<div class="dash-body">

    <!-- ═══ WELCOME ═══════════════════════════════════════ -->
    <div class="welcome-block">
        <p class="welcome-date">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
        <h1 class="welcome-title">
            Welcome back,<br>

            <span class="welcome-name">
                @Context.Session.GetString("Username")
            </span>

            👋
        </h1>
        <p class="welcome-sub">
            Here's what's happening at
            <strong>@Context.Session.GetString("PlantName")</strong> today.
        </p>
        <div class="welcome-actions">
            <a href="@Url.Action("StartBatch", "Production")" class="btn-primary">
                <svg width="14" height="14"><use href="#icon-plus" /></svg>
                Start Batch
            </a>
            <a href="@Url.Action("Index", "Production")" class="btn-outline">
                <svg width="14" height="14"><use href="#icon-list" /></svg>
                All Records
            </a>
        </div>
    </div>

    <!-- ═══ FINANCIAL KPI CARDS ══════════════════════════ -->
    <div class="fin-grid">

        <!-- Card 1: My Balance (dark) -->
        <div class="fin-card card-dark">
            <div class="fin-card-head">
                <div class="fin-card-label">
                    <div class="fin-card-label-icon icon-dark-blue">
                        <svg><use href="#icon-card" /></svg>
                    </div>
                    Center Payments
                </div>
                <span class="fin-pill dark">ALL TIME</span>
            </div>

            <div class="fin-value">₹@((totalCenterPaid / 100000m).ToString("F2"))L</div>

            @if (pendingCenterAmt > 0)
            {
                <div class="fin-delta down">
                    <svg><use href="#icon-trend-down" /></svg>
                    ₹@pendingCenterAmt.ToString("N0") pending settlement
                </div>
            }
            else
            {
                <div class="fin-delta up">
                    <svg><use href="#icon-trend-up" /></svg>
                    All center payments settled
                </div>
            }

            <div class="fin-divider dark"></div>

            <div class="fin-actions">
                <a href="@Url.Action("ProcessCenterPayment", "Finance")" class="fin-btn solid">
                    <svg><use href="#icon-plus" /></svg>
                    Process Payment
                </a>
                <a href="@Url.Action("CenterPayments", "Finance")" class="fin-btn ghost">
                    <svg><use href="#icon-eye" /></svg>
                    View All
                </a>
            </div>
        </div>

        <!-- Todo List Card -->
               
        <div class="fin-card card-white todo-card">

            <div class="fin-card-head">

                <div class="fin-card-label">

                    <div class="fin-card-label-icon icon-blue">
                        <svg width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M9 11l3 3L22 4"></path>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                        </svg>
                    </div>

                    Pending Tasks

                </div>

                <span class="fin-pill amber-pill">

                    @{
                        int pendingCount = 0;

                        if (Model.PendingTransfers > 0)
                            pendingCount++;

                        if (pendingCenterAmt > 0)
                            pendingCount++;

                        if (Model.QCFailedBatches > 0)
                            pendingCount++;

                        if (Model.InProgressBatches > 0)
                            pendingCount++;
                    }

                    @pendingCount Pending

                </span>

            </div>

            <div class="ops-list">

                @if (Model.PendingTransfers > 0)
                {
                    <div class="ops-item">

                        <div class="ops-left">

                            <div class="ops-icon blue">

                                <svg width="18" height="18"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">

                                    <rect x="1" y="3"
                                          width="15"
                                          height="13"></rect>

                                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>

                                    <circle cx="5.5" cy="18.5" r="2.5"></circle>

                                    <circle cx="18.5" cy="18.5" r="2.5"></circle>

                                </svg>

                            </div>

                            <div>

                                <div class="ops-title">
                                    Pending Milk Transfers
                                </div>

                                <div class="ops-sub">
                                    Awaiting plant receipt
                                </div>

                            </div>

                        </div>

                        <span class="ops-badge warning">
                            @Model.PendingTransfers
                        </span>

                    </div>
                }

                @if (pendingCenterAmt > 0)
                {
                    <div class="ops-item">

                        <div class="ops-left">

                            <div class="ops-icon green">

                                <svg width="18" height="18"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">

                                    <rect x="2" y="5"
                                          width="20"
                                          height="14"
                                          rx="2"></rect>

                                    <line x1="2" y1="10"
                                          x2="22" y2="10"></line>

                                </svg>

                            </div>

                            <div>

                                <div class="ops-title">
                                    Pending Payments
                                </div>

                                <div class="ops-sub">
                                    Center settlements due
                                </div>

                            </div>

                        </div>

                        <span class="ops-badge danger">
                            ₹@pendingCenterAmt.ToString("N0")
                        </span>

                    </div>
                }

                @if (Model.QCFailedBatches > 0)
                {
                    <div class="ops-item">

                        <div class="ops-left">

                            <div class="ops-icon red">

                                <svg width="18" height="18"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">

                                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>

                                    <line x1="12" y1="9"
                                          x2="12" y2="13"></line>

                                    <line x1="12" y1="17"
                                          x2="12.01" y2="17"></line>

                                </svg>

                            </div>

                            <div>

                                <div class="ops-title">
                                    QC Failed Batches
                                </div>

                                <div class="ops-sub">
                                    Requires immediate review
                                </div>

                            </div>

                        </div>

                        <span class="ops-badge danger">
                            @Model.QCFailedBatches
                        </span>

                    </div>
                }

                @if (Model.InProgressBatches > 0)
                {
                    <div class="ops-item">

                        <div class="ops-left">

                            <div class="ops-icon amber">

                                <svg width="18" height="18"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">

                                    <path d="M6 22V12"></path>
                                    <path d="M18 22V12"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M12 2v20"></path>

                                </svg>

                            </div>

                            <div>

                                <div class="ops-title">
                                    Active Production
                                </div>

                                <div class="ops-sub">
                                    Batches currently running
                                </div>

                            </div>

                        </div>

                        <span class="ops-badge info">
                            @Model.InProgressBatches
                        </span>

                    </div>
                }

                @if (pendingCount == 0)
                {
                    <div class="todo-empty">

                        <svg width="42"
                             height="42"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="#10b981"
                             stroke-width="2">

                            <path d="M20 6L9 17l-5-5"></path>

                        </svg>

                        <div style="margin-top:10px;font-weight:700;">
                            No Pending Tasks
                        </div>

                        <div style="margin-top:4px;font-size:12px;color:var(--text-muted);">
                            Everything looks good.
                        </div>

                    </div>
                }

            </div>

        </div>


    </div>

    <!-- ═══ ROW 2 — Batch Stats | Transfer Overview ════ -->
    <div class="mid-grid">

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon amber"><svg><use href="#icon-factory" /></svg></div>
                    Production Batches
                </div>
            </div>
            <div class="panel-body">
                <div class="batch-grid">
                    <div class="batch-cell amber-bg">
                        <div class="batch-num amber">@Model.InProgressBatches</div>
                        <div class="batch-lbl">In Progress</div>
                    </div>
                    <div class="batch-cell teal-bg">
                        <div class="batch-num teal">@Model.CompletedBatches</div>
                        <div class="batch-lbl">Completed</div>
                    </div>
                    <div class="batch-cell red-bg">
                        <div class="batch-num red">@Model.QCFailedBatches</div>
                        <div class="batch-lbl">QC Failed</div>
                    </div>
                    <div class="batch-cell gray-bg">
                        <div class="batch-num gray">@(Model.TotalBatches - Model.InProgressBatches - Model.CompletedBatches - Model.QCFailedBatches)</div>
                        <div class="batch-lbl">Cancelled</div>
                    </div>
                </div>
            </div>
            <div class="panel-footer">
                <a href="@Url.Action("Batches", "Production")" class="view-all-btn amber-btn">
                    <svg width="14" height="14"><use href="#icon-list" /></svg>
                    View All Batches
                </a>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon aqua"><svg><use href="#icon-truck" /></svg></div>
                    Transfer Overview
                </div>
            </div>
            <div class="panel-body">
                <div class="transfer-row">
                    <span class="t-label">Total Dispatched</span>
                    <span class="t-value">@totalDispatched.ToString("N0") L</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Total Loss</span>
                    <span class="t-value red">@Model.TotalLossLitres.ToString("N1") L</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Loss %</span>
                    <span class="t-value red">@Model.AvgLossPct.ToString("F2")%</span>
                </div>
                <div class="transfer-row">
                    <span class="t-label">Pending Receipt</span>
                    <span class="t-value">
                        @if (Model.PendingTransfers == 0)
                        {
                            <span class="pill pill-active">0</span>
                        }
                        else
                        {
                            <span class="pill pill-pending">@Model.PendingTransfers</span>
                        }
                    </span>
                </div>
                <div class="progress-wrap">
                    <div class="progress-track">
                        <div class="progress-fill" style="width:@receivedPct%"></div>
                    </div>
                    <p class="progress-label">@receivedPct% transfers received</p>
                </div>
            </div>
            <div class="panel-footer">
                <a href="@Url.Action("Index", "Production")" class="view-all-btn">
                    <svg width="14" height="14"><use href="#icon-list" /></svg>
                    View All Transfers
                </a>
            </div>
        </div>

    </div>

    <!-- ═══ ROW 3 — Recent Transfers | Recent Batches ══ -->
    <div class="bottom-grid">

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon aqua"><svg><use href="#icon-truck" /></svg></div>
                    Recent Transfers
                </div>
                <a href="@Url.Action("Index", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentTransfers.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Batch Ref</th>
                            <th>Center</th>
                            <th>Dispatched</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.RecentTransfers.Take(6))
                        {
                            <tr>
                                <td style="font-weight:700;font-size:12px;font-family:'DM Mono',monospace;color:var(--text)">@t.BatchRef</td>
                                <td>@t.CenterName</td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-muted)">@t.DispatchDate.ToString("dd MMM yy")</td>
                                <td>
                                    @if (t.Status == "Received")
                                    {
                                        <span class="pill pill-completed">Received</span>
                                    }
                                    else
                                    {
                                        <span class="pill pill-pending">Dispatched</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No transfers recorded yet.</div>
            }
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon amber"><svg><use href="#icon-factory" /></svg></div>
                    Recent Batches
                </div>
                <a href="@Url.Action("Batches", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentBatches.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Plant</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.RecentBatches.Take(6))
                        {
                            <tr>
                                <td style="font-weight:600;color:var(--text)">@b.ProductName</td>
                                <td style="color:var(--text-muted)">@b.PlantName</td>
                                <td style="font-size:12px;font-family:'DM Mono',monospace;color:var(--text-muted)">@b.ProductionDate.ToString("dd MMM yy")</td>
                                <td>
                                    @switch (b.BatchStatus)
                                    {
                                        case "InProgress":
                                            <span class="pill pill-inprogress">In Progress</span>
                                            break;
                                        case "Completed":

                                            <span class="pill pill-completed">Completed</span>
                                            break;
                                        case "QCFailed":

                                            <span class="pill pill-failed">QC Failed</span>
                                            break;
                                        case "Cancelled":

                                            <span class="pill pill-cancelled">Cancelled</span>
                                            break;
                                        default:

                                            <span class="pill pill-cancelled">@b.BatchStatus</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No production batches found.</div>
            }
        </div>

    </div>

    <!-- ═══ ROW 4 — Raw Milk Inventory | Transfer Loss ══ -->
    <div class="bottom-grid">

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon mint"><svg><use href="#icon-droplet" /></svg></div>
                    Raw Milk Inventory
                </div>
                <a href="@Url.Action("RawMilkInventory", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.Inventory.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr><th>Plant</th><th>Milk Type</th><th>Quantity</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Inventory.Take(7))
                        {
                            <tr>
                                <td style="font-size:12px;font-weight:600;color:var(--text)">@inv.PlantName</td>
                                <td style="font-size:12px;color:var(--text-muted)">@inv.MilkTypeName</td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600">@inv.Quantity.ToString("N0") L</td>
                                <td>
                                    @switch (inv.StockLabel)
                                    {
                                        case "Available":
                                            <span class="pill pill-active">Available</span>
                                            break;
                                        case "Low":

                                            <span class="pill pill-inprogress">Low</span>
                                            break;
                                        default:

                                            <span class="pill pill-failed">Empty</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No inventory data found.</div>
            }
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="panel-icon coral"><svg><use href="#icon-trend-down" /></svg></div>
                    Transfer Loss Log
                </div>
                <a href="@Url.Action("TransferLossLog", "Production")" class="panel-view-all">View All</a>
            </div>
            @if (Model.RecentLosses.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr><th>Route</th><th>Loss (L)</th><th>Loss %</th><th>Category</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model.RecentLosses.Take(6))
                        {
                            <tr>
                                <td>
                                    <div style="font-size:12px;font-weight:600;color:var(--text)">@l.PlantName</div>
                                    <div style="font-size:11px;color:var(--text-light);margin-top:1px">@l.DispatchDate.ToString("dd MMM")</div>
                                </td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600">@l.LossQty.ToString("N1")</td>
                                <td style="font-family:'DM Mono',monospace;font-size:12px">@l.LossPct.ToString("F1")%</td>
                                <td>
                                    @switch (l.LossCategory)
                                    {
                                        case "Severe":
                                            <span class="pill pill-failed">Severe</span>
                                            break;
                                        case "Moderate":

                                            <span class="pill pill-inprogress">Moderate</span>
                                            break;
                                        default:

                                            <span class="pill pill-active">Minor</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No loss records yet.</div>
            }
        </div>

    </div>

    <!-- ═══ ROW 5 — Center Payments Full Width ════════ -->
    <div class="panel">
        <div class="panel-header">
            <div class="panel-title">
                <div class="panel-icon blue"><svg><use href="#icon-card" /></svg></div>
                Recent Center Payments
            </div>
            <a href="@Url.Action("CenterPayments", "Finance")" class="panel-view-all">View All</a>
        </div>
        @if (Model.RecentCenterPayments.Any())
        {
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Center</th>
                        <th>Plant</th>
                        <th>Qty (L)</th>
                        <th>Rate / L</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cp in Model.RecentCenterPayments.Take(6))
                    {
                        <tr>
                            <td>
                                <div style="font-weight:700;color:var(--text)">@cp.CenterName</div>
                                <div style="font-size:11px;color:var(--text-light);font-family:'DM Mono',monospace;margin-top:2px">@cp.BatchRef</div>
                            </td>
                            <td style="font-size:13px;color:var(--text-muted)">@cp.PlantName</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600">@cp.ReceivedQty.ToString("N0")</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px">₹@cp.RatePerLiter.ToString("F2")</td>
                            <td style="font-family:'DM Mono',monospace;font-size:13px;font-weight:700;color:var(--text)">₹@cp.TotalAmount.ToString("N2")</td>
                            <td style="font-size:12px;color:var(--text-muted)">@cp.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (cp.PaymentStatus)
                                {
                                    case "Processed":
                                        <span class="pill pill-completed">Processed</span>
                                        break;
                                    case "Failed":

                                        <span class="pill pill-failed">Failed</span>
                                        break;
                                    default:

                                        <span class="pill pill-pending">Pending</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No center payments recorded yet.</div>
        }
        <div class="panel-action-bar">
            <a href="@Url.Action("ProcessCenterPayment", "Finance")" class="btn-primary">
                <svg width="13" height="13"><use href="#icon-plus" /></svg>
                Process Payment
            </a>
            <a href="@Url.Action("CenterPayments", "Finance")" class="btn-outline">
                <svg width="13" height="13"><use href="#icon-list" /></svg>
                All Payments
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Counter animation
        document.querySelectorAll('.fin-value').forEach(el => {
            const txt = el.textContent.trim();
            const hasCurr = txt.startsWith('₹');
            const raw = txt.replace(/[^\d.]/g, '');
            const num = parseFloat(raw);
            if (isNaN(num) || num === 0) return;
            const suffix = txt.replace(/[\d,. ₹]/g, '').trim();
            const prefix = hasCurr ? '₹' : '';
            const isFloat = txt.includes('.');
            const decs = isFloat ? (txt.split('.')[1]?.replace(/\D/, '').length || 1) : 0;
            const dur = 900;
            const start = performance.now();
            function tick(now) {
                const p = Math.min((now - start) / dur, 1);
                const ease = 1 - Math.pow(1 - p, 3);
                const v = num * ease;
                const disp = isFloat ? v.toFixed(decs) : Math.round(v).toLocaleString('en-IN');
                el.textContent = prefix + disp + suffix;
                if (p < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        });

        // Bar animations
        document.querySelectorAll('.fin-bar-fill, .progress-fill').forEach(el => {
            const target = el.style.width;
            el.style.width = '0%';
            setTimeout(() => { el.style.width = target; }, 200);
        });

        // Card stagger entrance
        document.querySelectorAll('.fin-card, .panel').forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(16px)';
            card.style.transition = 'opacity 0.45s ease, transform 0.45s ease, box-shadow 0.25s ease';
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 60 + i * 50);
        });


                let todos = [];

        function renderTodos() {

            const list = document.getElementById("todoList");
            const count = document.getElementById("todoCount");

            if (todos.length === 0) {

                list.innerHTML = `
                    <div class="todo-empty" id="todoEmpty">
                        No tasks added yet.
                    </div>
                `;

                count.innerText = "0";

                return;
            }

            list.innerHTML = "";

            todos.forEach((todo, index) => {

                list.innerHTML += `
                    <div class="todo-item">

                        <div class="todo-text">
                            ${todo}
                        </div>

                        <div class="todo-actions">

                            <button type="button"
                                    class="todo-btn todo-edit"
                                    onclick="editTodo(${index})">

                                Edit

                            </button>

                            <button type="button"
                                    class="todo-btn todo-delete"
                                    onclick="deleteTodo(${index})">

                                Delete

                            </button>

                        </div>

                    </div>
                `;
            });

            count.innerText = todos.length;
        }

        function addTodo() {

            const input = document.getElementById("todoInput");

            const value = input.value.trim();

            if (value === "")
                return;

            todos.unshift(value);

            input.value = "";

            renderTodos();
        }

        function deleteTodo(index) {

            todos.splice(index, 1);

            renderTodos();
        }

        function editTodo(index) {

            const updated = prompt("Edit task", todos[index]);

            if (updated === null)
                return;

            const clean = updated.trim();

            if (clean === "")
                return;

            todos[index] = clean;

            renderTodos();
        }

        document
            .getElementById("todoInput")
            .addEventListener("keypress", function (e) {

                if (e.key === "Enter") {
                    addTodo();
                }
            });

        renderTodos();
    </script>
}
