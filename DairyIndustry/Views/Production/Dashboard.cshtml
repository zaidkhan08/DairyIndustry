                    <tr>
                        <th>Center</th>
                        <th>Plant</th>
                        <th>Qty (L)</th>
                        <th>Rate / L</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cp in Model.RecentCenterPayments.Take(6))
                    {
                        <tr>
                            <td>
                                <div style="font-weight:700;color:var(--text)">@cp.CenterName</div>
                                <div style="font-size:11px;color:var(--text-light);font-family:'DM Mono',monospace;margin-top:2px">@cp.BatchRef</div>
                            </td>
                            <td style="font-size:13px;color:var(--text-muted)">@cp.PlantName</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600">@cp.ReceivedQty.ToString("N0")</td>
                            <td style="font-family:'DM Mono',monospace;font-size:12px">₹@cp.RatePerLiter.ToString("F2")</td>
                            <td style="font-family:'DM Mono',monospace;font-size:13px;font-weight:700;color:var(--text)">₹@cp.TotalAmount.ToString("N2")</td>
                            <td style="font-size:12px;color:var(--text-muted)">@cp.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (cp.PaymentStatus)
                                {
                                    case "Processed":
                                        <span class="pill pill-completed">Processed</span>
                                        break;
                                    case "Failed":
                                        <span class="pill pill-failed">Failed</span>
                                        break;
                                    default:
                                        <span class="pill pill-pending">Pending</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="padding:2.5rem;text-align:center;color:var(--text-muted);font-size:13px;font-weight:500">No center payments recorded yet.</div>
        }
        <div class="panel-action-bar">
            <a href="@Url.Action("ProcessCenterPayment", "Finance")" class="btn-primary">
                <svg width="13" height="13"><use href="#icon-plus" /></svg>
                Process Payment
            </a>
            <a href="@Url.Action("CenterPayments", "Finance")" class="btn-outline">
                <svg width="13" height="13"><use href="#icon-list" /></svg>
                All Payments
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── Counter animation ─────────────────────────────
        document.querySelectorAll('.sum-value').forEach(el => {
            const txt  = el.textContent.trim();
            const hasCurr = txt.startsWith('₹');
            const raw  = txt.replace(/[^\d.]/g, '');
            const num  = parseFloat(raw);
            if (isNaN(num) || num === 0) return;

            const suffix  = txt.replace(/[\d,. ₹]/g, '').trim();
            const prefix  = hasCurr ? '₹' : '';
            const isFloat = txt.includes('.');
            const decs    = isFloat ? (txt.split('.')[1]?.replace(/\D/, '').length || 1) : 0;

            const dur   = 900;
            const start = performance.now();

            function tick(now) {
                const p    = Math.min((now - start) / dur, 1);
                const ease = 1 - Math.pow(1 - p, 3);
                const v    = num * ease;
                const disp = isFloat ? v.toFixed(decs) : Math.round(v).toLocaleString('en-IN');
                el.textContent = prefix + disp + suffix;
                if (p < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        });

        // ── Progress bar animation ────────────────────────
        document.querySelectorAll('.progress-fill').forEach(el => {
            const target = el.style.width;
            el.style.width = '0%';
            setTimeout(() => { el.style.width = target; }, 150);
        });

        // ── Card stagger entrance ─────────────────────────
        const cards = document.querySelectorAll('.sum-card, .panel');
        cards.forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(14px)';
            card.style.transition = 'opacity 0.45s ease, transform 0.45s ease, box-shadow 0.25s ease';
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 60 + i * 40);
        });
    </script>
}
