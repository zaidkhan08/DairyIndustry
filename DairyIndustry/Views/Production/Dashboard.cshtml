@model DairyIndustry.Models.Production.ProductionDashboardViewModel
@{
    ViewData["Title"] = "Production Dashboard";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        /* Core palette */
        --bg: #f5f6fb;
        --surface: rgba(255,255,255,0.85);
        --surface-solid: #ffffff;
        --border: rgba(220,224,240,0.7);
        --border-light: rgba(220,224,240,0.4);
        /* Text */
        --text: #0f172a;
        --text-mid: #334155;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        /* Accent colors */
        --mint: #10b981;
        --mint-bg: #ecfdf5;
        --mint-text: #065f46;
        --aqua: #06b6d4;
        --aqua-bg: #ecfeff;
        --aqua-text: #155e75;
        --lavender: #8b5cf6;
        --lavender-bg: #f5f3ff;
        --lavender-text: #4c1d95;
        --amber: #f59e0b;
        --amber-bg: #fffbeb;
        --amber-text: #78350f;
        --blue: #3b82f6;
        --blue-bg: #eff6ff;
        --blue-text: #1e3a8a;
        --coral: #f43f5e;
        --coral-bg: #fff1f2;
        --coral-text: #881337;
        /* Shadows */
        --shadow-card: 0 8px 32px rgba(15,23,42,0.05), 0 2px 8px rgba(15,23,42,0.03);
        --shadow-hover: 0 20px 48px rgba(15,23,42,0.10), 0 4px 16px rgba(15,23,42,0.06);
        --shadow-sm: 0 2px 8px rgba(15,23,42,0.04);
        --radius-xl: 24px;
        --radius-lg: 18px;
        --radius-md: 12px;
        --radius-sm: 8px;
        --radius-pill: 100px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text);
        font-size: 14px;
        min-height: 100vh;
    }

        /* Subtle mesh background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 800px 600px at 10% 20%, rgba(139,92,246,0.04) 0%, transparent 60%), radial-gradient(ellipse 600px 500px at 85% 80%, rgba(59,130,246,0.04) 0%, transparent 60%), radial-gradient(ellipse 500px 400px at 50% 50%, rgba(16,185,129,0.03) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

    /* ── Page Header ─────────────────────────────── */
    .page-header {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.75rem 2rem 1.5rem;
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
    }

    .page-title {
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.5px;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 4px;
        font-weight: 400;
    }

        .page-subtitle strong {
            color: var(--text-mid);
            font-weight: 600;
        }

    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-shrink: 0;
    }

    /* ── Buttons ──────────────────────────────────── */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(99,102,241,0.30);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.40);
            color: #fff;
        }

    .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--surface-solid);
        color: var(--text-mid);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-outline:hover {
            background: var(--bg);
            border-color: rgba(99,102,241,0.3);
            color: var(--lavender);
            transform: translateY(-1px);
        }

    /* ── Main Body ────────────────────────────────── */
    .dash-body {
        position: relative;
        z-index: 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    /* ── Section Label ────────────────────────────── */
    .section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 0.75rem;
    }

    /* ── Summary Grid ─────────────────────────────── */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 16px;
    }

    .sum-card {
        background: var(--surface);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 1.5rem 1.4rem 1.3rem;
        box-shadow: var(--shadow-card);
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        cursor: default;
        position: relative;
        overflow: hidden;
    }

        .sum-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--radius-xl) var(--radius-xl) 0 0;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .sum-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

            .sum-card:hover::before {
                opacity: 1;
            }

        .sum-card.c-mint::before {
            background: linear-gradient(90deg, var(--mint), var(--aqua));
        }

        .sum-card.c-aqua::before {
            background: linear-gradient(90deg, var(--aqua), #38bdf8);
        }

        .sum-card.c-amber::before {
            background: linear-gradient(90deg, var(--amber), #fb923c);
        }

        .sum-card.c-coral::before {
            background: linear-gradient(90deg, var(--coral), #f97316);
        }

        .sum-card.c-blue::before {
            background: linear-gradient(90deg, var(--blue), #6366f1);
        }

        .sum-card.c-lavender::before {
            background: linear-gradient(90deg, var(--lavender), #ec4899);
        }

    .sum-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    /* Icon containers — pastel gradients */
    .sum-icon {
        width: 42px;
        height: 42px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .sum-icon svg {
            width: 20px;
            height: 20px;
        }

        .sum-icon.mint {
            background: linear-gradient(135deg, #a7f3d0, #6ee7b7);
        }

        .sum-icon.aqua {
            background: linear-gradient(135deg, #a5f3fc, #67e8f9);
        }

        .sum-icon.amber {
            background: linear-gradient(135deg, #fde68a, #fcd34d);
        }

        .sum-icon.coral {
            background: linear-gradient(135deg, #fecdd3, #fda4af);
        }

        .sum-icon.blue {
            background: linear-gradient(135deg, #bfdbfe, #93c5fd);
        }

        .sum-icon.lavender {
            background: linear-gradient(135deg, #ddd6fe, #c4b5fd);
        }

    /* Badges */
    .sum-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        white-space: nowrap;
        letter-spacing: 0.2px;
    }

    .badge-mint {
        background: var(--mint-bg);
        color: var(--mint-text);
    }

    .badge-amber {
        background: var(--amber-bg);
        color: var(--amber-text);
    }

    .badge-coral {
        background: var(--coral-bg);
        color: var(--coral-text);
    }

    .badge-blue {
        background: var(--blue-bg);
        color: var(--blue-text);
    }

    .badge-lavender {
        background: var(--lavender-bg);
        color: var(--lavender-text);
    }

    .badge-gray {
        background: #f1f5f9;
        color: #64748b;
    }

    /* Number + label */
    .sum-value {
        font-size: 36px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1px;
    }

    .sum-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 3px;
        font-weight: 500;
    }

    .sum-link {
        font-size: 12px;
        color: var(--blue);
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        opacity: 0.8;
        transition: opacity 0.15s;
    }

        .sum-link:hover {
            opacity: 1;
            text-decoration: underline;
        }

    /* ── Mid / Bottom Grid ────────────────────────── */
    .mid-grid, .bottom-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    /* ── Generic Panel ────────────────────────────── */
    .panel {
        background: var(--surface);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.25s ease;
    }

        .panel:hover {
            box-shadow: 0 12px 40px rgba(15,23,42,0.07), 0 2px 12px rgba(15,23,42,0.04);
        }

    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem 1rem;
        border-bottom: 1px solid var(--border-light);
    }

    .panel-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: -0.2px;
    }

    .panel-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .panel-icon svg {
            width: 16px;
            height: 16px;
        }

        .panel-icon.amber {
            background: var(--amber-bg);
            color: var(--amber);
        }

        .panel-icon.mint {
            background: var(--mint-bg);
            color: var(--mint);
        }

        .panel-icon.blue {
            background: var(--blue-bg);
            color: var(--blue);
        }

        .panel-icon.coral {
            background: var(--coral-bg);
            color: var(--coral);
        }

        .panel-icon.lavender {
            background: var(--lavender-bg);
            color: var(--lavender);
        }

        .panel-icon.aqua {
            background: var(--aqua-bg);
            color: var(--aqua);
        }

    .panel-view-all {
        font-size: 12px;
        font-weight: 600;
        color: var(--blue);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        opacity: 0.8;
        transition: opacity 0.15s;
    }

        .panel-view-all:hover {
            opacity: 1;
        }

    .panel-body {
        padding: 1.25rem 1.5rem;
        flex: 1;
    }

    .panel-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-light);
    }

    /* ── Batch Stat Grid ──────────────────────────── */
    .batch-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .batch-cell {
        border-radius: var(--radius-lg);
        padding: 1.25rem 1rem 1rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease;
    }

        .batch-cell:hover {
            transform: scale(1.02);
        }

        .batch-cell::after {
            content: '';
            position: absolute;
            bottom: -10px;
            right: -10px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            opacity: 0.15;
        }

        .batch-cell.amber-bg {
            background: linear-gradient(145deg, #fffbeb, #fef3c7);
        }

            .batch-cell.amber-bg::after {
                background: var(--amber);
            }

        .batch-cell.teal-bg {
            background: linear-gradient(145deg, #ecfdf5, #d1fae5);
        }

            .batch-cell.teal-bg::after {
                background: var(--mint);
            }

        .batch-cell.red-bg {
            background: linear-gradient(145deg, #fff1f2, #ffe4e6);
        }

            .batch-cell.red-bg::after {
                background: var(--coral);
            }

        .batch-cell.gray-bg {
            background: linear-gradient(145deg, #f8fafc, #f1f5f9);
        }

            .batch-cell.gray-bg::after {
                background: #94a3b8;
            }

    .batch-num {
        font-size: 38px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 6px;
        letter-spacing: -1.5px;
    }

        .batch-num.amber {
            color: #d97706;
        }

        .batch-num.teal {
            color: var(--mint);
        }

        .batch-num.red {
            color: var(--coral);
        }

        .batch-num.gray {
            color: #94a3b8;
        }

    .batch-lbl {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text-muted);
    }

    /* ── View All Button ──────────────────────────── */
    .view-all-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 10px;
        background: transparent;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 600;
        color: var(--text-mid);
        text-decoration: none;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: all 0.2s ease;
    }

        .view-all-btn:hover {
            background: var(--bg);
            transform: translateY(-1px);
        }

        .view-all-btn.amber-btn {
            border-color: rgba(245,158,11,0.4);
            color: #d97706;
        }

            .view-all-btn.amber-btn:hover {
                background: var(--amber-bg);
                border-color: var(--amber);
            }

    /* ── Transfer Overview ────────────────────────── */
    .transfer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 11px 0;
        border-bottom: 1px solid var(--border-light);
        font-size: 13px;
    }

        .transfer-row:last-of-type {
            border-bottom: none;
        }

        .transfer-row .t-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .transfer-row .t-value {
            font-weight: 700;
            color: var(--text);
            font-family: 'DM Mono', monospace;
            font-size: 13px;
        }

            .transfer-row .t-value.red {
                color: var(--coral);
            }

    /* Progress bar */
    .progress-wrap {
        margin-top: 16px;
    }

    .progress-track {
        height: 8px;
        background: #f1f5f9;
        border-radius: var(--radius-pill);
        overflow: hidden;
        margin-bottom: 8px;
    }

    .progress-fill {
        height: 100%;
        border-radius: var(--radius-pill);
        background: linear-gradient(90deg, var(--mint), var(--aqua));
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 20px;
            height: 100%;
            background: rgba(255,255,255,0.4);
            border-radius: var(--radius-pill);
            animation: shimmer 2s infinite;
        }

    @@keyframes shimmer {
        0% {
            opacity: 0;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: 0;
        }
    }

    .progress-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* ── Tables ───────────────────────────────────── */
    .dash-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .dash-table thead {
            background: #f8fafc;
        }

        .dash-table th {
            font-size: 10.5px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 10px 1.5rem;
            text-align: left;
            border-bottom: 1px solid var(--border-light);
        }

        .dash-table td {
            padding: 13px 1.5rem;
            color: var(--text-mid);
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
            font-weight: 500;
        }

        .dash-table tr:last-child td {
            border-bottom: none;
        }

        .dash-table tbody tr {
            transition: background 0.15s ease;
        }

            .dash-table tbody tr:hover td {
                background: rgba(59,130,246,0.03);
            }

    /* ── Status Pills ─────────────────────────────── */
    .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 11px;
        border-radius: var(--radius-pill);
        white-space: nowrap;
        letter-spacing: 0.2px;
    }

    .pill-active {
        background: #dcfce7;
        color: #166534;
    }

    .pill-inactive {
        background: var(--coral-bg);
        color: var(--coral-text);
    }

    .pill-inprogress {
        background: #fef9c3;
        color: #713f12;
    }

    .pill-completed {
        background: #dcfce7;
        color: #166534;
    }

    .pill-failed {
        background: var(--coral-bg);
        color: var(--coral-text);
    }

    .pill-cancelled {
        background: #f1f5f9;
        color: #64748b;
    }

    .pill-pending {
        background: var(--amber-bg);
        color: var(--amber-text);
    }

    /* ── Panel Action Bar ─────────────────────────── */
    .panel-action-bar {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-light);
        display: flex;
        gap: 10px;
        background: #fafbfc;
    }

    /* ── Responsive ───────────────────────────────── */
    @@media (max-width: 1400px) {
        .summary-grid {
            grid-template-columns: repeat(3, minmax(0,1fr));
        }
    }

    @@media (max-width: 1024px) {
        .summary-grid {
            grid-template-columns: repeat(3, minmax(0,1fr));
        }

        .mid-grid, .bottom-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }

        .dash-body {
            padding: 1.25rem;
        }

        .page-header {
            flex-direction: column;
            gap: 14px;
            align-items: flex-start;
        }

        .batch-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 400px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

