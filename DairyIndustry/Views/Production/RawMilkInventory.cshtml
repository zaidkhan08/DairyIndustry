@model List<DairyIndustry.Models.Production.RawMilkInventoryModel>
@{
    ViewData["Title"] = "Raw Milk Inventory";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">🥛 Raw Milk Inventory</h4>
    <span class="text-muted small">Auto-updated when milk is received at plant</span>
</div>

@* Summary Cards *@
<div class="row g-3 mb-4">
    @foreach (var plant in Model.GroupBy(x => x.PlantName))
    {
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <strong>🏭 @plant.Key</strong>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Milk Type</th>
                                <th>Available (L)</th>
                                <th>Stock</th>
                                <th>Last Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in plant)
                            {
                                <tr>
                                    <td><strong>@row.MilkTypeName</strong></td>
                                    <td>@row.Quantity.ToString("N2")</td>
                                    <td>
                                        <span class="badge @row.StockBadgeClass">
                                            @row.StockLabel
                                        </span>
                                    </td>
                                    <td>@row.LastUpdated.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                </tr>
                            }
                            <tr class="table-secondary fw-bold">
                                <td>Total</td>
                                <td>@plant.Sum(x => x.Quantity).ToString("N2") L</td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">
                No raw milk inventory found. Receive a milk transfer first to populate inventory.
            </div>
        </div>
    }
</div>

<small class="text-muted">
    💡 Inventory is automatically increased when a transfer is received and decreased when a production batch is started.
</small>
