@model List<DairyIndustry.Models.Production.RawMilkInventoryModel>
@using DairyIndustry.Models.Production
@{
    ViewData["Title"] = "Plant Inventory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var plantName = Context.Session.GetString("PlantName");
    var plantLabel = plantName ?? Model.FirstOrDefault()?.PlantName ?? "Unknown Plant";
    var grouped = Model.GroupBy(x => x.PlantName);
    var globalTotal = Model.Sum(x => x.Quantity);
    var totalTypes = Model.Select(x => x.MilkTypeName).Distinct().Count();
    var lastSync = Model.Any() ? Model.Max(x => x.LastUpdated) : DateTime.Now;
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg: #F4F5F7;
        --surface: #FFFFFF;
        --surface-2: #F9FAFB;
        --border: #E4E7EC;
        --border-2: #D0D5DD;
        --text-1: #101828;
        --text-2: #344054;
        --text-3: #667085;
        --text-4: #98A2B3;
        --accent: #1D4ED8;
        --accent-bg: #EFF4FF;
        --accent-bd: #C7D7FD;
        --green: #027A48;
        --green-bg: #ECFDF3;
        --green-bd: #ABEFC6;
        --radius: 10px;
        --radius-lg: 14px;
        --shadow: 0 1px 2px rgba(16,24,40,.06), 0 1px 3px rgba(16,24,40,.1);
        --shadow-md: 0 4px 8px -2px rgba(16,24,40,.08), 0 2px 4px -2px rgba(16,24,40,.04);
    }

    .inv {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 2rem 1.75rem 4rem;
        color: var(--text-1);
    }

    /* ── TOP BAR ── */
    .inv-topbar {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .inv-page-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-4);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 6px;
    }

    .inv-page-title {
        font-size: 26px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: -.4px;
        line-height: 1.1;
    }

    .inv-page-plant {
        font-size: 13px;
        color: var(--text-3);
        margin-top: 5px;
        font-weight: 400;
    }

    .inv-sync-tag {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 7px 13px;
        font-size: 12px;
        color: var(--text-3);
        font-weight: 500;
        box-shadow: var(--shadow);
        white-space: nowrap;
    }

    .sync-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #17B26A;
        flex-shrink: 0;
        animation: blink 2.4s ease-in-out infinite;
    }
    @@keyframes blink {
        0%,100%

    {
        opacity: 1
    }

    50% {
        opacity: .4
    }

    }

    /* ── KPI CARDS ── */
    .inv-kpis {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .875rem;
        margin-bottom: 1.75rem;
    }

    .inv-kpi {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.35rem 1.5rem;
        box-shadow: var(--shadow);
    }

    .kpi-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-4);
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: 10px;
    }

    .kpi-val {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: -.6px;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

        .kpi-val .u {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-4);
            margin-left: 3px;
        }

    .kpi-sub {
        font-size: 12px;
        color: var(--text-3);
        margin-top: 6px;
    }

    /* ── SECTION ── */
    .inv-section {
        margin-bottom: 1.75rem;
    }

    .inv-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .75rem;
    }

    .inv-section-left {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .section-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-1);
    }

    .section-pill {
        font-size: 11px;
        font-weight: 500;
        background: var(--accent-bg);
        color: var(--accent);
        border: 1px solid var(--accent-bd);
        border-radius: 20px;
        padding: 2px 9px;
    }

    .section-total {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-2);
        font-variant-numeric: tabular-nums;
    }

    /* ── TABLE ── */
    .inv-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .inv-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .inv-tbl thead tr {
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        .inv-tbl thead th {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-4);
            text-transform: uppercase;
            letter-spacing: .07em;
            padding: 11px 20px;
            text-align: left;
        }

            .inv-tbl thead th.right {
                text-align: right;
            }

        .inv-tbl tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .inv-tbl tbody tr:last-child {
                border-bottom: none;
            }

            .inv-tbl tbody tr:hover {
                background: var(--surface-2);
            }

        .inv-tbl td {
            padding: 15px 20px;
            vertical-align: middle;
        }

    /* rank */
    .td-num {
        width: 48px;
    }

    .row-num {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-4);
        width: 26px;
        height: 26px;
        border-radius: 6px;
        background: var(--bg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* type */
    .milk-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-1);
    }

    .milk-meta {
        font-size: 11.5px;
        color: var(--text-4);
        margin-top: 3px;
    }

    /* status */
    .td-status {
        width: 130px;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 500;
        background: var(--green-bg);
        color: var(--green);
        border: 1px solid var(--green-bd);
        border-radius: 20px;
        padding: 3px 10px;
    }

        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #17B26A;
            flex-shrink: 0;
        }

    /* qty */
    .td-qty {
        text-align: right;
    }

    .qty-num {
        font-size: 17px;
        font-weight: 700;
        color: var(--text-1);
        font-variant-numeric: tabular-nums;
        letter-spacing: -.3px;
    }

        .qty-num .u {
            font-size: 11px;
            font-weight: 500;
            color: var(--text-4);
            margin-left: 3px;
        }

    /* table footer */
    .tbl-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 20px;
        background: var(--surface-2);
        border-top: 1px solid var(--border);
    }

    .tbl-foot-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-3);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .tbl-foot-val {
        font-size: 15px;
        font-weight: 700;
        color: var(--accent);
        font-variant-numeric: tabular-nums;
    }

        .tbl-foot-val .u {
            font-size: 11px;
            font-weight: 500;
            color: var(--text-4);
            margin-left: 3px;
        }

    /* ── EMPTY ── */
    .inv-empty {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 4rem 2rem;
        text-align: center;
        color: var(--text-3);
        font-size: 14px;
    }

    /* ── FOOTER ── */
    .inv-footer {
        margin-top: 2.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 11.5px;
        color: var(--text-4);
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 680px) {
        .inv-kpis

    {
        grid-template-columns: 1fr 1fr;
    }

    .inv-kpi:last-child {
        grid-column: 1/-1;
    }

    .hide-sm {
        display: none;
    }

    }
    @@media (max-width: 440px) {
        .inv-kpis

    {
        grid-template-columns: 1fr;
    }

    .inv-kpi:last-child {
        grid-column: auto;
    }

    }
</style>

<div class="inv">

    <!-- TOP BAR -->
    <div class="inv-topbar">
        <div>
            <div class="inv-page-label">Production · Raw Milk</div>
            <div class="inv-page-title">Milk Inventory</div>
            <div class="inv-page-plant">@plantLabel</div>
        </div>
        <div class="inv-sync-tag">
            <span class="sync-dot"></span>
            Updated @lastSync.ToString("dd MMM yyyy, h:mm tt")
        </div>
    </div>

    <!-- KPI STRIP -->
    <div class="inv-kpis">
        <div class="inv-kpi">
            <div class="kpi-label">Total Inventory</div>
            <div class="kpi-val">@globalTotal.ToString("N0")<span class="u">L</span></div>
            <div class="kpi-sub">All milk types combined</div>
        </div>
        <div class="inv-kpi">
            <div class="kpi-label">Milk Types</div>
            <div class="kpi-val">@totalTypes</div>
            <div class="kpi-sub">Active varieties</div>
        </div>
        <div class="inv-kpi">
            <div class="kpi-label">Last Logged</div>
            <div class="kpi-val" style="font-size:20px;letter-spacing:-.3px;">@lastSync.ToString("dd MMM yyyy")</div>
            <div class="kpi-sub">@lastSync.ToString("h:mm tt")</div>
        </div>
    </div>

    <!-- PLANT SECTIONS -->
    @if (!Model.Any())
    {
        <div class="inv-empty">No inventory records found for @plantLabel.</div>
    }
    else
    {
        @foreach (var plant in grouped)
        {
            decimal plantTotal = plant.Sum(x => x.Quantity);
            var rows = plant.OrderByDescending(x => x.Quantity).ToList();

            <div class="inv-section">
                <div class="inv-section-header">
                    <div class="inv-section-left">
                        <span class="section-name">@plant.Key</span>
                        <span class="section-pill">@plant.Count() types</span>
                    </div>
                    <span class="section-total">@plantTotal.ToString("N0") L</span>
                </div>

                <div class="inv-card">
                    <table class="inv-tbl">
                        <thead>
                            <tr>
                                <th class="hide-sm" style="width:52px;">#</th>
                                <th>Milk Type</th>
                                <th class="hide-sm">Status</th>
                                <th class="right">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < rows.Count; i++)
                            {
                                var milk = rows[i];
                                <tr>
                                    <td class="td-num hide-sm"><div class="row-num">@(i + 1)</div></td>
                                    <td>
                                        <div class="milk-name">@milk.MilkTypeName</div>
                                        <div class="milk-meta">@plant.Key · Raw Milk</div>
                                    </td>
                                    <td class="td-status hide-sm">
                                        <span class="status-badge">Available</span>
                                    </td>
                                    <td class="td-qty">
                                        <span class="qty-num">@milk.Quantity.ToString("N0")<span class="u">L</span></span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="tbl-foot">
                        <span class="tbl-foot-label">Net Total — @plant.Key</span>
                        <span class="tbl-foot-val">@plantTotal.ToString("N0")<span class="u">L</span></span>
                    </div>
                </div>
            </div>
        }
    }

    <!-- FOOTER -->
    <div class="inv-footer">
        <span>© @DateTime.Now.Year Dairy Management System · v1.0</span>
        <span>All quantities in litres (L)</span>
    </div>

</div>
