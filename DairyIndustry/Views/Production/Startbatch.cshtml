@{
    ViewData["Title"] = "Start Production Batch";
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";

}

<h4 class="mb-4">🏭 Start Production Batch</h4>

<div class="card shadow-sm" style="max-width: 550px;">
    <div class="card-header bg-primary text-white"><strong>New Production Batch</strong></div>
    <div class="card-body">
        <form asp-action="StartBatch" method="post">

            <div class="mb-3">
                <label class="form-label">Processing Plant</label>
                <select name="plantId" class="form-select" required>
                    <option value="">-- Select Plant --</option>
                    @foreach (var p in (IEnumerable<DairyIndustry.Models.Admin.PlantModel>)ViewBag.Plants)
                    {
                        <option value="@p.PlantId">@p.PlantName</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Milk Type to Use</label>
                <select name="milkTypeId" class="form-select" required>
                    <option value="">-- Select Milk Type --</option>
                    @foreach (var m in (IEnumerable<DairyIndustry.Models.Admin.MilkTypeModel>)ViewBag.MilkTypes)
                    {
                        <option value="@m.MilkTypeId">@m.MilkTypeName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Product</label>
                <select name="productId" class="form-select" required>
                    <option value="">-- Select Product --</option>
                    @foreach (var p in (IEnumerable<DairyIndustry.Models.Production.ProductModel>)ViewBag.Products)
                    {
                        <option value="@p.ProductId">@p.ProductName (@p.ProductType — @p.Unit)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Milk Used (Litres)</label>
                <input type="number" name="milkUsedQuantity" class="form-control"
                       step="0.01" min="1" placeholder="e.g. 200.00" required />
                <small class="text-muted">Must not exceed available raw milk inventory at selected plant.</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Production Date</label>
                <input type="date" name="productionDate" class="form-control"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Batches" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-success fw-bold">🚀 Start Batch</button>
            </div>

        </form>
    </div>
</div>
