@model List<DairyIndustry.Models.Production.QualityTestModel>
@using DairyIndustry.Models.Production
@{
    ViewData["Title"] = "Quality Tests";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";


    var totalTests = Model.Count;
    var normalCount = Model.Count(t => t.QualityResult == "Normal");
    var deviatedCount = Model.Count(t => t.QualityResult == "Deviated");
    var deviationRate = totalTests > 0 ? Math.Round((decimal)deviatedCount / totalTests * 100, 1) : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* ── Root tokens (match Milk Transfers palette) ───────────────────── */
    .qt2 {
        --c-bg: #f4f6f9;
        --c-surface: #ffffff;
        --c-border: #e5e7eb;
        --c-border-lt: #f3f4f6;
        --c-text: #111827;
        --c-text-2: #374151;
        --c-text-3: #6b7280;
        --c-text-4: #9ca3af;
        --c-accent: #2563eb;
        --c-accent-bg: #eff6ff;
        --c-green: #16a34a;
        --c-green-bg: #f0fdf4;
        --c-green-bd: #bbf7d0;
        --c-red: #dc2626;
        --c-red-bg: #fef2f2;
        --c-red-bd: #fecaca;
        --c-amber: #d97706;
        --c-amber-bg: #fffbeb;
        --c-amber-bd: #fde68a;
        --r: 8px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: 14px;
        color: var(--c-text);
    }

    /* ── Page header ──────────────────────────────────────────────────── */
    .qt2-header {
        margin-bottom: 16px;
    }

        .qt2-header h1 {
            font-size: 22px;
            font-weight: 700;
            color: var(--c-text);
            margin: 0 0 6px;
            letter-spacing: -0.4px;
        }

    .qt2-header-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .qt2-role-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        color: var(--c-accent);
        background: var(--c-accent-bg);
        border: 1px solid #bfdbfe;
        border-radius: 5px;
        padding: 3px 10px;
    }

    .qt2-stat-pill {
        font-size: 12px;
        font-weight: 500;
        color: var(--c-text-3);
        padding: 3px 10px;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: 5px;
    }

        .qt2-stat-pill .pill-num {
            font-weight: 700;
            color: var(--c-text-2);
            margin-right: 2px;
        }

        .qt2-stat-pill.green {
            color: var(--c-green);
            background: var(--c-green-bg);
            border-color: var(--c-green-bd);
        }

        .qt2-stat-pill.red {
            color: var(--c-red);
            background: var(--c-red-bg);
            border-color: var(--c-red-bd);
        }

        .qt2-stat-pill.amber {
            color: var(--c-amber);
            background: var(--c-amber-bg);
            border-color: var(--c-amber-bd);
        }

    /* ── KPI strip ────────────────────────────────────────────────────── */
    .qt2-kpi-strip {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: 16px;
    }

    .qt2-kpi {
        padding: 16px 20px;
        border-right: 1px solid var(--c-border);
    }

        .qt2-kpi:last-child {
            border-right: none;
        }

    .qt2-kpi-label {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--c-text-3);
        margin-bottom: 5px;
    }

    .qt2-kpi-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--c-text);
        letter-spacing: -0.8px;
        line-height: 1;
    }

        .qt2-kpi-value .unit {
            font-size: 13px;
            font-weight: 400;
            color: var(--c-text-3);
            margin-left: 1px;
            letter-spacing: 0;
        }

    .qt2-kpi-sub {
        font-size: 11px;
        color: var(--c-text-3);
        margin-top: 4px;
    }

    /* ── Filter tabs ──────────────────────────────────────────────────── */
    .qt2-tabs {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }

    .qt2-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 500;
        color: var(--c-text-3);
        padding: 6px 14px;
        border-radius: 6px;
        border: 1px solid transparent;
        background: var(--c-surface);
        border-color: var(--c-border);
        cursor: pointer;
        transition: all .15s;
        user-select: none;
    }

        .qt2-tab:hover {
            color: var(--c-text-2);
            border-color: #d1d5db;
        }

        .qt2-tab.active {
            background: var(--c-text);
            color: #fff;
            border-color: var(--c-text);
        }

            .qt2-tab.active.green {
                background: var(--c-green);
                border-color: var(--c-green);
            }

            .qt2-tab.active.red {
                background: var(--c-red);
                border-color: var(--c-red);
            }

    .qt2-tab-count {
        font-size: 11px;
        font-weight: 600;
        background: rgba(255,255,255,.22);
        border-radius: 20px;
        padding: 1px 7px;
        min-width: 20px;
        text-align: center;
        line-height: 1.5;
    }

    .qt2-tab:not(.active) .qt2-tab-count {
        background: var(--c-bg);
        color: var(--c-text-3);
        border: 1px solid var(--c-border);
    }

    /* ── Card wrapper ─────────────────────────────────────────────────── */
    .qt2-card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r);
        overflow: hidden;
    }

    /* ── Table filter row ─────────────────────────────────────────────── */
    .qt2-filter-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid var(--c-border);
        gap: 10px;
        flex-wrap: wrap;
    }

    .qt2-filter-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--c-text-3);
    }

        .qt2-filter-label i {
            font-size: 13px;
        }

    /* ── Table ────────────────────────────────────────────────────────── */
    .qt2-scroll {
        overflow-x: auto;
        max-height: 58vh;
        overflow-y: auto;
    }

        .qt2-scroll::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }

        .qt2-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .qt2-scroll::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

    .qt2-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 920px;
    }

        .qt2-table thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--c-text-3);
            padding: 9px 16px;
            text-align: left;
            background: #fafbfc;
            border-bottom: 1px solid var(--c-border);
            white-space: nowrap;
        }

            .qt2-table thead th.c {
                text-align: center;
            }

            .qt2-table thead th.r {
                text-align: right;
            }

        .qt2-table tbody td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--c-border-lt);
            vertical-align: middle;
            color: var(--c-text-2);
        }

        .qt2-table tbody tr:last-child td {
            border-bottom: none;
        }

        .qt2-table tbody tr:hover td {
            background: #f8faff;
        }

        .qt2-table td.c {
            text-align: center;
        }

        .qt2-table td.r {
            text-align: right;
        }

    /* ── Transfer ID cell ─────────────────────────────────────────────── */
    .qt2-tid {
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 12px;
        font-weight: 600;
        color: var(--c-accent);
        letter-spacing: 0.2px;
    }

    .qt2-tid-sub {
        font-size: 11px;
        color: var(--c-text-3);
        margin-top: 2px;
    }

    /* ── Origin / logistics cell ──────────────────────────────────────── */
    .qt2-center-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text);
    }

    .qt2-logistics {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: var(--c-text-3);
        margin-top: 3px;
    }

        .qt2-logistics i {
            font-size: 10px;
        }

        .qt2-logistics .sep {
            color: #d1d5db;
        }

    /* ── Metric pair cell ─────────────────────────────────────────────── */
    .qt2-metric-pair {
        display: flex;
        align-items: stretch;
    }

    .qt2-metric-half {
        flex: 1;
        padding: 0 10px;
        text-align: center;
    }

        .qt2-metric-half + .qt2-metric-half {
            border-left: 1px solid var(--c-border-lt);
        }

    .qt2-metric-sub {
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        color: var(--c-text-4);
        margin-bottom: 3px;
    }

    .qt2-metric-val {
        font-size: 13px;
        font-weight: 600;
        color: var(--c-text);
        font-variant-numeric: tabular-nums;
    }

        .qt2-metric-val.avg {
            font-size: 12px;
            font-weight: 400;
            color: var(--c-text-3);
        }

        .qt2-metric-val.dev {
            color: var(--c-red);
        }

    .qt2-dev-flag {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        font-size: 10px;
        color: var(--c-red);
        font-weight: 500;
        margin-top: 2px;
    }

    /* ── Result badge ─────────────────────────────────────────────────── */
    .qt2-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

        .qt2-badge.normal {
            background: var(--c-green-bg);
            color: var(--c-green);
            border: 1px solid var(--c-green-bd);
        }

        .qt2-badge.deviated {
            background: var(--c-red-bg);
            color: var(--c-red);
            border: 1px solid var(--c-red-bd);
        }

    .qt2-badge-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    /* ── Action button ────────────────────────────────────────────────── */
    .qt2-action-btn {
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 5px;
        border: 1px solid var(--c-border);
        color: var(--c-text-3);
        background: var(--c-surface);
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .qt2-action-btn:hover {
            background: var(--c-accent-bg);
            border-color: #bfdbfe;
            color: var(--c-accent);
        }

    /* ── Footer / pagination ──────────────────────────────────────────── */
    .qt2-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-top: 1px solid var(--c-border);
        background: #fafbfc;
        flex-wrap: wrap;
        gap: 8px;
    }

    .qt2-footer-info {
        font-size: 12px;
        color: var(--c-text-3);
    }

        .qt2-footer-info strong {
            color: var(--c-text-2);
        }

    .qt2-pagination {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .qt2-pg-btn {
        min-width: 28px;
        height: 28px;
        padding: 0 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 5px;
        border: 1px solid var(--c-border);
        background: var(--c-surface);
        color: var(--c-text-2);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
    }

        .qt2-pg-btn:hover:not(:disabled) {
            background: var(--c-accent-bg);
            border-color: #bfdbfe;
            color: var(--c-accent);
        }

        .qt2-pg-btn.active {
            background: var(--c-accent);
            border-color: var(--c-accent);
            color: #fff;
        }

        .qt2-pg-btn:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    /* ── Empty state ──────────────────────────────────────────────────── */
    .qt2-empty {
        padding: 60px 24px;
        text-align: center;
        color: var(--c-text-3);
        font-size: 13px;
    }

        .qt2-empty i {
            font-size: 32px;
            display: block;
            margin-bottom: 10px;
            color: var(--c-border);
        }

    /* ── Responsive ───────────────────────────────────────────────────── */
    @@media (max-width: 900px) {
        .qt2-kpi-strip {
            grid-template-columns: repeat(3, 1fr);
        }

        .qt2-kpi:nth-child(3) {
            border-right: none;
        }

        .qt2-kpi:nth-child(4), .qt2-kpi:nth-child(5) {
            border-top: 1px solid var(--c-border);
        }
    }

    @@media (max-width: 600px) {
        .qt2-kpi-strip {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="qt2">

    <!-- Page header -->
    <div class="qt2-header">
        <h1>Quality Tests</h1>
        <div class="qt2-header-meta">
            <span class="qt2-role-badge"><i class="bi bi-shield-check"></i> QC Audit View</span>
            <span class="qt2-stat-pill"><span class="pill-num">@totalTests</span> total tests</span>
            @if (normalCount > 0)
            {
                <span class="qt2-stat-pill green"><i class="bi bi-check-circle" style="margin-right:3px;"></i>@normalCount Compliant</span>
            }
            @if (deviatedCount > 0)
            {
                <span class="qt2-stat-pill red"><i class="bi bi-exclamation-circle" style="margin-right:3px;"></i>@deviatedCount Deviated</span>
            }
            @if (deviationRate > 0)
            {
                <span class="qt2-stat-pill @(deviationRate >= 10 ? "red" : deviationRate >= 5 ? "amber" : "")">
                    @deviationRate% deviation rate
                </span>
            }
        </div>
    </div>

    <!-- KPI strip -->
    <div class="qt2-kpi-strip">
        <div class="qt2-kpi">
            <div class="qt2-kpi-label">Total Samples</div>
            <div class="qt2-kpi-value">@totalTests</div>
            <div class="qt2-kpi-sub">Analysed</div>
        </div>
        <div class="qt2-kpi">
            <div class="qt2-kpi-label">Compliant</div>
            <div class="qt2-kpi-value" style="color:var(--c-green);">@normalCount</div>
            <div class="qt2-kpi-sub">Passed quality check</div>
        </div>
        <div class="qt2-kpi">
            <div class="qt2-kpi-label">Deviations</div>
            <div class="qt2-kpi-value" style="color:var(--c-red);">@deviatedCount</div>
            <div class="qt2-kpi-sub">Flagged alerts</div>
        </div>
        <div class="qt2-kpi">
            <div class="qt2-kpi-label">Deviation Rate</div>
            <div class="qt2-kpi-value" style="color:@(deviationRate >= 10 ? "var(--c-red)" : deviationRate >= 5 ? "var(--c-amber)" : "var(--c-green)");">
                @deviationRate<span class="unit">%</span>
            </div>
            <div class="qt2-kpi-sub">Of total samples</div>
        </div>
        <div class="qt2-kpi">
            <div class="qt2-kpi-label">Avg Fat Tested</div>
            <div class="qt2-kpi-value">
                @(Model.Any() && Model.Any(t => t.TestedFat.HasValue)
                                ? Model.Where(t => t.TestedFat.HasValue).Average(t => t.TestedFat!.Value).ToString("F2")
                                : "—")<span class="unit">%</span>
            </div>
            <div class="qt2-kpi-sub">Across all batches</div>
        </div>
    </div>

    <!-- Filter tabs -->
    <div class="qt2-tabs">
        <button class="qt2-tab active" data-filter="all" onclick="filterTable('all', this)">
            <i class="bi bi-list-ul"></i> All
            <span class="qt2-tab-count">@totalTests</span>
        </button>
        <button class="qt2-tab green" data-filter="normal" onclick="filterTable('normal', this)">
            <i class="bi bi-check-circle"></i> Compliant
            <span class="qt2-tab-count">@normalCount</span>
        </button>
        <button class="qt2-tab red" data-filter="deviated" onclick="filterTable('deviated', this)">
            <i class="bi bi-exclamation-circle"></i> Deviated
            <span class="qt2-tab-count">@deviatedCount</span>
        </button>
    </div>

    <!-- Table card -->
    <div class="qt2-card">

        <div class="qt2-filter-bar">
            <div class="qt2-filter-label">
                <i class="bi bi-funnel"></i>
                <span id="filterLabel">Plant transfer quality records</span>
            </div>
        </div>

        <div class="qt2-scroll">
            <table class="qt2-table" id="qualityTable">
                <thead>
                    <tr>
                        <th style="width:110px;">BATCH / REF</th>
                        <th>ORIGIN / LOGISTICS</th>
                        <th style="width:190px;" class="c">FAT CONTENT (%)</th>
                        <th style="width:190px;" class="c">CLR ANALYSIS</th>
                        <th style="width:120px;" class="c">RESULT</th>
                        <th style="width:50px;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @if (!Model.Any())
                    {
                        <tr id="emptyRow">
                            <td colspan="6">
                                <div class="qt2-empty">
                                    <i class="bi bi-clipboard-x"></i>
                                    No quality test records found.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in Model)
                        {
                            <tr class="qt2-row" data-result="@t.QualityResult.ToLower()">
                                <td>
                                    <div class="qt2-tid">T-@t.TransferId</div>
                                    <div class="qt2-tid-sub">@t.TestDate.ToString("dd MMM yy")</div>
                                </td>
                                <td>
                                    <div class="qt2-center-name">@t.CenterName</div>
                                    <div class="qt2-logistics">
                                        <i class="bi bi-truck"></i>
                                        @t.VehicleNumber
                                        <span class="sep">·</span>
                                        @t.PlantName
                                    </div>
                                </td>
                                <td>
                                    <div class="qt2-metric-pair">
                                        <div class="qt2-metric-half">
                                            <div class="qt2-metric-sub">Batch Avg</div>
                                            <div class="qt2-metric-val avg">@t.BatchAvgFat?.ToString("F2")</div>
                                        </div>
                                        <div class="qt2-metric-half">
                                            <div class="qt2-metric-sub">Tested</div>
                                            <div class="qt2-metric-val @(t.IsFatDeviated ? "dev" : "")">
                                                @t.TestedFat?.ToString("F2")
                                            </div>
                                            @if (t.IsFatDeviated)
                                            {
                                                <div class="qt2-dev-flag"><i class="bi bi-arrow-down-short"></i>Low</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="qt2-metric-pair">
                                        <div class="qt2-metric-half">
                                            <div class="qt2-metric-sub">Batch Avg</div>
                                            <div class="qt2-metric-val avg">@t.BatchAvgCLR?.ToString("F2")</div>
                                        </div>
                                        <div class="qt2-metric-half">
                                            <div class="qt2-metric-sub">Tested</div>
                                            <div class="qt2-metric-val @(t.IsCLRDeviated ? "dev" : "")">
                                                @t.TestedCLR?.ToString("F2")
                                            </div>
                                            @if (t.IsCLRDeviated)
                                            {
                                                <div class="qt2-dev-flag"><i class="bi bi-arrow-down-short"></i>Low</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="c">
                                    <span class="qt2-badge @(t.QualityResult == "Normal" ? "normal" : "deviated")">
                                        <span class="qt2-badge-dot"></span>
                                        @t.QualityResult
                                    </span>
                                </td>
                                <td class="c">
                                    <a href="@Url.Action("QualityTestDetail", new { id = t.TransferId })" class="qt2-action-btn" title="View detail">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="qt2-footer">
            <div class="qt2-footer-info" id="paginationInfo">
                Showing <strong id="rangeText">—</strong> of <strong id="totalText">@totalTests</strong>
            </div>
            <div class="qt2-pagination">
                <button class="qt2-pg-btn" id="prevBtn" onclick="changePage(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div id="pageNumbers" style="display:flex;gap:4px;"></div>
                <button class="qt2-pg-btn" id="nextBtn" onclick="changePage(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const PAGE_SIZE   = 15;
    let currentPage   = 1;
    let currentFilter = 'all';
    let visibleRows   = [];

    const allRows = Array.from(document.querySelectorAll('.qt2-row'));

    function filterTable(filter, btn) {
        currentFilter = filter;
        currentPage   = 1;

        // Update tab styles
        document.querySelectorAll('.qt2-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        // Filter label
        const labels = { all: 'Plant transfer quality records', normal: 'Compliant transfers only', deviated: 'Deviated transfers only' };
        document.getElementById('filterLabel').textContent = labels[filter] || '';

        updateTable();
    }

    function updateTable() {
        // Determine visible rows after filter
        if (currentFilter === 'all') {
            visibleRows = allRows;
        } else {
            visibleRows = allRows.filter(r => r.dataset.result === currentFilter);
        }

        const total   = visibleRows.length;
        const totalPg = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage   = Math.min(currentPage, totalPg);

        const start = (currentPage - 1) * PAGE_SIZE;
        const end   = start + PAGE_SIZE;

        // Show/hide all rows
        allRows.forEach(r => r.style.display = 'none');
        visibleRows.forEach((r, i) => {
            r.style.display = (i >= start && i < end) ? '' : 'none';
        });

        // Empty state
        let emptyRow = document.getElementById('emptyRow');
        if (total === 0) {
            if (!emptyRow) {
                const tbody = document.getElementById('tableBody');
                const tr    = document.createElement('tr');
                tr.id       = 'emptyRow';
                tr.innerHTML = `<td colspan="6"><div class="qt2-empty"><i class="bi bi-clipboard-x"></i>No records match this filter.</div></td>`;
                tbody.appendChild(tr);
            }
        } else {
            if (emptyRow) emptyRow.remove();
        }

        // Footer
        document.getElementById('rangeText').textContent = total === 0
            ? '0'
            : `${start + 1}–${Math.min(end, total)}`;
        document.getElementById('totalText').textContent = total;
        document.getElementById('prevBtn').disabled = currentPage === 1;
        document.getElementById('nextBtn').disabled = currentPage === totalPg;

        renderPageNumbers(totalPg);
        document.querySelector('.qt2-scroll').scrollTop = 0;
    }

    function changePage(dir) {
        const total   = visibleRows.length;
        const totalPg = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage   = Math.max(1, Math.min(totalPg, currentPage + dir));
        updateTable();
    }

    function setPage(n) { currentPage = n; updateTable(); }

    function renderPageNumbers(totalPg) {
        const c = document.getElementById('pageNumbers');
        c.innerHTML = '';
        let s = Math.max(1, currentPage - 2);
        let e = Math.min(totalPg, s + 4);
        if (e - s < 4) s = Math.max(1, e - 4);
        for (let i = s; i <= e; i++) {
            const b       = document.createElement('button');
            b.textContent = i;
            b.className   = 'qt2-pg-btn' + (i === currentPage ? ' active' : '');
            b.onclick     = () => setPage(i);
            c.appendChild(b);
        }
    }

    // Init
    if (allRows.length > 0) updateTable();
</script>
