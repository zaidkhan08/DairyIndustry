@model List<DairyIndustry.Models.Production.ProductWastageModel>
@{
    ViewData["Title"] = "Wastage by Batch";
    int batchId = ViewBag.BatchId;
    Layout = "~/Views/Shared/_ProductionLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">🗑️ Wastage for Batch PB-@batchId</h4>
    <div>
        <a asp-action="AddWastage" class="btn btn-danger btn-sm me-2">+ Record Wastage</a>
        <a asp-action="ProductWastage" class="btn btn-outline-secondary btn-sm">← All Wastage</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No wastage recorded for this batch yet.</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body">
                    <p class="mb-1 small">Total Records</p>
                    <h4 class="fw-bold mb-0">@Model.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body">
                    <p class="mb-1 small">Total Wasted</p>
                    <h4 class="fw-bold mb-0">@Model.Sum(x => x.Quantity).ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body">
                    <p class="mb-1 small">Plant</p>
                    <h5 class="fw-bold mb-0">@Model.First().PlantName</h5>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Type</th>
                        <th>Qty Wasted</th>
                        <th>Reason</th>
                        <th>Recorded Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model)
                    {
                        <tr>
                            <td>@w.WastageId</td>
                            <td><strong>@w.ProductName</strong></td>
                            <td><span class="badge bg-info text-dark">@w.ProductType</span></td>
                            <td><span class="text-danger fw-bold">@w.Quantity.ToString("N2") @w.Unit</span></td>
                            <td>@(w.Reason ?? "—")</td>
                            <td>@w.RecordedDate.ToString("dd-MMM-yyyy")</td>
                        </tr>
                    }
                    <tr class="table-secondary fw-bold">
                        <td colspan="3">Total</td>
                        <td>@Model.Sum(x => x.Quantity).ToString("N2")</td>
                        <td colspan="2"></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}
