@model List<DairyIndustry.Models.Production.MilkProcessWastageModel>
@{
    ViewData["Title"] = "Milk Process Wastage";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var qcFailed = Model.Where(w => w.WastageType == "QCFailed").ToList();
    var procWaste = Model.Where(w => w.WastageType == "ProcessWastage").ToList();
    decimal totalQC = qcFailed.Sum(w => w.WastageQuantity);
    decimal totalProc = procWaste.Sum(w => w.WastageQuantity);
    decimal totalAll = Model.Sum(w => w.WastageQuantity);
}

<style>

    .mpw-root {
        font-family: 'DM Sans', sans-serif;
        --ink: #0f172a;
        --ink-muted: #64748b;
        --ink-faint: #94a3b8;
        --surface: #ffffff;
        --surface-2: #f8fafc;
        --surface-3: #f1f5f9;
        --border: #e2e8f0;
        --border-strong: #cbd5e1;
        --accent: #2563eb;
        --accent-light: #eff6ff;
        --danger: #dc2626;
        --danger-light: #fef2f2;
        --danger-mid: #fecaca;
        --warning: #d97706;
        --warning-light: #fffbeb;
        --warning-mid: #fde68a;
        --success: #16a34a;
        --success-light: #f0fdf4;
        --success-mid: #bbf7d0;
        --purple: #7c3aed;
        --purple-light: #f5f3ff;
        --purple-mid: #ddd6fe;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
        --shadow-md: 0 4px 12px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
    }

    /* ── Page header ── */
    .mpw-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .mpw-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -0.4px;
        margin: 0 0 3px;
    }

    .mpw-sub {
        font-size: 13px;
        color: var(--ink-muted);
        margin: 0;
    }

    .mpw-btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 36px;
        padding: 0 14px;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 600;
        color: var(--ink-muted);
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
        font-family: 'DM Sans', sans-serif;
    }

        .mpw-btn-back:hover {
            border-color: var(--border-strong);
            color: var(--ink);
        }

    /* ── Alerts ── */
    .mpw-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 13px 16px;
        border-radius: var(--radius-md);
        font-size: 13.5px;
        font-weight: 500;
        margin-bottom: 18px;
        border: 1px solid;
    }

    .mpw-alert-success {
        background: var(--success-light);
        border-color: var(--success-mid);
        color: var(--success);
    }

    .mpw-alert-danger {
        background: var(--danger-light);
        border-color: var(--danger-mid);
        color: var(--danger);
    }

    .mpw-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: 0.6;
        font-size: 16px;
        padding: 0;
        line-height: 1;
    }

        .mpw-alert-close:hover {
            opacity: 1;
        }

    /* ── Stat cards ── */
    .mpw-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .mpw-stat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 16px;
    }

        .mpw-stat::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        }

        .mpw-stat.qc::after {
            background: var(--danger);
        }

        .mpw-stat.proc::after {
            background: var(--warning);
        }

        .mpw-stat.total::after {
            background: var(--purple);
        }

    .mpw-stat-icon {
        width: 46px;
        height: 46px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .mpw-stat.qc .mpw-stat-icon {
        background: var(--danger-light);
        color: var(--danger);
    }

    .mpw-stat.proc .mpw-stat-icon {
        background: var(--warning-light);
        color: var(--warning);
    }

    .mpw-stat.total .mpw-stat-icon {
        background: var(--purple-light);
        color: var(--purple);
    }

    .mpw-stat-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.55px;
        color: var(--ink-faint);
        margin-bottom: 4px;
    }

    .mpw-stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: -0.5px;
        line-height: 1;
        margin-bottom: 3px;
    }

    .mpw-stat-sub {
        font-size: 12px;
        color: var(--ink-faint);
    }

    /* ── Toolbar ── */
    .mpw-toolbar {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        box-shadow: var(--shadow-sm);
    }

    .mpw-toolbar-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink-faint);
        margin-right: 4px;
    }

    .mpw-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 32px;
        padding: 0 12px;
        border-radius: 20px;
        font-size: 12.5px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        border: 1.5px solid var(--border);
        background: var(--surface);
        color: var(--ink-muted);
        transition: all 0.15s;
    }

        .mpw-filter-btn:hover {
            border-color: var(--border-strong);
            color: var(--ink);
        }

        .mpw-filter-btn.active-all {
            background: var(--accent-light);
            border-color: #bfdbfe;
            color: var(--accent);
        }

        .mpw-filter-btn.active-qc {
            background: var(--danger-light);
            border-color: var(--danger-mid);
            color: var(--danger);
        }

        .mpw-filter-btn.active-proc {
            background: var(--warning-light);
            border-color: var(--warning-mid);
            color: var(--warning);
        }

    .mpw-filter-count {
        background: currentColor;
        color: #fff;
        border-radius: 20px;
        padding: 1px 7px;
        font-size: 11px;
        font-weight: 700;
        opacity: 0.85;
    }

    /* Search */
    .mpw-search {
        margin-left: auto;
        position: relative;
        width: 220px;
    }

        .mpw-search input {
            width: 100%;
            height: 32px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            background: var(--surface-2);
            padding: 0 12px 0 32px;
            font-size: 13px;
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

            .mpw-search input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
                background: var(--surface);
            }

    .mpw-search-icon {
        position: absolute;
        left: 9px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--ink-faint);
        font-size: 13px;
        pointer-events: none;
    }

    /* ── Table card ── */
    .mpw-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .mpw-table-wrap {
        overflow-x: auto;
    }

    .mpw-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .mpw-table thead tr {
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }

        .mpw-table th {
            padding: 11px 14px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.55px;
            color: var(--ink-muted);
            white-space: nowrap;
        }

            .mpw-table th.r, .mpw-table td.r {
                text-align: right;
            }

        .mpw-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.12s;
        }

            .mpw-table tbody tr:last-child {
                border-bottom: none;
            }

            .mpw-table tbody tr:hover {
                background: var(--surface-2);
            }

        .mpw-table td {
            padding: 13px 14px;
            color: var(--ink);
            vertical-align: middle;
        }

    /* Batch cell */
    .mpw-batch-id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--ink);
    }

    .mpw-batch-date {
        font-size: 11.5px;
        color: var(--ink-faint);
        font-family: 'JetBrains Mono', monospace;
        margin-top: 2px;
    }

    .mpw-plant {
        font-size: 13px;
        color: var(--ink);
        font-weight: 500;
    }

    .mpw-milk-type {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 3px 9px;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-muted);
    }

    /* Qty lost */
    .mpw-qty {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        font-weight: 700;
        color: var(--danger);
    }

    /* Type pill */
    .mpw-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
        white-space: nowrap;
    }

    .mpw-pill-qc {
        background: var(--danger-light);
        color: var(--danger);
        border: 1px solid var(--danger-mid);
    }

    .mpw-pill-proc {
        background: var(--warning-light);
        color: var(--warning);
        border: 1px solid var(--warning-mid);
    }

    .mpw-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    /* Reason */
    .mpw-reason {
        font-size: 12.5px;
        color: var(--ink-muted);
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Recorded date */
    .mpw-recorded {
        font-size: 12px;
        color: var(--ink-faint);
        font-family: 'JetBrains Mono', monospace;
        white-space: nowrap;
    }

    /* Tfoot */
    .mpw-tfoot td {
        padding: 12px 14px;
        background: var(--surface-2);
        font-size: 13px;
        font-weight: 700;
        border-top: 1.5px solid var(--border);
    }

    .mpw-total-label {
        text-align: right;
        color: var(--ink-muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .mpw-total-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 15px;
        font-weight: 700;
        color: var(--danger);
    }

    /* Empty */
    .mpw-empty {
        text-align: center;
        padding: 64px 20px;
    }

    .mpw-empty-icon {
        width: 52px;
        height: 52px;
        background: var(--success-light);
        border: 1px solid var(--success-mid);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: var(--success);
        margin-bottom: 14px;
    }

    .mpw-empty-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 6px;
    }

    .mpw-empty-sub {
        font-size: 13px;
        color: var(--ink-muted);
    }

    @@media (max-width: 768px) {
        .mpw-stats {
            grid-template-columns: 1fr 1fr;
        }

            .mpw-stats .mpw-stat.total {
                grid-column: 1 / -1;
            }

        .mpw-search {
            margin-left: 0;
            width: 100%;
        }
    }
</style>

<div class="mpw-root">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="mpw-alert mpw-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="mpw-alert-close" onclick="this.closest('.mpw-alert').remove()">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mpw-alert mpw-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="mpw-alert-close" onclick="this.closest('.mpw-alert').remove()">&times;</button>
        </div>
    }

    <!-- Header -->
    <div class="mpw-header">
        <div>
            <h1 class="mpw-title">Milk Process Wastage</h1>
            <p class="mpw-sub">Raw milk lost during production — QC failures &amp; process losses</p>
        </div>
        <a asp-action="Batches" class="mpw-btn-back">
            <i class="bi bi-arrow-left"></i> Back to Batches
        </a>
    </div>

    <!-- Stats -->
    <div class="mpw-stats">
        <div class="mpw-stat qc">
            <div class="mpw-stat-icon"><i class="bi bi-x-circle-fill"></i></div>
            <div>
                <div class="mpw-stat-label">QC Failed</div>
                <div class="mpw-stat-value">@totalQC.ToString("N2") <span style="font-size:13px;font-weight:500;color:var(--ink-faint)">L</span></div>
                <div class="mpw-stat-sub">@qcFailed.Count event(s)</div>
            </div>
        </div>
        <div class="mpw-stat proc">
            <div class="mpw-stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div>
                <div class="mpw-stat-label">Process Wastage</div>
                <div class="mpw-stat-value">@totalProc.ToString("N2") <span style="font-size:13px;font-weight:500;color:var(--ink-faint)">L</span></div>
                <div class="mpw-stat-sub">@procWaste.Count event(s)</div>
            </div>
        </div>
        <div class="mpw-stat total">
            <div class="mpw-stat-icon"><i class="bi bi-layers-fill"></i></div>
            <div>
                <div class="mpw-stat-label">Total Milk Lost</div>
                <div class="mpw-stat-value">@totalAll.ToString("N2") <span style="font-size:13px;font-weight:500;color:var(--ink-faint)">L</span></div>
                <div class="mpw-stat-sub">@Model.Count total event(s)</div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="mpw-toolbar">
        <span class="mpw-toolbar-label">Filter</span>

        <button class="mpw-filter-btn active-all" id="btnAll" onclick="filterType('all')">
            All
            <span class="mpw-filter-count">@Model.Count</span>
        </button>
        <button class="mpw-filter-btn" id="btnQC" onclick="filterType('QCFailed')">
            <i class="bi bi-x-circle"></i> QC Failed
            <span class="mpw-filter-count">@qcFailed.Count</span>
        </button>
        <button class="mpw-filter-btn" id="btnProc" onclick="filterType('ProcessWastage')">
            <i class="bi bi-exclamation-triangle"></i> Process Wastage
            <span class="mpw-filter-count">@procWaste.Count</span>
        </button>

        <div class="mpw-search">
            <i class="bi bi-search mpw-search-icon"></i>
            <input type="text" id="mpwSearch" placeholder="Search…" oninput="searchTable()">
        </div>
    </div>

    <!-- Table card -->
    <div class="mpw-card">
        @if (!Model.Any())
        {
            <div class="mpw-empty">
                <div class="mpw-empty-icon"><i class="bi bi-check2-circle"></i></div>
                <div class="mpw-empty-title">No wastage recorded</div>
                <div class="mpw-empty-sub">No milk process wastage events have been logged yet.</div>
            </div>
        }
        else
        {
            <div class="mpw-table-wrap">
                <table class="mpw-table" id="mpwTable">
                    <thead>
                        <tr>
                            <th>Batch</th>
                            <th>Plant</th>
                            <th>Milk Type</th>
                            <th class="r">Qty Lost (L)</th>
                            <th>Type</th>
                            <th>Reason</th>
                            <th>Recorded</th>
                        </tr>
                    </thead>
                    <tbody id="mpwTbody">
                        @foreach (var w in Model)
                        {
                            string pillClass = w.WastageType == "QCFailed" ? "mpw-pill-qc" : "mpw-pill-proc";
                            <tr data-type="@w.WastageType">
                                <td>
                                    <div class="mpw-batch-id">PB-@w.ProductionBatchId.ToString("D4")</div>
                                    <div class="mpw-batch-date">@w.ProductionDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td><span class="mpw-plant">@w.PlantName</span></td>
                                <td><span class="mpw-milk-type"><i class="bi bi-droplet"></i>@w.MilkTypeName</span></td>
                                <td class="r"><span class="mpw-qty">@w.WastageQuantity.ToString("N2")</span></td>
                                <td>
                                    <span class="mpw-pill @pillClass">
                                        <span class="mpw-pill-dot"></span>
                                        @w.WastageTypeLabel
                                    </span>
                                </td>
                                <td>
                                    <span class="mpw-reason" title="@w.Reason">
                                        @(string.IsNullOrEmpty(w.Reason) ? "—" : w.Reason)
                                    </span>
                                </td>
                                <td><span class="mpw-recorded">@w.RecordedDate.ToString("dd MMM yy, hh:mm tt")</span></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="mpw-total-label">Total Milk Lost</td>
                            <td class="r mpw-total-value">@totalAll.ToString("N2") L</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        let currentFilter = 'all';

        function filterType(type) {
            currentFilter = type;

            document.getElementById('btnAll').className  = 'mpw-filter-btn' + (type === 'all'            ? ' active-all'  : '');
            document.getElementById('btnQC').className   = 'mpw-filter-btn' + (type === 'QCFailed'       ? ' active-qc'   : '');
            document.getElementById('btnProc').className = 'mpw-filter-btn' + (type === 'ProcessWastage' ? ' active-proc' : '');

            applyFilters();
        }

        function searchTable() { applyFilters(); }

        function applyFilters() {
            const q = document.getElementById('mpwSearch').value.toLowerCase();
            document.querySelectorAll('#mpwTbody tr').forEach(row => {
                const typeMatch  = currentFilter === 'all' || row.dataset.type === currentFilter;
                const searchMatch = !q || row.textContent.toLowerCase().includes(q);
                row.style.display = (typeMatch && searchMatch) ? '' : 'none';
            });
        }
    </script>
}
