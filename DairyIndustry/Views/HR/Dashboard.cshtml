@model DairyIndustry.Models.HRDashboardViewModel
@{
    Layout = "~/Views/Shared/_HRLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    int thisYear = DateTime.Today.Year;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">
            <span class="page-icon"><i class="bi bi-speedometer2"></i></span>
            HR Dashboard
        </h1>
        <p class="page-subtitle">Welcome back — @DateTime.Today.ToString("dddd, dd MMMM yyyy")</p>
    </div>
    <a asp-action="Create" class="btn-hr-primary">
        <i class="bi bi-person-plus-fill"></i> Add Staff
    </a>
</div>

<!-- ── Stat Cards ── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-blue stat-blue">
            <div class="stat-icon stat-icon-blue"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="stat-value">@Model.Summary.TotalStaff</div>
                <div class="stat-label">Total Staff</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-green stat-green">
            <div class="stat-icon stat-icon-green"><i class="bi bi-person-check-fill"></i></div>
            <div>
                <div class="stat-value">@Model.Summary.ActiveStaff</div>
                <div class="stat-label">Active Staff</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-red stat-red">
            <div class="stat-icon stat-icon-red"><i class="bi bi-person-dash-fill"></i></div>
            <div>
                <div class="stat-value">@Model.Summary.InactiveStaff</div>
                <div class="stat-label">Inactive Staff</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-amber stat-amber">
            <div class="stat-icon stat-icon-amber"><i class="bi bi-person-plus-fill"></i></div>
            <div>
                <div class="stat-value">@Model.Summary.NewJoiningThisMonth</div>
                <div class="stat-label">Joined This Month</div>
            </div>
        </div>
    </div>
</div>

<!-- ── Alerts: Anniversaries + New Joinings ── -->
@if (Model.AnniversariesThisMonth.Any() || Model.NewJoiningsThisMonth.Any())
{
    <div class="row g-3 mb-4">
        @if (Model.AnniversariesThisMonth.Any())
        {
            string col = Model.NewJoiningsThisMonth.Any() ? "col-md-6" : "col-12";
            <div class="@col">
                <div class="hr-card h-100">
                    <div class="hr-card-header" style="background:#fffbeb; border-color:#fde68a;">
                        <div class="hch-icon" style="background:#fef3c7; color:#d97706;"><i class="bi bi-award-fill"></i></div>
                        <span style="color:#92400e;">Work Anniversaries — @DateTime.Today.ToString("MMMM yyyy")</span>
                        <span class="ms-auto badge" style="background:#f59e0b;color:#fff;border-radius:20px;font-size:.68rem;padding:4px 10px;">@Model.AnniversariesThisMonth.Count</span>
                    </div>
                    @foreach (var s in Model.AnniversariesThisMonth)
                    {
                        int years = thisYear - s.DOJ!.Value.Year;
                        <div class="d-flex align-items-center gap-3 px-4 py-3" style="border-bottom:1px solid #fef9c3;">
                            @if (!string.IsNullOrEmpty(s.ProfilePhoto))
                            {
                                <img src="@s.ProfilePhoto" class="rounded-circle flex-shrink-0" style="width:38px;height:38px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center" style="width:38px;height:38px;background:#fef3c7;color:#d97706;font-size:1rem;"><i class="bi bi-person-fill"></i></div>
                            }
                            <div class="flex-grow-1">
                                <div style="font-size:.83rem;font-weight:600;color:#0f172a;">@s.FullName</div>
                                <div style="font-size:.72rem;color:#94a3b8;">@s.RoleName</div>
                            </div>
                            <div class="text-end">
                                <span style="background:#fef3c7;color:#92400e;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;">🏆 @years yr@(years > 1 ? "s" : "")</span>
                                <div style="font-size:.68rem;color:#94a3b8;margin-top:3px;">@s.DOJ.Value.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        @if (Model.NewJoiningsThisMonth.Any())
        {
            string col = Model.AnniversariesThisMonth.Any() ? "col-md-6" : "col-12";
            <div class="@col" id="new-joinings-card">
                <div class="hr-card h-100">
                    <div class="hr-card-header" style="background:#f0fdf4; border-color:#bbf7d0;">
                        <div class="hch-icon" style="background:#dcfce7; color:#16a34a;"><i class="bi bi-person-plus-fill"></i></div>
                        <span style="color:#166534;">New Joinings — @DateTime.Today.ToString("MMMM yyyy")</span>
                        <span class="ms-auto badge bg-success" style="border-radius:20px;font-size:.68rem;padding:4px 10px;margin-right:8px;">@Model.NewJoiningsThisMonth.Count</span>
                    </div>
                    <div id="new-joinings-list">
                        @foreach (var s in Model.NewJoiningsThisMonth)
                        {
                            string dismissKey = $"hr_newjoin_{s.StaffId}_{DateTime.Today.Month}_{DateTime.Today.Year}";
                            <div class="d-flex align-items-center gap-3 px-4 py-3 new-join-row"
                                 id="newjoin-@s.StaffId"
                                 data-dismiss-key="@dismissKey"
                                 style="border-bottom:1px solid #f0fdf4;">
                                @if (!string.IsNullOrEmpty(s.ProfilePhoto))
                                {
                                    <img src="@s.ProfilePhoto" class="rounded-circle flex-shrink-0" style="width:38px;height:38px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center" style="width:38px;height:38px;background:#dcfce7;color:#16a34a;font-size:1rem;"><i class="bi bi-person-fill"></i></div>
                                }
                                <div class="flex-grow-1">
                                    <div style="font-size:.83rem;font-weight:600;color:#0f172a;">@s.FullName</div>
                                    <div style="font-size:.72rem;color:#94a3b8;">@s.RoleName</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="text-end">
                                        <span style="background:#dcfce7;color:#166534;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;">✨ New</span>
                                        <div style="font-size:.68rem;color:#94a3b8;margin-top:3px;">@s.DOJ!.Value.ToString("dd MMM yyyy")</div>
                                    </div>
                                    <!-- Dismiss button -->
                                    <button onclick="dismissNewJoin('@s.StaffId', '@dismissKey')"
                                            title="Dismiss this alert"
                                            style="width:26px;height:26px;border-radius:50%;border:1px solid #bbf7d0;
                                                               background:#f0fdf4;color:#94a3b8;font-size:.7rem;cursor:pointer;
                                                               display:flex;align-items:center;justify-content:center;
                                                               flex-shrink:0;transition:all .15s;"
                                            onmouseover="this.style.background='#fee2e2';this.style.borderColor='#fecaca';this.style.color='#dc2626';"
                                            onmouseout="this.style.background='#f0fdf4';this.style.borderColor='#bbf7d0';this.style.color='#94a3b8';">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="hr-card-footer">
                        <a asp-action="Index" class="btn-hr-secondary w-100 justify-content-center" style="font-size:.78rem;">View All Staff <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- ── Inactive Staff Alert ── -->
@if (Model.InactiveStaffList.Any())
{
    <div class="hr-card mb-4">
        <div class="hr-card-header" style="background:#fef2f2; border-color:#fecaca;">
            <div class="hch-icon" style="background:#fee2e2; color:#dc2626;"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <span style="color:#991b1b;">Inactive Staff Requiring Attention</span>
            <span class="ms-auto badge bg-danger" style="border-radius:20px;font-size:.68rem;padding:4px 10px;">@Model.InactiveStaffList.Count</span>
        </div>
        <div>
            @for (int i = 0; i < Model.InactiveStaffList.Count; i++)
            {
                var s = Model.InactiveStaffList[i];
                <div class="d-flex align-items-center gap-3 px-4 py-3 @(i >= 5 ? "inactive-extra d-none" : "")" style="border-bottom:1px solid #fef2f2;">
                    @if (!string.IsNullOrEmpty(s.ProfilePhoto))
                    {
                        <img src="@s.ProfilePhoto" class="rounded-circle flex-shrink-0" style="width:36px;height:36px;object-fit:cover;filter:grayscale(1);opacity:.6;" />
                    }
                    else
                    {
                        <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fee2e2;color:#ef4444;font-size:.9rem;"><i class="bi bi-person-fill"></i></div>
                    }
                    <div class="flex-grow-1">
                        <div style="font-size:.83rem;font-weight:600;color:#64748b;">@s.FullName</div>
                        <div style="font-size:.72rem;color:#94a3b8;">@s.RoleName</div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge-inactive">Inactive</span>
                        <a asp-action="Details" asp-route-id="@s.StaffId" class="btn-hr-secondary" style="padding:5px 12px;font-size:.72rem;">
                            <i class="bi bi-eye"></i> View
                        </a>
                    </div>
                </div>
            }
        </div>
        @if (Model.InactiveStaffList.Count > 5)
        {
            <div class="text-center py-2" style="border-top:1px solid #fef2f2;">
                <button class="btn btn-link btn-sm text-danger text-decoration-none" id="show-all-inactive" onclick="toggleInactive()" style="font-size:.78rem;">
                    <i class="bi bi-chevron-down me-1"></i>Show all @Model.InactiveStaffList.Count inactive staff
                </button>
            </div>
        }
        <div class="hr-card-footer d-flex justify-content-between align-items-center">
            <span style="font-size:.75rem;color:#94a3b8;"><i class="bi bi-info-circle me-1"></i>Review and reactivate or remove as needed</span>
            <a asp-action="Index" asp-route-isActive="false" class="btn-hr-secondary" style="font-size:.75rem;padding:6px 14px;">View All Inactive <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
    </div>
}

<!-- ── Staff by Role + Recent Joinings ── -->
<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="hr-card h-100">
            <div class="hr-card-header">
                <div class="hch-icon" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-bar-chart-fill"></i></div>
                Staff by Role
            </div>
            <div class="hr-card-body">
                @if (Model.StaffByType.Any())
                {
                    @foreach (var item in Model.StaffByType)
                    {
                        int pct = Model.Summary.TotalStaff > 0 ? (int)((item.Count * 100.0) / Model.Summary.TotalStaff) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span style="font-size:.8rem;font-weight:500;color:#0f172a;">@item.StaffType</span>
                                <span style="font-size:.75rem;font-weight:700;color:#2563eb;">@item.Count</span>
                            </div>
                            <div class="hr-progress">
                                <div class="hr-progress-bar" style="width:@pct%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-bar-chart empty-state-icon"></i><div class="empty-state-title">No data yet</div></div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="hr-card h-100">
            <div class="hr-card-header">
                <div class="hch-icon" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-person-lines-fill"></i></div>
                Recently Joined
            </div>
            @if (Model.RecentJoinings.Any())
            {
                @foreach (var s in Model.RecentJoinings)
                {
                    <div class="d-flex align-items-center gap-3 px-4 py-3" style="border-bottom:1px solid #f8fafc;">
                        @if (!string.IsNullOrEmpty(s.ProfilePhoto))
                        {
                            <img src="@s.ProfilePhoto" class="rounded-circle flex-shrink-0" style="width:40px;height:40px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:#eff6ff;color:#2563eb;font-size:1rem;"><i class="bi bi-person-fill"></i></div>
                        }
                        <div class="flex-grow-1">
                            <div style="font-size:.83rem;font-weight:600;color:#0f172a;">@s.FullName</div>
                            <div style="font-size:.72rem;color:#94a3b8;">@s.RoleName</div>
                        </div>
                        <div class="text-end">
                            <span class="@(s.IsActive ? "badge-active" : "badge-inactive")">@s.StatusLabel</span>
                            <div style="font-size:.68rem;color:#94a3b8;margin-top:3px;">@(s.DOJ.HasValue? s.DOJ.Value.ToString("dd MMM yyyy") : "—")</div>
                        </div>
                    </div>
                }
                <div class="hr-card-footer">
                    <a asp-action="Index" class="btn-hr-secondary w-100 justify-content-center" style="font-size:.78rem;">View All Staff <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            }
            else
            {

                <div class="empty-state"><i class="bi bi-people empty-state-icon"></i><div class="empty-state-title">No recent joinings</div></div>
            }
        </div>
    </div>
</div>

<!-- ── Pending Payments + Quick Nav ── -->
<div class="row g-3">
    <div class="col-md-4">
        <div class="hr-card h-100">
            <div class="hr-card-header" style="background:#fffbeb;border-color:#fde68a;">
                <div class="hch-icon" style="background:#fef3c7;color:#d97706;"><i class="bi bi-cash-coin"></i></div>
                <span style="color:#92400e;">Pending Payments</span>
            </div>
            <div class="hr-card-body text-center py-4">
                <div style="font-size:2.5rem;font-weight:900;color:#d97706;letter-spacing:-.04em;">@Model.Summary.PendingPaymentsCount</div>
                <div style="font-size:.78rem;color:#94a3b8;margin-bottom:12px;">payments awaiting processing</div>
                <div style="font-size:1.2rem;font-weight:800;color:#0f172a;">₹@Model.Summary.PendingPaymentsAmount.ToString("N0")</div>
                <div style="font-size:.72rem;color:#94a3b8;">total pending amount</div>
            </div>
            <div class="hr-card-footer">
                <a asp-action="Payments" asp-route-status="Pending"
                   class="d-flex align-items-center justify-content-center gap-2 w-100 py-2 px-4 rounded-3 fw-semibold"
                   style="background:#fef3c7;color:#92400e;text-decoration:none;font-size:.8rem;border:1px solid #fde68a;transition:all .15s;"
                   onmouseover="this.style.background='#fde68a'" onmouseout="this.style.background='#fef3c7'">
                    View Pending <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="hr-card h-100">
            <div class="hr-card-header">
                <div class="hch-icon" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-grid-fill"></i></div>
                Quick Navigation
            </div>
            <div class="hr-card-body">
                <div class="row g-3">
                    @{
                        var navItems = new[]
                        {
                                        new { Action="Index",   Route=(string?)null,  Icon="bi-people-fill",      Label="All Staff",    Color="#eff6ff", TextColor="#1d4ed8", BorderColor="#bfdbfe" },
                                        new { Action="Create",  Route=(string?)null,  Icon="bi-person-plus-fill", Label="Add Staff",    Color="#f0fdf4", TextColor="#166534", BorderColor="#bbf7d0" },
                                        new { Action="Payments",Route=(string?)null,  Icon="bi-cash-stack",       Label="All Payments", Color="#fffbeb", TextColor="#92400e", BorderColor="#fde68a" },
                                        new { Action="Payments",Route="Pending",      Icon="bi-hourglass-split",  Label="Pending Pay",  Color="#fef2f2", TextColor="#991b1b", BorderColor="#fecaca" },
                                        };
                    }
                    @foreach (var nav in navItems)
                    {
                        <div class="col-6">
                            @if (nav.Route != null)
                            {
                                <a asp-action="@nav.Action" asp-route-isActive="@nav.Route"
                                   class="d-flex flex-column align-items-center justify-content-center py-3 px-2 rounded-3 text-decoration-none"
                                   style="background:@nav.Color;border:1px solid @nav.BorderColor;color:@nav.TextColor;transition:all .15s;gap:6px;"
                                   onmouseover="this.style.opacity='.8';this.style.transform='translateY(-2px)'"
                                   onmouseout="this.style.opacity='1';this.style.transform='translateY(0)'">
                                    <i class="bi @nav.Icon" style="font-size:1.4rem;"></i>
                                    <span style="font-size:.75rem;font-weight:600;">@nav.Label</span>
                                </a>
                            }
                            else
                            {
                                <a asp-action="@nav.Action"
                                   class="d-flex flex-column align-items-center justify-content-center py-3 px-2 rounded-3 text-decoration-none"
                                   style="background:@nav.Color;border:1px solid @nav.BorderColor;color:@nav.TextColor;transition:all .15s;gap:6px;"
                                   onmouseover="this.style.opacity='.8';this.style.transform='translateY(-2px)'"
                                   onmouseout="this.style.opacity='1';this.style.transform='translateY(0)'">
                                    <i class="bi @nav.Icon" style="font-size:1.4rem;"></i>
                                    <span style="font-size:.75rem;font-weight:600;">@nav.Label</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleInactive() {
            var extras = document.querySelectorAll('.inactive-extra');
            var btn    = document.getElementById('show-all-inactive');
            var hidden = extras[0] && extras[0].classList.contains('d-none');
            extras.forEach(function(el){ el.classList.toggle('d-none', !hidden); });
            btn.innerHTML = hidden
                ? '<i class="bi bi-chevron-up me-1"></i>Show less'
                : '<i class="bi bi-chevron-down me-1"></i>Show all @Model.InactiveStaffList.Count inactive staff';
        }

        // ── New Joining Dismiss Logic ──────────────────────────────────
        // On page load — hide any rows that were previously dismissed
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.new-join-row').forEach(function (row) {
                var key = row.getAttribute('data-dismiss-key');
                if (key && localStorage.getItem(key) === 'dismissed') {
                    row.style.display = 'none';
                }
            });
            checkNewJoinsEmpty();
        });

        // Dismiss a specific staff's new joining alert
        function dismissNewJoin(staffId, key) {
            // Save dismissed state to localStorage
            localStorage.setItem(key, 'dismissed');

            // Hide the row with smooth animation
            var row = document.getElementById('newjoin-' + staffId);
            if (row) {
                row.style.transition = 'opacity .2s, max-height .3s';
                row.style.opacity    = '0';
                row.style.overflow   = 'hidden';
                setTimeout(function () {
                    row.style.maxHeight = '0';
                    row.style.padding   = '0';
                    setTimeout(function () {
                        row.style.display = 'none';
                        checkNewJoinsEmpty();
                    }, 300);
                }, 200);
            }
        }

        // Hide the entire New Joinings card if all rows are dismissed
        function checkNewJoinsEmpty() {
            var card    = document.getElementById('new-joinings-card');
            var rows    = document.querySelectorAll('.new-join-row');
            var visible = 0;
            rows.forEach(function (r) {
                if (r.style.display !== 'none') visible++;
            });
            if (card && visible === 0) {
                card.style.transition = 'opacity .3s';
                card.style.opacity    = '0';
                setTimeout(function () { card.style.display = 'none'; }, 300);
            }
        }
    </script>
}
