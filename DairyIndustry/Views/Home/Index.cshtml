@model DairyIndustry.Models.ViewModels.LandingStatsModel

@{
    ViewData["Title"] = "DairyFlow — Farm to Table";
    Layout = null;

    if (Model == null)
    {
        <h2 style="padding:40px;font-family:sans-serif;">
            Model data not available.
        </h2>
        ;
        return;
    }

    var todayMilk =
        Model.TodayMilkCollection >= 1000
            ? (Model.TodayMilkCollection / 1000m).ToString("N1") + "K"
            : Model.TodayMilkCollection.ToString("N0");

    var monthMilk =
        Model.TotalMilkThisMonth >= 1000
            ? (Model.TotalMilkThisMonth / 1000m).ToString("N1") + "K"
            : Model.TotalMilkThisMonth.ToString("N0");

    var revenue =
        Model.RevenueThisMonth >= 100000
            ? "₹" + (Model.RevenueThisMonth / 100000m).ToString("N1") + "L"
            : "₹" + Model.RevenueThisMonth.ToString("N0");

    var pendingPayments =
        Model.PendingPayments >= 100000
            ? "₹" + (Model.PendingPayments / 100000m).ToString("N1") + "L"
            : "₹" + Model.PendingPayments.ToString("N0");

    var features = new[]
    {
        "Real-time milk collection tracking",
        "Automated rate calculation & receipts",
        "End-to-end payment processing via Stripe",
        "Transfer logistics & quality testing",
        "Sales order management for distributors",
        "Role-based access for every team member"
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>DairyFlow — Farm to Table Management</title>

    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />

    <style>

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --navy: #0a1628;
            --navy-mid: #0f2044;
            --navy-soft: #162850;
            --blue: #1e40af;
            --blue-mid: #2563eb;
            --accent: #38bdf8;
            --white: #ffffff;
            --off-white: #f0f4ff;
            --text-dim: #94a3b8;
            --text-mid: #cbd5e1;
            --border: rgba(255,255,255,0.08);
            --card-bg: rgba(255,255,255,0.04);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Sora',sans-serif;
            background: var(--navy);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                background-image: radial-gradient(circle at 20% 20%, rgba(37,99,235,0.15) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(56,189,248,0.08) 0%, transparent 50%), radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
                background-size: 100% 100%,100% 100%,32px 32px;
            }

        /* NAV */

        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 3rem;
            height: 64px;
            background: rgba(10,22,40,0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo-mark {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg,var(--blue-mid),var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            box-shadow: 0 0 20px rgba(56,189,248,0.3);
        }

        .logo-name {
            font-family: 'Lora',serif;
            font-size: 1.35rem;
            font-weight: 600;
            color: var(--white);
        }

            .logo-name span {
                color: var(--accent);
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-btn {
            padding: 0.45rem 1.1rem;
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            border: none;
            font-family: inherit;
            transition: all .2s;
        }

        .nav-btn-ghost {
            background: transparent;
            color: var(--text-mid);
            border: 1px solid var(--border);
        }

            .nav-btn-ghost:hover {
                background: var(--card-bg);
                color: var(--white);
            }

        .nav-btn-primary {
            background: var(--blue-mid);
            color: var(--white);
            border: 1px solid rgba(37,99,235,0.5);
        }

            .nav-btn-primary:hover {
                background: #1d4ed8;
            }

        /* HERO */

        .hero {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 100px 2rem 4rem;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            border: 1px solid rgba(56,189,248,0.3);
            border-radius: 50px;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--accent);
            margin-bottom: 2rem;
            background: rgba(56,189,248,0.06);
        }

        .hero-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent);
        }

        .hero-title {
            font-family: 'Lora',serif;
            font-size: clamp(2.8rem,6vw,5rem);
            font-weight: 600;
            line-height: 1.12;
            margin-bottom: 1.5rem;
        }

            .hero-title em {
                font-style: italic;
                background: linear-gradient(90deg,var(--blue-mid),var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .hero-sub {
            font-size: 1rem;
            color: var(--text-dim);
            max-width: 520px;
            margin: 0 auto 3rem;
        }

        .hero-cta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-hero-primary,
        .btn-hero-ghost {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.8rem 2rem;
            border-radius: 10px;
            text-decoration: none;
            transition: all .2s;
        }

        .btn-hero-primary {
            background: linear-gradient(135deg,var(--blue-mid),#3b82f6);
            color: #fff;
        }

        .btn-hero-ghost {
            background: var(--card-bg);
            color: var(--text-mid);
            border: 1px solid var(--border);
        }

        /* STATS */

        .stats-strip {
            position: relative;
            z-index: 1;
            padding: 0 2rem 5rem;
        }

        .stats-inner {
            max-width: 1180px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
        }

        .stat-cell {
            background: var(--navy-mid);
            padding: 1.8rem 1.5rem;
            text-align: center;
        }

        .stat-value {
            font-size: 1.9rem;
            font-weight: 700;
        }

        .stat-label {
            font-size: 0.72rem;
            color: var(--text-dim);
        }

        .stat-blue {
            color: #60a5fa;
        }

        .stat-green {
            color: #34d399;
        }

        .stat-yellow {
            color: #fbbf24;
        }

        .stat-accent {
            color: var(--accent);
        }

        /* PORTALS */

        .portals {
            position: relative;
            z-index: 1;
            padding: 2rem 2rem 5rem;
        }

        .section-label {
            text-align: center;
            color: var(--text-dim);
            margin-bottom: 1rem;
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            margin-bottom: 3rem;
        }

            .section-title span {
                background: linear-gradient(90deg,var(--blue-mid),var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .portals-grid {
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px;
        }

        .portal-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            text-decoration: none;
            transition: all .25s;
        }

            .portal-card:hover {
                transform: translateY(-4px);
            }

        .portal-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin: 1rem 0;
            color: #fff;
        }

        .portal-desc {
            color: var(--text-dim);
            font-size: 0.85rem;
        }

        /* LOGIN */

        .login-section {
            padding: 2rem 2rem 5rem;
        }

        .login-wrap {
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
        }

        .login-panel {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
        }

        .form-tabs {
            display: flex;
            gap: 4px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 4px;
            margin-bottom: 1.5rem;
        }

        .tab-btn {
            flex: 1;
            padding: 0.55rem;
            border: none;
            border-radius: 7px;
            background: transparent;
            color: var(--text-dim);
            cursor: pointer;
        }

            .tab-btn.active {
                background: var(--blue-mid);
                color: #fff;
            }

        .form-pane {
            display: none;
        }

            .form-pane.active {
                display: block;
            }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            display: block;
            margin-bottom: 6px;
            font-size: 0.75rem;
            color: var(--text-dim);
        }

        .form-input {
            width: 100%;
            padding: 0.7rem 0.95rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 9px;
            color: #fff;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .btn-submit {
            width: 100%;
            padding: 0.8rem;
            background: linear-gradient(135deg,var(--blue-mid),#3b82f6);
            border: none;
            border-radius: 9px;
            color: #fff;
            cursor: pointer;
        }

        .form-error {
            color: #f87171;
            font-size: 0.72rem;
            margin-top: 4px;
            display: none;
        }

            .form-error.show {
                display: block;
            }

        .invalid {
            border-color: #f87171;
        }

        /* FOOTER */

        footer {
            border-top: 1px solid var(--border);
            padding: 1.5rem 3rem;
            display: flex;
            justify-content: space-between;
            color: var(--text-dim);
        }

        /* RESPONSIVE */

        @@media(max-width:900px) {

            .stats-inner {
                grid-template-columns: repeat(2,1fr);
            }

            .portals-grid {
                grid-template-columns: 1fr;
            }

            .login-wrap {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:600px) {

            nav {
                padding: 0 1rem;
            }

            .stats-inner {
                grid-template-columns: 1fr;
            }

            .form-row {
                grid-template-columns: 1fr;
            }
        }

    </style>
</head>

<body>

    <nav>
        <a href="/" class="logo">
            <div class="logo-mark">🥛</div>
            <span class="logo-name">Dairy<span>Flow</span></span>
        </a>

        <div class="nav-links">
            <a href="#portals" class="nav-btn nav-btn-ghost">Portals</a>

            <a href="#login-section"
               class="nav-btn nav-btn-ghost"
               onclick="switchTab('login')">
                Staff Login
            </a>

            <a href="#login-section"
               class="nav-btn nav-btn-primary"
               onclick="switchTab('driver')">
                Driver Register
            </a>
        </div>
    </nav>

    <section class="hero">

        <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Live Operations · @(DateTime.Now.ToString("dd MMM yyyy"))
        </div>

        <h1 class="hero-title">
            Dairy operations,<br />
            <em>intelligently</em> managed.
        </h1>

        <p class="hero-sub">
            One platform connecting farmers, collection centers,
            processing plants, drivers and distributors.
        </p>

        <div class="hero-cta">

            <a href="#login-section"
               class="btn-hero-primary"
               onclick="switchTab('login')">
                🔐 Sign In
            </a>

            <a href="#portals" class="btn-hero-ghost">
                View Portals ↓
            </a>

        </div>

    </section>

    <section class="stats-strip">

        <div class="stats-inner">

            <div class="stat-cell">
                <div class="stat-value stat-blue">@Model.ActivePlants</div>
                <div class="stat-label">Active Plants</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-blue">@Model.ActiveCenters</div>
                <div class="stat-label">Collection Centers</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-green">@Model.ActiveFarmers</div>
                <div class="stat-label">Farmers</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-green">@Model.ActiveStaff</div>
                <div class="stat-label">Staff</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-accent">@todayMilk</div>
                <div class="stat-label">Today's Collection</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-green">@monthMilk</div>
                <div class="stat-label">Monthly Collection</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-green">@revenue</div>
                <div class="stat-label">Revenue</div>
            </div>

            <div class="stat-cell">
                <div class="stat-value stat-yellow">@pendingPayments</div>
                <div class="stat-label">Pending Payments</div>
            </div>

        </div>

    </section>

    <section class="portals" id="portals">

        <div class="section-label">Access Portals</div>

        <h2 class="section-title">
            Your gateway to <span>DairyFlow</span>
        </h2>

        <div class="portals-grid">

            <a href="#login-section"
               class="portal-card"
               onclick="switchTab('login')">

                <div class="portal-title">
                    🔑 Staff & Admin Login
                </div>

                <div class="portal-desc">
                    Access management dashboards and operations.
                </div>

            </a>

            <a href="/Farmer" class="portal-card">

                <div class="portal-title">
                    👨‍🌾 Farmer Portal
                </div>

                <div class="portal-desc">
                    View collections, receipts and payments.
                </div>

            </a>

            <a href="#login-section"
               class="portal-card"
               onclick="switchTab('driver')">

                <div class="portal-title">
                    🚛 Driver Registration
                </div>

                <div class="portal-desc">
                    Register as DairyFlow logistics driver.
                </div>

            </a>

        </div>

    </section>

    <section class="login-section" id="login-section">

        <div class="login-wrap">

            <div class="login-left">

                <h2>
                    Access your dashboard
                </h2>

                <div class="feature-list">

                    @foreach (var f in features)
                    {
                        <div style="margin-bottom:10px;">
                            ✅ @f
                        </div>
                    }

                </div>

            </div>

            <div class="login-panel">

                <div class="form-tabs">

                    <button type="button"
                            class="tab-btn active"
                            onclick="switchTab('login')"
                            id="tab-login">
                        Login
                    </button>

                    <button type="button"
                            class="tab-btn"
                            onclick="switchTab('driver')"
                            id="tab-driver">
                        Driver
                    </button>

                </div>

                <!-- LOGIN -->

                <div class="form-pane active" id="pane-login">

                    <form method="post"
                          action="/Admin/Login"
                          id="loginForm"
                          novalidate>

                        @Html.AntiForgeryToken()

                        <div class="form-group">

                            <label class="form-label">
                                Username
                            </label>

                            <input type="text"
                                   name="username"
                                   id="login-username"
                                   class="form-input">

                            <div class="form-error"
                                 id="err-login-username">
                                Username required.
                            </div>

                        </div>

                        <div class="form-group">

                            <label class="form-label">
                                Password
                            </label>

                            <input type="password"
                                   name="password"
                                   id="login-password"
                                   class="form-input">

                            <div class="form-error"
                                 id="err-login-password">
                                Password required.
                            </div>

                        </div>

                        <button type="submit"
                                class="btn-submit"
                                id="loginBtn">
                            🔐 Sign In
                        </button>

                    </form>

                </div>

                <!-- DRIVER -->

                <div class="form-pane" id="pane-driver">

                    <form method="post"
                          action="/Logistics/RegisterDriver"
                          id="driverForm"
                          novalidate>

                        @Html.AntiForgeryToken()

                        <div class="form-group">

                            <label class="form-label">
                                Full Name
                            </label>

                            <input type="text"
                                   id="d-name"
                                   class="form-input">

                            <div class="form-error"
                                 id="err-d-name">
                                Name required.
                            </div>

                        </div>

                        <div class="form-group">

                            <label class="form-label">
                                Username
                            </label>

                            <input type="text"
                                   id="d-username"
                                   class="form-input">

                            <div class="form-error"
                                 id="err-d-username">
                                Username required.
                            </div>

                        </div>

                        <div class="form-group">

                            <label class="form-label">
                                Password
                            </label>

                            <input type="password"
                                   id="d-password"
                                   class="form-input">

                            <div class="form-error"
                                 id="err-d-password">
                                Password required.
                            </div>

                        </div>

                        <button type="submit"
                                class="btn-submit">
                            🚛 Register Driver
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </section>

    <footer>

        <div>
            🥛 DairyFlow
        </div>

        <div>
            © @(DateTime.Now.Year)
        </div>

    </footer>

    <script>

        function switchTab(name){

            document.querySelectorAll('.form-pane')
                .forEach(p => p.classList.remove('active'));

            document.querySelectorAll('.tab-btn')
                .forEach(b => b.classList.remove('active'));

            const pane = document.getElementById('pane-' + name);
            const tab  = document.getElementById('tab-' + name);

            if(pane){
                pane.classList.add('active');
            }

            if(tab){
                tab.classList.add('active');
            }
        }

        function validateField(inputId,errorId,condition){

            const input=document.getElementById(inputId);
            const error=document.getElementById(errorId);

            const ok=condition(input.value.trim());

            input.classList.toggle('invalid',!ok);
            error.classList.toggle('show',!ok);

            return ok;
        }

        document.getElementById('loginForm')
        .addEventListener('submit',function(e){

            let ok=true;

            ok = validateField(
                'login-username',
                'err-login-username',
                v => v.length > 0
            ) && ok;

            ok = validateField(
                'login-password',
                'err-login-password',
                v => v.length > 0
            ) && ok;

            if(!ok){
                e.preventDefault();
            }
        });

        document.getElementById('driverForm')
        .addEventListener('submit',function(e){

            let ok=true;

            ok = validateField(
                'd-name',
                'err-d-name',
                v => v.length > 1
            ) && ok;

            ok = validateField(
                'd-username',
                'err-d-username',
                v => v.length > 3
            ) && ok;

            ok = validateField(
                'd-password',
                'err-d-password',
                v => v.length > 5
            ) && ok;

            if(!ok){
                e.preventDefault();
            }
        });

    </script>

</body>
</html>