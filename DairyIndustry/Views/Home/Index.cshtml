@{
    ViewData["Title"] = "DairyFlow — Welcome";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DairyFlow — Pure From Farm to Table</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cream: #fdf6ec;
            --warm-white: #fff9f2;
            --gold: #c8922a;
            --gold-light: #e8b84b;
            --brown: #3d2b1f;
            --brown-mid: #6b4c35;
            --green: #2d6a4f;
            --green-light: #52b788;
            --text-main: #2a1f14;
            --text-muted: #7a6555;
            --border: rgba(200,146,42,0.25);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text-main);
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
                opacity: 0.4;
            }

        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 3rem;
            background: rgba(253,246,236,0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            box-shadow: 0 2px 12px rgba(200,146,42,0.35);
        }

        .nav-logo-text {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--brown);
            letter-spacing: -0.02em;
        }

        .btn-nav-login {
            padding: 0.55rem 1.4rem;
            border: 1.5px solid var(--gold);
            border-radius: 50px;
            background: transparent;
            color: var(--gold);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.25s ease;
        }

            .btn-nav-login:hover {
                background: var(--gold);
                color: #fff;
            }

        .hero {
            position: relative;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            padding-top: 80px;
        }

        .hero-left {
            padding: 5rem 3rem 5rem 5rem;
            z-index: 1;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.8rem, 5vw, 4.2rem);
            font-weight: 900;
            line-height: 1.1;
            color: var(--brown);
            margin-bottom: 1.5rem;
        }

            .hero-title em {
                font-style: italic;
                color: var(--gold);
            }

        .hero-desc {
            font-size: 1.05rem;
            line-height: 1.75;
            color: var(--text-muted);
            max-width: 480px;
            margin-bottom: 2.5rem;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.85rem 2rem;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            color: #fff;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            box-shadow: 0 6px 24px rgba(200,146,42,0.45);
            cursor: pointer;
        }

        .hero-right {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 5rem 4rem 5rem 2rem;
            gap: 1.5rem;
            z-index: 1;
        }

        .register-card {
            width: 100%;
            max-width: 400px;
            background: var(--warm-white);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1.8rem 2rem;
            display: flex;
            align-items: center;
            gap: 1.2rem;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
        }

            .register-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 40px rgba(61,43,31,0.12);
            }

        .card-icon-wrap {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .login-section {
            padding: 6rem 5rem;
            background: linear-gradient(135deg, var(--brown) 0%, #5a3d2b 100%);
        }

        .login-inner {
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 5rem;
            align-items: center;
        }

        /* Left Illustration Panel Style */
        .login-left-panel {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 40px;
            border: 1px solid rgba(255,255,255,0.1);
            position: relative;
            overflow: hidden;
        }

            .login-left-panel h2 {
                color: #fff;
                font-family: 'Playfair Display';
                font-size: 2.5rem;
                margin-bottom: 1rem;
            }

            .login-left-panel p {
                color: rgba(255,255,255,0.7);
                line-height: 1.6;
            }

        .login-card {
            background: var(--cream);
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .form-group {
            margin-bottom: 1.1rem;
        }

        .form-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--brown-mid);
            margin-bottom: 0.4rem;
        }

        .form-control, .form-select, textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid rgba(200,146,42,0.25);
            border-radius: 10px;
            background: var(--warm-white);
            font-family: inherit;
            font-size: 0.9rem;
            outline: none;
        }

            .form-control:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(200,146,42,0.1);
            }

        .btn-login-submit {
            width: 100%;
            padding: 0.9rem;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            color: #fff;
            border: none;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 0.5rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(200,146,42,0.3);
        }

        .alert-box {
            padding: 0.8rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .form-container {
            display: none;
        }

            .form-container.active {
                display: block;
                animation: fadeUp 0.4s ease forwards;
            }

        footer {
            background: var(--brown);
            padding: 2rem 5rem;
            display: flex;
            justify-content: space-between;
            color: rgba(255,255,255,0.5);
            font-size: 0.8rem;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 900px) {
            .hero, .login-inner {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <nav>
        <a href="#" class="nav-logo">
            <div class="nav-logo-icon">🥛</div>
            <span class="nav-logo-text">DairyFlow</span>
        </a>
        <div class="nav-actions">
            <a href="#login-section" class="btn-nav-login" onclick="showForm('login')">Login</a>
        </div>
    </nav>

    <section class="hero">
        <div class="hero-left">
            <div class="hero-badge" style="background:rgba(200,146,42,0.1); padding:5px 15px; border-radius:20px; color:var(--gold); font-size:0.75rem; font-weight:700; display:inline-block; margin-bottom:1rem;">🌿 &nbsp; Farm-to-Table Management</div>
            <h1 class="hero-title">Pure dairy,<br /><em>perfectly</em><br />managed.</h1>
            <p class="hero-desc">Connecting farmers, drivers, and distributors in one seamless industry platform.</p>
            <div class="hero-cta-group">
                <a class="btn-primary" onclick="showForm('login')">🔐 &nbsp; Sign In to Dashboard</a>
            </div>
        </div>

        <div class="hero-right">
            <span style="font-size:0.75rem; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px;">New here? Register as</span>
            <div class="register-card" onclick="showForm('driver')">
                <div class="card-icon-wrap" style="background:#fff3cd">🚛</div>
                <div class="card-content">
                    <div class="card-title" style="font-weight:700;">Register as Driver</div>
                    <div class="card-desc" style="font-size:0.8rem; color:var(--text-muted)">Join the fleet. Admin approval required.</div>
                </div>
            </div>
            <div class="register-card" onclick="showForm('distributor')">
                <div class="card-icon-wrap" style="background:#d1fae5">🏪</div>
                <div class="card-content">
                    <div class="card-title" style="font-weight:700;">Register as Distributor</div>
                    <div class="card-desc" style="font-size:0.8rem; color:var(--text-muted)">Partner with us to distribute fresh products.</div>
                </div>
            </div>
        </div>
    </section>

    <section class="login-section" id="login-section">
        <div class="login-inner">

            <div class="login-left-panel">
                <div style="font-size:1.2rem; font-weight:700; color:var(--gold-light); margin-bottom:2rem;">Dairy Industry</div>
                <h2 id="form-context-title">Secure Login</h2>
                <p id="form-context-desc">Access your dedicated management dashboard to oversee operations and track inventory in real-time.</p>

                <div style="margin-top:3rem; opacity:0.2;">
                    <svg width="200" height="150" viewBox="0 0 200 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="20" y="20" width="100" height="120" rx="10" stroke="white" stroke-width="2" />
                        <circle cx="150" cy="70" r="30" stroke="white" stroke-width="2" />
                        <line x1="20" y1="50" x2="120" y2="50" stroke="white" stroke-width="2" />
                    </svg>
                </div>
            </div>

            <div class="login-card">
                @if (ViewBag.Error != null)
                {
                    <div class="alert-box alert-error">⚠️ @ViewBag.Error</div>
                }

                <div id="login-form" class="form-container active">
                    <div style="font-size:1.5rem; font-weight:700; color:var(--brown); margin-bottom:0.5rem; font-family:'Playfair Display';">Login</div>
                    <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:2rem;">Welcome back!</div>
                    <form method="post" action="/Admin/Login">
                        <div class="form-group">
                            <label class="form-label">Username</label>
                            <input class="form-control" type="text" name="username" placeholder="Username" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Password</label>
                            <input class="form-control" type="password" name="password" placeholder="Password" required />
                        </div>
                        <button type="submit" class="btn-login-submit">LOG IN</button>
                    </form>
                </div>

                <div id="driver-form" class="form-container">
                    <div style="font-size:1.5rem; font-weight:700; color:var(--brown); margin-bottom:0.5rem; font-family:'Playfair Display';">Driver Registration</div>
                    <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:1.5rem;">Join our logistics network</div>
                    <form method="post" action="/Logistics/RegisterDriver">
                        <div class="form-group">
                            <label class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="driverName" class="form-control" placeholder="Enter your full name" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">License Number <span class="text-danger">*</span></label>
                            <input type="text" name="licenseNo" class="form-control" placeholder="e.g. GJ05 2024 001234" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Phone</label>
                            <input type="text" name="phone" class="form-control" placeholder="Enter phone number" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Username <span class="text-danger">*</span></label>
                            <input type="text" name="username" class="form-control" placeholder="Choose a username" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="password" name="password" class="form-control" placeholder="Choose a password" required />
                        </div>
                        <button type="submit" class="btn-login-submit">Register</button>
                        <button type="button" class="btn-login-submit" style="background:#7a6555; margin-top:10px;" onclick="showForm('login')">Cancel</button>
                    </form>
                </div>

                <div id="distributor-form" class="form-container">
                    <div style="font-size:1.5rem; font-weight:700; color:var(--brown); margin-bottom:0.5rem; font-family:'Playfair Display';">Add Distributor</div>
                    <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:1.5rem;">New Partner Application</div>
                    <form action="/Admin/RegisterDistributor" method="post">
                        <div class="form-group">
                            <label class="form-label">Distributor Name <span class="text-danger">*</span></label>
                            <input type="text" name="DistributorName" class="form-control" placeholder="e.g. Surat Dairy Distributors" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Contact Number</label>
                            <input type="text" name="ContactNumber" class="form-control" placeholder="9265431001" maxlength="15" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" class="form-control" placeholder="distributor@example.com" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Location</label>
                            <input type="text" name="Location" class="form-control" placeholder="Ring Road, Surat" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Full Address</label>
                            <textarea name="Address" rows="2" class="form-control" placeholder="Shop No., Street, City, PIN"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">GSTIN</label>
                            <input type="text" name="GSTIN" class="form-control" placeholder="22AAAAA0000A1Z5" maxlength="20" />
                        </div>
                        <button type="submit" class="btn-login-submit" style="background:var(--green)">Add Distributor</button>
                        <button type="button" class="btn-login-submit" style="background:#7a6555; margin-top:10px;" onclick="showForm('login')">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div>🥛 DairyFlow Management System</div>
        <div>© @DateTime.Now.Year All rights reserved.</div>
    </footer>

    <script>
        function showForm(type) {
            document.querySelectorAll('.form-container').forEach(f => f.classList.remove('active'));
            const title = document.getElementById('form-context-title');
            const desc = document.getElementById('form-context-desc');

            if(type === 'login') {
                document.getElementById('login-form').classList.add('active');
                title.innerText = "Secure Login";
                desc.innerText = "Access your dedicated management dashboard to oversee operations and track inventory in real-time.";
            } else if(type === 'driver') {
                document.getElementById('driver-form').classList.add('active');
                title.innerText = "Join the Fleet";
                desc.innerText = "Register as a driver to manage deliveries and routes. Submissions are reviewed by administrators.";
            } else if(type === 'distributor') {
                document.getElementById('distributor-form').classList.add('active');
                title.innerText = "Partner With Us";
                desc.innerText = "Help us expand our reach. Provide your business details and GSTIN to apply for a distribution partnership.";
            }
            document.getElementById('login-section').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
</body>
</html>