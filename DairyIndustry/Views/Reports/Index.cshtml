@using DairyIndustry.Models.Reports
@{
    ViewData["Title"] = "Reports & Analytics";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var daily = ViewBag.DailySummary as List<DailySummaryModel> ?? new();
    var farmers = ViewBag.FarmerReport as List<FarmerCollectionModel> ?? new();
    var production = ViewBag.Production as List<ProductionSummaryModel> ?? new();
    var wastage = ViewBag.Wastage as List<WastageModel> ?? new();
    var sales = ViewBag.Sales as List<SalesReportModel> ?? new();
}

<div class="bg-dark text-white py-4 px-4 mb-4 shadow-sm">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-bar-chart-fill me-2"></i>Reports & Analytics
            </h4>
            <p class="mb-0 opacity-75 small">
                Live insights across collection, production, sales and wastage.
            </p>
        </div>
        <form method="get" action="/Reports/Index" class="d-flex gap-2 align-items-center flex-wrap">
            <input type="date" name="fromDate" value="@ViewBag.FromDate"
                   class="form-control form-control-sm" style="width:150px;" />
            <span class="text-white small">to</span>
            <input type="date" name="toDate" value="@ViewBag.ToDate"
                   class="form-control form-control-sm" style="width:150px;" />
            <button type="submit" class="btn btn-light btn-sm fw-semibold">
                <i class="bi bi-funnel me-1"></i>Filter
            </button>
        </form>
    </div>
</div>

<div class="container-fluid px-4 pb-5">

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3 border-start border-4 border-primary">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small fw-semibold">Total Collection</div>
                            <div class="fw-bold fs-4">@daily.Sum(d => d.TotalQuantityLtr).ToString("N0") Ltr</div>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center
                                    justify-content-center" style="width:48px; height:48px;">
                            <i class="bi bi-bucket-fill text-primary fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3 border-start border-4 border-success">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small fw-semibold">Total Sales</div>
                            <div class="fw-bold fs-4">₹@sales.Sum(s => s.LineTotal).ToString("N0")</div>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 d-flex align-items-center
                                    justify-content-center" style="width:48px; height:48px;">
                            <i class="bi bi-cart-fill text-success fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3 border-start border-4 border-warning">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small fw-semibold">Farmer Payable</div>
                            <div class="fw-bold fs-4">₹@farmers.Sum(f => f.TotalPayable).ToString("N0")</div>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 d-flex align-items-center
                                    justify-content-center" style="width:48px; height:48px;">
                            <i class="bi bi-people-fill text-warning fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-3 border-start border-4 border-danger">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small fw-semibold">Total Wastage</div>
                            <div class="fw-bold fs-4">@wastage.Sum(w => w.TotalWastage).ToString("N1") Ltr</div>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-3 d-flex align-items-center
                                    justify-content-center" style="width:48px; height:48px;">
                            <i class="bi bi-trash-fill text-danger fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="row g-4 mb-4">

        <!-- Collection by Center Bar Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-bar-chart-fill text-primary"></i>
                    <span class="fw-semibold">Collection by Center</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="collectionChart" height="120"></canvas>
                </div>
            </div>
        </div>

        <!-- Milk Type Pie Chart -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-pie-chart-fill text-success"></i>
                    <span class="fw-semibold">Milk Type Split</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="milkTypeChart" height="200"></canvas>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts Row 2 -->
    <div class="row g-4 mb-4">

        <!-- Production Bar Chart -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-gear-fill text-warning"></i>
                    <span class="fw-semibold">Production — Milk Used per Product</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="productionChart" height="160"></canvas>
                </div>
            </div>
        </div>

        <!-- Wastage Bar Chart -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-trash-fill text-danger"></i>
                    <span class="fw-semibold">Wastage Summary</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="wastageChart" height="160"></canvas>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts Row 3 -->
    <div class="row g-4 mb-4">

        <!-- Sales Line Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-graph-up text-success"></i>
                    <span class="fw-semibold">Sales Revenue by Product</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="salesChart" height="120"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Farmers -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center gap-2">
                    <i class="bi bi-trophy-fill text-warning"></i>
                    <span class="fw-semibold">Top 5 Farmers</span>
                </div>
                <div class="card-body p-3">
                    @{
                        var top5 = farmers.OrderByDescending(f => f.TotalQtyLtr).Take(5).ToList();
                        int rank = 1;
                    }
                    @foreach (var f in top5)
                    {
                        string color = rank switch
                        {
                            1 => "warning",
                            2 => "secondary",
                            3 => "danger",
                            _ => "primary"
                        };
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="bg-@color bg-opacity-10 text-@color rounded-circle d-flex
                                            align-items-center justify-content-center fw-bold flex-shrink-0"
                                 style="width:36px; height:36px; font-size:.85rem;">
                                @rank
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold small">@f.FarmerName</div>
                                <div class="progress mt-1" style="height:5px;">
                                    @{
                                        decimal max = top5.Max(x => x.TotalQtyLtr);
                                        decimal pct = max > 0 ? (f.TotalQtyLtr / max) * 100 : 0;
                                    }
                                    <div class="progress-bar bg-@color" style="width:@pct%"></div>
                                </div>
                            </div>
                            <div class="text-muted small fw-semibold">
                                @f.TotalQtyLtr.ToString("N0") L
                            </div>
                        </div>
                        rank++;
                    }
                    @if (!top5.Any())
                    {
                        <div class="text-center text-muted py-4 small">No data available.</div>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Farmer Collection Table -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-table text-primary"></i>
                <span class="fw-semibold">Farmer Collection Detail</span>
            </div>
            <span class="badge bg-primary px-3">@farmers.Count records</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                            <th class="py-3 text-muted fw-semibold small">Farmer</th>
                            <th class="py-3 text-muted fw-semibold small">Center</th>
                            <th class="py-3 text-muted fw-semibold small">Milk Type</th>
                            <th class="py-3 text-muted fw-semibold small">Qty (Ltr)</th>
                            <th class="py-3 text-muted fw-semibold small">Avg Fat</th>
                            <th class="py-3 text-muted fw-semibold small">Avg CLR</th>
                            <th class="py-3 text-muted fw-semibold small">Payable (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!farmers.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                    No data for selected period.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int sr = 1;
                            foreach (var f in farmers)
                            {
                                <tr>
                                    <td class="px-4 text-muted small">@sr</td>
                                    <td class="fw-semibold small">@f.FarmerName</td>
                                    <td class="small text-muted">@f.CenterName</td>
                                    <td>
                                        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                                            @f.MilkTypeName
                                        </span>
                                    </td>
                                    <td class="fw-semibold small">@f.TotalQtyLtr.ToString("N1")</td>
                                    <td class="small">@f.AvgFat.ToString("F2")</td>
                                    <td class="small">@f.AvgCLR.ToString("F2")</td>
                                    <td class="fw-bold text-success small">₹@f.TotalPayable.ToString("N2")</td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                    @if (farmers.Any())
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="px-4 fw-bold text-end">Total</td>
                                <td class="fw-bold">@farmers.Sum(f => f.TotalQtyLtr).ToString("N1")</td>
                                <td></td>
                                <td></td>
                                <td class="fw-bold text-success">₹@farmers.Sum(f => f.TotalPayable).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    <!-- Sales Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-table text-success"></i>
                <span class="fw-semibold">Sales Detail</span>
            </div>
            <span class="badge bg-success px-3">@sales.Count records</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3 text-muted fw-semibold small">#</th>
                            <th class="py-3 text-muted fw-semibold small">Distributor</th>
                            <th class="py-3 text-muted fw-semibold small">Order Date</th>
                            <th class="py-3 text-muted fw-semibold small">Product</th>
                            <th class="py-3 text-muted fw-semibold small">Qty</th>
                            <th class="py-3 text-muted fw-semibold small">Unit Price</th>
                            <th class="py-3 text-muted fw-semibold small">Line Total</th>
                            <th class="py-3 text-muted fw-semibold small">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!sales.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                    No sales data for selected period.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int sr = 1;
                            foreach (var s in sales)
                            {
                                string statusColor = s.OrderStatus switch
                                {
                                    "Delivered" => "success",
                                    "Dispatched" => "primary",
                                    "Confirmed" => "info",
                                    "Pending" => "warning",
                                    "Cancelled" => "danger",
                                    _ => "secondary"
                                };
                                <tr>
                                    <td class="px-4 text-muted small">@sr</td>
                                    <td class="fw-semibold small">@s.DistributorName</td>
                                    <td class="small text-muted">@s.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td class="small">@s.ProductName</td>
                                    <td class="small">@s.Quantity.ToString("N0")</td>
                                    <td class="small">₹@s.UnitPrice.ToString("N2")</td>
                                    <td class="fw-bold text-success small">₹@s.LineTotal.ToString("N2")</td>
                                    <td>
                                        <span class="badge bg-@statusColor">@s.OrderStatus</span>
                                    </td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                    @if (sales.Any())
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="6" class="px-4 fw-bold text-end">Total Revenue</td>
                                <td class="fw-bold text-success">₹@sales.Sum(s => s.LineTotal).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>

        // ── Data from server ────────────────────────────────

        const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    daily.GroupBy(d => d.CenterName)
                              .Select(g => new { center = g.Key, qty = g.Sum(x => x.TotalQuantityLtr) })
                              .ToList()
            ));

    const milkTypeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                daily.GroupBy(d => d.MilkTypeName)
                          .Select(g => new { type = g.Key, qty = g.Sum(x => x.TotalQuantityLtr) })
                          .ToList()
        ));

    const productionData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                production.GroupBy(p => p.ProductName)
                                    .Select(g => new { product = g.Key, milk = g.Sum(x => x.TotalMilkUsedLtr) })
                                    .ToList()
        ));

    const wastageData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                wastage.Select(w => new { item = w.Item, qty = w.TotalWastage, category = w.WastageCategory })
                              .ToList()
        ));

    const salesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                sales.GroupBy(s => s.ProductName)
                          .Select(g => new { product = g.Key, total = g.Sum(x => x.LineTotal) })
                          .ToList()
        ));

    // ── Chart defaults ───────────────────────────────────

        Chart.defaults.font.family = "'Segoe UI', sans-serif";
        Chart.defaults.font.size   = 12;
        Chart.defaults.color       = '#6c757d';

        // ── 1. Collection by Center (Bar) ───────────────────

        new Chart(document.getElementById('collectionChart'), {
            type: 'bar',
            data: {
                labels:   dailyData.map(d => d.center),
                datasets: [{
                    label:           'Total Quantity (Ltr)',
                    data:            dailyData.map(d => d.qty),
                    backgroundColor: 'rgba(13, 110, 253, 0.15)',
                    borderColor:     'rgba(13, 110, 253, 0.8)',
                    borderWidth:     2,
                    borderRadius:    6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales:  { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                           x: { grid: { display: false } } }
            }
        });

        // ── 2. Milk Type Pie ─────────────────────────────────

        new Chart(document.getElementById('milkTypeChart'), {
            type: 'doughnut',
            data: {
                labels:   milkTypeData.map(m => m.type),
                datasets: [{
                    data:            milkTypeData.map(m => m.qty),
                    backgroundColor: ['rgba(13,110,253,0.7)', 'rgba(25,135,84,0.7)', 'rgba(255,193,7,0.7)'],
                    borderWidth:     2,
                    borderColor:     '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 16 } }
                }
            }
        });

        // ── 3. Production Bar ────────────────────────────────

        new Chart(document.getElementById('productionChart'), {
            type: 'bar',
            data: {
                labels:   productionData.map(p => p.product),
                datasets: [{
                    label:           'Milk Used (Ltr)',
                    data:            productionData.map(p => p.milk),
                    backgroundColor: 'rgba(255, 193, 7, 0.15)',
                    borderColor:     'rgba(255, 193, 7, 0.8)',
                    borderWidth:     2,
                    borderRadius:    6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales:  { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                           x: { grid: { display: false } } }
            }
        });

        // ── 4. Wastage Bar ───────────────────────────────────

        new Chart(document.getElementById('wastageChart'), {
            type: 'bar',
            data: {
                labels:   wastageData.map(w => w.item),
                datasets: [{
                    label:           'Wastage',
                    data:            wastageData.map(w => w.qty),
                    backgroundColor: wastageData.map(w =>
                        w.category === 'ProductWastage'
                            ? 'rgba(220, 53, 69, 0.15)'
                            : 'rgba(253, 126, 20, 0.15)'),
                    borderColor:     wastageData.map(w =>
                        w.category === 'ProductWastage'
                            ? 'rgba(220, 53, 69, 0.8)'
                            : 'rgba(253, 126, 20, 0.8)'),
                    borderWidth:     2,
                    borderRadius:    6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales:  { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                           x: { grid: { display: false } } }
            }
        });

        // ── 5. Sales Bar ─────────────────────────────────────

        new Chart(document.getElementById('salesChart'), {
            type: 'bar',
            data: {
                labels:   salesData.map(s => s.product),
                datasets: [{
                    label:           'Revenue (₹)',
                    data:            salesData.map(s => s.total),
                    backgroundColor: 'rgba(25, 135, 84, 0.15)',
                    borderColor:     'rgba(25, 135, 84, 0.8)',
                    borderWidth:     2,
                    borderRadius:    6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales:  { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                           x: { grid: { display: false } } }
            }
        });

    </script>
}