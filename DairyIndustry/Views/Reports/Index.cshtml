@* ── Chart.js + all chart initialisation ─────────────────────── *@
@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>

    // ── helpers ──────────────────────────────────────────────────

    function makeLegend(containerId, labels, colors) {
        var el = document.getElementById(containerId);
        if (!el) return;
        el.innerHTML = labels.map(function(l, i) {
            return '<span style="display:flex;align-items:center;gap:4px;">' +
                '<span style="width:10px;height:10px;border-radius:2px;background:' + colors[i] + ';flex-shrink:0;"></span>' +
                '<span style="color:#555;">' + l + '</span></span>';
        }).join('');
    }

    function hBar(id, labels, data, color) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: color,
                    borderColor: color,
                    borderWidth: 0,
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ' ₹' + ctx.parsed.x.toLocaleString('en-IN', {maximumFractionDigits: 0});
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: {
                            font: { size: 11 },
                            callback: function(v) { return '₹' + (v/1000).toFixed(0) + 'k'; }
                        }
                    },
                    y: { grid: { display: false }, ticks: { font: { size: 11 } } }
                }
            }
        });
    }

    function hBarPlain(id, labels, data, color) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: color,
                    borderWidth: 0,
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ' ' + ctx.parsed.x.toLocaleString('en-IN', {maximumFractionDigits: 0});
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { size: 11 } }
                    },
                    y: { grid: { display: false }, ticks: { font: { size: 11 } } }
                }
            }
        });
    }

    function donut(id, legendId, labels, data, colors) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        var total = data.reduce(function(a, b) { return a + b; }, 0);
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: colors,
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                var pct = total > 0
                                    ? Math.round(ctx.parsed / total * 100) : 0;
                                return ' ' + ctx.label + ': ' + pct + '%';
                            }
                        }
                    }
                }
            }
        });
        if (legendId) {
            var lgLabels = labels.map(function(l, i) {
                var pct = total > 0 ? Math.round(data[i] / total * 100) : 0;
                return l + ' ' + pct + '%';
            });
            makeLegend(legendId, lgLabels, colors);
        }
    }

    // ── colour palettes ──────────────────────────────────────────

    var BLUE    = '#378ADD';
    var TEAL    = '#1D9E75';
    var AMBER   = '#BA7517';
    var RED     = '#E24B4A';
    var PURPLE  = '#7F77DD';
    var CORAL   = '#D85A30';
    var GREEN   = '#639922';
    var GRAY    = '#888780';

    var PALETTE = [BLUE, TEAL, AMBER, RED, PURPLE, CORAL, GREEN, GRAY];

    var STATUS_COLORS = {
        'Processed' : TEAL,
        'Pending'   : AMBER,
        'Failed'    : RED,
        'Cancelled' : GRAY,
        'Completed' : TEAL,
        'InProgress': BLUE,
        'QCFailed'  : RED,
        'Delivered' : TEAL,
        'Dispatched': BLUE,
        'Confirmed' : PURPLE,
        'Staff'     : BLUE,
        'Center'    : TEAL,
        'Farmer'    : AMBER
    };

    function colorForStatus(s) { return STATUS_COLORS[s] || GRAY; }

    // ── data from Razor ──────────────────────────────────────────

    // Dashboard
    var distLabels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByDist.Select(x => x.Name)));
    var distRevenue  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByDist.Select(x => x.Total)));
    var osLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByStatus.Select(x => x.Status)));
    var osCount      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByStatus.Select(x => x.Count)));

    // Sales
    var spLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByProduct.Select(x => x.Name)));
    var spRevenue    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesByProduct.Select(x => x.Total)));

    // Production
    var ppLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(prodByProduct.Select(x => x.Name)));
    var ppMilk       = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(prodByProduct.Select(x => x.Milk)));
    var psLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(prodByStatus.Select(x => x.Status)));
    var psCount      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(prodByStatus.Select(x => x.Count)));

    // Wastage
    var wcLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(wastageByCategory.Select(x => x.Cat == "ProductWastage" ? "Product" : "Milk")));
    var wcTotals     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(wastageByCategory.Select(x => x.Total)));
    var wiLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(wastageTopItems.Select(x => x.Item)));
    var wiTotals     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(wastageTopItems.Select(x => x.TotalWastage)));

    // Transfers
    var trLabels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(transfersTop.Select(x => "#" + x.TransferId)));
    var trDispatch   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(transfersTop.Select(x => x.DispatchQty)));
    var trReceived   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(transfersTop.Select(x => x.ReceivedQty ?? 0)));
    var trLoss       = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(transfersTop.Select(x => x.LossQty ?? 0)));

    // Staff payments
    var spersLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(staffPayByPerson.Select(x => x.Name)));
    var spersAmounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(staffPayByPerson.Select(x => x.Total)));
    var sstatLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(staffPayByStatus.Select(x => x.Status)));
    var sstatTotals  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(staffPayByStatus.Select(x => x.Total)));

    // Center payments
    var ctrLabels    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(centerPayByCtr.Select(x => x.Name)));
    var ctrTotals    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(centerPayByCtr.Select(x => x.Total)));

    // Pending
    var pendLabels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pendingByType.Select(x => x.Type)));
    var pendTotals   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pendingByType.Select(x => x.Total)));


    // ── dashboard charts ─────────────────────────────────────────

    // vertical bar – revenue by distributor
    (function() {
        var ctx = document.getElementById('dash_distRevenue');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: distLabels,
                datasets: [{
                    label: 'Revenue',
                    data: distRevenue,
                    backgroundColor: BLUE,
                    borderWidth: 0,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: function(c) { return ' ₹' + c.parsed.y.toLocaleString('en-IN', {maximumFractionDigits:0}); } } }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 11 }, maxRotation: 30 } },
                    y: { grid: { color:'rgba(0,0,0,0.05)' }, ticks: { font:{ size:11 }, callback: function(v){ return '₹' + (v/1000).toFixed(0)+'k'; } } }
                }
            }
        });
    })();

    donut('dash_orderStatus', 'dash_orderStatusLegend',
        osLabels, osCount,
        osLabels.map(colorForStatus));

    // ── sales charts ─────────────────────────────────────────────

    hBar('sales_distBar', distLabels, distRevenue, BLUE);
    hBar('sales_prodBar', spLabels,   spRevenue,   TEAL);

    // ── production charts ─────────────────────────────────────────

    hBarPlain('prod_milkBar', ppLabels, ppMilk, TEAL);

    donut('prod_statusDonut', 'prod_statusLegend',
        psLabels, psCount,
        psLabels.map(colorForStatus));

    // ── wastage charts ────────────────────────────────────────────

    donut('waste_catDonut', 'waste_catLegend',
        wcLabels, wcTotals,
        [CORAL, AMBER]);

    hBarPlain('waste_itemBar', wiLabels, wiTotals, CORAL);

    // ── transfer grouped bar ──────────────────────────────────────

    (function() {
        var ctx = document.getElementById('transfer_grouped');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: trLabels,
                datasets: [
                    { label: 'Dispatched', data: trDispatch, backgroundColor: BLUE,   borderWidth: 0, borderRadius: 3 },
                    { label: 'Received',   data: trReceived, backgroundColor: TEAL,   borderWidth: 0, borderRadius: 3 },
                    { label: 'Loss',       data: trLoss,     backgroundColor: CORAL,  borderWidth: 0, borderRadius: 3 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: function(c) { return ' ' + c.dataset.label + ': ' + c.parsed.y.toLocaleString('en-IN', {maximumFractionDigits:0}) + ' L'; } } }
                },
                scales: {
                    x: { grid:{ display:false }, ticks:{ font:{ size:11 } } },
                    y: { grid:{ color:'rgba(0,0,0,0.05)' }, ticks:{ font:{ size:11 } } }
                }
            }
        });

        // custom legend
        var leg = [['Dispatched', BLUE], ['Received', TEAL], ['Loss', CORAL]];
        var lc  = document.createElement('div');
        lc.style.cssText = 'display:flex;gap:16px;font-size:12px;color:#555;margin-top:8px;justify-content:center;';
        leg.forEach(function(item) {
            lc.innerHTML += '<span style="display:flex;align-items:center;gap:4px;">' +
                '<span style="width:10px;height:10px;border-radius:2px;background:' + item[1] + ';"></span>' + item[0] + '</span>';
        });
        ctx.parentElement.parentElement.appendChild(lc);
    })();

    // ── staff payment charts ──────────────────────────────────────

    hBar('staff_payBar', spersLabels, spersAmounts, PURPLE);

    donut('staff_statusDonut', 'staff_statusLegend',
        sstatLabels, sstatTotals,
        sstatLabels.map(colorForStatus));

    // ── center payment chart ──────────────────────────────────────

    hBar('center_payBar', ctrLabels, ctrTotals, TEAL);

    // ── pending donut ─────────────────────────────────────────────

    donut('pending_donut', 'pending_donutLegend',
        pendLabels, pendTotals,
        pendLabels.map(colorForStatus));

</script>
}
