@using DairyIndustry.Models.Reports
@model AdminReportViewModel
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string tab = Model.ActiveTab ?? "dashboard";

    string TabClass(string name) => tab == name
        ? "nav-link active fw-semibold"
        : "nav-link text-secondary";

    string PaneClass(string name) => tab == name
        ? "tab-pane fade show active"
        : "tab-pane fade";

    string BadgeStatus(string? s) => s switch
    {
        "Processed" => "bg-success",
        "Pending"   => "bg-warning text-dark",
        "Failed"    => "bg-danger",
        "Cancelled" => "bg-secondary",
        _           => "bg-secondary"
    };

    string BadgeOrder(string? s) => s switch
    {
        "Delivered"  => "bg-success",
        "Dispatched" => "bg-primary",
        "Confirmed"  => "bg-info text-dark",
        "Pending"    => "bg-warning text-dark",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };

    string BadgeBatch(string? s) => s switch
    {
        "Completed"  => "bg-success",
        "InProgress" => "bg-info text-dark",
        "QCFailed"   => "bg-danger",
        "Cancelled"  => "bg-secondary",
        _            => "bg-secondary"
    };

    // ── pre-compute chart data server-side ──────────────────────

    // Sales: revenue by distributor
    var salesByDist = Model.Sales
        .GroupBy(s => s.DistributorName)
        .Select(g => new { Name = g.Key, Total = g.Sum(x => x.LineTotal) })
        .OrderByDescending(x => x.Total)
        .Take(8)
        .ToList();

    // Sales: revenue by product
    var salesByProduct = Model.Sales
        .GroupBy(s => s.ProductName)
        .Select(g => new { Name = g.Key, Total = g.Sum(x => x.LineTotal) })
        .OrderByDescending(x => x.Total)
        .Take(8)
        .ToList();

    // Sales: order status distribution
    var salesByStatus = Model.Sales
        .GroupBy(s => s.OrderStatus)
        .Select(g => new { Status = g.Key, Count = g.Count() })
        .ToList();

    // Production: milk used by product
    var prodByProduct = Model.Production
        .GroupBy(p => p.ProductName)
        .Select(g => new { Name = g.Key, Milk = g.Sum(x => x.TotalMilkUsedLtr) })
        .OrderByDescending(x => x.Milk)
        .Take(8)
        .ToList();

    // Production: batches by status
    var prodByStatus = Model.Production
        .GroupBy(p => p.BatchStatus)
        .Select(g => new { Status = g.Key, Count = g.Sum(x => x.TotalBatches) })
        .ToList();

    // Wastage: by category
    var wastageByCategory = Model.Wastage
        .GroupBy(w => w.WastageCategory)
        .Select(g => new { Cat = g.Key, Total = g.Sum(x => x.TotalWastage) })
        .ToList();

    // Wastage: top items
    var wastageTopItems = Model.Wastage
        .OrderByDescending(w => w.TotalWastage)
        .Take(8)
        .ToList();

    // Transfers: dispatch vs received by transfer id
    var transfersTop = Model.Transfers
        .OrderByDescending(t => t.DispatchDate)
        .Take(10)
        .ToList();

    // Staff payments: by status
    var staffPayByStatus = Model.StaffPayments
        .GroupBy(s => s.PaymentStatus)
        .Select(g => new { Status = g.Key, Total = g.Sum(x => x.TotalAmount) })
        .ToList();

    // Staff payments: by staff member
    var staffPayByPerson = Model.StaffPayments
        .GroupBy(s => s.FirstName + " " + s.LastName)
        .Select(g => new { Name = g.Key, Total = g.Sum(x => x.TotalAmount) })
        .OrderByDescending(x => x.Total)
        .Take(8)
        .ToList();

    // Center payments: by center
    var centerPayByCtr = Model.CenterPayments
        .GroupBy(c => c.CenterName)
        .Select(g => new { Name = g.Key, Total = g.Sum(x => x.TotalAmount) })
        .OrderByDescending(x => x.Total)
        .ToList();

    // Pending payments: by type
    var pendingByType = Model.PendingPayments
        .GroupBy(p => p.PaymentType)
        .Select(g => new { Type = g.Key, Total = g.Sum(x => x.TotalAmount) })
        .ToList();

    // Dashboard metrics dict
    var metricsDict = Model.Dashboard.ToDictionary(m => m.MetricName ?? "", m => m.Value);
}

<div class="container-fluid px-4 mt-4">

    @* ── Filter bar ──────────────────────────────────────────────── *@
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" asp-action="Index" asp-controller="Reports"
                  class="row g-2 align-items-end">

                <input type="hidden" name="activeTab" value="@tab" />

                <div class="col-auto">
                    <label class="form-label small text-muted mb-1">From</label>
                    <input type="date" name="fromDate" class="form-control form-control-sm"
                           value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-auto">
                    <label class="form-label small text-muted mb-1">To</label>
                    <input type="date" name="toDate" class="form-control form-control-sm"
                           value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-auto">
                    <label class="form-label small text-muted mb-1">Plant ID</label>
                    <input type="number" name="plantId" class="form-control form-control-sm"
                           placeholder="All" style="width:90px;" value="@Model.PlantId" />
                </div>

                <div class="col-auto">
                    <label class="form-label small text-muted mb-1">Distributor ID</label>
                    <input type="number" name="distributorId" class="form-control form-control-sm"
                           placeholder="All" style="width:110px;" value="@Model.DistributorId" />
                </div>

                <div class="col-auto d-flex gap-2">
                    <button type="submit" class="btn btn-dark btn-sm">Apply</button>
                    <a asp-action="Index" asp-controller="Reports"
                       class="btn btn-outline-secondary btn-sm">Reset</a>
                </div>

            </form>
        </div>
    </div>

    @* ── Tabs ───────────────────────────────────────────────────── *@
    <ul class="nav nav-tabs mb-0" role="tablist"
        style="border-bottom: 2px solid #dee2e6; flex-wrap:nowrap; overflow-x:auto;">
        @foreach (var t in new[] {
            ("dashboard",  "bi-grid-fill",         "Dashboard"),
            ("sales",      "bi-cart-fill",          "Sales"),
            ("production", "bi-gear-fill",          "Production"),
            ("wastage",    "bi-trash3-fill",        "Wastage"),
            ("transfers",  "bi-arrow-left-right",   "Milk Transfers"),
            ("staffpay",   "bi-briefcase-fill",     "Staff Payments"),
            ("centerpay",  "bi-bucket-fill",        "Center Payments"),
            ("pending",    "bi-hourglass-split",    "Pending Payments")
        })
        {
            <li class="nav-item" role="presentation" style="white-space:nowrap;">
                <a class="@TabClass(t.Item1)"
                   href="@Url.Action("Index","Reports", new {
                       activeTab     = t.Item1,
                       fromDate      = Model.FromDate.ToString("yyyy-MM-dd"),
                       toDate        = Model.ToDate.ToString("yyyy-MM-dd"),
                       plantId       = Model.PlantId,
                       distributorId = Model.DistributorId
                   })"
                   style="font-size:13px;">
                    <i class="bi @t.Item2 me-1"></i>@t.Item3
                </a>
            </li>
        }
    </ul>

    <div class="tab-content bg-white border border-top-0 rounded-bottom shadow-sm p-4">


        @* ══════════════════════════════════════════════════════════
           TAB 1 — DASHBOARD
        ══════════════════════════════════════════════════════════ *@
        <div class="@PaneClass("dashboard")">

            @* Metric cards *@
            <div class="row g-3 mb-4">
                @{
                    var cards = new[] {
                        ("TodayCollection",        "bi-droplet-fill",    "#185FA5", "Today's Collection",       "L"),
                        ("OpenBatches",            "bi-layers",          "#0F6E56", "Open Batches",             ""),
                        ("TodayProductionBatches", "bi-gear-fill",       "#854F0B", "Today's Production",       ""),
                        ("PendingSalesOrders",     "bi-cart-fill",       "#A32D2D", "Pending Sales Orders",     ""),
                        ("PendingFarmerPayments",  "bi-cash-stack",      "#534AB7", "Pending Payments (₹)",     ""),
                        ("ActiveFarmers",          "bi-person-check",    "#3B6D11", "Active Farmers",           "")
                    };
                }
                @foreach (var (key, icon, color, label, unit) in cards)
                {
                    decimal val = metricsDict.ContainsKey(key) ? metricsDict[key] : 0;
                    string display = unit == "L"
                        ? val.ToString("N0") + " L"
                        : key.Contains("Payment")
                            ? "₹" + val.ToString("N0")
                            : val.ToString("N0");

                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="card border-0 h-100" style="background:#f8f9fa;">
                            <div class="card-body text-center py-3 px-2">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-2"
                                     style="width:42px;height:42px;background:@color + "22";">
                                    <i class="bi @icon" style="font-size:18px;color:@color;"></i>
                                </div>
                                <p class="mb-0 fw-semibold" style="font-size:20px;">@display</p>
                                <p class="mb-0 text-muted" style="font-size:11px;">@label</p>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Dashboard charts row *@
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="card border shadow-sm h-100">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Revenue by distributor</span>
                        </div>
                        <div class="card-body">
                            <div style="position:relative;height:260px;">
                                <canvas id="dash_distRevenue"
                                        role="img"
                                        aria-label="Bar chart showing revenue per distributor">
                                    Revenue by distributor.
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border shadow-sm h-100">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Order status split</span>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-center">
                            <div style="position:relative;height:220px;">
                                <canvas id="dash_orderStatus"
                                        role="img"
                                        aria-label="Donut chart of order status distribution">
                                    Order status distribution.
                                </canvas>
                            </div>
                            <div id="dash_orderStatusLegend"
                                 class="d-flex flex-wrap gap-2 justify-content-center mt-2"
                                 style="font-size:11px;"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>


        @* ══════════════════════════════════════════════════════════
           TAB 2 — SALES
        ══════════════════════════════════════════════════════════ *@
        <div class="@PaneClass("sales")">

            @* Summary strip *@
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Revenue</p>
                        <p class="mb-0 fw-semibold fs-5">₹@Model.Sales.Sum(s => s.LineTotal).ToString("N0")</p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Orders</p>
                        <p class="mb-0 fw-semibold fs-5">@Model.Sales.Select(s => s.OrderDate.Date.ToString() + s.DistributorName).Distinct().Count()</p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Quantity</p>
                        <p class="mb-0 fw-semibold fs-5">@Model.Sales.Sum(s => s.Quantity).ToString("N0")</p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Distributors</p>
                        <p class="mb-0 fw-semibold fs-5">@Model.Sales.Select(s => s.DistributorName).Distinct().Count()</p>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Revenue by distributor</span>
                        </div>
                        <div class="card-body">
                            <div style="position:relative;height:@(Math.Max(salesByDist.Count * 42 + 60, 180))px;">
                                <canvas id="sales_distBar"
                                        role="img"
                                        aria-label="Horizontal bar chart of revenue by distributor">
                                    Revenue by distributor.
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Revenue by product</span>
                        </div>
                        <div class="card-body">
                            <div style="position:relative;height:@(Math.Max(salesByProduct.Count * 42 + 60, 180))px;">
                                <canvas id="sales_prodBar"
                                        role="img"
                                        aria-label="Horizontal bar chart of revenue by product">
                                    Revenue by product.
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Detailed table *@
            @if (Model.Sales.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                @* <th>#</th> *@
                                <th>Distributor</th>
                                <th>Order Date</th>
                                <th>Product</th>
                                <th>Type</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Line Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* @{ int sr = 1; } *@
                            @foreach (var s in Model.Sales)
                            {
                                <tr>
                                    @* <td class="text-muted small">@sr</td> *@
                                    <td>@s.DistributorName</td>
                                    <td class="small">@s.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td>@s.ProductName</td>
                                    <td><span class="badge bg-light text-dark border">@s.ProductType</span></td>
                                    <td class="text-end">@s.Quantity.ToString("N0")</td>
                                    <td class="text-end">₹@s.UnitPrice.ToString("N2")</td>
                                    <td class="text-end fw-semibold">₹@s.LineTotal.ToString("N2")</td>
                                    <td><span class="badge @BadgeOrder(s.OrderStatus)">@s.OrderStatus</span></td>
                                </tr>
                                @* sr++; *@
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="7" class="text-end fw-semibold">Grand Total</td>
                                <td class="text-end fw-semibold">₹@Model.Sales.Sum(s => s.LineTotal).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center text-muted py-4">No sales data for the selected period.</p>
            }
        </div>


        @* ══════════════════════════════════════════════════════════
           TAB 3 — PRODUCTION
        ══════════════════════════════════════════════════════════ *@
        <div class="@PaneClass("production")">

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Batches</p>
                        <p class="mb-0 fw-semibold fs-5">@Model.Production.Sum(p => p.TotalBatches)</p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Milk Used</p>
                        <p class="mb-0 fw-semibold fs-5">@Model.Production.Sum(p => p.TotalMilkUsedLtr).ToString("N0") L</p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Completed</p>
                        <p class="mb-0 fw-semibold fs-5 text-success">
                            @Model.Production.Where(p => p.BatchStatus == "Completed").Sum(p => p.TotalBatches)
                        </p>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">In Progress</p>
                        <p class="mb-0 fw-semibold fs-5 text-info">
                            @Model.Production.Where(p => p.BatchStatus == "InProgress").Sum(p => p.TotalBatches)
                        </p>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-7">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Milk used per product (L)</span>
                        </div>
                        <div class="card-body">
                            <div style="position:relative;height:@(Math.Max(prodByProduct.Count * 42 + 60, 180))px;">
                                <canvas id="prod_milkBar"
                                        role="img"
                                        aria-label="Horizontal bar chart of milk used per product">
                                    Milk used per product.
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Batch status breakdown</span>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-center">
                            <div style="position:relative;height:220px;">
                                <canvas id="prod_statusDonut"
                                        role="img"
                                        aria-label="Donut chart showing batch status breakdown">
                                    Batch status breakdown.
                                </canvas>
                            </div>
                            <div id="prod_statusLegend"
                                 class="d-flex flex-wrap gap-2 justify-content-center mt-2"
                                 style="font-size:11px;"></div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Production.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                @* <th>#</th> *@
                                <th>Plant</th><th>Product</th><th>Type</th>
                                <th class="text-end">Batches</th>
                                <th class="text-end">Milk Used (L)</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* @{ sr = 1; } *@
                            @foreach (var p in Model.Production)
                            {
                                <tr>
                                    @* <td class="text-muted small">@sr</td> *@
                                    <td>@p.PlantName</td><td>@p.ProductName</td>
                                    <td><span class="badge bg-light text-dark border">@p.ProductType</span></td>
                                    <td class="text-end">@p.TotalBatches</td>
                                    <td class="text-end">@p.TotalMilkUsedLtr.ToString("N2")</td>
                                    <td><span class="badge @BadgeBatch(p.BatchStatus)">@p.BatchStatus</span></td>
                                </tr>
                                @* sr++; *@
                            }
                        </tbody>
                    </table>
                </div>
            }
            else { <p class="text-center text-muted py-4">No production data for the selected period.</p> }
        </div>


        @* ══════════════════════════════════════════════════════════
           TAB 4 — WASTAGE
        ══════════════════════════════════════════════════════════ *@
        <div class="@PaneClass("wastage")">

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Wastage by category</span>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-center">
                            <div style="position:relative;height:220px;">
                                <canvas id="waste_catDonut"
                                        role="img"
                                        aria-label="Donut chart of wastage by category">
                                    Wastage by category.
                                </canvas>
                            </div>
                            <div id="waste_catLegend"
                                 class="d-flex flex-wrap gap-2 justify-content-center mt-2"
                                 style="font-size:11px;"></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border shadow-sm">
                        <div class="card-header bg-white border-bottom py-2 px-3">
                            <span class="small fw-semibold">Top wastage items</span>
                        </div>
                        <div class="card-body">
                            <div style="position:relative;height:@(Math.Max(wastageTopItems.Count * 42 + 60, 180))px;">
                                <canvas id="waste_itemBar"
                                        role="img"
                                        aria-label="Horizontal bar chart of top wastage items">
                                    Top wastage items.
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Wastage.Any())
            {
                @foreach (var grp in Model.Wastage.GroupBy(w => w.WastageCategory))
                {
                    <h6 class="mt-3 mb-2 small fw-semibold"
                        style="border-left:3px solid #0d6efd;padding-left:8px;border-radius:0;">
                        @(grp.Key == "ProductWastage" ? "Product Wastage" : "Milk Process Wastage")
                    </h6>
                    <div class="table-responsive mb-3">
                        <table class="table table-hover table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    @* <th>#</th> *@
                                    <th>Plant</th><th>Item</th>
                                    @if (grp.Key == "MilkWastage") { <th>Wastage Type</th> }
                                    <th class="text-end">Total Wastage</th><th>Unit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @* @{ sr = 1; } *@
                                @foreach (var w in grp)
                                {
                                    <tr>
                                        @* <td class="text-muted small">@sr</td> *@
                                        <td>@w.PlantName</td><td>@w.Item</td>
                                        @if (grp.Key == "MilkWastage")
                                        { <td><span class="badge bg-light text-dark border">@w.WastageType</span></td> }
                                        <td class="text-end text-danger fw-semibold">@w.TotalWastage.ToString("N2")</td>
                                        <td class="text-muted small">@w.Unit</td>
                                    </tr>
                                    @* sr++; *@
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else { <p class="text-center text-muted py-4">No wastage data for the selected period.</p> }
        </div>


        @* ══════════════════════════════════════════════════════════
           TAB 5 — MILK TRANSFERS
        ══════════════════════════════════════════════════════════ *@
        <div class="@PaneClass("transfers")">

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card border-0 bg-light text-center p-3">
                        <p class="mb-0 text-muted small">Total Dispatched</p>
