<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DairyMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

    <style>
        :root {
            --blue-900: #0a2540;
            --blue-700: #1a4480;
            --blue-500: #1d6fce;
            --blue-300: #5ea3f0;
            --blue-100: #dbeafe;
            --blue-50: #f0f7ff;
            --cream: #fafaf8;
            --ink: #0f1923;
            --muted: #6b7a8d;
            --border: #e2e8f0;
            --white: #ffffff;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--cream);
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── MAIN ── */
        .main-content {
            flex: 1;
            padding-top: 32px;
            padding-bottom: 56px;
        }

        /* ── GLOBAL COMPONENT OVERRIDES ── */
        .card {
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.05);
            background: var(--white);
        }

        .card-header {
            background: transparent;
            border-bottom: 1px solid var(--border);
            padding: 1.1rem 1.5rem;
            font-weight: 600;
        }

        .btn {
            font-weight: 500;
            border-radius: 9px;
            font-size: 0.875rem;
            transition: all 0.15s;
        }

        .btn-primary {
            background: var(--blue-500);
            border-color: var(--blue-500);
        }

            .btn-primary:hover {
                background: var(--blue-700);
                border-color: var(--blue-700);
                transform: translateY(-1px);
            }

        .btn-success:hover,
        .btn-warning:hover,
        .btn-danger:hover {
            transform: translateY(-1px);
            filter: brightness(0.92);
        }

        .alert {
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
        }

        .alert-success {
            background: #f0fdf4;
            color: #15803d;
            border-left: 4px solid #16a34a;
        }

        .alert-danger {
            background: #fff1f2;
            color: #be123c;
            border-left: 4px solid #e11d48;
        }

        .alert-warning {
            background: #fffbeb;
            color: #b45309;
            border-left: 4px solid #d97706;
        }

        .alert-info {
            background: var(--blue-50);
            color: var(--blue-700);
            border-left: 4px solid var(--blue-300);
        }

        .table {
            font-size: 0.9rem;
        }

            .table thead th {
                background: var(--blue-900);
                color: white;
                font-weight: 600;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border: none;
                padding: 13px 16px;
            }

                .table thead th:first-child {
                    border-radius: 10px 0 0 0;
                }

                .table thead th:last-child {
                    border-radius: 0 10px 0 0;
                }

            .table tbody td {
                padding: 12px 16px;
                vertical-align: middle;
                border-color: var(--border);
            }

            .table tbody tr:hover {
                background: var(--blue-50);
            }

        .form-control, .form-select {
            border-radius: 9px;
            border: 1px solid var(--border);
            font-size: 0.9rem;
            padding: 10px 14px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--blue-500);
                box-shadow: 0 0 0 3px rgba(29,111,206,0.12);
            }

        .form-label {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 6px;
        }

        .badge {
            font-weight: 500;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: 0.78rem;
        }
    </style>
</head>
<body>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
