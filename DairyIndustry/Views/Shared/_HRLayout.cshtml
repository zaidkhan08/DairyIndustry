<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HR Module</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --sb-width: 240px;
            --sb-collapsed: 68px;
            --sb-bg: #0f1f3d;
            --sb-hover: #1a3a6e;
            --sb-active: #2563eb;
            --sb-text: #c8d6f0;
            --sb-muted: #6b82a8;
            --sb-border: rgba(255,255,255,0.07);
            --topbar-h: 58px;
            --ease: 0.27s cubic-bezier(.4,0,.2,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: #f0f4fb;
            margin: 0;
            overflow-x: hidden;
        }

        /* ── Sidebar ── */
        #sidebar {
            position: fixed;
            inset: 0 auto 0 0;
            width: var(--sb-width);
            background: var(--sb-bg);
            display: flex;
            flex-direction: column;
            transition: width var(--ease);
            z-index: 1050;
            overflow: hidden;
            box-shadow: 3px 0 20px rgba(0,0,0,0.18);
        }

            #sidebar.collapsed {
                width: var(--sb-collapsed);
            }

        /* Brand */
        .sb-brand {
            display: flex;
            align-items: center;
            gap: 11px;
            height: var(--topbar-h);
            padding: 0 16px;
            border-bottom: 1px solid var(--sb-border);
            text-decoration: none;
            overflow: hidden;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .sb-brand-icon {
            width: 36px;
            height: 36px;
            background: var(--sb-active);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            color: #fff;
            flex-shrink: 0;
        }

        .sb-brand-text {
            transition: opacity var(--ease);
        }

            .sb-brand-text strong {
                display: block;
                font-size: .9rem;
                font-weight: 800;
                color: #fff;
                line-height: 1.2;
            }

            .sb-brand-text span {
                font-size: .68rem;
                color: var(--sb-muted);
                letter-spacing: .05em;
            }

        #sidebar.collapsed .sb-brand-text {
            opacity: 0;
            pointer-events: none;
        }

        /* Toggle */
        .sb-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            background: var(--sb-hover);
            border: none;
            border-radius: 8px;
            color: var(--sb-text);
            cursor: pointer;
            margin: 10px auto 2px;
            flex-shrink: 0;
            transition: background .2s;
        }

            .sb-toggle:hover {
                background: var(--sb-active);
                color: #fff;
            }

            .sb-toggle .ti {
                transition: transform var(--ease);
                font-size: 1rem;
            }

        #sidebar.collapsed .sb-toggle .ti {
            transform: rotate(180deg);
        }

        /* Section label */
        .sb-label {
            font-size: .63rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--sb-muted);
            padding: 14px 20px 5px;
            white-space: nowrap;
            overflow: hidden;
            transition: opacity var(--ease), height var(--ease), padding var(--ease);
        }

        #sidebar.collapsed .sb-label {
            opacity: 0;
            height: 0;
            padding: 0;
        }

        /* Nav scroll area */
        .sb-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 2px 0;
        }

            .sb-nav::-webkit-scrollbar {
                width: 3px;
            }

            .sb-nav::-webkit-scrollbar-thumb {
                background: var(--sb-border);
                border-radius: 2px;
            }

        /* Nav link */
        .sb-link {
            position: relative;
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 16px;
            margin: 2px 8px;
            border-radius: 8px;
            color: var(--sb-text);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            transition: background .18s, color .18s, padding var(--ease);
        }

            .sb-link:hover {
                background: var(--sb-hover);
                color: #fff;
            }

            .sb-link.active {
                background: var(--sb-active);
                color: #fff;
                box-shadow: 0 4px 14px rgba(37,99,235,.3);
            }

            .sb-link .si {
                font-size: 1.05rem;
                flex-shrink: 0;
                width: 20px;
                text-align: center;
            }

            .sb-link .st {
                transition: opacity var(--ease);
            }

        #sidebar.collapsed .sb-link .st {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        #sidebar.collapsed .sb-link {
            justify-content: center;
            padding: 9px;
            margin: 2px 10px;
        }

            /* Tooltip when collapsed */
            #sidebar.collapsed .sb-link::after {
                content: attr(data-tip);
                position: absolute;
                left: calc(var(--sb-collapsed) - 4px);
                top: 50%;
                transform: translateY(-50%);
                background: #1e293b;
                color: #fff;
                font-size: .75rem;
                font-weight: 600;
                padding: 5px 10px;
                border-radius: 6px;
                white-space: nowrap;
                opacity: 0;
                pointer-events: none;
                transition: opacity .15s;
                z-index: 9999;
            }

            #sidebar.collapsed .sb-link:hover::after {
                opacity: 1;
            }

        /* Footer / Logout */
        .sb-footer {
            padding: 10px 8px;
            border-top: 1px solid var(--sb-border);
            flex-shrink: 0;
        }

        .sb-logout {
            position: relative;
            display: flex;
            align-items: center;
            gap: 11px;
            width: 100%;
            padding: 9px 16px;
            border-radius: 8px;
            background: none;
            border: none;
            color: #f87171;
            font-family: 'Nunito', sans-serif;
            font-size: .875rem;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            overflow: hidden;
            cursor: pointer;
            transition: background .18s, color .18s, padding var(--ease);
        }

            .sb-logout:hover {
                background: rgba(248,113,113,.12);
                color: #ef4444;
            }

            .sb-logout .si {
                font-size: 1.05rem;
                flex-shrink: 0;
                width: 20px;
                text-align: center;
            }

            .sb-logout .st {
                transition: opacity var(--ease);
            }

        #sidebar.collapsed .sb-logout {
            justify-content: center;
            padding: 9px;
        }

            #sidebar.collapsed .sb-logout .st {
                opacity: 0;
                width: 0;
                overflow: hidden;
            }

            #sidebar.collapsed .sb-logout::after {
                content: attr(data-tip);
                position: absolute;
                left: calc(var(--sb-collapsed) - 4px);
                top: 50%;
                transform: translateY(-50%);
                background: #1e293b;
                color: #fff;
                font-size: .75rem;
                font-weight: 600;
                padding: 5px 10px;
                border-radius: 6px;
                white-space: nowrap;
                opacity: 0;
                pointer-events: none;
                transition: opacity .15s;
                z-index: 9999;
            }

            #sidebar.collapsed .sb-logout:hover::after {
                opacity: 1;
            }

        /* ── Main wrapper ── */
        #main {
            margin-left: var(--sb-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--ease);
        }

            #main.collapsed {
                margin-left: var(--sb-collapsed);
            }

        /* ── Topbar ── */
        #topbar {
            position: sticky;
            top: 0;
            z-index: 900;
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
        }

        .topbar-title {
            font-size: .95rem;
            font-weight: 700;
            color: #1e293b;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .topbar-chip {
            font-size: .75rem;
            font-weight: 700;
            background: #eff6ff;
            color: #2563eb;
            padding: 4px 12px;
            border-radius: 20px;
            border: 1px solid #bfdbfe;
        }

        .topbar-avatar {
            width: 33px;
            height: 33px;
            background: #2563eb;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: .95rem;
        }

        #mob-btn {
            display: none;
            align-items: center;
            justify-content: center;
            width: 33px;
            height: 33px;
            background: none;
            border: 1px solid #e2e8f0;
            border-radius: 7px;
            color: #475569;
            cursor: pointer;
            margin-right: 6px;
        }

        /* ── Content ── */
        #content {
            flex: 1;
            padding: 26px 26px 40px;
        }

        /* ── Mobile overlay ── */
        #overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1040;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--ease);
        }

        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
                width: var(--sb-width) !important;
                transition: transform var(--ease);
            }

                #sidebar.mob-open {
                    transform: translateX(0);
                }

            #main, #main.collapsed {
                margin-left: 0;
            }

            #overlay {
                display: block;
            }

            #mob-btn {
                display: flex;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <nav id="sidebar">

        <a class="sb-brand" asp-controller="HR" asp-action="Dashboard">
            <div class="sb-brand-icon"><i class="bi bi-droplet-half"></i></div>
            <div class="sb-brand-text">
                <strong>DairyIndustry</strong>
                <span>HR MODULE</span>
            </div>
        </a>

        <button class="sb-toggle" id="deskToggle" title="Collapse sidebar">
            <i class="bi bi-chevron-left ti"></i>
        </button>

        <div class="sb-nav">

            <div class="sb-label">Overview</div>
            <a class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="HR" asp-action="Dashboard" data-tip="Dashboard">
                <i class="bi bi-speedometer2 si"></i><span class="st">Dashboard</span>
            </a>

            <div class="sb-label">Staff</div>
            <a class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               asp-controller="HR" asp-action="Index" data-tip="All Staff">
                <i class="bi bi-people-fill si"></i><span class="st">All Staff</span>
            </a>
            <a class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
               asp-controller="HR" asp-action="Create" data-tip="Add Staff">
                <i class="bi bi-person-plus-fill si"></i><span class="st">Add Staff</span>
            </a>

            <div class="sb-label">Finance</div>
            <a class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payments" ? "active" : "")"
               asp-controller="HR" asp-action="Payments" data-tip="Payments">
                <i class="bi bi-cash-stack si"></i><span class="st">Payments</span>
            </a>
            <a class="sb-link"
               asp-controller="HR" asp-action="Payments" asp-route-status="Pending" data-tip="Pending">
                <i class="bi bi-hourglass-split si"></i><span class="st">Pending Payments</span>
            </a>

        </div>

        <div class="sb-footer">
            <a asp-controller="Admin" asp-action="Logout"
               class="sb-logout" data-tip="Logout"
               onclick="return confirm('Logout from HR Module?');">
                <i class="bi bi-box-arrow-left si"></i>
                <span class="st">Logout</span>
            </a>
        </div>

    </nav>

    <div id="overlay" onclick="closeMob()"></div>

    <!-- ═══════════ MAIN ═══════════ -->
    <div id="main">

        <header id="topbar">
            <div class="d-flex align-items-center">
                <button id="mob-btn" onclick="openMob()"><i class="bi bi-list fs-5"></i></button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>
            <div class="topbar-right">
                <span class="topbar-chip"><i class="bi bi-person-badge me-1"></i>HR Manager</span>
                <div class="topbar-avatar"><i class="bi bi-person-fill"></i></div>
            </div>
        </header>

        <div id="content">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3 border-0 rounded-3">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3 border-0 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        var sidebar = document.getElementById('sidebar');
        var main    = document.getElementById('main');
        var overlay = document.getElementById('overlay');

        // Restore saved collapse state
        if (localStorage.getItem('hr_sb') === '1') {
            sidebar.classList.add('collapsed');
            main.classList.add('collapsed');
        }

        document.getElementById('deskToggle').addEventListener('click', function () {
            var c = sidebar.classList.toggle('collapsed');
            main.classList.toggle('collapsed', c);
            localStorage.setItem('hr_sb', c ? '1' : '0');
        });

        function openMob() {
            sidebar.classList.add('mob-open');
            overlay.style.opacity = '1';
            overlay.style.pointerEvents = 'auto';
        }

        function closeMob() {
            sidebar.classList.remove('mob-open');
            overlay.style.opacity = '0';
            overlay.style.pointerEvents = 'none';
        }

        document.querySelectorAll('.sb-link, .sb-logout').forEach(function (el) {
            el.addEventListener('click', function () {
                if (window.innerWidth <= 768) closeMob();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
