@using System.Text.Json
@{
    string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string roleName = Context.Session.GetString("RoleName") ?? "";
    bool isAdmin = roleName == "Admin";
    bool isDist = roleName == "Distributor";

    string distName = Context.Session.GetString("DistributorName") ?? "";
    string username = Context.Session.GetString("Username") ?? "";
    string dispName = !string.IsNullOrEmpty(distName) ? distName : username;

    bool Active(string a) => string.Equals(action, a, StringComparison.OrdinalIgnoreCase);
    bool ActiveAny(string a, string b) => Active(a) || Active(b);

    // ── Notification badge — computed directly from session ──────────────
    // No ViewBag dependency. Reads NotifOrders_<distId> stored by controller.
    int notifCount = 0;
    var notifOrders = new List<NotifOrderItem>();

    // ── Profile completeness (for sidebar indicator) ────────────────────
    int profileComplete = 0;
    int profileTotal = 5;  // Name, Location, Contact, Email, GSTIN
    if (isDist)
    {
        int distId = Context.Session.GetInt32("DistributorId") ?? 0;
        if (distId > 0)
        {
            // Count filled profile fields stored in session
            if (!string.IsNullOrEmpty(Context.Session.GetString("DistributorName"))) profileComplete++;
            if (!string.IsNullOrEmpty(Context.Session.GetString("DistributorLocation"))) profileComplete++;
            if (!string.IsNullOrEmpty(Context.Session.GetString("DistributorContact"))) profileComplete++;
            if (!string.IsNullOrEmpty(Context.Session.GetString("DistributorEmail"))) profileComplete++;
            if (!string.IsNullOrEmpty(Context.Session.GetString("DistributorGSTIN"))) profileComplete++;

            string notifJson = Context.Session.GetString($"NotifOrders_{distId}") ?? "[]";
            try
            {
                using var doc = JsonDocument.Parse(notifJson);
                foreach (var el in doc.RootElement.EnumerateArray())
                {
                    notifOrders.Add(new NotifOrderItem
                    {
                        OrderId = el.GetProperty("OrderId").GetInt32(),
                        Status = el.GetProperty("Status").GetString() ?? "",
                        Date = el.GetProperty("Date").GetString() ?? "",
                        Amount = el.GetProperty("Amount").GetDecimal()
                    });
                }
                notifCount = notifOrders.Count;
            }
            catch { notifCount = 0; }
        }
    }
}

@functions {
    public class NotifOrderItem
    {
        public int OrderId { get; set; }
        public string Status { get; set; } = "";
        public string Date { get; set; } = "";
        public decimal Amount { get; set; }
    }
}

<div id="sales-sidebar" style="background:#0a1628; display:flex; flex-direction:column;">

    <!-- ── Header ── -->
    <div style="background:#060d18; padding:14px 16px; border-bottom:1px solid rgba(255,255,255,.06); flex-shrink:0;">
        <div style="font-size:.6rem; color:#64748b; text-transform:uppercase; letter-spacing:.12em;">
            Sales Module
        </div>
        <div style="font-size:.85rem; color:#fff; font-weight:600; margin-top:3px;
                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            @dispName
        </div>
        <div style="font-size:.68rem; color:#3b82f6; margin-top:2px; font-weight:500;">
            @roleName
        </div>
        @if (isDist && profileTotal > 0)
        {
            int pct = profileComplete * 100 / profileTotal;
            string pctColor = pct == 100 ? "#2ecc71" : pct >= 50 ? "#f39c12" : "#e74c3c";
            <div style="margin-top:8px;">
                <div style="display:flex; justify-content:space-between; font-size:.6rem; color:#64748b; margin-bottom:3px;">
                    <span>Profile</span>
                    <span style="color:@pctColor; font-weight:600;">@profileComplete/@profileTotal complete</span>
                </div>
                <div style="background:#0f1e30; border-radius:4px; height:4px; overflow:hidden;">
                    <div style="width:@pct%; height:100%; background:@pctColor; border-radius:4px;
                                                        transition:width .3s;"></div>
                </div>
                @if (pct < 100)
                {
                    <a asp-controller="Sales" asp-action="MyProfile"
                       style="font-size:.6rem; color:#64748b; text-decoration:none; display:block; margin-top:3px;">
                        Complete profile →
                    </a>
                }
            </div>
        }
    </div>

    <!-- ── Navigation ── -->
    <nav style="flex:1; padding:8px 0; overflow-y:auto; scrollbar-width:thin;">

        @if (isAdmin)
        {
            <div class="sb-section-label">Overview</div>

            <a asp-controller="Sales" asp-action="Dashboard"
               class="sb-link @(Active("Dashboard") ? "active" : "")">
                <span class="sb-icon">📊</span> Dashboard
            </a>

            <a asp-controller="Sales" asp-action="Reports"
               class="sb-link @(Active("Reports") ? "active" : "")">
                <span class="sb-icon">📈</span> Reports
            </a>

            <div class="sb-section-label">Orders</div>

            <a asp-controller="Sales" asp-action="Index"
               class="sb-link @(Active("Index") ? "active" : "")">
                <span class="sb-icon">📋</span> All Orders
            </a>

            <a asp-controller="Sales" asp-action="Create"
               class="sb-link @(Active("Create") ? "active" : "")">
                <span class="sb-icon">➕</span> New Order
            </a>

            <div class="sb-section-label">Distributors</div>

            <a asp-controller="Sales" asp-action="Distributors"
               class="sb-link @(Active("Distributors") ? "active" : "")">
                <span class="sb-icon">🏪</span> All Distributors
            </a>


            int pendingCount = ViewBag.PendingCount != null ? (int)ViewBag.PendingCount : 0;

            <a asp-controller="Sales" asp-action="Distributors" asp-route-status="Pending"
               class="sb-link @(Active("Distributors") && Context.Request.Query["status"] == "Pending" ? "active" : "")">
                <span class="sb-icon">⏳</span> Pending Approvals
                @if (pendingCount > 0)
                {
                    <span style="margin-left:auto; background:#e74c3c; color:#fff;
                                                                         font-size:.62rem; font-weight:700; min-width:18px;
                                                                         height:18px; border-radius:9px; display:inline-flex;
                                                                         align-items:center; justify-content:center; padding:0 5px;
                                                                         flex-shrink:0;">
                        @(pendingCount > 9 ? "9+" : pendingCount.ToString())
                    </span>
                }
            </a>

            <a asp-controller="Sales" asp-action="AddDistributor"
               class="sb-link @(Active("AddDistributor") ? "active" : "")">
                <span class="sb-icon">➕</span> Add Distributor
            </a>
        }

        @if (isDist)
        {
            <div class="sb-section-label">My Account</div>

            <a asp-controller="Sales" asp-action="MyDetails"
               class="sb-link @(Active("MyDetails") ? "active" : "")">
                <span class="sb-icon">👤</span> My Details
            </a>

            <a asp-controller="Sales" asp-action="MyProfile"
               class="sb-link @(ActiveAny("MyProfile", "EditDistributor") ? "active" : "")">
                <span class="sb-icon">✏️</span> Edit Profile
            </a>

            <a asp-controller="Sales" asp-action="Dashboard"
               class="sb-link @(Active("Dashboard") ? "active" : "")">
                <span class="sb-icon">📊</span> My Dashboard
            </a>

            <a asp-controller="Sales" asp-action="ProductCatalogue"
               class="sb-link @(Active("ProductCatalogue") ? "active" : "")">
                <span class="sb-icon">🛍️</span> Product Catalogue
            </a>

            <div class="sb-section-label">Orders</div>

            <!-- My Orders link with badge -->
            <a asp-controller="Sales" asp-action="MyOrders"
               class="sb-link @(Active("MyOrders") ? "active" : "")" id="sb-myorders-link">
                <span class="sb-icon">📋</span>
                My Orders
                @if (notifCount > 0)
                {
                    <span id="sb-notif-badge"
                          onclick="toggleNotifPanel(event)"
                          style="margin-left:auto; background:#e74c3c; color:#fff;
                                                                                                                                 font-size:.62rem; font-weight:700; min-width:18px;
                                                                                                                                 height:18px; border-radius:9px; display:inline-flex;
                                                                                                                                 align-items:center; justify-content:center; padding:0 5px;
                                                                                                                                 cursor:pointer; flex-shrink:0;"
                          title="Click to see which orders were updated">
                        @(notifCount > 9 ? "9+" : notifCount.ToString())
                    </span>
                }
            </a>

            <!-- Notification dropdown panel -->
            @if (notifCount > 0 && notifOrders != null)
            {
                <div id="sb-notif-panel"
                     style="display:none; margin:0 10px 6px; background:#060d18;
                                                                                                                            border:1px solid #2a4060; border-radius:6px; overflow:hidden;">

                    <div style="padding:8px 12px; font-size:.65rem; color:#64748b;
                                                                                                                                text-transform:uppercase; letter-spacing:.08em;
                                                                                                                                border-bottom:1px solid rgba(255,255,255,.06); background:#0f1e30;">
                        🔔 Admin updated these orders
                    </div>

                    @foreach (var o in notifOrders)
                    {
                        string statusColor = o.Status == "Delivered" ? "#2ecc71" :
                        o.Status == "Dispatched" ? "#4a9eda" :
                        "#f39c12";
                        <a href="/Sales/Details/@o.OrderId"
                           style="display:flex; align-items:center; justify-content:space-between;
                                                                                                                                                                                  padding:8px 12px; text-decoration:none; color:#94a3b8;
                                                                                                                                                                                  font-size:.78rem; border-bottom:1px solid #1e3450;
                                                                                                                                                                                  transition:background .13s;"
                           onmouseover="this.style.background='rgba(255,255,255,.05)'"
                           onmouseout="this.style.background='transparent'">
                            <div>
                                <div style="font-weight:600; color:#e8f2ff;">
                                    Order #@o.OrderId
                                </div>
                                <div style="font-size:.7rem; color:#64748b; margin-top:1px;">
                                    @o.Date · ₹@((o.Amount).ToString("N0"))
                                </div>
                            </div>
                            <span style="font-size:.65rem; font-weight:700; color:@statusColor;
                                                                                                                                                                                         background:rgba(255,255,255,.08); border-radius:4px;
                                                                                                                                                                                         padding:2px 7px; flex-shrink:0;">
                                @o.Status
                            </span>
                        </a>
                    }

                    <div style="padding:7px 12px; display:flex; justify-content:space-between; align-items:center;">
                        <a asp-controller="Sales" asp-action="MyOrders"
                           style="font-size:.72rem; color:#3b82f6; text-decoration:none;">
                            View all orders →
                        </a>
                        <form asp-controller="Sales" asp-action="DismissNotif"
                              method="post" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    style="background:none;border:none;color:#64748b;
                                                                                                                                   font-size:.68rem;cursor:pointer;padding:0;
                                                                                                                                   text-decoration:underline;">
                                ✓ Mark as seen
                            </button>
                        </form>
                    </div>
                </div>
            }

            <a asp-controller="Sales" asp-action="Create"
               class="sb-link @(Active("Create") ? "active" : "")">
                <span class="sb-icon">➕</span> New Order
            </a>
        }

    </nav>

    <!-- ── Footer ── -->
    <div style="padding:12px 16px; border-top:1px solid rgba(255,255,255,.06); font-size:.74rem; flex-shrink:0;">
        <a asp-controller="DistributorRegister" asp-action="Index"
           style="color:#64748b; text-decoration:none; display:flex; align-items:center; gap:8px;
                  transition:color .13s;">
            <span>🔗</span> Distributor Register Page
        </a>
    </div>
</div>

<style>
    .sb-section-label {
        font-size: .6rem;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: .12em;
        padding: 12px 18px 4px;
    }

    .sb-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 18px;
        color: #64748b;
        text-decoration: none;
        font-size: .82rem;
        border-left: 2px solid transparent;
        transition: background .13s, color .13s, border-left-color .13s;
        white-space: nowrap;
    }

        .sb-link:hover {
            background: rgba(255,255,255,.07);
            color: #e8f2ff;
            border-left-color: rgba(59,130,246,.5);
        }

        .sb-link.active {
            background: rgba(59,130,246,.12);
            color: #ffffff;
            border-left-color: rgba(59,130,246,.5);
            font-weight: 600;
        }

    .sb-icon {
        width: 20px;
        text-align: center;
        font-size: .88rem;
        flex-shrink: 0;
    }
</style>

<script>
    function toggleNotifPanel(event) {
        event.preventDefault();
        event.stopPropagation();
        const panel = document.getElementById('sb-notif-panel');
        if (!panel) return;
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function (e) {
        const panel = document.getElementById('sb-notif-panel');
        const badge = document.getElementById('sb-notif-badge');
        if (panel && badge &&
            !panel.contains(e.target) &&
            !badge.contains(e.target)) {
            panel.style.display = 'none';
        }
    });
</script>
