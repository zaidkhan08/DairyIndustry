<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DairyFlow Production</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            --sidebar-width: 260px;
            --nav-bg: #ffffff;
            --accent-color: #6366f1;
        }

        body {
            background-color: #f8fafc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Sidebar Container */
        .sidebar-main {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--nav-bg);
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            padding: 24px 20px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Brand Logo Section */
        .brand-section {
            margin-bottom: 30px;
            padding-left: 10px;
        }

        .search-container {
            position: relative;
            margin-bottom: 25px;
        }

            .search-container input {
                width: 100%;
                padding: 8px 12px 8px 35px;
                border-radius: 8px;
                border: 1px solid #e2e8f0;
                background-color: #f8fafc;
                font-size: 0.9rem;
            }

            .search-container i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
            }

        .nav-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 12px;
            letter-spacing: 0.5px;
            padding-left: 12px;
        }

        .nav-item-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            color: #475569;
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.92rem;
            font-weight: 500;
            transition: all 0.2s;
            margin-bottom: 4px;
        }

            .nav-item-custom:hover {
                background-color: #f1f5f9;
                color: #1e293b;
            }

            .nav-item-custom.active {
                background-color: #eef2ff;
                color: var(--accent-color);
            }

        .badge-new {
            background-color: #6366f1;
            color: white;
            font-size: 0.65rem;
            padding: 2px 8px;
            border-radius: 10px;
            margin-left: auto;
        }

        /* CTA Card */
        .cta-card {
            margin-top: auto;
            background-color: #6366f1;
            border-radius: 12px;
            padding: 16px;
            color: white;
        }

            .cta-card h6 {
                font-size: 0.85rem;
                font-weight: 600;
                margin-bottom: 8px;
            }

            .cta-card p {
                font-size: 0.75rem;
                opacity: 0.9;
                margin-bottom: 12px;
                line-height: 1.4;
            }

            .cta-card .dismiss {
                font-size: 0.7rem;
                opacity: 0.7;
                text-decoration: underline;
                cursor: pointer;
            }

        .topbar {
            height: 70px;
            background: white;
            border-bottom: 1px solid #e2e8f0;
        }
    </style>
</head>

<body>

    <div class="d-flex">

        <!-- SIMPLIFIED SIDEBAR -->
        <aside class="sidebar-main shadow-sm">
            <div class="brand-section">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-droplet-fill text-primary fs-4"></i>
                    <span class="fw-bold fs-5 text-dark">DairyFlow</span>
                </div>
            </div>

            <div class="search-container">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search operations...">
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Production</div>
                <a asp-controller="Production" asp-action="Index" class="nav-item-custom">
                    <i class="bi bi-arrow-left-right"></i> Milk Transfer <span class="badge-new">New</span>
                </a>
                <a asp-controller="Production" asp-action="Batches" class="nav-item-custom">
                    <i class="bi bi-calendar-check"></i> Batch Tracking
                </a>
                <a asp-controller="Production" asp-action="Products" class="nav-item-custom">
                    <i class="bi bi-bar-chart-line"></i> Add Product 
                </a>
                <a asp-controller="Production" asp-action="RawMilkInventory" class="nav-item-custom">
                    <i class="bi bi-box-seam"></i> Plant Milk Inventory
                </a>
            </div>

            <div class="nav-section mt-4">
                <div class="nav-section-title">Quality Control</div>
                <a asp-controller="Production" asp-action="Productwastage" class="nav-item-custom">
                    <i class="bi bi-trash3"></i> Product Wastage
                </a>
                <a asp-controller ="Production" asp-action="Addwastage" class="nav-item-custom">
                    <i class="bi bi-shield-check"></i> Add New Detail
                </a>
                
            </div>

            <!-- CTA Card -->
            <div class="cta-card shadow-sm">
                <i class="bi bi-lightning-charge-fill mb-2 d-block"></i>
                <h6>Yield Prediction Beta</h6>
                <p>Unlock AI-driven milk yield forecasting for your production lines.</p>
                <div class="dismiss">Dismiss</div>
            </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <div class="flex-grow-1 d-flex flex-column min-vw-0">

            <!-- TOPBAR -->
            <header class="navbar navbar-expand px-4 sticky-top topbar">
                <div class="container-fluid p-0">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">Production /</span>
                        <span class="text-dark fw-bold">@ViewData["Title"]</span>
                    </div>

                    <div class="ms-auto d-flex align-items-center gap-4">
                        <div class="text-muted small fw-medium d-none d-lg-block border-end pe-3">
                            <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-light btn-sm rounded-pill px-3 dropdown-toggle border shadow-sm" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @Context.Session.GetString("Username")
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger fw-bold" asp-controller="Admin" asp-action="Logout"><i class="bi bi-power me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </header>

            <!-- VIEWPORT CONTENT -->
            <main class="flex-grow-1 p-4">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
            </main>

            <!-- PAGE FOOTER -->
            <footer class="bg-white border-top px-4 py-3 d-flex justify-content-between align-items-center">
                <div>
                    <span class="text-primary fw-bold small">DairyFlow</span>
                    <span class="text-muted ms-2" style="font-size: 0.75rem;">&copy; 2024 Digital Production Management</span>
                </div>
                <div class="badge bg-light text-dark border fw-normal">v1.2.0-STABLE</div>
            </footer>

        </div>

    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            document.querySelectorAll('.nav-item-custom').forEach(link => {
                if(link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>
</body>
</html>