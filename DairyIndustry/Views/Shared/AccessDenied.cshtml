@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="min-vh-100 d-flex justify-content-center align-items-center">
        <div class="card shadow border-0 text-center p-5" style="max-width: 500px; width: 90%; border-radius: 12px;">

            <div class="mb-3" style="font-size: 64px;">🔒</div>

            <h1 class="display-4 fw-bold text-danger mb-2">403</h1>

            <h4 class="fw-semibold text-dark mb-3">Access Denied</h4>

            <p class="text-muted mb-4">
                You do not have permission to access this page. <br />
                Please contact your administrator if you think this is a mistake.
            </p>

            <div class="d-flex justify-content-center gap-3">
                <a href="/Admin/Index" class="btn btn-primary px-4">
                    Go to Dashboard
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-primary px-4">
                    Go Back
                </a>
            </div>

        </div>
    </div>

</body>
</html>