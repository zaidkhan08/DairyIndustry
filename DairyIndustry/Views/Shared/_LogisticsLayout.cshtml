<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dairy Logistics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="d-flex min-vh-100">

        <!-- ═══════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════ -->
        <div class="d-flex flex-column bg-dark text-white shadow"
             style="width:260px; min-width:260px;">

            <!-- Brand -->
            <div class="px-4 py-4 border-bottom border-secondary">
                <div class="d-flex align-items-center gap-2">
                    <div class="bg-success rounded-3 d-flex align-items-center justify-content-center"
                         style="width:40px; height:40px;">
                        <i class="bi bi-truck text-white fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-white lh-1">Dairy</div>
                        <div class="text-success fw-semibold lh-1" style="font-size:.8rem;">
                            Logistics Panel
                        </div>
                    </div>
                </div>
            </div>

            <!-- Driver Info -->
            <div class="px-4 py-3 border-bottom border-secondary">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success text-white rounded-circle d-flex align-items-center
                             justify-content-center fw-bold flex-shrink-0"
                         style="width:42px; height:42px;">
                        @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "D")
                    </div>
                    <div class="overflow-hidden">
                        <div class="text-white fw-semibold text-truncate small">
                            @Context.Session.GetString("Username")
                        </div>
                        <span class="badge bg-success bg-opacity-75 mt-1" style="font-size:.68rem;">
                            Driver
                        </span>
                    </div>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-grow-1 px-3 py-3">

                <div class="text-uppercase text-secondary fw-semibold mb-2 px-2"
                     style="font-size:.65rem; letter-spacing:.8px;">
                    Main Menu
                </div>

                <a asp-controller="Logistics" asp-action="Index"
                   class="d-flex align-items-center gap-3 px-3 py-2 rounded-3 mb-1 text-decoration-none
                      @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-success text-white" : "text-secondary")">
                    <i class="bi bi-speedometer2 fs-5"></i>
                    <span class="fw-medium">Dashboard</span>
                </a>

                <a asp-controller="Logistics" asp-action="RegisterVehicle"
                   class="d-flex align-items-center gap-3 px-3 py-2 rounded-3 mb-1 text-decoration-none
                      @(ViewContext.RouteData.Values["action"]?.ToString() == "RegisterVehicle" ? "bg-success text-white" : "text-secondary")">
                    <i class="bi bi-truck fs-5"></i>
                    <span class="fw-medium">Register Vehicle</span>
                </a>

                <div class="text-uppercase text-secondary fw-semibold mt-4 mb-2 px-2"
                     style="font-size:.65rem; letter-spacing:.8px;">
                    Account
                </div>

                <a asp-controller="Admin" asp-action="Logout"
                   class="d-flex align-items-center gap-3 px-3 py-2 rounded-3 mb-1
                      text-decoration-none text-secondary">
                    <i class="bi bi-box-arrow-left fs-5"></i>
                    <span class="fw-medium">Logout</span>
                </a>

            </nav>

            <!-- Footer -->
            <div class="px-4 py-3 border-top border-secondary">
                <small class="text-secondary" style="font-size:.7rem;">
                    <i class="bi bi-c-circle me-1"></i>2024 Dairy Management
                </small>
            </div>

        </div>

        <!-- ═══════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════ -->
        <div class="flex-grow-1 d-flex flex-column overflow-auto">

            <!-- Top Navbar -->
            <nav class="navbar bg-white border-bottom shadow-sm px-4 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-chevron-right text-muted small"></i>
                    <span class="text-muted small">@ViewData["Title"]</span>
                </div>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="badge bg-success bg-opacity-10 text-success fw-semibold px-3 py-2">
                        <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i>Active Session
                    </span>
                    <div class="vr text-muted"></div>
                    <span class="text-muted small">
                        <i class="bi bi-calendar3 me-1"></i>
                        @DateTime.Now.ToString("dd MMM yyyy")
                    </span>
                    <div class="vr text-muted"></div>
                    <a asp-controller="Admin" asp-action="Logout"
                       class="btn btn-outline-danger btn-sm fw-semibold">
                        <i class="bi bi-box-arrow-left me-1"></i>Logout
                    </a>
                </div>
            </nav>

            <!-- Page Content -->
            <main class="flex-grow-1 p-0">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="bg-white border-top px-4 py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <small class="text-muted">
                        <i class="bi bi-truck me-1 text-success"></i>
                        Dairy Management System — Logistics Module
                    </small>
                    <small class="text-muted">
                        Version 1.0
                    </small>
                </div>
            </footer>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>