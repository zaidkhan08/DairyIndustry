<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dairy Logistics</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Admin Layout CSS (same as admin) -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />

</head>
<body>

    <!-- ══════════════════════════════════════════ -->
    <!-- SIDEBAR                                    -->
    <!-- ══════════════════════════════════════════ -->

    <div id="sidebar">

        <!-- Brand -->
        <a class="sidebar-brand" asp-controller="Logistics" asp-action="Index">
            <div class="brand-icon">
                <i class="bi bi-truck-front-fill"></i>
            </div>
            <div class="brand-text">
                <span>DairyManage</span>
                <small>Logistics Panel</small>
            </div>
        </a>

        <!-- Nav -->
        <div class="sidebar-nav">

            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var act = ViewContext.RouteData.Values["action"]?.ToString();
            }

            <!-- ── Main ────────────────────────── -->
            <div class="nav-label">Main</div>

            <a asp-controller="Logistics" asp-action="Index"
               class="nav-item-link @(ctrl == "Logistics" && act == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>

            <!-- ── My Account ─────────────────── -->
            <div class="nav-label">My Account</div>

            <a asp-controller="Logistics" asp-action="RegisterVehicle"
               class="nav-item-link @(ctrl == "Logistics" && act == "RegisterVehicle" ? "active" : "")">
                <i class="bi bi-truck"></i>
                <span>Register Vehicle</span>
            </a>

            <a asp-controller="Logistics" asp-action="MyTransfers"
               class="nav-item-link @(ctrl == "Logistics" && act == "MyTransfers" ? "active" : "")">
                <i class="bi bi-arrow-left-right"></i>
                <span>My Transfers</span>
            </a>

            <a asp-controller="Logistics" asp-action="MyVehicles"
               class="nav-item-link @(ctrl == "Logistics" && act == "MyVehicles" ? "active" : "")">
                <i class="bi bi-car-front-fill"></i>
                <span>My Vehicles</span>
            </a>

            <!-- ── System ──────────────────────── -->
            <div class="nav-label">System</div>

            <a asp-controller="Admin" asp-action="Logout"
               class="nav-item-link text-danger-subtle">
                <i class="bi bi-box-arrow-left"></i>
                <span>Logout</span>
            </a>

        </div>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer d-flex align-items-center gap-2">
            <div class="user-avatar">
                @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "D")
            </div>
            <div class="user-info">
                <span>Driver</span>
                <small>@Context.Session.GetString("Username")</small>
            </div>
        </div>

    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- TOPBAR                                     -->
    <!-- ══════════════════════════════════════════ -->

    <div id="topbar">

        <!-- Toggle Button -->
        <button class="topbar-icon-btn me-3"
                onclick="toggleSidebar()"
                title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Page Title -->
        <div>
            <p class="topbar-title mb-0">@ViewData["Title"]</p>
            <p class="page-breadcrumb mb-0">
                Logistics &rsaquo; @ViewData["Title"]
            </p>
        </div>

        <!-- Right Side -->
        <div class="topbar-right">

            <!-- Full Screen -->
            <a class="topbar-icon-btn"
               onclick="toggleFullScreen()"
               title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </a>

            <!-- Date Badge -->
            <span class="badge bg-success bg-opacity-10 text-success fw-semibold px-3 py-2 d-none d-md-inline-flex align-items-center gap-1">
                <i class="bi bi-circle-fill" style="font-size:8px;"></i>
                Active Session
            </span>

            <!-- User Dropdown -->
            <div class="dropdown">
                <div class="topbar-avatar dropdown-toggle"
                     data-bs-toggle="dropdown"
                     aria-expanded="false"
                     title="Account">
                    @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "D")
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li>
                        <div class="px-3 py-2 border-bottom">
                            <p class="mb-0 fw-semibold text-dark small">Driver</p>
                            <p class="mb-0 text-muted" style="font-size:11px;">
                                @Context.Session.GetString("Username")
                            </p>
                        </div>
                    </li>
                    
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li>
                        <a class="dropdown-item small py-2 text-danger"
                           asp-controller="Admin" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                               -->
    <!-- ══════════════════════════════════════════ -->

    <div id="main-content">
        @RenderBody()
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- FOOTER                                     -->
    <!-- ══════════════════════════════════════════ -->

    <footer id="main-footer">
        <div class="d-flex justify-content-between w-100 align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year
                <strong class="text-primary">Dairy Management System</strong>
                &mdash; Logistics Module
            </small>
            <small class="text-muted">
                Version 1.0 &nbsp;|&nbsp;
                <span class="text-success fw-semibold">
                    <i class="bi bi-circle-fill" style="font-size:8px;"></i>
                    System Online
                </span>
            </small>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Admin Layout JS (same toggleSidebar / toggleFullScreen functions) -->
    <script src="~/js/admin-layout.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
