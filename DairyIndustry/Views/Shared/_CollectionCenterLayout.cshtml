<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DairyMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --nescafe-red: #E1261C;
            --nescafe-dark: #121212;
            --sidebar-width: 260px;
        }

        body {
            background-color: #f8f9fa;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- SIDEBAR --- */
        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: var(--nescafe-dark);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
            padding-top: 2rem;
        }

            #sidebar.collapsed {
                left: calc(var(--sidebar-width) * -1);
            }

        .sidebar-heading {
            padding: 0 1.5rem 2rem;
            font-weight: 800;
            font-size: 1.5rem;
            color: white;
            text-decoration: none;
            display: block;
        }

            .sidebar-heading span {
                color: var(--nescafe-red);
            }

        .nav-link-sidebar {
            color: #888;
            padding: 12px 25px;
            display: block;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .nav-link-sidebar:hover, .nav-link-sidebar.active {
                color: white;
                background: rgba(255,255,255,0.05);
                border-left: 4px solid var(--nescafe-red);
            }

        /* --- MAIN CONTENT --- */
        #content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

            #content-wrapper.full-width {
                margin-left: 0;
                width: 100%;
            }

        /* --- HEADER --- */
        .top-navbar {
            background: #fff;
            padding: 1rem 2rem;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .menu-toggle {
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--nescafe-dark);
        }

        .main-container {
            padding: 40px;
            flex: 1;
        }

        footer {
            background: #fff;
            border-top: 1px solid #eee;
            padding: 20px 0;
            text-align: center;
        }
    </style>
</head>
<body>

    <nav id="sidebar">
        <a class="sidebar-heading" href="#">DAIRY<span>MS</span></a>
        <a class="nav-link-sidebar active" asp-area="" asp-controller="CollectionCenter" asp-action="Dashboard"><i class="bi bi-grid-1x2 me-2"></i> Dashboard</a>
        <a class="nav-link-sidebar" href="#"><i class="bi bi-droplet me-2"></i> Milk Entry</a>
        <a class="nav-link-sidebar" asp-area="" asp-controller="CollectionCenter" asp-action="FarmersDashboard"><i class="bi bi-people me-2"></i> Farmers</a>
        <a class="nav-link-sidebar" href="#"><i class="bi bi-box-seam me-2"></i> Batches</a>
    </nav>

    <div id="content-wrapper">
   

        <header class="top-navbar">
            <div class="d-flex align-items-center">
                <div id="sidebarToggle" class="menu-toggle me-3">
                    <i class="bi bi-list"></i>
                </div>
                <h5 class="mb-0 fw-bold">Collection Center Dashboard</h5>
            </div>
            <div class="d-flex align-items-center">
                <div class="text-end me-3">
                    <small class="text-muted d-block" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">Name</small>
                    <span class="fw-bold">@Context.Session.GetString("Username")</span>
                </div>

                <a class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold"
                   asp-area="" asp-controller="Account" asp-action="LogOut">
                    <i class="bi bi-box-arrow-right me-1"></i> LogOut
                </a>
            </div>
        </header>

        <main class="main-container">
            @RenderBody()
        </main>

        <footer>
            <p class="text-secondary small mb-0">© 2026 Dairy Management System. All Rights Reserved.</p>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#sidebarToggle").click(function () {
                $("#sidebar").toggleClass("collapsed");
                $("#content-wrapper").toggleClass("full-width");
            });
        });
    </script>
</body>
</html>