<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DairyMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@@9..40,300;400;500;600;700&family=DM+Serif+Display:ital@@0;1&display=swap" rel="stylesheet">

    <style>
        :root {
            --blue-900: #0a2540;
            --blue-700: #1a4480;
            --blue-500: #1d6fce;
            --blue-300: #5ea3f0;
            --blue-100: #dbeafe;
            --blue-50:  #f0f7ff;
            --cream:    #f5f7fa;
            --ink:      #0f1923;
            --muted:    #6b7a8d;
            --border:   #e2e8f0;
            --white:    #ffffff;
            --sidebar-w: 252px;
            --header-h:  64px;
        }

        *, *::before, *::after { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            margin: 0;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ───────────────────────────────── */
        #sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: var(--blue-900);
            display: flex;
            flex-direction: column;
            z-index: 1050;
            transition: transform 0.28s cubic-bezier(.4,0,.2,1);
            overflow: hidden;
        }

        #sidebar.collapsed {
            transform: translateX(-100%);
        }

        /* brand */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 22px;
            height: var(--header-h);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            text-decoration: none;
            flex-shrink: 0;
        }

        .sidebar-brand-text {
            font-family: 'DM Serif Display', serif;
            font-size: 1.45rem;
            color: var(--white);
            letter-spacing: -0.3px;
        }

        .sidebar-brand-text em {
            font-style: italic;
            color: var(--blue-300);
        }

        /* section label */
        .sidebar-label {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255,255,255,0.3);
            padding: 20px 22px 6px;
        }

        /* nav items */
        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 8px 12px 12px;
            scrollbar-width: none;
        }

        .sidebar-nav::-webkit-scrollbar { display: none; }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 10px 14px;
            border-radius: 9px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            transition: background 0.15s, color 0.15s, transform 0.15s;
            margin-bottom: 2px;
        }

        .sidebar-link i {
            font-size: 1.05rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar-link:hover {
            background: rgba(255,255,255,0.08);
            color: var(--white);
            transform: translateX(3px);
        }

        .sidebar-link.active {
            background: var(--blue-500);
            color: var(--white);
            box-shadow: 0 4px 12px rgba(29,111,206,0.35);
        }

        .sidebar-link.active:hover {
            transform: none;
        }

        /* divider */
        .sidebar-divider {
            height: 1px;
            background: rgba(255,255,255,0.08);
            margin: 8px 12px;
        }

        /* footer area of sidebar */
        .sidebar-footer {
            padding: 14px 12px;
            border-top: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
        }

        /* ── CONTENT AREA ──────────────────────────── */
        #content-wrapper {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.28s cubic-bezier(.4,0,.2,1);
        }

        #content-wrapper.full-width {
            margin-left: 0;
        }

        /* ── TOP HEADER ────────────────────────────── */
        .top-header {
            height: var(--header-h);
            background: var(--white);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            position: sticky;
            top: 0;
            z-index: 900;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .sidebar-toggle-btn {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--muted);
            transition: background 0.15s, color 0.15s;
            flex-shrink: 0;
        }

        .sidebar-toggle-btn:hover {
            background: var(--blue-50);
            color: var(--blue-700);
        }

        .header-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--ink);
            margin: 0;
        }

        .header-subtitle {
            font-size: 0.78rem;
            color: var(--muted);
            margin: 0;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        /* user pill */
        .user-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--blue-50);
            border: 1px solid var(--blue-100);
            border-radius: 50px;
            padding: 6px 14px 6px 6px;
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--blue-500);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.8rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--ink);
        }

        .btn-logout {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #fff1f2;
            color: #be123c;
            border: 1px solid #fecdd3;
            border-radius: 9px;
            padding: 7px 16px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s, transform 0.15s;
        }

        .btn-logout:hover {
            background: #ffe4e6;
            color: #9f1239;
            transform: translateY(-1px);
        }

        /* ── MAIN CONTENT ──────────────────────────── */
        .main-container {
            flex: 1;
            padding: 28px 30px;
        }

        /* ── GLOBAL COMPONENT STYLES ───────────────── */
        .card {
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.05);
            background: var(--white);
        }

        .card-header {
            background: transparent;
            border-bottom: 1px solid var(--border);
            padding: 1.1rem 1.5rem;
            font-weight: 600;
            border-radius: 14px 14px 0 0 !important;
        }

        .btn {
            font-weight: 500;
            border-radius: 9px;
            font-size: 0.875rem;
            transition: all 0.15s;
        }

        .btn-primary { background: var(--blue-500); border-color: var(--blue-500); }
        .btn-primary:hover { background: var(--blue-700); border-color: var(--blue-700); transform: translateY(-1px); }
        .btn-success:hover, .btn-warning:hover, .btn-danger:hover, .btn-secondary:hover {
            transform: translateY(-1px); filter: brightness(0.92);
        }

        .alert { border: none; border-radius: 10px; font-size: 0.9rem; }
        .alert-success { background:#f0fdf4; color:#15803d; border-left:4px solid #16a34a; }
        .alert-danger  { background:#fff1f2; color:#be123c; border-left:4px solid #e11d48; }
        .alert-warning { background:#fffbeb; color:#b45309; border-left:4px solid #d97706; }
        .alert-info    { background:var(--blue-50); color:var(--blue-700); border-left:4px solid var(--blue-300); }

        .table { font-size: 0.9rem; }
        .table thead th {
            background: var(--blue-900);
            color: white;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: none;
            padding: 13px 16px;
        }
        .table thead th:first-child { border-radius: 10px 0 0 0; }
        .table thead th:last-child  { border-radius: 0 10px 0 0; }
        .table tbody td { padding: 12px 16px; vertical-align: middle; border-color: var(--border); }
        .table tbody tr:hover { background: var(--blue-50); }

        .form-control, .form-select {
            border-radius: 9px;
            border: 1px solid var(--border);
            font-size: 0.9rem;
            padding: 10px 14px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--blue-500);
            box-shadow: 0 0 0 3px rgba(29,111,206,0.12);
        }
        .form-label { font-size: 0.875rem; font-weight: 600; color: var(--ink); margin-bottom: 6px; }

        .badge { font-weight: 500; border-radius: 6px; padding: 4px 10px; font-size: 0.78rem; }

        /* ── FOOTER ────────────────────────────────── */
        .site-footer {
            background: var(--white);
            border-top: 1px solid var(--border);
            padding: 14px 30px;
            text-align: center;
        }

        .site-footer p {
            font-size: 0.8rem;
            color: var(--muted);
            margin: 0;
        }

        /* ── MOBILE OVERLAY ────────────────────────── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(10,37,64,0.45);
            z-index: 1040;
            backdrop-filter: blur(2px);
        }

        .sidebar-overlay.show { display: block; }

        @@media (max-width: 991px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.open { transform: translateX(0); }
            #content-wrapper { margin-left: 0 !important; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR OVERLAY (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- SIDEBAR -->
    <nav id="sidebar">

        <a class="sidebar-brand" href="#">
            <div class="sidebar-brand-text">Dairy<em>MS</em></div>
        </a>


        <!-- ONLY showing sidebar section (icons updated) -->

        <div class="sidebar-nav">

            <div class="sidebar-label">Main</div>

            <a class="sidebar-link active"
               asp-controller="CollectionCenter" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="sidebar-label">Farmer Management</div>

            <a class="sidebar-link"
               asp-controller="Farmer" asp-action="ListAllFarmers">
                <i class="bi bi-person-lines-fill"></i> Farmer List
            </a>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="PendingApprovals">
                <i class="bi bi-person-check-fill"></i> Approve/Reject
            </a>
            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="RejectedFarmersByCenter">
                <i class="bi bi-person-check-fill"></i> Rejected Farmers
            </a>
            <div class="sidebar-label">Milk Management</div>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="AddMilkCollection">
                <i class="bi bi-droplet-half"></i> Milk Entry
            </a>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="RateChart">
                <i class="bi bi-graph-up-arrow"></i> Rate Chart
            </a>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="Inventory">
                <i class="bi bi-box-seam"></i> Inventory
            </a>

            <div class="sidebar-label">Batch Management</div>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="BatchStatus">
                <i class="bi bi-calendar-check"></i> Batch Status
            </a>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="AllBatchDetails">
                <i class="bi bi-calendar-check"></i>All Batches
            </a>
            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="AllMilkEntriesCenter">
                <i class="bi bi-table"></i> All Milk Entries
            </a>
           
            <div class="sidebar-label">Transfer Management</div>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="Dispatch">
                <i class="bi bi-truck"></i> Dispatch Milk
            </a>

            <a class="sidebar-link"
               asp-controller="CollectionCenter" asp-action="DispatchHistory">
                <i class="bi bi-clock-history"></i> Dispatch Milk History
            </a>
     
        </div>

        <!-- Sidebar bottom user info -->
        <div class="sidebar-footer">
            <div style="display:flex;align-items:center;gap:10px;">
                <div class="user-avatar" style="width:34px;height:34px;font-size:0.85rem;">
                    @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "?")
                </div>
                <div style="overflow:hidden;">
                    <div style="font-size:0.82rem;font-weight:600;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                        @Context.Session.GetString("Username")
                    </div>
                    <div style="font-size:0.72rem;color:rgba(255,255,255,0.4);">Collection Agent</div>
                </div>
            </div>
        </div>

    </nav>

    <!-- CONTENT WRAPPER -->
    <div id="content-wrapper">

        <!-- TOP HEADER -->
        <header class="top-header">
            <div class="header-left">
                <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
                    <i class="bi bi-list" style="font-size:1.1rem;"></i>
                </button>
                <div>
                    <p class="header-title">@(ViewData["Title"] ?? "Collection Center")</p>
                    <p class="header-subtitle">Dairy Management System</p>
                </div>
            </div>

            <div class="header-right">
                <div class="user-pill d-none d-md-flex">
                    <div class="user-avatar">
                        @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "?")
                    </div>
                    <span class="user-name">@Context.Session.GetString("Username")</span>
                </div>

                <a class="btn-logout"
                   asp-controller="Admin"
                   asp-action="LogOut">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="d-none d-sm-inline">Logout</span>
                </a>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="main-container">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="site-footer">
            <p>© 2026 Dairy Management System. All rights reserved.</p>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const sidebar      = document.getElementById('sidebar');
        const wrapper      = document.getElementById('content-wrapper');
        const toggleBtn    = document.getElementById('sidebarToggle');
        const overlay      = document.getElementById('sidebarOverlay');
        const isDesktop    = () => window.innerWidth >= 992;

        function openSidebar() {
            if (isDesktop()) {
                sidebar.classList.remove('collapsed');
                wrapper.classList.remove('full-width');
            } else {
                sidebar.classList.add('open');
                overlay.classList.add('show');
            }
        }

        function closeSidebar() {
            if (isDesktop()) {
                sidebar.classList.add('collapsed');
                wrapper.classList.add('full-width');
            } else {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            }
        }

        toggleBtn.addEventListener('click', () => {
            const desktopCollapsed = isDesktop() && sidebar.classList.contains('collapsed');
            const mobileOpen       = !isDesktop() && sidebar.classList.contains('open');

            if (desktopCollapsed || (!isDesktop() && !mobileOpen)) {
                openSidebar();
            } else {
                closeSidebar();
            }
        });

        overlay.addEventListener('click', closeSidebar);

        // Highlight active link
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar-link').forEach(link => {
            link.classList.remove('active');
            const href = link.getAttribute('href')?.toLowerCase() ?? '';
            if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
