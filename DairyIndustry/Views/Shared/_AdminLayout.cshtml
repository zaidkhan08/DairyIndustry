<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dairy Management System</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Admin Layout CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />

</head>
<body>

    <!-- ══════════════════════════════════════════ -->
    <!-- SIDEBAR                                    -->
    <!-- ══════════════════════════════════════════ -->

    <div id="sidebar">

        <!-- Brand -->
        <a class="sidebar-brand" asp-controller="Admin" asp-action="Index">
            <div class="brand-icon">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <div class="brand-text">
                <span>DairyManage</span>
                <small>Management System</small>
            </div>
        </a>

        <!-- Nav -->
        <div class="sidebar-nav">

            <!-- ── Main ────────────────────────── -->
            <div class="nav-label">Main</div>

            <a asp-controller="Admin" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" && ViewContext.RouteData.Values["controller"].ToString() == "Admin" ? "active" : "")">
                <i class="bi bi-grid-fill"></i>
                <span>Dashboard</span>
            </a>

            <!-- ── User Management ─────────────── -->
            <div class="nav-label">User Management</div>

            <a asp-controller="Admin" asp-action="Users"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Users" ? "active" : "")">
                <i class="bi bi-people-fill"></i>
                <span>All Users</span>
            </a>

            <a asp-controller="Admin" asp-action="RegisterUser"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "RegisterUser" ? "active" : "")">
                <i class="bi bi-person-plus-fill"></i>
                <span>Register User</span>
            </a>

            <a asp-controller="Admin" asp-action="Roles"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Roles" ? "active" : "")">
                <i class="bi bi-shield-fill"></i>
                <span>Roles</span>
            </a>

            <a asp-controller="Admin" asp-action="Staff"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Staff" || ViewContext.RouteData.Values["action"].ToString() == "AddStaff" ? "active" : "")">
                <i class="bi bi-briefcase-fill"></i>
                <span>Staff</span>
            </a>
            <!-- ── Master Data ─────────────────── -->
            <div class="nav-label">Master Data</div>

            <a asp-controller="Admin" asp-action="Location"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Location" ? "active" : "")">
                <i class="bi bi-geo-alt-fill"></i>
                <span>Location</span>
            </a>

            <a asp-controller="Admin" asp-action="MilkTypes"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "MilkTypes" ? "active" : "")">
                <i class="bi bi-droplet-half"></i>
                <span>Milk Types</span>
            </a>

            <a asp-controller="Admin" asp-action="RateChart"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "RateChart" ? "active" : "")">
                <i class="bi bi-cash-stack"></i>
                <span>Rate Chart</span>
            </a>

            <a asp-controller="Admin" asp-action="GetAllPlants"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "GetAllPlants" || ViewContext.RouteData.Values["action"].ToString() == "AddPlant" ? "active" : "")">
                <i class="bi bi-building-fill"></i>
                <span>Processing Plants</span>
            </a>
            <!-- ── System ──────────────────────── -->
            <div class="nav-label">System</div>

            <a asp-controller="Admin" asp-action="AuditLogs"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "AuditLogs" ? "active" : "")">
                <i class="bi bi-clock-history"></i>
                <span>Audit Logs</span>
            </a>

            <!-- ── Modules ─────────────────────── -->
            <div class="nav-label">Modules</div>

            <div class="nav-label">Logistics</div>

            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#logisticsMenu"
               role="button"
               aria-expanded="@(ViewContext.RouteData.Values["controller"].ToString() == "Logistics" ? "true" : "false")">
                <span>
                    <i class="bi bi-truck-front-fill me-2"></i>Logistics
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(ViewContext.RouteData.Values["controller"].ToString() == "Logistics" ? "show" : "")"
                 id="logisticsMenu">

                <a asp-controller="Logistics" asp-action="AllDrivers"
                   class="nav-item-link ps-4 @(ViewContext.RouteData.Values["controller"].ToString() == "Logistics" &&
                                (ViewContext.RouteData.Values["action"].ToString() == "AllDrivers" ||
                                 ViewContext.RouteData.Values["action"].ToString() == "UpdateDriverStatus") ? "active" : "")">
                    <i class="bi bi-person-badge-fill me-2"></i>
                    <span>Drivers</span>
                </a>

                <a asp-controller="Logistics" asp-action="AllVehicles"
                   class="nav-item-link ps-4 @(ViewContext.RouteData.Values["controller"].ToString() == "Logistics" &&
                                (ViewContext.RouteData.Values["action"].ToString() == "AllVehicles" ||
                                 ViewContext.RouteData.Values["action"].ToString() == "UpdateVehicleStatus") ? "active" : "")">
                    <i class="bi bi-truck me-2"></i>
                    <span>Vehicles</span>
                </a>

            </div>

            <a asp-controller="Farmer" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "Farmer" ? "active" : "")">
                <i class="bi bi-person-badge-fill"></i>
                <span>Farmers</span>
            </a>

            <a asp-controller="Collection" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "Collection" ? "active" : "")">
                <i class="bi bi-bucket-fill"></i>
                <span>Collection</span>
            </a>

            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#productionMenu"
               role="button"
               aria-expanded="@(ViewContext.RouteData.Values["controller"].ToString() == "Admin" ? "true" : "false")">
                <span>
                    <i class="bi bi-gear-fill me-2"></i>Production
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" ? "show" : "")"
                 id="productionMenu">

                <a asp-controller="Admin" asp-action="Products"
                   class="nav-item-link ps-4 @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" &&
                                       ViewContext.RouteData.Values["action"].ToString() == "Products" ||
                                       ViewContext.RouteData.Values["action"].ToString() == "AddProduct" ||
                                       ViewContext.RouteData.Values["action"].ToString() == "EditProduct" ||
                                       ViewContext.RouteData.Values["action"].ToString() == "ProductDetail" ? "active" : "")">
                    <i class="bi bi-box-seam me-2"></i>
                    <span>Products</span>
                </a>

                <a asp-controller="Admin" asp-action="ProductionBatches"
                   class="nav-item-link ps-4 @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" &&
                                       ViewContext.RouteData.Values["action"].ToString() == "ProductionBatches" ? "active" : "")">
                    <i class="bi bi-layers me-2"></i>
                    <span>Production Batches</span>
                </a>

                <a asp-controller="Admin" asp-action="MilkTransfers"
                   class="nav-item-link ps-4 @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" &&
                                       ViewContext.RouteData.Values["action"].ToString() == "MilkTransfers" ? "active" : "")">
                    <i class="bi bi-arrow-left-right me-2"></i>
                    <span>Milk Transfers</span>
                </a>

            </div>

            <a asp-controller="Sales" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "Sales" ? "active" : "")">
                <i class="bi bi-cart-fill"></i>
                <span>Sales</span>
            </a>

            <a asp-controller="Finance" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "Finance" ? "active" : "")">
                <i class="bi bi-cash-stack"></i>
                <span>Finance</span>
            </a>

            <a asp-controller="HR" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "HR" ? "active" : "")">
                <i class="bi bi-briefcase-fill"></i>
                <span>HR</span>
            </a>

            <a asp-controller="Reports" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"].ToString() == "Reports" ? "active" : "")">
                <i class="bi bi-bar-chart-fill"></i>
                <span>Reports</span>
            </a>

        </div>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer d-flex align-items-center gap-2">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <span>@Context.Session.GetString("RoleName")</p></span>
                <small>@Context.Session.GetString("Username")</small>
            </div>
        </div>

    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- TOPBAR                                     -->
    <!-- ══════════════════════════════════════════ -->

    <div id="topbar">

        <!-- Toggle Button -->
        <button class="topbar-icon-btn me-3"
                onclick="toggleSidebar()"
                title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Page Title -->
        <div>
            <p class="topbar-title mb-0">@ViewData["Title"]</p>
            <p class="page-breadcrumb mb-0">
                Admin &rsaquo; @ViewData["Title"]
            </p>
        </div>

        <!-- Right Side -->
        <div class="topbar-right">

            <!-- Full Screen -->
            <a class="topbar-icon-btn"
               onclick="toggleFullScreen()"
               title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </a>

            <!-- Notifications -->
            <a class="topbar-icon-btn position-relative"
               href="#"
               title="Notifications">
                <i class="bi bi-bell-fill"></i>
                <span class="position-absolute top-0 end-0 translate-middle
                             badge rounded-pill bg-danger"
                      style="font-size:9px; padding:3px 5px;">
                    3
                </span>
            </a>

            <!-- User Dropdown -->
            <div class="dropdown">
                <div class="topbar-avatar dropdown-toggle"
                     data-bs-toggle="dropdown"
                     aria-expanded="false"
                     title="Account">
                    A
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li>
                        <div class="px-3 py-2 border-bottom">
                            <p class="mb-0 fw-semibold text-dark small">@Context.Session.GetString("RoleName")</p>
                            <p class="mb-0 text-muted" style="font-size:11px;">
                                @Context.Session.GetString("Username")
                            </p>
                        </div>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-person me-2 text-primary"></i> My Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-gear me-2 text-secondary"></i> Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li>
                        <a class="dropdown-item small py-2 text-danger"
                           asp-controller="Admin" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                               -->
    <!-- ══════════════════════════════════════════ -->

    <div id="main-content">
        @RenderBody()
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- FOOTER                                     -->
    <!-- ══════════════════════════════════════════ -->

    <footer id="main-footer">
        <div class="d-flex justify-content-between w-100 align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year
                <strong class="text-primary">Dairy Management System</strong>
                — All rights reserved
            </small>
            <small class="text-muted">
                Version 1.0 &nbsp;|&nbsp;
                <span class="text-success fw-semibold">
                    <i class="bi bi-circle-fill" style="font-size:8px;"></i>
                    System Online
                </span>
            </small>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Admin Layout JS -->
    <script src="~/js/admin-layout.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>