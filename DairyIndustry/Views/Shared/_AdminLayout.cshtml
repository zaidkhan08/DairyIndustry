

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dairy Management System</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Admin Layout CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />

    <!-- Notification CSS -->
    <link rel="stylesheet" href="~/css/admin-notifications.css" />

</head>
<body>

    <!-- ══════════════════════════════════════════ -->
    <!-- SIDEBAR                                    -->
    <!-- ══════════════════════════════════════════ -->

    <div id="sidebar">

        <!-- Brand -->
        <a class="sidebar-brand" asp-controller="Admin" asp-action="Index">
            <div class="brand-icon">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <div class="brand-text">
                <span>DairyManage</span>
                <small>Management System</small>
            </div>
        </a>

        <!-- Nav -->
        <div class="sidebar-nav">

            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var act = ViewContext.RouteData.Values["action"]?.ToString();
            }

            <!-- ── Main ────────────────────────── -->
            <div class="nav-label">Main</div>

            <a asp-controller="Admin" asp-action="Index"
               class="nav-item-link @(ctrl == "Admin" && act == "Index" ? "active" : "")">
                <i class="bi bi-grid-fill"></i>
                <span>Dashboard</span>
            </a>

            <!-- ── User Management ─────────────── -->
            <div class="nav-label">User Management</div>

            <a asp-controller="Admin" asp-action="Users"
               class="nav-item-link @(ctrl == "Admin" && act == "Users" ? "active" : "")">
                <i class="bi bi-people-fill"></i>
                <span>All Users</span>
            </a>

            <a asp-controller="Admin" asp-action="RegisterUser"
               class="nav-item-link @(ctrl == "Admin" && act == "RegisterUser" ? "active" : "")">
                <i class="bi bi-person-plus-fill"></i>
                <span>Register User</span>
            </a>

            <a asp-controller="Admin" asp-action="Roles"
               class="nav-item-link @(ctrl == "Admin" && act == "Roles" ? "active" : "")">
                <i class="bi bi-shield-fill"></i>
                <span>Roles</span>
            </a>

            <a asp-controller="Admin" asp-action="Staff"
               class="nav-item-link @(ctrl == "Admin" && (act == "Staff" || act == "AddStaff" || act == "GetStaffById") ? "active" : "")">
                <i class="bi bi-briefcase-fill"></i>
                <span>Staff</span>
            </a>

            <a asp-controller="Admin" asp-action="AssignUserToPlant"
               class="nav-item-link @(ctrl == "Admin" && act == "AssignUserToPlant" ? "active" : "")">
                <i class="bi bi-building-up"></i>
                <span>Assign to Plant</span>
            </a>

            <a asp-controller="Admin" asp-action="AssignUserToCenter"
               class="nav-item-link @(ctrl == "Admin" && act == "AssignUserToCenter" ? "active" : "")">
                <i class="bi bi-house-check-fill"></i>
                <span>Assign to Center</span>
            </a>

            <!-- ── Master Data ─────────────────── -->
            <div class="nav-label">Master Data</div>

            <a asp-controller="Admin" asp-action="Location"
               class="nav-item-link @(ctrl == "Admin" && act == "Location" ? "active" : "")">
                <i class="bi bi-geo-alt-fill"></i>
                <span>Location</span>
            </a>

            <a asp-controller="Admin" asp-action="MilkTypes"
               class="nav-item-link @(ctrl == "Admin" && act == "MilkTypes" ? "active" : "")">
                <i class="bi bi-droplet-half"></i>
                <span>Milk Types</span>
            </a>

            <a asp-controller="Admin" asp-action="RateChart"
               class="nav-item-link @(ctrl == "Admin" && act == "RateChart" ? "active" : "")">
                <i class="bi bi-cash-stack"></i>
                <span>Rate Chart</span>
            </a>

            <!-- Processing Plants -->
            <a asp-controller="Admin" asp-action="GetAllPlants"
               class="nav-item-link @(ctrl == "Admin" && (act == "GetAllPlants" || act == "AddPlant" || act == "EditPlant") ? "active" : "")">
                <i class="bi bi-building-fill"></i>
                <span>Processing Plants</span>
            </a>

            <!-- Collection Centers -->
            <a asp-controller="Admin" asp-action="GetAllCollection"
               class="nav-item-link @(ctrl == "Admin" && (act == "GetAllCollection" || act == "AddCollection" || act == "EditCollection") ? "active" : "")">
                <i class="bi bi-bucket-fill"></i>
                <span>Collection Centers</span>
            </a>

            <!-- ── Modules ─────────────────────── -->
            <div class="nav-label">Modules</div>

            <!-- Farmers -->
            <a asp-controller="Farmer" asp-action="Index"
               class="nav-item-link @(ctrl == "Farmer" ? "active" : "")">
                <i class="bi bi-person-badge-fill"></i>
                <span>Farmers</span>
            </a>

            <!-- Logistics submenu -->
            @{
                bool logisticsOpen = ctrl == "Logistics";
            }
            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#logisticsMenu"
               role="button"
               aria-expanded="@(logisticsOpen ? "true" : "false")">
                <span>
                    <i class="bi bi-truck-front-fill me-2"></i>Logistics
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(logisticsOpen ? "show" : "")" id="logisticsMenu">

                <a asp-controller="Logistics" asp-action="AllDrivers"
                   class="nav-item-link ps-4 @(ctrl == "Logistics" && (act == "AllDrivers" || act == "UpdateDriverStatus") ? "active" : "")">
                    <i class="bi bi-person-badge-fill me-2"></i>
                    <span>Drivers</span>
                </a>

                <a asp-controller="Logistics" asp-action="AllVehicles"
                   class="nav-item-link ps-4 @(ctrl == "Logistics" && (act == "AllVehicles" || act == "UpdateVehicleStatus") ? "active" : "")">
                    <i class="bi bi-truck me-2"></i>
                    <span>Vehicles</span>
                </a>

            </div>

            <!-- Production submenu -->
            @{
                var productionActions = new[] {
                        "Products", "AddProduct", "EditProduct", "ProductDetail",
                        "ProductionBatches", "WastageSummary", "MilkTransfers"
                        };
                bool productionOpen = ctrl == "Admin" && productionActions.Contains(act);
            }
            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#productionMenu"
               role="button"
               aria-expanded="@(productionOpen ? "true" : "false")">
                <span>
                    <i class="bi bi-gear-fill me-2"></i>Production
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(productionOpen ? "show" : "")" id="productionMenu">

                <a asp-controller="Admin" asp-action="Products"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && (act == "Products" || act == "AddProduct" || act == "EditProduct" || act == "ProductDetail") ? "active" : "")">
                    <i class="bi bi-box-seam me-2"></i>
                    <span>Products</span>
                </a>

                <a asp-controller="Admin" asp-action="ProductionBatches"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "ProductionBatches" ? "active" : "")">
                    <i class="bi bi-layers me-2"></i>
                    <span>Production Batches</span>
                </a>

                <a asp-controller="Admin" asp-action="WastageSummary"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "WastageSummary" ? "active" : "")">
                    <i class="bi bi-trash3-fill me-2"></i>
                    <span>Wastage</span>
                </a>

                <a asp-controller="Admin" asp-action="MilkTransfers"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "MilkTransfers" ? "active" : "")">
                    <i class="bi bi-arrow-left-right me-2"></i>
                    <span>Milk Transfers</span>
                </a>

            </div>

            <!-- Distributors + Orders submenu -->
            @{
                var distributorActions = new[] {
                        "Distributors", "AddDistributor",
                        "PendingDistributors", "UpdateDistributorStatus",
                        "AdminOrder", "AdminOrderList", "UpdateOrderStatus"
                        };
                bool distributorsOpen = ctrl == "Admin" && distributorActions.Contains(act);
            }
            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#distributorMenu"
               role="button"
               aria-expanded="@(distributorsOpen ? "true" : "false")">
                <span>
                    <i class="bi bi-diagram-3-fill me-2"></i>Distributors
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(distributorsOpen ? "show" : "")" id="distributorMenu">

                <a asp-controller="Admin" asp-action="Distributors"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "Distributors" ? "active" : "")">
                    <i class="bi bi-people-fill me-2"></i>
                    <span>All Distributors</span>
                </a>

                <a asp-controller="Admin" asp-action="PendingDistributors"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && (act == "PendingDistributors" || act == "UpdateDistributorStatus") ? "active" : "")">
                    <i class="bi bi-hourglass-split me-2"></i>
                    <span>Pending Approvals</span>
                </a>

                <a asp-controller="Admin" asp-action="AddDistributor"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "AddDistributor" ? "active" : "")">
                    <i class="bi bi-person-plus-fill me-2"></i>
                    <span>Add Distributor</span>
                </a>

                <!-- Orders nested under Distributors -->
                <div class="nav-label ps-4 mt-1" style="font-size:10px; opacity:0.6; letter-spacing:.06em;">
                    Orders
                </div>

                <a asp-controller="Admin" asp-action="AdminOrderList"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && (act == "AdminOrderList" || act == "UpdateOrderStatus") ? "active" : "")">
                    <i class="bi bi-list-check me-2"></i>
                    <span>All Orders</span>
                </a>

                <a asp-controller="Admin" asp-action="AdminOrder"
                   class="nav-item-link ps-4 @(ctrl == "Admin" && act == "AdminOrder" ? "active" : "")">
                    <i class="bi bi-cart-plus-fill me-2"></i>
                    <span>Place Order</span>
                </a>

            </div>

            <!-- Collection / Center Payment -->
            <a asp-controller="Finance" asp-action="CenterPayments"
               class="nav-item-link @(ctrl == "Finance" && act == "CenterPayments" ? "active" : "")">
                <i class="bi bi-bucket-fill"></i>
                <span>Center Payment</span>
            </a>

            <!-- Finance submenu -->
            @{
                var financeActions = new[] { "Index", "FarmerPayments", "StaffPayments" };
                bool financeOpen = ctrl == "Finance" && financeActions.Contains(act);
            }
            <a class="nav-item-link d-flex align-items-center justify-content-between"
               data-bs-toggle="collapse"
               href="#financeMenu"
               role="button"
               aria-expanded="@(financeOpen ? "true" : "false")">
                <span>
                    <i class="bi bi-cash-stack me-2"></i>Finance
                </span>
                <i class="bi bi-chevron-down small"></i>
            </a>

            <div class="collapse @(financeOpen ? "show" : "")" id="financeMenu">

                <a asp-controller="Finance" asp-action="Index"
                   class="nav-item-link ps-4 @(ctrl == "Finance" && act == "Index" ? "active" : "")">
                    <i class="bi bi-grid me-2"></i>
                    <span>Overview</span>
                </a>

                <a asp-controller="Finance" asp-action="FarmerPayments"
                   class="nav-item-link ps-4 @(ctrl == "Finance" && act == "FarmerPayments" ? "active" : "")">
                    <i class="bi bi-person-check-fill me-2"></i>
                    <span>Farmer Payments</span>
                </a>

                <a asp-controller="Finance" asp-action="StaffPayments"
                   class="nav-item-link ps-4 @(ctrl == "Finance" && act == "StaffPayments" ? "active" : "")">
                    <i class="bi bi-briefcase me-2"></i>
                    <span>Staff Payments</span>
                </a>

            </div>

            <!-- HR -->
            <a asp-controller="HR" asp-action="Index"
               class="nav-item-link @(ctrl == "HR" ? "active" : "")">
                <i class="bi bi-people-fill"></i>
                <span>HR</span>
            </a>

            <!-- Reports -->
            <a asp-controller="Reports" asp-action="Index"
               class="nav-item-link @(ctrl == "Reports" ? "active" : "")">
                <i class="bi bi-bar-chart-fill"></i>
                <span>Reports</span>
            </a>

            <!-- ── System ──────────────────────── -->
            <div class="nav-label">System</div>

            <a asp-controller="Admin" asp-action="AuditLogs"
               class="nav-item-link @(ctrl == "Admin" && act == "AuditLogs" ? "active" : "")">
                <i class="bi bi-clock-history"></i>
                <span>Audit Logs</span>
            </a>

        </div>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer d-flex align-items-center gap-2">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <span>@Context.Session.GetString("RoleName")</span>
                <small>@Context.Session.GetString("Username")</small>
            </div>
        </div>

    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- TOPBAR                                     -->
    <!-- ══════════════════════════════════════════ -->

    <div id="topbar">

        <!-- Toggle Button -->
        <button class="topbar-icon-btn me-3"
                onclick="toggleSidebar()"
                title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Page Title -->
        <div>
            <p class="topbar-title mb-0">@ViewData["Title"]</p>
            <p class="page-breadcrumb mb-0">
                Admin &rsaquo; @ViewData["Title"]
            </p>
        </div>

        <!-- Right Side -->
        <div class="topbar-right">

            <!-- Full Screen -->
            <a class="topbar-icon-btn"
               onclick="toggleFullScreen()"
               title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </a>

            <!-- ═══════════════════════════════════════ -->
            <!-- NOTIFICATIONS BELL                      -->
            <!-- ═══════════════════════════════════════ -->
            <div class="dropdown">
                <a class="topbar-icon-btn position-relative"
                   href="#"
                   title="Notifications"
                   id="notifBell"
                   data-bs-toggle="dropdown"
                   data-bs-auto-close="outside"
                   aria-expanded="false">
                    <i class="bi bi-bell-fill"></i>
                    <span id="notif-badge"
                          class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger"
                          style="font-size:9px; padding:3px 5px; display:none;">0</span>
                </a>

                <div class="dropdown-menu dropdown-menu-end p-0 notif-dropdown-menu"
                     aria-labelledby="notifBell">

                    <!-- Header -->
                    <div class="notif-header">
                        <span class="notif-header-title">Notifications</span>
                        <span id="notif-badge-header" class="badge bg-danger" style="font-size:10px;">0</span>
                    </div>

                    <!-- Filter Tabs -->
                    <div class="notif-tabs">
                        <button class="notif-tab active" data-sev="all">All</button>
                        <button class="notif-tab notif-tab-danger" data-sev="danger">Urgent</button>
                        <button class="notif-tab notif-tab-warning" data-sev="warning">Warning</button>
                        <button class="notif-tab notif-tab-info" data-sev="info">Info</button>
                    </div>

                    <!-- List -->
                    <div id="notif-list" class="notif-list">
                        <div class="notif-loading">
                            <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                            <div>Loading...</div>
                        </div>
                    </div>

                </div>
            </div>
            <!-- ═══════════════════════════════════════ -->
            <!-- User Dropdown -->
            <div class="dropdown">
                <div class="topbar-avatar dropdown-toggle"
                     data-bs-toggle="dropdown"
                     aria-expanded="false"
                     title="Account">
                    A
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li>
                        <div class="px-3 py-2 border-bottom">
                            <p class="mb-0 fw-semibold text-dark small">@Context.Session.GetString("RoleName")</p>
                            <p class="mb-0 text-muted" style="font-size:11px;">
                                @Context.Session.GetString("Username")
                            </p>
                        </div>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-person me-2 text-primary"></i> My Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-gear me-2 text-secondary"></i> Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li>
                        <a class="dropdown-item small py-2 text-danger"
                           asp-controller="Admin" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                               -->
    <!-- ══════════════════════════════════════════ -->

    <div id="main-content">
        @RenderBody()
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- FOOTER                                     -->
    <!-- ══════════════════════════════════════════ -->

    <footer id="main-footer">
        <div class="d-flex justify-content-between w-100 align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year
                <strong class="text-primary">Dairy Management System</strong>
                — All rights reserved
            </small>
            <small class="text-muted">
                Version 1.0 &nbsp;|&nbsp;
                <span class="text-success fw-semibold">
                    <i class="bi bi-circle-fill" style="font-size:8px;"></i>
                    System Online
                </span>
            </small>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Admin Layout JS -->
    <script src="~/js/admin-layout.js"></script>

    <!-- Notification JS -->
    <script src="~/js/admin-notifications.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
