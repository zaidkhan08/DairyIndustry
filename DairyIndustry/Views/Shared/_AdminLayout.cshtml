        @RenderBody()
    </main>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- FOOTER                                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <footer id="main-footer" role="contentinfo">
        <div class="d-flex justify-content-between w-100 align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year
                <strong style="color: #2563eb; font-weight:600;">Dairy Management System</strong>
            </small>
            <small class="text-muted d-flex align-items-center gap-2">
                <span style="font-family:'DM Mono',monospace; font-size:11px;">v1.0.0</span>
                <span class="d-flex align-items-center gap-1" style="color: #059669;">
                    <i class="bi bi-circle-fill" style="font-size:6px;" aria-hidden="true"></i>
                    <span style="font-size:11px;">Online</span>
                </span>
            </small>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Admin Layout JS -->
    <script src="~/js/admin-layout.js" asp-append-version="true"></script>

    <!-- Notification JS -->
    <script src="~/js/admin-notifications.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
