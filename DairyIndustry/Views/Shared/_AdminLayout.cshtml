<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Dairy Management System</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        /* ── Root Variables ───────────────────────── */
        :root {
            --sidebar-width     : 260px;
            --sidebar-bg        : #0f172a;
            --sidebar-hover     : #1e293b;
            --sidebar-active    : #2563eb;
            --sidebar-text      : #94a3b8;
            --sidebar-text-hover: #f1f5f9;
            --topbar-height     : 65px;
            --footer-height     : 55px;
        }

        /* ── Base ─────────────────────────────────── */
        body {
            background-color : #f1f5f9;
            font-family      : 'Segoe UI', sans-serif;
            overflow-x       : hidden;
        }

        /* ── Sidebar ──────────────────────────────── */
        #sidebar {
            width            : var(--sidebar-width);
            min-height       : 100vh;
            background       : var(--sidebar-bg);
            position         : fixed;
            top              : 0;
            left             : 0;
            z-index          : 1000;
            transition       : width 0.3s ease;
            display          : flex;
            flex-direction   : column;
        }

        /* Brand */
        .sidebar-brand {
            height          : var(--topbar-height);
            display         : flex;
            align-items     : center;
            padding         : 0 20px;
            background      : #0a1120;
            border-bottom   : 1px solid #1e293b;
            text-decoration : none;
        }

        .sidebar-brand .brand-icon {
            width           : 38px;
            height          : 38px;
            background      : var(--sidebar-active);
            border-radius   : 10px;
            display         : flex;
            align-items     : center;
            justify-content : center;
            font-size       : 18px;
            color           : #fff;
            flex-shrink     : 0;
        }

        .sidebar-brand .brand-text {
            margin-left  : 12px;
            line-height  : 1.2;
        }

        .sidebar-brand .brand-text span {
            display     : block;
            color       : #f1f5f9;
            font-weight : 700;
            font-size   : 14px;
        }

        .sidebar-brand .brand-text small {
            color     : var(--sidebar-text);
            font-size : 11px;
        }

        /* Nav Section Label */
        .nav-label {
            padding     : 18px 20px 6px;
            font-size   : 10px;
            font-weight : 700;
            letter-spacing : 1.2px;
            color       : #475569;
            text-transform : uppercase;
        }

        /* Nav Items */
        .sidebar-nav {
            padding    : 8px 12px;
            flex       : 1;
            overflow-y : auto;
        }

        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }

        .nav-item-link {
            display         : flex;
            align-items     : center;
            padding         : 10px 14px;
            border-radius   : 8px;
            color           : var(--sidebar-text);
            text-decoration : none;
            font-size       : 14px;
            font-weight     : 500;
            margin-bottom   : 2px;
            transition      : all 0.2s ease;
        }

        .nav-item-link i {
            font-size   : 17px;
            width       : 22px;
            flex-shrink : 0;
        }

        .nav-item-link span {
            margin-left : 12px;
        }

        .nav-item-link:hover {
            background : var(--sidebar-hover);
            color      : var(--sidebar-text-hover);
        }

        .nav-item-link.active {
            background : var(--sidebar-active);
            color      : #ffffff;
            box-shadow : 0 4px 12px rgba(37, 99, 235, 0.35);
        }

        .nav-item-link .nav-badge {
            margin-left  : auto;
            font-size    : 10px;
            padding      : 2px 7px;
            border-radius: 20px;
            background   : #1e293b;
            color        : #94a3b8;
        }

        .nav-item-link.active .nav-badge {
            background : rgba(255,255,255,0.2);
            color      : #fff;
        }

        /* Sidebar Footer (user info) */
        .sidebar-footer {
            padding       : 14px 16px;
            border-top    : 1px solid #1e293b;
            background    : #0a1120;
        }

        .sidebar-footer .user-avatar {
            width           : 36px;
            height          : 36px;
            border-radius   : 50%;
            background      : var(--sidebar-active);
            display         : flex;
            align-items     : center;
            justify-content : center;
            color           : #fff;
            font-weight     : 700;
            font-size       : 14px;
            flex-shrink     : 0;
        }

        .sidebar-footer .user-info span {
            display     : block;
            font-size   : 13px;
            color       : #f1f5f9;
            font-weight : 600;
        }

        .sidebar-footer .user-info small {
            font-size : 11px;
            color     : var(--sidebar-text);
        }

        /* ── Topbar ───────────────────────────────── */
        #topbar {
            height          : var(--topbar-height);
            background      : #ffffff;
            border-bottom   : 1px solid #e2e8f0;
            position        : fixed;
            top             : 0;
            left            : var(--sidebar-width);
            right           : 0;
            z-index         : 999;
            display         : flex;
            align-items     : center;
            padding         : 0 24px;
            box-shadow      : 0 1px 4px rgba(0,0,0,0.06);
            transition      : left 0.3s ease;
        }

        .topbar-title {
            font-size   : 16px;
            font-weight : 600;
            color       : #1e293b;
            margin      : 0;
        }

        .topbar-right {
            margin-left     : auto;
            display         : flex;
            align-items     : center;
            gap             : 12px;
        }

        .topbar-icon-btn {
            width           : 38px;
            height          : 38px;
            border-radius   : 50%;
            background      : #f1f5f9;
            border          : none;
            display         : flex;
            align-items     : center;
            justify-content : center;
            color           : #64748b;
            font-size       : 17px;
            cursor          : pointer;
            transition      : background 0.2s;
            text-decoration : none;
        }

        .topbar-icon-btn:hover {
            background : #e2e8f0;
            color      : #1e293b;
        }

        .topbar-avatar {
            width           : 38px;
            height          : 38px;
            border-radius   : 50%;
            background      : var(--sidebar-active);
            display         : flex;
            align-items     : center;
            justify-content : center;
            color           : #fff;
            font-weight     : 700;
            font-size       : 14px;
            cursor          : pointer;
        }

        /* ── Main Content ─────────────────────────── */
        #main-content {
            margin-left  : var(--sidebar-width);
            margin-top   : var(--topbar-height);
            min-height   : calc(100vh - var(--topbar-height) - var(--footer-height));
            padding      : 24px;
            transition   : margin-left 0.3s ease;
        }

        /* ── Footer ───────────────────────────────── */
        #main-footer {
            margin-left  : var(--sidebar-width);
            height       : var(--footer-height);
            background   : #ffffff;
            border-top   : 1px solid #e2e8f0;
            display      : flex;
            align-items  : center;
            padding      : 0 24px;
            transition   : margin-left 0.3s ease;
        }

        /* ── Collapsed Sidebar ────────────────────── */
        body.sidebar-collapsed #sidebar       { width: 70px; }
        body.sidebar-collapsed #topbar        { left: 70px; }
        body.sidebar-collapsed #main-content  { margin-left: 70px; }
        body.sidebar-collapsed #main-footer   { margin-left: 70px; }

        body.sidebar-collapsed .brand-text,
        body.sidebar-collapsed .nav-item-link span,
        body.sidebar-collapsed .nav-item-link .nav-badge,
        body.sidebar-collapsed .nav-label,
        body.sidebar-collapsed .sidebar-footer .user-info { display: none; }

        body.sidebar-collapsed .sidebar-brand  { justify-content: center; padding: 0; }
        body.sidebar-collapsed .nav-item-link  { justify-content: center; padding: 12px 0; }
        body.sidebar-collapsed .nav-item-link i{ width: auto; }
        body.sidebar-collapsed .sidebar-footer { justify-content: center; }
        body.sidebar-collapsed .sidebar-footer .user-avatar { margin: 0 auto; }

        /* ── Breadcrumb ───────────────────────────── */
        .page-breadcrumb {
            font-size : 13px;
            color     : #64748b;
        }

        /* ── Responsive ───────────────────────────── */
        @@media (max-width: 768px) {
            #sidebar         { left: calc(-1 * var(--sidebar-width)); }
            #topbar          { left: 0; }
            #main-content    { margin-left: 0; }
            #main-footer     { margin-left: 0; }

            body.mobile-open #sidebar { left: 0; }
        }

    </style>

</head>
<body>

    <!-- ══════════════════════════════════════════ -->
    <!-- SIDEBAR                                    -->
    <!-- ══════════════════════════════════════════ -->

    <div id="sidebar">

        <!-- Brand -->
        <a class="sidebar-brand" href="/Admin/Index">
            <div class="brand-icon">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <div class="brand-text">
                <span>DairyManage</span>
                <small>Management System</small>
            </div>
        </a>

        <!-- Nav -->
        <div class="sidebar-nav">

            <!-- Main -->
            <div class="nav-label">Main</div>

            <a href="/Admin/Index"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                <i class="bi bi-grid-fill"></i>
                <span>Dashboard</span>
            </a>

            <!-- User Management -->
            <div class="nav-label">User Management</div>

            <a href="/Admin/Users"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Users" ? "active" : "")">
                <i class="bi bi-people-fill"></i>
                <span>All Users</span>
            </a>

            <a href="/Admin/RegisterUser"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "RegisterUser" ? "active" : "")">
                <i class="bi bi-person-plus-fill"></i>
                <span>Register User</span>
            </a>

            <a href="/Admin/Roles"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "Roles" ? "active" : "")">
                <i class="bi bi-shield-fill"></i>
                <span>Roles</span>
            </a>

            <!-- System -->
            <div class="nav-label">System</div>

            <a href="/Admin/AuditLogs"
               class="nav-item-link @(ViewContext.RouteData.Values["action"].ToString() == "AuditLogs" ? "active" : "")">
                <i class="bi bi-clock-history"></i>
                <span>Audit Logs</span>
            </a>

            <!-- Modules -->
            <div class="nav-label">Modules</div>

            <a href="/Farmer/Index" class="nav-item-link">
                <i class="bi bi-person-badge-fill"></i>
                <span>Farmers</span>
            </a>

            <a href="/Collection/Index" class="nav-item-link">
                <i class="bi bi-bucket-fill"></i>
                <span>Collection</span>
            </a>

            <a href="/Production/Index" class="nav-item-link">
                <i class="bi bi-gear-fill"></i>
                <span>Production</span>
            </a>

            <a href="/Sales/Index" class="nav-item-link">
                <i class="bi bi-cart-fill"></i>
                <span>Sales</span>
            </a>

            <a href="/Finance/Index" class="nav-item-link">
                <i class="bi bi-cash-stack"></i>
                <span>Finance</span>
            </a>

            <a href="/HR/Index" class="nav-item-link">
                <i class="bi bi-briefcase-fill"></i>
                <span>HR</span>
            </a>

            <a href="/Reports/Index" class="nav-item-link">
                <i class="bi bi-bar-chart-fill"></i>
                <span>Reports</span>
            </a>

        </div>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer d-flex align-items-center gap-2">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <span>Admin</span>
                <small>Administrator</small>
            </div>
        </div>

    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- TOPBAR                                     -->
    <!-- ══════════════════════════════════════════ -->

    <div id="topbar">

        <!-- Toggle Button -->
        <button class="topbar-icon-btn me-3" onclick="toggleSidebar()" title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Page Title -->
        <div>
            <p class="topbar-title mb-0">@ViewData["Title"]</p>
            <p class="page-breadcrumb mb-0">
                Admin &rsaquo; @ViewData["Title"]
            </p>
        </div>

        <!-- Right Side -->
        <div class="topbar-right">

            <!-- Full Screen -->
            <a class="topbar-icon-btn" onclick="toggleFullScreen()" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </a>

            <!-- Notifications -->
            <a class="topbar-icon-btn position-relative" href="#" title="Notifications">
                <i class="bi bi-bell-fill"></i>
                <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger"
                      style="font-size:9px; padding:3px 5px;">
                    3
                </span>
            </a>

            <!-- User Dropdown -->
            <div class="dropdown">
                <div class="topbar-avatar dropdown-toggle"
                     data-bs-toggle="dropdown"
                     aria-expanded="false"
                     title="Account">
                    A
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li>
                        <div class="px-3 py-2 border-bottom">
                            <p class="mb-0 fw-semibold text-dark small">Admin</p>
                            <p class="mb-0 text-muted" style="font-size:11px;">Administrator</p>
                        </div>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-person me-2 text-primary"></i> My Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small py-2" href="#">
                            <i class="bi bi-gear me-2 text-secondary"></i> Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li>
                        <a class="dropdown-item small py-2 text-danger" href="/Admin/Login">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                               -->
    <!-- ══════════════════════════════════════════ -->

    <div id="main-content">
        @RenderBody()
    </div>


    <!-- ══════════════════════════════════════════ -->
    <!-- FOOTER                                     -->
    <!-- ══════════════════════════════════════════ -->

    <footer id="main-footer">
        <div class="d-flex justify-content-between w-100 align-items-center">
            <small class="text-muted">
                &copy; @DateTime.Now.Year
                <strong class="text-primary">Dairy Management System</strong>
                — All rights reserved
            </small>
            <small class="text-muted">
                Version 1.0 &nbsp;|&nbsp;
                <span class="text-success fw-semibold">
                    <i class="bi bi-circle-fill" style="font-size:8px;"></i> System Online
                </span>
            </small>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        // ── Toggle Sidebar ─────────────────────────
        function toggleSidebar() {
            if (window.innerWidth <= 768) {
                document.body.classList.toggle('mobile-open');
            } else {
                document.body.classList.toggle('sidebar-collapsed');
            }
        }

        // ── Full Screen ────────────────────────────
        function toggleFullScreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                document.exitFullscreen();
            }
        }

        // ── Auto close mobile sidebar on nav click ─
        document.querySelectorAll('.nav-item-link').forEach(link => {
            link.addEventListener('click', () => {
                if (window.innerWidth <= 768) {
                    document.body.classList.remove('mobile-open');
                }
            });
        });

    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>