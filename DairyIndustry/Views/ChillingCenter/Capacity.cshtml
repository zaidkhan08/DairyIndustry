@using DairyIndustry.Models.ChillingStorage
@model List<ChillingPlantCapacityModel>

@{
    ViewData["Title"] = "Capacity Monitor";

    // Max quantity across all plants — used to calculate fill %
    var maxQty = Model.Any() ? Model.Max(x => x.TotalStoredAllTime) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-semibold text-primary mb-0">Plant Capacity Monitor</h3>
        <small class="text-muted">Visual storage summary per processing plant</small>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-primary">← Dashboard</a>
</div>

<!-- Summary bar -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <svg width="22" height="22" fill="none" stroke="#0d6efd" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                </div>
                <div>
                    <div class="text-muted small">Total Plants</div>
                    <div class="fs-4 fw-bold">@Model.Count</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <svg width="22" height="22" fill="none" stroke="#0d6efd" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                </div>
                <div>
                    <div class="text-muted small">Total Stored All Time</div>
                    <div class="fs-4 fw-bold">@Model.Sum(x => x.TotalStoredAllTime).ToString("N0") L</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="@(Model.Sum(x => x.AlertCount) > 0 ? "bg-danger" : "bg-success") bg-opacity-10 rounded-3 p-3">
                    <svg width="22" height="22" fill="none" stroke="@(Model.Sum(x => x.AlertCount) > 0 ? "#dc3545" : "#198754")" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                </div>
                <div>
                    <div class="text-muted small">Total Alerts</div>
                    <div class="fs-4 fw-bold @(Model.Sum(x => x.AlertCount) > 0 ? "text-danger" : "text-success")">
                        @Model.Sum(x => x.AlertCount)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tank Visual Cards -->
<div class="row g-4">
    @foreach (var plant in Model)
    {
        // Calculate fill percentage based on all-time total vs max
        var fillPct = maxQty > 0
        ? (int)Math.Min(Math.Round((double)plant.TotalStoredAllTime / (double)maxQty * 100), 100)
        : 0;

        var tankColor = plant.AlertCount > 0 ? "#dc3545" : "#0d6efd";
        var tankColorLt = plant.AlertCount > 0 ? "#f8a3ab" : "#93c5fd";
        var statusText = plant.AlertCount > 0 ? "text-danger" : "text-success";
        var statusDot = plant.AlertCount > 0 ? "bg-danger" : "bg-success";

        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body d-flex flex-column align-items-center py-4">

                    <!-- Plant name -->
                    <div class="text-muted fw-bold text-uppercase mb-3"
                         style="font-size:10px; letter-spacing:.15em;">
                        @plant.PlantName
                    </div>

                    <!-- Tank visual -->
                    <div class="position-relative mb-3"
                         style="width:80px; height:160px;
                                    background:#f1f5f9;
                                    border-radius:2rem 2rem 2.5rem 2.5rem;
                                    overflow:hidden;
                                    border:4px solid #e2e8f0;">

                        <!-- Fill level (animates on load) -->
                        <div class="tank-fill position-absolute bottom-0 w-100 d-flex align-items-center justify-content-center"
                             data-fill="@fillPct"
                             style="height:0%;
                                        background: linear-gradient(to top, @tankColor, @tankColorLt);
                                        transition: height 1.2s cubic-bezier(0.4,0,0.2,1);">
                            <span class="text-white fw-bold" style="font-size:13px; text-shadow:0 1px 3px rgba(0,0,0,.4);">
                                @fillPct%
                            </span>
                        </div>

                        <!-- Gloss overlay -->
                        <div class="position-absolute top-0 end-0 h-100"
                             style="width:16px; background:rgba(255,255,255,0.12); pointer-events:none;"></div>
                    </div>

                    <!-- Quantity -->
                    <div class="fs-5 fw-bold text-dark">
                        @plant.TotalStoredAllTime.ToString("N0")
                        <span class="text-muted fw-normal" style="font-size:13px;">L</span>
                    </div>

                    <!-- Today -->
                    <div class="text-muted mt-1" style="font-size:12px;">
                        Today: <strong>@plant.StoredToday.ToString("N0") L</strong>
                    </div>

                    <!-- Status -->
                    <div class="d-flex align-items-center gap-1 mt-2 @statusText fw-semibold"
                         style="font-size:12px;">
                        <span class="rounded-circle @statusDot d-inline-block"
                              style="width:8px;height:8px;"></span>
                        @if (plant.AlertCount > 0)
                        {
                            <span>@plant.AlertCount alert(s)</span>
                        }
                        else
                        {
                            <span>Safe</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(plant.Location))
                    {
                        <div class="text-muted mt-1" style="font-size:11px; letter-spacing:.05em;">
                            @plant.Location
                        </div>
                    }
                </div>

                <!-- Footer button -->
                <div class="card-footer bg-white border-top-0 pb-3">
                    <a asp-action="Index" asp-route-plantId="@plant.PlantId"
                       class="btn btn-sm btn-outline-primary w-100">
                        View Entries
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <div class="fs-5">No plants found.</div>
    </div>
}

@section Scripts {
    <script>
        // Animate tank fill bars after page load
        window.addEventListener('load', function () {
            document.querySelectorAll('.tank-fill').forEach(function (el) {
                var pct = el.getAttribute('data-fill');
                setTimeout(function () { el.style.height = pct + '%'; }, 100);
            });
        });
    </script>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-semibold text-primary mb-0">Plant Capacity Monitor</h3>
        <small class="text-muted">Storage summary per processing plant</small>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-primary">← Dashboard</a>
</div>

<!-- Summary bar -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 bg-primary text-white">
            <div class="card-body py-3">
                <div class="small text-white-50">Total Plants</div>
                <div class="fs-3 fw-bold">@Model.Count</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-primary text-white">
            <div class="card-body py-3">
                <div class="small text-white-50">Total Stored All Time (L)</div>
                <div class="fs-3 fw-bold">@Model.Sum(x => x.TotalStoredAllTime).ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 @(Model.Sum(x => x.AlertCount) > 0 ? "bg-danger" : "bg-success") text-white">
            <div class="card-body py-3">
                <div class="small text-white-50">Total Alerts</div>
                <div class="fs-3 fw-bold">@Model.Sum(x => x.AlertCount)</div>
            </div>
        </div>
    </div>
</div>

<!-- Per-plant cards -->
@foreach (var plant in Model)
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-semibold text-primary">@plant.PlantName</span>
                @if (!string.IsNullOrEmpty(plant.Location))
                {
                    <small class="text-muted ms-2">@plant.Location</small>
                }
            </div>
            @if (plant.AlertCount > 0)
            {
                <span class="badge bg-danger">@plant.AlertCount alert(s)</span>
            }
            else
            {
                <span class="badge bg-success">Safe</span>
            }
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-6 col-md-3 text-center">
                    <div class="text-muted small">Stored Today</div>
                    <div class="fs-4 fw-bold text-primary">
                        @plant.StoredToday.ToString("N2")
                    </div>
                    <div class="text-muted small">litres</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="text-muted small">All Time Total</div>
                    <div class="fs-4 fw-bold text-primary">
                        @plant.TotalStoredAllTime.ToString("N2")
                    </div>
                    <div class="text-muted small">litres</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="text-muted small">Total Entries</div>
                    <div class="fs-4 fw-bold text-primary">@plant.TotalEntries</div>
                    <div class="text-muted small">records</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="text-muted small">Temperature Alerts</div>
                    <div class="fs-4 fw-bold @(plant.AlertCount > 0 ? "text-danger" : "text-success")">
                        @plant.AlertCount
                    </div>
                    <div class="text-muted small">above 7°C</div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white">
            <a asp-action="Index" asp-route-plantId="@plant.PlantId"
               class="btn btn-sm btn-outline-primary">
                View Entries for this Plant
            </a>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <div class="fs-5">No plants found.</div>
    </div>
}
