@model List<DairyIndustry.Models.ChillingStorageModel>

@{
    ViewData["Title"] = "Storage Entries";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-semibold text-primary mb-0">Storage Entries</h3>
        <small class="text-muted">All chilling storage records</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ New Entry</a>
</div>

<!-- Success / Error -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter Bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">Plant</label>
                    <select name="plantId" class="form-select form-select-sm">
                        <option value="">— All Plants —</option>
                        @foreach (SelectListItem item in (SelectList)ViewBag.Plants)
                        {
                            if (item.Selected)
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">From Date</label>
                    <input type="date" name="fromDate" class="form-control form-control-sm"
                           value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">To Date</label>
                    <input type="date" name="toDate" class="form-control form-control-sm"
                           value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100">Filter</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Plant</th>
                            <th>Item</th>
                            <th class="text-end">Qty (L)</th>
                            <th class="text-center">Temp (&deg;C)</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model)
                        {
                            <tr>
                                <td class="text-muted small">@entry.StorageId</td>
                                <td>@entry.StoredDate.ToString("dd MMM yyyy")</td>
                                <td>@entry.PlantName</td>
                                <td>
                                    @entry.ItemName
                                    @if (!string.IsNullOrEmpty(entry.ProductType))
                                    {
                                        <br />
                                        <small class="text-muted">@entry.ProductType</small>
                                    }
                            </td>
                            <td class="text-end fw-semibold">
                                @entry.MilkQuantity.ToString("N2")
                            </td>
                            <td class="text-center">
                                @(entry.Temperature.HasValue
                                                            ? entry.Temperature.Value.ToString("N1") + "°C"
                                                            : "—")
                        </td>
                        <td class="text-center">
                            <span class="badge bg-@entry.TempBadgeClass">
                                @entry.TempStatus
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@entry.StorageId"
                               class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@entry.StorageId"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@entry.StorageId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                                        }
                    </tbody>
                </table>
            </div>

            <!-- Record count -->
            <div class="px-3 py-2 border-top text-muted small">
                Showing @Model.Count record(s)
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <div class="fs-5">No storage entries found.</div>
                <a asp-action="Create" class="btn btn-primary mt-3">Add First Entry</a>
            </div>
        }
    </div>
</div>

<!-- Back to Dashboard -->
<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-outline-primary">← Dashboard</a>
</div>
