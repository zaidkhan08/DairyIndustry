@using DairyIndustry.Models.ChillingStorage
@model List<ChillingStorageModel>

@{
    Layout = "_ChillingLayout";
    ViewData["Title"] = "Temperature Alerts";

    int criticalCount = Model.Count(e => e.TempBadgeClass == "danger");
    int warningCount = Model.Count(e => e.TempBadgeClass == "warning");
}

@section Styles {
    <style>
        .cc-alert-stat {
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .cc-alert-stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .cc-alert-stat-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: #94a3b8;
        }

        .cc-alert-stat-val {
            font-size: 24px;
            font-weight: 800;
            line-height: 1.1;
        }

        .cc-legend {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .cc-legend-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid;
        }

        .cc-filter-bar {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            padding: 16px 20px;
            margin-bottom: 24px;
        }

            .cc-filter-bar .form-label {
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .07em;
                color: #94a3b8;
                margin-bottom: 4px;
            }

            .cc-filter-bar .form-control {
                font-size: 13px;
                border-color: #e2e8f0;
                border-radius: 8px;
                height: 36px;
            }

                .cc-filter-bar .form-control:focus {
                    border-color: #0d6efd;
                    box-shadow: 0 0 0 3px rgba(13,110,253,.1);
                }

        .cc-table-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            overflow: hidden;
        }

            .cc-table-card .card-header {
                background: #fff;
                border-bottom: 1px solid #f1f5f9;
                padding: 16px 20px;
            }

        .cc-table thead tr {
            background: #f8fafc;
        }

        .cc-table thead th {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: #94a3b8;
            border: none;
            padding: 12px 16px;
        }

        .cc-table tbody tr {
            border-bottom: 1px solid #f8fafc;
            transition: background .15s;
        }

            .cc-table tbody tr:hover {
                background: #fff7f7;
            }

                .cc-table tbody tr:hover td:first-child {
                    box-shadow: inset 3px 0 0 #dc2626;
                }

        .cc-table tbody td {
            font-size: 13px;
            color: #334155;
            padding: 14px 16px;
            border: none;
            vertical-align: middle;
        }

        .cc-temp-val {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            font-size: 14px;
        }

        .cc-temp-warning {
            color: #ca8a04;
        }

        .cc-temp-danger {
            color: #dc2626;
        }

        .cc-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .cc-badge-warning {
            background: #fefce8;
            color: #ca8a04;
        }

        .cc-badge-danger {
            background: #fef2f2;
            color: #dc2626;
        }

        .cc-btn-view {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #64748b;
            text-decoration: none;
            transition: all .15s;
        }

            .cc-btn-view:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }
    </style>
}

<!-- Stat Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="cc-alert-stat" style="background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);border-top:3px solid #e2e8f0;">
            <div class="cc-alert-stat-icon" style="background:#f1f5f9;">
                <i class="bi bi-exclamation-circle" style="color:#64748b;"></i>
            </div>
            <div>
                <div class="cc-alert-stat-label">Total</div>
                <div class="cc-alert-stat-val" style="color:#0f172a;">@Model.Count</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="cc-alert-stat" style="background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);border-top:3px solid #facc15;">
            <div class="cc-alert-stat-icon" style="background:#fefce8;">
                <i class="bi bi-thermometer-half" style="color:#ca8a04;"></i>
            </div>
            <div>
                <div class="cc-alert-stat-label">Warnings</div>
                <div class="cc-alert-stat-val" style="color:#ca8a04;">@warningCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="cc-alert-stat" style="background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);border-top:3px solid #dc2626;">
            <div class="cc-alert-stat-icon" style="background:#fef2f2;">
                <i class="bi bi-thermometer-high" style="color:#dc2626;"></i>
            </div>
            <div>
                <div class="cc-alert-stat-label">Critical</div>
                <div class="cc-alert-stat-val" style="color:#dc2626;">@criticalCount</div>
            </div>
        </div>
    </div>
</div>

<!-- Legend -->
<div class="cc-legend">
    <span class="cc-legend-pill" style="background:#fefce8;color:#854d0e;border-color:#fde68a;">
        <i class="bi bi-thermometer-half"></i> Warning &nbsp;5°C – 7°C
    </span>
    <span class="cc-legend-pill" style="background:#fef2f2;color:#991b1b;border-color:#fecaca;">
        <i class="bi bi-thermometer-high"></i> Critical &nbsp;above 7°C
    </span>
</div>

<!-- Filter Bar -->
<div class="cc-filter-bar">
    <form method="get" asp-action="Alerts">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-4">
                <label class="form-label">To Date</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-danger btn-sm w-100" style="height:36px;font-size:13px;border-radius:8px;">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-action="Alerts" class="btn btn-outline-secondary btn-sm w-100" style="height:36px;font-size:13px;border-radius:8px;">Reset</a>
            </div>
        </div>
    </form>
</div>

<!-- Table -->
<div class="cc-table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <div style="font-size:15px;font-weight:700;color:#0f172a;">Alert Records</div>
            <div style="font-size:12px;color:#94a3b8;margin-top:2px;">@Model.Count alert@(Model.Count == 1 ? "" : "s") in selected range</div>
        </div>
        @if (Model.Any())
        {
            <span class="cc-badge cc-badge-danger" style="font-size:12px;padding:5px 14px;">
                <i class="bi bi-exclamation-triangle-fill"></i> @Model.Count Active
            </span>
        }
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table cc-table mb-0">
                <thead>
                    <tr>
                        <th style="padding-left:20px;">ID</th>
                        <th>Date</th>
                        <th>Plant</th>
                        <th>Item</th>
                        <th class="text-end">Qty (L)</th>
                        <th class="text-center">Temperature</th>
                        <th class="text-center">Level</th>
                        <th class="text-center" style="padding-right:20px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model)
                    {
                        var tempClass = entry.TempBadgeClass == "warning" ? "cc-temp-warning" : "cc-temp-danger";
                        var badgeClass = entry.TempBadgeClass == "warning" ? "cc-badge-warning" : "cc-badge-danger";
                        <tr>
                            <td style="padding-left:20px;"><span style="font-size:12px;color:#94a3b8;font-weight:500;">#@entry.StorageId</span></td>
                            <td>@entry.StoredDate.ToString("dd MMM yyyy")</td>
                            <td style="font-weight:600;color:#0f172a;">@entry.PlantName</td>
                            <td>@entry.ItemName</td>
                            <td class="text-end" style="font-weight:600;color:#0f172a;font-variant-numeric:tabular-nums;">@entry.MilkQuantity.ToString("N2")</td>
                            <td class="text-center">
                                <span class="cc-temp-val @tempClass">
                                    @(entry.Temperature.HasValue? entry.Temperature.Value.ToString("N1") + "°C" : "—")
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="cc-badge @badgeClass">@entry.TempStatus</span>
                            </td>
                            <td class="text-center" style="padding-right:20px;">
                                <a asp-action="Details" asp-route-id="@entry.StorageId" class="cc-btn-view">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align:center;padding:60px 20px;">
            <div style="width:56px;height:56px;border-radius:16px;background:#f0fdf4;display:inline-flex;align-items:center;justify-content:center;font-size:24px;color:#16a34a;margin-bottom:12px;">
                <i class="bi bi-shield-check"></i>
            </div>
            <div style="font-size:15px;font-weight:600;color:#0f172a;margin-bottom:4px;">All Clear</div>
            <div style="font-size:13px;color:#94a3b8;">No temperature alerts for the selected period.</div>
        </div>
    }
</div>
