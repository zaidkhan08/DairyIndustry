@model List<DairyIndustry.Models.FarmerModel.PendingApprovalModel>

@{
    ViewData["Title"] = "Pending Farmer Approvals";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

<style>
    :root {
        --green: #16a34a;
        --red: #dc2626;
        --muted: #6b7280;
        --border: #e5e7eb;
        --bg: #f9fafb;
    }

    /* ── Page ── */
    .pa-page {
        padding: 1.5rem;
    }

    .pa-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding-bottom: 1.25rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
    }

    .pa-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .pending-badge {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fcd34d;
        font-size: 12px;
        padding: 3px 10px;
        border-radius: 99px;
        font-weight: 600;
    }

    .pa-subtitle {
        font-size: 13px;
        color: var(--muted);
        margin: 0;
    }

    .btn-back {
        padding: 8px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        text-decoration: none;
        color: #374151;
        font-size: 13px;
        font-weight: 500;
        background: #fff;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

        .btn-back:hover {
            background: #f3f4f6;
            color: #111827;
        }

    /* ── Farmer Card ── */
    .farmer-card {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: #fff;
        margin-bottom: 1.25rem;
        overflow: hidden;
        transition: box-shadow .15s, border-color .15s;
    }

        .farmer-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.06);
            border-color: #d1d5db;
        }

    /* ── Card Header ── */
    .farmer-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 20px;
        cursor: pointer;
        user-select: none;
        background: #fff;
        transition: background .12s;
    }

        .farmer-card-header:hover {
            background: #f8fafc;
        }

    .farmer-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e2e8f0;
        flex-shrink: 0;
    }

    .farmer-avatar-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #94a3b8;
        flex-shrink: 0;
        border: 2px dashed #cbd5e1;
    }

    .header-info {
        flex: 1;
        min-width: 0;
    }

    .header-name {
        font-weight: 700;
        font-size: 15px;
        color: #1e293b;
        margin: 0 0 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .header-sub {
        font-size: 13px;
        color: #64748b;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .header-pills {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .verify-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 99px;
    }

        .verify-pill.ok {
            background: #dcfce7;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .verify-pill.miss {
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

    .days-chip {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 99px;
        background: #f1f5f9;
        color: #475569;
        white-space: nowrap;
        font-weight: 500;
        border: 1px solid #e2e8f0;
    }

        .days-chip.urgent {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444;
            font-weight: 600;
        }

    .toggle-icon {
        color: #94a3b8;
        font-size: 18px;
        flex-shrink: 0;
        transition: transform .2s, color .2s;
    }

    .farmer-card.open .toggle-icon {
        transform: rotate(180deg);
        color: #374151;
    }

    /* ── Card Body ── */
    .farmer-card-body {
        max-height: 0;
        overflow: hidden;
        transition: max-height .35s cubic-bezier(0,1,0,1), padding .3s;
        padding: 0 20px;
        background: var(--bg);
    }

    .farmer-card.open .farmer-card-body {
        max-height: 2000px;
        transition: max-height .4s ease-in-out;
        padding: 20px;
        border-top: 1px solid var(--border);
    }

    /* ── Body Layout ── */
    .body-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 14px;
    }

    .body-grid-3 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 14px;
        margin-bottom: 14px;
    }

    @@media (max-width: 900px) {
        .body-grid

    {
        grid-template-columns: 1fr;
    }

    .body-grid-3 {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 600px) {
        .header-pills

    {
        display: none;
    }

    .pa-page {
        padding: 1rem;
    }

    }

    /* ── Section Card ── */
    .sec {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px;
    }

    .sec-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #4b5563;
        margin: 0 0 14px;
        display: flex;
        align-items: center;
        gap: 6px;
        padding-bottom: 10px;
        border-bottom: 1px solid #f3f4f6;
    }

    /* ── Field Grid ── */
    .field-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 14px;
    }

    .field-item label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #9ca3af;
        margin-bottom: 3px;
    }

    .field-item span {
        font-size: 13px;
        color: #111827;
        font-weight: 500;
        word-break: break-word;
    }

    /* ── Doc Links ── */
    .doc-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 8px;
        text-decoration: none;
        color: #1f2937;
        background: #fff;
        font-size: 13px;
        font-weight: 500;
        margin-top: 12px;
        transition: all .12s;
    }

        .doc-link:hover {
            background: #f0f9ff;
            color: #2563eb;
            border-color: #bfdbfe;
        }

        .doc-link i {
            font-size: 16px;
            color: #4f46e5;
        }

        .doc-link .ext {
            margin-left: auto;
            font-size: 12px;
            color: #9ca3af;
        }

    .doc-missing {
        margin-top: 12px;
        padding: 10px 14px;
        border: 1px dashed #d1d5db;
        border-radius: 8px;
        color: #9ca3af;
        background: #f9fafb;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ── Action Bar ── */
    .action-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        margin-top: 4px;
    }

    .btn-approve {
        background: var(--green);
        color: #fff;
        border: none;
        padding: 10px 22px;
        border-radius: 8px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        font-size: 14px;
        transition: background .12s;
    }

        .btn-approve:hover {
            background: #15803d;
        }

    .btn-reject {
        background: #fff;
        color: var(--red);
        border: 1.5px solid var(--red);
        padding: 9px 20px;
        border-radius: 8px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        font-size: 14px;
        transition: all .12s;
    }

        .btn-reject:hover {
            background: #fee2e2;
        }

    .sys-id {
        margin-left: auto;
        font-size: 11px;
        color: #9ca3af;
        font-family: monospace;
        background: #f9fafb;
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 6px;
    }

    /* ── Empty State ── */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        border: 1px dashed var(--border);
        border-radius: 14px;
        background: #fff;
    }

    /* ── Approve Modal ── */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 9998;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .modal-box {
        background: #ffff;
        border-radius: 16px;
        padding: 32px 28px;
        width: 100%;
        max-width: 420px;
        text-align: center;
        box-shadow: 0 24px 60px rgba(0,0,0,.18);
        animation: modalIn .2s ease;
    }

    @@keyframes modalIn {
        from

    {
        transform: scale(.95);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }

    .modal-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #dcfce7;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 28px;
        color: #16a94a;
    }

    .modal-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 6px;
    }

    .modal-sub {
        font-size: 13px;
        color: #6b7280;
        margin: 0 0 6px;
    }

    .modal-name {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 16px;
    }

    .modal-desc {
        font-size: 13px;
        color: #6b7280;
        margin: 0 0 24px;
        line-height: 1.55;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    .modal-cancel {
        padding: 10px 24px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        color: #374151;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: background .12s;
    }

        .modal-cancel:hover {
            background: #f3f4f6;
        }

    .modal-confirm {
        padding: 10px 24px;
        border: none;
        border-radius: 8px;
        background: #16a34a;
        color: #fff;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background .12s;
    }

        .modal-confirm:hover {
            background: #15803d;
        }
</style>

<!-- ── Approve Modal ── -->
<div class="modal-overlay" id="approveModalOverlay">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-check-circle-fill"></i></div>
        <p class="modal-title">Approve Registration?</p>
        <p class="modal-sub">You are about to approve</p>
        <p class="modal-name" id="approveModalFarmerName">—</p>
        <p class="modal-desc">Once approved, the farmer's account will be activated and linked to your collection center</p>
        <div class="modal-actions">
            <button type="button" class="modal-cancel" onclick="closeApproveModal()">Cancel</button>
            <button type="button" class="modal-confirm" onclick="submitApprove()">
                Yes, Approve
            </button>
        </div>
    </div>
</div>

<!-- ── Page ── -->
<div class="pa-page">

    <div class="pa-header">
        <div>
            <h1 class="pa-title">
                Pending Farmer Approvals
                @if (Model != null && Model.Count > 0)
                {
                    <span class="pending-badge">@Model.Count pending</span>
                }
            </h1>
            <p class="pa-subtitle">Review each self-registered farmer's details and documents, then approve or reject.</p>
        </div>
        <a asp-controller="CollectionCenter" asp-action="Dashboard" class="btn-back">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-person-check d-block mb-3" style="font-size:3rem; color:#9ca3af;"></i>
            <h5 style="font-weight:700; color:#111827; margin-bottom:6px;">All Caught Up!</h5>
            <p style="color:#6b7280; font-size:14px; margin:0;">All self-registered farmers have been reviewed.</p>
        </div>
    }
    else
    {
        @foreach (var f in Model)
        {
            <div class="farmer-card" id="card-@f.FarmerId">

                <!-- ── HEADER ── -->
                <div class="farmer-card-header" onclick="toggleCard(@f.FarmerId)">

                    @if (!string.IsNullOrEmpty(f.ProfilePhoto))
                    {
                        <img src="@f.ProfilePhoto" class="farmer-avatar" alt="Photo" />
                    }
                    else
                    {
                        <div class="farmer-avatar-placeholder"><i class="bi bi-person"></i></div>
                    }

                    <div class="header-info">
                        <p class="header-name">@f.FarmerName</p>
                        <p class="header-sub">
                            <i class="bi bi-telephone me-1"></i>@f.Phone
                            &nbsp;·&nbsp;
                            <i class="bi bi-geo-alt me-1"></i>@f.VillageName, @f.CityName
                        </p>
                    </div>

                    <div class="header-pills">
                        <span class="verify-pill @(f.HasAadhaarDoc ? "ok" : "miss")">
                            <i class="bi bi-card-text"></i> Aadhaar
                        </span>
                        <span class="verify-pill @(f.HasBankDetails ? "ok" : "miss")">
                            <i class="bi bi-bank"></i> Bank
                        </span>
                        <span class="days-chip @(f.DaysPending > 3 ? "urgent" : "")">
                            @(f.DaysPending == 0 ? "Today" : f.DaysPending + "d ago")
                        </span>
                    </div>

                    <i class="bi bi-chevron-down toggle-icon"></i>
                </div>

                <!-- ── BODY ── -->
                <div class="farmer-card-body">

                    <!-- Row 1: Personal + Aadhaar -->
                    <div class="body-grid">

                        <div class="sec">
                            <p class="sec-title"><i class="bi bi-person-lines-fill" style="color:#3b82f6;"></i> Personal Details</p>
                            <div class="field-grid">
                                <div class="field-item"><label>Full Name</label><span>@f.FarmerName</span></div>
                                <div class="field-item"><label>Phone</label><span>@f.Phone</span></div>
                                <div class="field-item">
                                    <label>Email</label>
                                    <span>@(!string.IsNullOrEmpty(f.Email) ? f.Email : "Not provided")</span>
                                </div>
                                <div class="field-item">
                                    <label>Gender</label>
                                    <span>@(!string.IsNullOrEmpty(f.Gender) ? f.Gender : "Not provided")</span>
                                </div>
                                <div class="field-item">
                                    <label>Date of Birth</label>
                                    <span>@(f.DateOfBirth.HasValue? f.DateOfBirth.Value.ToString("dd MMM yyyy") : "Not provided")</span>
                                </div>
                                <div class="field-item">
                                    <label>Applied On</label>
                                    <span>@(f.CreatedDate.HasValue? f.CreatedDate.Value.ToString("dd MMM yyyy, hh:mm tt") : "—")</span>
                                </div>
                            </div>
                        </div>

                        <div class="sec">
                            <p class="sec-title"><i class="bi bi-shield-check" style="color:#f59e0b;"></i> Aadhaar Verification</p>
                            <div class="field-grid">
                                <div class="field-item">
                                    <label>Aadhaar Number</label>
                                    <span style="font-family:monospace; font-weight:700;">@f.AadhaarMasked</span>
                                </div>
                            </div>
                            @if (f.HasAadhaarDoc)
                            {
                                <a href="@f.AadhaarCardPath" target="_blank" class="doc-link">
                                    <i class="bi bi-file-earmark-image"></i>
                                    <span>View Aadhaar Card</span>
                                    <span class="ext"><i class="bi bi-box-arrow-up-right"></i></span>
                                </a>
                            }
                            else
                            {
                                <div class="doc-missing">
                                    <i class="bi bi-file-earmark-x" style="color:#dc2626;"></i>
                                    Document not uploaded
                                </div>
                            }
                        </div>

                    </div>

                    <!-- Row 2: Location + Bank -->
                    <div class="body-grid">

                        <div class="sec">
                            <p class="sec-title"><i class="bi bi-geo-alt" style="color:#16a34a;"></i> Location</p>
                            <div class="field-grid">
                                <div class="field-item"><label>Village</label><span>@f.VillageName</span></div>
                                <div class="field-item"><label>City</label><span>@f.CityName</span></div>
                                <div class="field-item"><label>State</label><span>@f.StateName</span></div>
                                <div class="field-item"><label>Collection Center</label><span>@f.CenterName</span></div>
                            </div>
                        </div>

                        <div class="sec">
                            <p class="sec-title"><i class="bi bi-bank" style="color:#06b6d4;"></i> Bank Details</p>
                            @if (f.HasBankDetails)
                            {
                                <div class="field-grid">
                                    <div class="field-item"><label>Bank Name</label><span style="font-weight:700;">@f.BankName</span></div>
                                    <div class="field-item"><label>Account Number</label><span style="font-family:monospace;">@f.AccountNumber</span></div>
                                    <div class="field-item"><label>IFSC Code</label><span style="font-family:monospace;">@f.IFSCCode</span></div>
                                </div>
                                @if (f.HasPassbookDoc)
                                {
                                    <a href="@f.PassbookPath" target="_blank" class="doc-link">
                                        <i class="bi bi-file-earmark-image"></i>
                                        <span>View Bank Passbook</span>
                                        <span class="ext"><i class="bi bi-box-arrow-up-right"></i></span>
                                    </a>
                                }
                            }
                            else
                            {
                                <p style="color:#9ca3af; font-size:13px; margin:0;">
                                    <i class="bi bi-info-circle me-1"></i> No bank details provided.
                                </p>
                            }
                        </div>

                    </div>

                    <!-- ── Action Bar ── -->
                    <div class="action-bar">
                        <form method="post" asp-controller="CollectionCenter" asp-action="ApproveFarmer" class="d-inline" id="approveForm-@f.FarmerId">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="farmerId" value="@f.FarmerId" />
                            <button type="button" class="btn-approve" onclick="openApproveModal(@f.FarmerId, '@f.FarmerName')">
                                Approve
                            </button>
                        </form>

                        <a asp-controller="CollectionCenter" asp-action="RejectFarmer" asp-route-farmerId="@f.FarmerId" class="btn-reject">
                            Reject
                        </a>

                        <span class="sys-id">ID #@f.FarmerId</span>
                    </div>

                </div>
            </div>
        }
    }

</div>

@section Scripts {
    <script>
        /* ── Toggle card ── */
        function toggleCard(id) {
            document.getElementById('card-' + id).classList.toggle('open');
        }

        /* Open first card by default */
        document.addEventListener('DOMContentLoaded', function () {
            const first = document.querySelector('.farmer-card');
            if (first) first.classList.add('open');
        });

        /* ── Approve modal ── */
        let _pendingFormId = null;

        function openApproveModal(farmerId, farmerName) {
            _pendingFormId = farmerId;
            document.getElementById('approveModalFarmerName').innerText = farmerName;
            const overlay = document.getElementById('approveModalOverlay');
            overlay.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeApproveModal() {
            document.getElementById('approveModalOverlay').style.display = 'none';
            document.body.style.overflow = '';
            _pendingFormId = null;
        }

        function submitApprove() {
            if (_pendingFormId) {
                document.getElementById('approveForm-' + _pendingFormId).submit();
            }
        }

        /* Close on overlay click */
        document.getElementById('approveModalOverlay').addEventListener('click', function (e) {
            if (e.target === this) closeApproveModal();
        });

        /* Close on Escape key */
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeApproveModal();
        });
    </script>
}
