@model List<DairyIndustry.Models.Collection.BatchStatusViewModel>

@{
    ViewData["Title"] = "Batch Status";
    Layout = "_CollectionCenterLayout";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Today's Batch Status</h4>
        <span class="text-muted">@DateTime.Today.ToString("dd MMM yyyy")</span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">No batch data found. Please contact admin.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var batch in Model)
            {
                @* Determine badge color by status *@
                var badgeClass = batch.BatchStatus switch
                {
                    "Open" => "bg-success",
                    "Closed" => "bg-secondary",
                    "Missed" => "bg-danger",
                    "Not Started" => "bg-warning text-dark",
                    _ => "bg-light text-dark border"
                };

                var cardBorder = batch.IsCurrentShift ? "border-success border-2" : "";

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm @cardBorder">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">@batch.Shift Shift</h5>
                                <small class="text-muted">@batch.ShiftWindow</small>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1">
                                <span class="badge @badgeClass fs-6">@batch.BatchStatus</span>
                                @if (batch.IsCurrentShift)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success">Active Now</span>
                                }
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="row text-center g-3">
                                <div class="col-4">
                                    <div class="fw-bold fs-5">@batch.TotalQuantity.ToString("F2") L</div>
                                    <div class="text-muted small">Total Milk</div>
                                </div>
                                <div class="col-4">
                                    <div class="fw-bold fs-5">@batch.EntryCount</div>
                                    <div class="text-muted small">Entries</div>
                                </div>
                                <div class="col-4">
                                    <div class="fw-bold fs-5">@batch.BatchDate.ToString("dd/MM")</div>
                                    <div class="text-muted small">Date</div>
                                </div>
                            </div>

                            <hr />

                            <div class="row text-center g-2">
                                <div class="col-6">
                                    <div class="text-muted small">Avg Fat</div>
                                    <div class="fw-semibold">
                                        @(batch.AvgFat.HasValue? batch.AvgFat.Value.ToString("F2") : "—")
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-muted small">Avg CLR</div>
                                    <div class="fw-semibold">
                                        @(batch.AvgCLR.HasValue? batch.AvgCLR.Value.ToString("F2") : "—")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent">
                            @if (batch.BatchId.HasValue)
                            {
                                <a asp-action="ViewCollectionBatch"
                                   asp-route-shift="@batch.Shift"
                                   asp-route-batchId="@batch.BatchId"
                                   class="btn btn-outline-primary btn-sm w-100">
                                    View Collection Entries
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm w-100" disabled>
                                    No Batch Available
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="Dashboard" class="btn btn-link text-decoration-none">
            &larr; Back to Dashboard
        </a>
    </div>

</div>
