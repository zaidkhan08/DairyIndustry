@model List<DairyIndustry.Models.Collection.BatchStatusViewModel>

@{
    ViewData["Title"] = "Batch Status";
    Layout = "_CollectionCenterLayout";
    var centerName = ViewBag.CenterName as string ?? "Your Center";
    var now = DateTime.Now;
}

<div class="container mt-4">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4>Batch Status</h4>
            <p class="text-muted mb-0">
                @centerName - @now.ToString("dd MMM yyyy")
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            New Milk Entry
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No batch data available.
        </div>
    }
    else
    {
        <!-- Cards -->
        <div class="row mb-4">
            @foreach (var batch in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-header">
                            @batch.Shift
                        </div>

                        <div class="card-body">

                            <p><strong>Time:</strong> @batch.ShiftWindow</p>

                            <p>
                                <strong>Status:</strong>
                                @if (batch.BatchStatus == "Open")
                                {
                                    <span class="badge bg-success">Open</span>
                                }
                                else if (batch.BatchStatus == "Closed")
                                {
                                    <span class="badge bg-danger">Closed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@batch.BatchStatus</span>
                                }
                            </p>

                            @if (batch.BatchId.HasValue)
                            {
                                <p><strong>Batch ID:</strong> #@batch.BatchId</p>
                                <p><strong>Total Qty:</strong> @batch.TotalQuantity.ToString("F2") L</p>

                                @if (batch.AvgFat.HasValue)
                                {
                                    <p><strong>Avg Fat:</strong> @batch.AvgFat.Value.ToString("F2") %</p>
                                }

                                @if (batch.AvgCLR.HasValue)
                                {
                                    <p><strong>Avg CLR:</strong> @batch.AvgCLR.Value.ToString("F2")</p>
                                }

                                <a asp-action="BatchCollections"
                                   asp-route-batchId="@batch.BatchId"
                                   class="btn btn-outline-primary btn-sm">
                                    View Entries
                                </a>
                            }
                            else
                            {
                                <p class="text-muted">
                                    No batch available for this shift.
                                </p>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-header">
                Today's Summary
            </div>

            <div class="card-body">

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Shift</th>
                            <th>Time</th>
                            <th>Batch ID</th>
                            <th>Status</th>
                            <th>Total Qty</th>
                            <th>Avg Fat</th>
                            <th>Avg CLR</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var batch in Model)
                        {
                            <tr>
                                <td>@batch.Shift</td>
                                <td>@batch.ShiftWindow</td>

                                <td>
                                    @(batch.BatchId.HasValue ? "#" + batch.BatchId : "-")
                                </td>

                                <td>
                                    @if (batch.BatchStatus == "Open")
                                    {
                                        <span class="badge bg-success">Open</span>
                                    }
                                    else if (batch.BatchStatus == "Closed")
                                    {
                                        <span class="badge bg-danger">Closed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@batch.BatchStatus</span>
                                    }
                                </td>

                                <td>
                                    @(batch.BatchId.HasValue? batch.TotalQuantity.ToString("F2") : "-")
                                </td>

                                <td>
                                    @(batch.AvgFat.HasValue? batch.AvgFat.Value.ToString("F2") : "-")
                                </td>

                                <td>
                                    @(batch.AvgCLR.HasValue? batch.AvgCLR.Value.ToString("F2") : "-")
                                </td>

                                <td>
                                    @if (batch.BatchId.HasValue)
                                    {
                                        <a asp-action="BatchCollections"
                                           asp-route-batchId="@batch.BatchId"
                                           class="btn btn-outline-primary btn-sm">
                                            View
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }

</div>