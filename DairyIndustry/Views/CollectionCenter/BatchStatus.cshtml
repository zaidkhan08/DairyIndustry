@model List<DairyIndustry.Models.Collection.BatchStatusViewModel>

@{
    ViewData["Title"] = "Batch Operations";
    Layout = "_CollectionCenterLayout";

    var totalMilk = Model.Sum(x => x.TotalQuantity);

    var totalAmount = Model.Sum(x => x.TotalAmount);

    var totalEntries = Model.Sum(x => x.EntryCount);

    var totalRejected = Model.Sum(x => x.RejectionCount);

    var todayEntries = Model.FirstOrDefault()?.TodayEntries;
}

<div class="container-fluid py-4">

    <!-- KPI -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-muted">Total Milk</div>
                    <h5 class="fw-bold text-primary mb-0">@totalMilk.ToString("F2") L</h5>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-muted">Collection Amount</div>
                    <h5 class="fw-bold mb-0">₹ @totalAmount</h5>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-muted">Entries</div>
                    <h5 class="fw-bold text-success mb-0">@totalEntries</h5>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-muted">Rejections</div>
                    <h5 class="fw-bold text-danger mb-0">@totalRejected</h5>
                </div>
            </div>
        </div>

    </div>

    <!-- SHIFT CARDS -->
    <div class="row g-4 mb-4">

        @foreach (var batch in Model)
        {
            var statusClass = batch.BatchStatus == "Open"? "success": batch.BatchStatus == "Closed"? "secondary": "danger";

            <div class="col-lg-6">

                <div class="card border-0 shadow-sm h-100">

                    <div class="card-header bg-white border-0">
                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <h5 class="fw-semibold mb-1">@batch.Shift Shift</h5>
                                <div class="small text-muted">@batch.ShiftWindow</div>
                            </div>

                            <span class="badge bg-@statusClass-subtle text-@statusClass border">
                                @batch.BatchStatus
                            </span>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="border rounded">
                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Total Milk</span>
                                <strong>@batch.TotalQuantity.ToString("F2") L</strong>
                            </div>

                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Amount</span>
                                <strong>₹ @batch.TotalAmount</strong>
                            </div>

                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Entries</span>
                                <strong>@batch.EntryCount</strong>
                            </div>

                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Rejections</span>
                                <strong class="text-danger">
                                    @batch.RejectionCount
                                </strong>
                            </div>

                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Avg FAT</span>

                                <strong>
                                    @(batch.AvgFat.HasValue? batch.AvgFat.Value.ToString("F2"): "-")
                                </strong>
                            </div>

                            <div class="d-flex justify-content-between p-3">
                                <span>Avg CLR</span>

                                <strong>
                                    @(batch.AvgCLR.HasValue? batch.AvgCLR.Value.ToString("F2"): "-")
                                </strong>
                            </div>

                        </div>

                        <div class="mt-3">
                            <button class="btn btn-sm btn-outline-primary shift-filter-btn" data-shift="@batch.Shift">
                                <i class="bi bi-eye"></i>View Entries
                            </button>
                        </div>

                    </div>

                </div>

            </div>
                }

    </div>

    <!-- TODAY LIVE ENTRIES -->
    <div class="card border-0 shadow-sm"
         id="todayEntriesSection">

        <div class="card-header bg-white">

            <div class="d-flex justify-content-between align-items-center">

                <h5 class="fw-semibold mb-0">
                    Today's Live Milk Entries
                </h5>

                <button class="btn btn-sm btn-dark" id="showAllEntries">Show All</button>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table align-middle table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Farmer</th>
                        <th>Code</th>
                        <th>Shift</th>
                        <th>Qty</th>
                        <th>FAT</th>
                        <th>CLR</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in todayEntries)
                    {
                        var statusClass =
                        item.Status == "Accepted"? "success": "danger";

                        <tr class="entry-row"
                            data-shift="@item.Shift">

                            <td>@item.FarmerName</td>

                            <td>@item.FarmerCode</td>

                            <td>@item.Shift</td>

                            <td>@item.Quantity</td>

                            <td>@item.Fat</td>

                            <td>@item.CLR</td>

                            <td>
                                @(item.Status == "Accepted"? $"₹ {item.Amount}": "-")
                            </td>

                            <td>
                                <span class="badge bg-@statusClass-subtle text-@statusClass border">
                                    @item.Status
                                </span>
                            </td>

                            <td>
                                @(string.IsNullOrEmpty(item.RejectionReason)? "-": item.RejectionReason)
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    const shiftButtons =
        document.querySelectorAll(".shift-filter-btn");

    const rows =
        document.querySelectorAll(".entry-row");

    shiftButtons.forEach(button => {

        button.addEventListener("click", function () {

            const shift = this.dataset.shift;

            rows.forEach(row => {

                row.style.display =
                    row.dataset.shift === shift? "": "none";

            });

            document.getElementById("todayEntriesSection")
                .scrollIntoView({
                    behavior: "smooth"
                });

        });

    });

    document
        .getElementById("showAllEntries")
        .addEventListener("click", function () {

            rows.forEach(row => {

                row.style.display = "";

            });

        });

</script>