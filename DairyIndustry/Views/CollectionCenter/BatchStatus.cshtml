@model List<DairyIndustry.Models.Collection.BatchStatusViewModel>

@{
    ViewData["Title"] = "Batch Status";
    Layout = "_CollectionCenterLayout";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Today's Batch Status</h4>
        <span class="text-muted">@DateTime.Today.ToString("dd MMM yyyy")</span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">No batch data found. Please contact admin.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Shift</th>
                        <th>Window</th>
                        <th>Status</th>
                        <th>Total Milk (L)</th>
                        <th>Entries</th>
                        <th>Date</th>
                        <th>Avg Fat</th>
                        <th>Avg CLR</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var batch in Model)
                    {
                        var badgeClass = batch.BatchStatus switch
                        {
                            "Open" => "bg-success",
                            "Closed" => "bg-secondary",
                            "Missed" => "bg-danger",
                            "Not Started" => "bg-warning text-dark",
                            _ => "bg-light text-dark border"
                        };

                        <tr class="@(batch.IsCurrentShift ? "table-success" : "")">

                            <td>
                                <strong>@batch.Shift</strong>
                                @if (batch.IsCurrentShift)
                                {
                                    <div><span class="badge bg-success-subtle text-success border">Active</span></div>
                                }
                            </td>

                            <td>@batch.ShiftWindow</td>

                            <td>
                                <span class="badge @badgeClass">
                                    @batch.BatchStatus
                                </span>
                            </td>

                            <td>@batch.TotalQuantity.ToString("F2")</td>

                            <td>@batch.EntryCount</td>

                            <td>@batch.BatchDate.ToString("dd/MM/yyyy")</td>

                            <td>
                                @(batch.AvgFat.HasValue? batch.AvgFat.Value.ToString("F2") : "—")
                            </td>

                            <td>
                                @(batch.AvgCLR.HasValue? batch.AvgCLR.Value.ToString("F2") : "—")
                            </td>

                            <td>
                                @if (batch.BatchId.HasValue)
                                {
                                    <a asp-action="ViewCollectionBatch"
                                       asp-route-shift="@batch.Shift"
                                       asp-route-batchId="@batch.BatchId"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled>
                                        No Batch
                                    </button>
                                }
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Dashboard" class="btn btn-link text-decoration-none">
            &larr; Back to Dashboard
        </a>
    </div>

</div>