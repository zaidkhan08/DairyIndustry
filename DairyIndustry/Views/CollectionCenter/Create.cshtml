@model DairyIndustry.Models.Collection.MilkCollectionViewModel
@{
    ViewData["Title"] = "Milk Entry";
    Layout = "_CollectionCenterLayout";
    var now = DateTime.Now;
    bool hasActiveShift = Model?.CurrentShift != "No Active Shift";
}

<div class="container mt-4">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4>Milk Entry</h4>
            <p class="text-muted mb-0">Record milk collection</p>
        </div>

        <a asp-action="BatchStatus" class="btn btn-outline-secondary">
            Back to Batch Status
        </a>
    </div>

    <!-- No Active Shift -->
    @if (!hasActiveShift)
    {
        <div class="alert alert-warning">
            <strong>No active shift.</strong>
            Milk entry allowed only during shift time.
        </div>
    }

    <!-- Info Cards -->
    <div class="row mb-3">

        <div class="col-md-3">
            <div class="card p-2">
                <strong>Center</strong>
                <div>@Model?.CenterName</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-2">
                <strong>Date</strong>
                <div>@now.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-2">
                <strong>Shift</strong>
                <div>
                    @if (hasActiveShift)
                    {
                        <span class="badge bg-success">@Model.CurrentShift</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">None</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-2">
                <strong>Batch</strong>
                <div class="text-muted">Auto</div>
            </div>
        </div>

    </div>

    <!-- Form -->
    <div class="card">
        <div class="card-header">Entry Details</div>
        <div class="card-body">

            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()

                <!-- ✅ FIX: Hidden Shift inside form -->
                <input type="hidden" asp-for="Shift" />

                <div class="row">

                    <!-- Farmer -->
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Farmer</label>
                        <select asp-for="FarmerId" class="form-select" required>
                            <option value="">Select Farmer</option>
                            @foreach (var f in Model.Farmers)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Milk Type -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Milk Type</label>
                        <select asp-for="MilkTypeId" class="form-select" required>
                            <option value="">Select Type</option>
                            @foreach (var t in Model.MilkTypes)
                            {
                                <option value="@t.Value">@t.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Quantity -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Quantity (Litres)</label>
                        <input asp-for="Quantity" class="form-control"
                               type="number" step="0.01" min="0.01" required />
                    </div>

                    <!-- Fat -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fat %</label>
                        <input asp-for="AppliedFat" class="form-control"
                               type="number" step="0.01" min="0" max="20" required />
                    </div>

                    <!-- CLR -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">CLR</label>
                        <input asp-for="AppliedCLR" class="form-control"
                               type="number" step="0.01" min="0" required />
                    </div>

                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>

                    <button type="submit"
                            class="btn btn-primary"
                            @(hasActiveShift ? "" : "disabled")>
                        Save Entry
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>