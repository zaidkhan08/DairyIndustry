@model DairyIndustry.Models.Collection.MilkCollectionViewModel

@{
    ViewData["Title"] = "New Milk Entry";
    Layout = "_CollectionCenterLayout";

    bool isShiftActive = Model.Shift == "Morning" || Model.Shift == "Evening";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">New Milk Entry</h4>
        <a asp-action="BatchStatus" class="btn btn-outline-secondary btn-sm">
            &larr; Back
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* 🔥 Current Shift Info *@
    <div class="alert @(isShiftActive ? "alert-success" : "alert-danger") d-flex justify-content-between align-items-center">
        <span>
            <strong>Current Shift:</strong> @Model.Shift
            @if (!isShiftActive)
            {
                <span class="ms-2 text-danger">(Entry Closed)</span>
            }
        </span>
        <span class="text-muted small">@DateTime.Now.ToString("hh:mm tt")</span>
    </div>

    @* 🔥 Warning when shift closed *@
    @if (!isShiftActive)
    {
        <div class="alert alert-warning">
            Milk entry is allowed only during:
            <br />
            🕗 Morning: 10:30 AM – 11:00 AM<br />
            🌆 Evening: 04:00 PM – 07:00 PM
        </div>
    }

    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
        <div class="alert alert-danger">@error.ErrorMessage</div>
    }

    <div class="card shadow-sm">
       
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                @* Farmer *@
                <div class="mb-3">
                    <label asp-for="FarmerId" class="form-label fw-semibold">Farmer</label>
                    <select asp-for="FarmerId"
                            asp-items="ViewBag.Farmers"
                            class="form-select"
                            disabled="@(isShiftActive ? null : "disabled")">
                        <option value="">— Select Farmer —</option>
                    </select>
                    <span asp-validation-for="FarmerId" class="text-danger small"></span>
                </div>

                @* Milk Type *@
                <div class="mb-3">
                    <label asp-for="MilkTypeId" class="form-label fw-semibold">Milk Type</label>
                    <select asp-for="MilkTypeId"
                            asp-items="ViewBag.MilkTypes"
                            class="form-select"
                            disabled="@(isShiftActive ? null : "disabled")">
                        <option value="">— Select Milk Type —</option>
                    </select>
                    <span asp-validation-for="MilkTypeId" class="text-danger small"></span>
                </div>

                @* Quantity *@
                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label fw-semibold">Quantity (Litres)</label>
                    <input asp-for="Quantity"
                           type="number"
                           step="0.01"
                           min="0.1"
                           class="form-control"
                           placeholder="e.g. 12.50"
                           disabled="@(isShiftActive ? null : "disabled")" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                @* Fat & CLR *@
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="AppliedFat" class="form-label fw-semibold">Fat (%)</label>
                        <input asp-for="AppliedFat"
                               type="number"
                               step="0.01"
                               class="form-control"
                               placeholder="e.g. 4.20"
                               disabled="@(isShiftActive ? null : "disabled")" />
                        <span asp-validation-for="AppliedFat" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="AppliedCLR" class="form-label fw-semibold">CLR</label>
                        <input asp-for="AppliedCLR"
                               type="number"
                               step="0.01"
                               class="form-control"
                               placeholder="e.g. 28.50"
                               disabled="@(isShiftActive ? null : "disabled")" />
                        <span asp-validation-for="AppliedCLR" class="text-danger small"></span>
                    </div>
                </div>

                @* Hidden fields *@
                <input type="hidden" asp-for="Shift" />
                <input type="hidden" asp-for="CollectionDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />

                <div class="d-flex gap-2 mt-4">
                    <button type="submit"
                            class="btn btn-primary px-4"
                            disabled="@(isShiftActive ? null : "disabled")">
                        Save Entry
                    </button>

                    <a asp-action="BatchStatus" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>


    <hr class="my-4" />

    <h5 class="mb-3">Rate Chart</h5>

    <div style="max-height:300px; overflow-y:auto;">
        <table class="table table-bordered table-sm">
            <thead class="table-dark">
                <tr>
                    <th>Milk Type</th>
                    <th>Fat Range</th>
                    <th>CLR Range</th>
                    <th>Rate (₹)</th>
                    <th>Effective From</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.RateCharts != null)
                {
                    foreach (var item in (List<DairyIndustry.Models.Admin.RateChartModel>)ViewBag.RateCharts)
                    {
                        <tr>
                            <td>@item.MilkTypeName</td>
                            <td>@item.FatFrom - @item.FatTo</td>
                            <td>@item.CLRFrom - @item.CLRTo</td>
                            <td>@item.RatePerLiter</td>
                            <td>@item.EffectiveFrom.ToString("dd-MM-yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>


    <div class="text-muted small mt-3">
        Rate is auto-calculated from the Fat and CLR values. Receipt is auto-generated on save.
        Entry is only allowed during the active shift window.
    </div>

</div>