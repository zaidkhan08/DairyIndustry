@using DairyIndustry.Models.Collection
@model OpenBatchRequest
@{
    ViewData["Title"] = "Open Batch";
    Layout = "_CollectionCenterLayout"; // Using the sidebar layout we created
}

<div class="container mt-4">
    <div class="card shadow p-4" style="max-width: 700px; margin:auto;">

        <h4 class="mb-4 text-center">Open Batch</h4>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Center</label>
                <input asp-for="CenterId" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Shift</label>
                <select asp-for="Shift" class="form-control">
                    <option>Morning</option>
                    <option>Evening</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Batch Date</label>
                <input asp-for="BatchDate" type="date" class="form-control" />
            </div>

            <div class="text-center">
                <button class="btn btn-success px-4">Open Batch</button>
            </div>

        </form>

    </div>
</div>