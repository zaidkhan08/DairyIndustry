@using DairyIndustry.Models.Collection
@model List<CenterInventoryViewModel>

@{
    ViewData["Title"] = "Batch Collections";
    Layout = "_CollectionCenterLayout"; // Using the sidebar layout we created
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4>Center Milk Inventory</h4>
        </div>

        <div class="card-body">
@* 
            <!-- FORM -->
            @using (Html.BeginForm("Inventory", "CollectionCenter", FormMethod.Get))
            {
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Select Center</label>

                        @Html.DropDownList(
                        "centerId",
                                        new SelectList(ViewBag.CenterList, "Value", "Text", ViewBag.SelectedCenter),
                                        new { @class = "form-control" }
                                        )
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        View Inventory
                    </button>
                </div>
            </div>
                        } *@

            <!-- TABLE -->
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Center</th>
                        <th>Milk Type</th>
                        <th>Available (Liters)</th>
                        <th>Last Updated</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CenterName</td>
                                <td>@item.MilkTypeName</td>
                                <td class="fw-bold text-success">
                                    @item.AvailableQuantity
                                </td>
                                <td>
                                    @item.LastUpdated.ToString("dd MMM yyyy hh:mm tt")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No inventory found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>