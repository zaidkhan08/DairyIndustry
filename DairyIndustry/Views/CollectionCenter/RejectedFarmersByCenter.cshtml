@using DairyIndustry.Models.FarmerModel
@model List<CenterRejectedFarmerModel>

@{
    ViewData["Title"] = "Rejected Farmers";
    Layout = "_CollectionCenterLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

<div class="container-fluid px-4 mt-4" style="max-width:1200px;">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-controller="Farmer" asp-action="ListAllFarmers" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    <!-- 🔎 FILTER SECTION -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2">

                <!-- Search -->
                <div class="col-md-4">
                    <input type="text" id="searchBox" class="form-control"
                           placeholder="Search farmer / phone..." />
                </div>

                <!-- Location Filter -->
                <div class="col-md-3">
                    <input type="text" id="locationFilter" class="form-control"
                           placeholder="Filter by city / village..." />
                </div>

                <!-- Bank Filter -->
                <div class="col-md-3">
                    <select id="bankFilter" class="form-select">
                        <option value="">All Bank Status</option>
                        <option value="Added">Bank Added</option>
                        <option value="Pending">Bank Pending</option>
                    </select>
                </div>

                <!-- Reset -->
                <div class="col-md-2">
                    <button class="btn btn-outline-danger w-100" onclick="resetFilters()">
                        Reset
                    </button>
                </div>

            </div>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-check-circle text-success" style="font-size:3rem;"></i>
                <p class="mt-3 text-muted fs-5">No rejected farmers. All clear!</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="farmersTable">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Farmer</th>
                            <th>Phone</th>
                            <th>Location</th>
                            <th>Gender</th>
                            <th>Bank</th>
                            <th>Reason</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int row = 1;
                        }

                        @foreach (var f in Model)
                        {
                            <tr>

                                <td class="fw-semibold text-muted">@row</td>

                                <td class="farmer-col">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(f.ProfilePhoto) ? "/images/user.png" : f.ProfilePhoto)"
                                             width="45" height="45"
                                             class="rounded-circle border me-3"
                                             style="object-fit:cover;" />

                                        <div class="fw-bold">
                                            @f.FarmerName
                                        </div>
                                    </div>
                                </td>

                                <td class="phone-col">@f.Phone</td>

                                <td class="location-col">
                                    <div class="fw-semibold">@f.VillageName</div>
                                    <div class="small text-muted">@f.CityName, @f.StateName</div>
                                </td>

                                <td>@(string.IsNullOrEmpty(f.Gender) ? "-" : f.Gender)</td>

                                <!-- BANK -->
                                <td class="bank-col">
                                    @if (!string.IsNullOrEmpty(f.BankName))
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2">
                                            Added
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-dark px-3 py-2">
                                            Pending
                                        </span>
                                    }
                            </td>

                            <td class="text-danger small fw-semibold">
                                @(string.IsNullOrWhiteSpace(f.ApprovalRemark)
                                                            ? "No reason provided."
                                                            : f.ApprovalRemark)
                        </td>

                                <td>
                                    <span class="badge bg-danger px-3 py-2">Rejected</span>
                                </td>

                            </tr>

                                        row++;
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }
</div>

<!-- 🔥 FILTER SCRIPT -->
<script>
    const searchBox = document.getElementById("searchBox");
    const locationFilter = document.getElementById("locationFilter");
    const bankFilter = document.getElementById("bankFilter");

    const table = document.getElementById("farmersTable");

    function filterTable() {
        const search = searchBox.value.toLowerCase();
        const location = locationFilter.value.toLowerCase();
        const bank = bankFilter.value.toLowerCase();

        const rows = table.getElementsByTagName("tr");

        for (let i = 1; i < rows.length; i++) {
            const row = rows[i];

            const farmer = row.querySelector(".farmer-col")?.innerText.toLowerCase() || "";
            const phone = row.querySelector(".phone-col")?.innerText.toLowerCase() || "";
            const loc = row.querySelector(".location-col")?.innerText.toLowerCase() || "";
            const bankText = row.querySelector(".bank-col")?.innerText.trim().toLowerCase() || "";

            const matchSearch = farmer.includes(search) || phone.includes(search);
            const matchLocation = loc.includes(location);
            const matchBank = bank === "" || bankText.includes(bank);

            if (matchSearch && matchLocation && matchBank) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        }
    }

    searchBox.addEventListener("keyup", filterTable);
    locationFilter.addEventListener("keyup", filterTable);
    bankFilter.addEventListener("change", filterTable);

    function resetFilters() {
        searchBox.value = "";
        locationFilter.value = "";
        bankFilter.value = "";
        filterTable();
    }
</script>