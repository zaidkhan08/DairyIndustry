
@model DairyIndustry.Models.Collection.MilkCollectionModel

@{
    ViewData["Title"] = "Milk Entry";
    Layout = "_CollectionCenterLayout";
    bool isShiftActive = Model.Shift == "Morning" || Model.Shift == "Evening";
}

<div class="container-fluid mt-4" style="max-width:1100px;">

    <!-- ALERTS -->
    @foreach (var key in new[] { "Success", "Error", "RejectionSuccess" })
    {
        if (TempData[key] != null)
        {
            <div class="alert alert-@(key == "Success" ? "success" : key == "Error" ? "danger" : "warning") alert-dismissible fade show shadow-sm">
                @TempData[key]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    }

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Milk Entry</h3>
            <small class="text-muted">Record farmer milk collection</small>
        </div>
        <a asp-action="BatchStatus" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <!-- INFO CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card p-3 shadow-sm border-0">
                <small class="text-muted">Collection Center</small>
                <h5 class="mb-0">@Model.CenterName</h5>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-3 shadow-sm border-0">
                <small class="text-muted">Current Shift</small>
                <h5 class="mb-0">
                    @Model.Shift
                    @if (isShiftActive)
                    {
                        <span class="badge bg-success ms-2">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger ms-2">Closed</span>
                    }
                </h5>
            </div>
        </div>
    </div>

    @if (!isShiftActive)
    {
        <div class="alert alert-warning shadow-sm">
             Morning: 06:20–13:00 | Evening: 16:00–19:00
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold fs-5">
            Farmer Milk Entry
        </div>

        <div class="card-body">
            <form asp-action="AddMilkCollection" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-4">

                    <!-- LEFT SIDE -->
                    <div class="col-md-6">

                        <!-- FARMER -->
                        <div>
                            <label class="form-label fw-semibold">Farmer Code *</label>
                            <select asp-for="FarmerId" class="form-select" id="farmerSelect">
                                <option value="">Select Farmer</option>
                                @foreach (var f in ViewBag.Farmers)
                                {
                                    <option value="@f.FarmerId" data-name="@f.FarmerName">
                                        @f.FarmerCode
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mt-3">
                            <label class="form-label fw-semibold">Farmer Name</label>
                            <input type="text" id="farmerName" class="form-control bg-light" readonly />
                        </div>

                        <!-- MILK TYPE -->
                        <div class="mt-3">
                            <label class="form-label fw-semibold">Milk Type *</label>
                            <select asp-for="MilkTypeId" class="form-select">
                                <option value="">Select Type</option>
                                @foreach (var mt in ViewBag.MilkTypes)
                                {
                                    <option value="@mt.MilkTypeId">@mt.MilkTypeName</option>
                                }
                            </select>
                        </div>

                        <!-- QUANTITY -->
                        <div class="mt-3">
                            <label class="form-label fw-semibold">Quantity (Liters) *</label>
                            <input asp-for="Quantity" type="number" step="0.01" class="form-control" />
                        </div>

                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="col-md-6">

                        <!-- FAT + CLR -->
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label fw-semibold">Fat %</label>
                                <input asp-for="AppliedFat" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold">CLR</label>
                                <input asp-for="AppliedCLR" type="number" step="0.01" class="form-control" />
                            </div>
                        </div>

                        <!-- REJECTION -->
                        <div class="mt-4 p-3 border rounded bg-light">
                            <small class="text-muted">Optional (only for rejection)</small>

                            <div class="mt-2">
                                <label class="form-label fw-semibold">Reason</label>
                                <select name="RejectionReason" class="form-select">
                                    <option value="">Select Reason</option>
                                    <option>Adulterated</option>
                                    <option>Low Quality</option>
                                    <option>Wrong Temperature</option>
                                    <option>Smell / Spoiled</option>
                                    <option>Farmer Refused Rate</option>
                                    <option>Other</option>
                                </select>
                            </div>

                            <div class="mt-2">
                                <label class="form-label fw-semibold">Remarks</label>
                                <textarea name="Remarks" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Shift" />
                <input type="hidden" asp-for="CollectionDate" />
                <input type="hidden" asp-for="CenterName" />

                <!-- BUTTONS -->
                <div class="mt-4 d-flex gap-3">
                    <button type="submit" name="submitAction" value="Accept"
                            class="btn btn-success flex-fill py-2"
                            @(isShiftActive ? "" : "disabled")>
                        <i class="bi bi-check-circle"></i> Accept
                    </button>

                    <button type="submit" name="submitAction" value="Reject"
                            class="btn btn-danger flex-fill py-2"
                            @(isShiftActive ? "" : "disabled")>
                        <i class="bi bi-x-circle"></i> Reject
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('farmerSelect').addEventListener('change', function () {
            var name = this.options[this.selectedIndex].getAttribute('data-name');
            document.getElementById('farmerName').value = name || '';
        });
    </script>
}
