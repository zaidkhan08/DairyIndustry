@model DairyIndustry.Models.Collection.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_CollectionCenterLayout";
    var now = DateTime.Now;

    string shift = "No Active Shift";
    if (now.Hour >= 6 && now.Hour < 10) { shift = "Morning"; }
    else if (now.Hour >= 15 && now.Hour < 19) { shift = "Evening"; }
    else if (now.Hour >= 21 || now.Hour < 1) { shift = "Night"; }
}

<div class="container mt-4">

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4>Dashboard</h4>
            <p class="text-muted mb-0">Welcome, @Model?.StaffName</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            New Milk Entry
        </a>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    else
    {
        <!-- Center Info -->
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card p-2">
                    <strong>Center</strong>
                    <div>@Model.CenterName</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-2">
                    <strong>Center ID</strong>
                    <div>#@Model.CenterId</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-2">
                    <strong>Date</strong>
                    <div>@now.ToString("dd MMM yyyy")</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-2">
                    <strong>Shift</strong>
                    <div>
                        @if (shift == "No Active Shift")
                        {
                            <span class="badge bg-secondary">No Active Shift</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@shift</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card mb-3">
            <div class="card-header">Quick Actions</div>
            <div class="card-body">

                <a asp-action="Create" class="btn btn-primary me-2 mb-2">
                    Record Milk Entry
                </a>

                <a asp-action="BatchStatus" class="btn btn-outline-primary me-2 mb-2">
                    Batch Status
                </a>

                <a asp-action="Inventory" class="btn btn-outline-primary mb-2">
                    Inventory
                </a>

            </div>
        </div>

        <!-- Shift Status -->
        <div class="card">
            <div class="card-header">Today's Shift Status</div>
            <div class="card-body">

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Shift</th>
                            <th>Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>

                        <!-- Morning -->
                        <tr>
                            <td>Morning</td>
                            <td>06:00 - 10:00</td>
                            <td>
                                @if (now.Hour >= 6 && now.Hour < 10)
                                {
                                    <span class="badge bg-success">Open</span>
                                }
                                else if (now.Hour >= 10)
                                {
                                    <span class="badge bg-danger">Closed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Not Started</span>
                                }
                            </td>
                        </tr>

                        <!-- Evening -->
                        <tr>
                            <td>Evening</td>
                            <td>15:00 - 19:00</td>
                            <td>
                                @if (now.Hour >= 15 && now.Hour < 19)
                                {
                                    <span class="badge bg-success">Open</span>
                                }
                                else if (now.Hour >= 19)
                                {
                                    <span class="badge bg-danger">Closed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Not Started</span>
                                }
                            </td>
                        </tr>

                        <!-- Night -->
                        <tr>
                            <td>Night</td>
                            <td>21:00 - 01:00</td>
                            <td>
                                @if (now.Hour >= 21 || now.Hour < 1)
                                {
                                    <span class="badge bg-success">Open</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Closed</span>
                                }
                            </td>
                        </tr>

                    </tbody>
                </table>

            </div>
        </div>
    }
</div>