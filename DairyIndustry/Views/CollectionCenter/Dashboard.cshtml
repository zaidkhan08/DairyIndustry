@model DairyIndustry.Models.Collection.CollectionAgentDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_CollectionCenterLayout";
}

<div class="container-fluid p-3" style="background:#f6f8fb; min-height:100vh;">

    <!-- =========================================================
        1. STAFF HEADER
    ========================================================= -->
    <div class="card border-0 shadow-sm mb-3 p-3" style="border-radius:14px;">

        <div class="d-flex align-items-center gap-3">

            <img src="@Model.StaffCenter.StaffPhoto"
                 style="width:70px;height:70px;object-fit:cover;border-radius:50%;border:3px solid #e9ecef;" />

            <div>
                <h5 class="mb-0 fw-bold">@Model.StaffCenter.StaffName</h5>
                <div class="text-muted small">
                    @Model.StaffCenter.RoleName • @Model.StaffCenter.CenterName
                </div>
                <div class="text-muted small">
                    @Model.StaffCenter.VillageName, @Model.StaffCenter.CityName
                </div>
            </div>

        </div>
    </div>


    <!-- =========================================================
        2. ALERTS (MOST IMPORTANT SECTION)
    ========================================================= -->
    <div class="row g-3 mb-3">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 text-center" style="border-radius:14px;">
                <div class="text-muted small">Pending Approvals</div>
                <h4 class="fw-bold text-warning">
                    @Model.FarmerStats.PendingApprovals
                </h4>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 text-center" style="border-radius:14px;">
                <div class="text-muted small">Pending Payments</div>
                <h4 class="fw-bold text-danger">
                    @Model.FarmerStats.TotalPendingPaymentAmount
                </h4>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 text-center" style="border-radius:14px;">
                <div class="text-muted small">Rejected Farmers</div>
                <h4 class="fw-bold text-dark">
                    @Model.FarmerStats.RejectedFarmers
                </h4>
            </div>
        </div>

    </div>
    <!-- =========================================================
        FARMER OVERVIEW (MATCHES YOUR UI IMAGE)
    ========================================================= -->
    <div class="card border-0 shadow-sm p-3 mb-3" style="border-radius:14px;">

        <h6 class="fw-bold mb-3">Farmer Overview</h6>

        <div class="row g-3">

            <!-- LEFT BIG CARD -->
            <div class="col-md-6">

                <div class="p-3 border rounded h-100 bg-light">

                    <div class="text-muted small">TOTAL FARMERS REGISTERED</div>
                    <h2 class="fw-bold mb-1">@Model.FarmerStats.TotalFarmers</h2>
                    <div class="text-muted small">At this center</div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Active</span>
                        <b class="text-success">@Model.FarmerStats.ActiveFarmers</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Inactive</span>
                        <b class="text-secondary">@Model.FarmerStats.InactiveFarmers</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Pending approval</span>
                        <b class="text-warning">@Model.FarmerStats.PendingApprovals</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Rejected</span>
                        <b class="text-danger">@Model.FarmerStats.RejectedFarmers</b>
                    </div>

                    <hr />

                    @{
                        var activePercent = Model.FarmerStats.TotalFarmers == 0
                        ? 0
                        : (Model.FarmerStats.ActiveFarmers * 100 / Model.FarmerStats.TotalFarmers);
                    }

                    <div class="small text-muted mb-1">
                        Active Farmers
                    </div>

                    <div class="progress" style="height:8px;">
                        <div class="progress-bar bg-success"
                             style="width:@activePercent%"></div>
                    </div>

                    <div class="text-end small text-muted mt-1">
                        @activePercent%
                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE CARDS -->
            <div class="col-md-6">

                <div class="row g-3">

                    <!-- DELIVERED TODAY -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm p-3" style="border-radius:14px;">
                            <div class="text-muted small">DELIVERED TODAY</div>
                            <h3 class="fw-bold text-success mb-0">
                                @Model.FarmerStats.FarmersDeliveredToday
                            </h3>
                            <div class="text-muted small">
                                Out of @Model.FarmerStats.ActiveFarmers active farmers
                            </div>
                        </div>
                    </div>

                    <!-- PENDING APPROVAL -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm p-3" style="border-radius:14px;">
                            <div class="text-muted small">PENDING APPROVAL</div>
                            <h3 class="fw-bold text-warning mb-0">
                                @Model.FarmerStats.PendingApprovals
                            </h3>
                            <div class="text-muted small">
                                Waiting for your review
                            </div>
                        </div>
                    </div>

                    <!-- PAYMENT -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm p-3" style="border-radius:14px;">
                            <div class="text-muted small">FARMERS OWED PAYMENT</div>
                            <h3 class="fw-bold text-primary mb-0">
                                @Model.FarmerStats.FarmersPendingPayment
                            </h3>
                            <div class="text-muted small">
                                Payment not yet processed
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>

    <!-- =========================================================
        3. TODAY SUMMARY (CLEAN KPI)
    ========================================================= -->
    <div class="card border-0 shadow-sm mb-3 p-3" style="border-radius:14px;">

        <h6 class="fw-bold mb-3">Today Summary</h6>

        <div class="row g-3">

            <div class="col-md-3">
                <div class="p-3 rounded bg-light">
                    <div class="text-muted small">Milk Collected</div>
                    <h5 class="fw-bold">@Model.TodaySummary.TotalMilkToday L</h5>
                </div>
            </div>

            <div class="col-md-3">
                <div class="p-3 rounded bg-light">
                    <div class="text-muted small">Amount</div>
                    <h5 class="fw-bold">@Model.TodaySummary.TotalAmountToday</h5>
                </div>
            </div>

            <div class="col-md-3">
                <div class="p-3 rounded bg-light">
                    <div class="text-muted small">Farmers Delivered</div>
                    <h5 class="fw-bold">
                        @Model.FarmerStats.FarmersDeliveredToday / @Model.FarmerStats.TotalFarmers
                    </h5>
                </div>
            </div>

            <div class="col-md-3">
                <div class="p-3 rounded bg-light">
                    <div class="text-muted small">Rejections</div>
                    <h5 class="fw-bold">@Model.TodaySummary.RejectionsToday</h5>
                </div>
            </div>

        </div>
    </div>


    <!-- =========================================================
        4. SHIFT STATUS (SIMPLIFIED)
    ========================================================= -->
    <div class="row g-3 mb-3">

        @foreach (var shift in Model.Shifts)
        {
            <div class="col-md-6">

                <div class="card border-0 shadow-sm p-3" style="border-radius:14px;">

                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold mb-0">@shift.Shift</h6>

                        @if (shift.IsCurrentShift)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>

                    <div class="text-muted small">@shift.ShiftWindow</div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Status</span>
                        <b>@shift.BatchStatus</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Entries</span>
                        <b>@shift.EntryCount</b>
                    </div>

                </div>

            </div>
        }

    </div>


    <!-- =========================================================
        5. INVENTORY (ONLY ALERT - NOT TABLE)
    ========================================================= -->
    <div class="card border-0 shadow-sm p-3" style="border-radius:14px;">

        <h6 class="fw-bold mb-2">Inventory Status</h6>

        @{
            var highUsage = Model.Inventory
            .Where(x => x.CapacityUsedPct >= 85)
            .ToList();
        }

        @if (highUsage.Any())
        {
            foreach (var item in highUsage)
            {
                <div class="alert alert-warning mb-2">
                    @item.MilkTypeName is at @item.CapacityUsedPct% capacity
                </div>
            }
        }
        else
        {
            <div class="text-muted small">
                All inventory levels are normal
            </div>
        }

    </div>

</div>

@* @model DairyIndustry.Models.Collection.StaffDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_CollectionCenterLayout";
}

<div class="container py-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <!-- ================= STAFF PROFILE HEADER ================= -->
    <div class="card border-0 shadow-sm mb-4 overflow-hidden">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-4">
                <div class="position-relative">
                    @if (!string.IsNullOrEmpty(Model.StaffPhoto))
                    {
                        <img src="@Model.StaffPhoto" alt="Photo"
                             class="rounded-circle border border-4 border-light shadow-sm"
                             style="width:80px;height:80px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center border border-4 border-light shadow-sm fw-bold fs-3"
                             style="width:80px;height:80px;">
                            @(Model.StaffName?.Length > 0 ? Model.StaffName[0].ToString().ToUpper() : "?")
                        </div>
                    }
                    <span class="position-absolute bottom-0 end-0 badge rounded-pill bg-success border border-2 border-white p-2">
                        <span class="visually-hidden">Online</span>
                    </span>
                </div>

                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <h4 class="mb-0 fw-bold text-dark">@Model.StaffName</h4>
                        <span class="badge rounded-pill bg-primary-subtle text-primary px-3">
                            @Model.RoleName
                        </span>
                    </div>
                    <div class="text-muted">
                        <i class="bi bi-geo-alt-fill me-1"></i>
                        @Model.CenterName <span class="mx-1 text-secondary">|</span> @Model.VillageName, @Model.CityName
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ================= STATS SUMMARY ================= -->

    <div class="row g-3 mb-4">

        <!-- Milk -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-primary mb-2">
                        <i class="bi bi-droplet-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Milk Collected
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.TotalMilkToday.ToString("F2") L
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-success mb-2">
                        <i class="bi bi-currency-rupee fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Revenue
                    </div>

                    <div class="fs-4 fw-bold text-success">
                        ? @Model.TotalAmountToday.ToString("N2")
                    </div>
                </div>
            </div>
        </div>

        <!-- Entries -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-warning mb-2">
                        <i class="bi bi-clipboard-data-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Total Entries
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.TotalEntriesToday
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Farmers -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-info mb-2">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Total Farmers
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.TotalFarmers
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Farmers -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-success mb-2">
                        <i class="bi bi-person-check-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Active Farmers
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.ActiveFarmers
                    </div>
                </div>
            </div>
        </div>

        <!-- Inactive Farmers -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-danger mb-2">
                        <i class="bi bi-person-x-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Inactive Farmers
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.InactiveFarmers
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-warning mb-2">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Pending Approvals
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.PendingApprovals
                    </div>
                </div>
            </div>
        </div>

        <!-- Rejected -->
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-danger mb-2">
                        <i class="bi bi-x-circle-fill fs-4"></i>
                    </div>

                    <div class="text-muted small">
                        Rejected Approvals
                    </div>

                    <div class="fs-4 fw-bold">
                        @Model.RejectedApprovals
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ================= TANK STATUS (REPLACED PROGRESS BAR) ================= -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0 fw-bold text-uppercase small tracking-wider text-muted">Milk Tank Status</h6>
        </div>
        <div class="card-body pt-0 pb-4">
            <div class="row g-0 text-center">
                <div class="col-4 border-end">
                    <div class="py-2">
                        <div class="text-muted small mb-1">Total Capacity</div>
                        <div class="fw-bold text-dark fs-5">@Model.Capacity.ToString("N0") L</div>
                    </div>
                </div>
                <div class="col-4 border-end">
                    <div class="py-2">
                        <div class="text-muted small mb-1">Current Stock</div>
                        @{
                            var percent = Model.Capacity > 0 ? (Model.CurrentStock / Model.Capacity) * 100 : 0;
                            var statusColor = percent > 85 ? "text-danger" : percent > 60 ? "text-warning" : "text-success";
                        }
                        <div class="fw-bold fs-5 @statusColor">@Model.CurrentStock.ToString("N2") L</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="py-2">
                        <div class="text-muted small mb-1">Space Available</div>
                        <div class="fw-bold text-info fs-5">@Model.AvailableSpace.ToString("N2") L</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= PENDING ACTIONS ================= -->
    @if (Model.PendingPaymentAmount > 0)
    {
        <div class="alert bg-warning-subtle border-warning border-start border-4 shadow-sm d-flex align-items-center p-3">
            <div class="bg-warning rounded-circle p-2 me-3">
                <i class="bi bi-exclamation-circle text-white"></i>
            </div>
            <div class="flex-grow-1">
                <div class="text-warning-emphasis fw-bold">Pending Farmer Payments</div>
                <div class="small text-muted">Action required for pending center payouts.</div>
            </div>
            <div class="text-end">
                <h5 class="mb-0 fw-bold text-dark">? @Model.PendingPaymentAmount.ToString("N2")</h5>
            </div>
        </div>
    }

</div>

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Inter', sans-serif;
    }

    .card {
        border-radius: 12px;
    }

    .bg-primary-subtle {
        background-color: #e7f1ff;
    }

    .text-primary {
        color: #0d6efd !important;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>
 *@