@model List<DairyIndustry.Models.Collection.AllBatchsModel>

@{
    ViewData["Title"] = "All Batch Details";
    // Layout = "_CollectionCenterLayout";
    Layout = "_AdminLayout";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
    body { background: #f5f6f8; }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 14px;
    }
    .summary-card {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 12px;
        padding: 14px;
    }
    .summary-label {
        font-size: 11px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: .4px;
    }
    .summary-value {
        font-size: 18px;
        font-weight: 700;
        margin-top: 4px;
    }
    .text-green  { color: #198754; }
    .text-blue   { color: #185FA5; }
    .text-orange { color: #b58900; }
    .text-red    { color: #a32d2d; }

    .pw-card {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 12px;
        overflow: hidden;
    }
    .pw-card-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 18px;
        border-bottom: 1px solid #f0f0f0;
        flex-wrap: wrap;
        gap: 10px;
    }
    .pw-card-title { font-size: 13px; font-weight: 600; }

    .pw-filters { display: flex; gap: 8px; flex-wrap: wrap; }
    .pw-filters input,
    .pw-filters select {
        padding: 7px 11px;
        font-size: 12px;
        border: 1px solid #e8e8e8;
        border-radius: 7px;
        background: #fafafa;
        outline: none;
    }

    .pw-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .pw-table thead th {
        padding: 10px 14px;
        font-size: 11px;
        text-transform: uppercase;
        background: #fafafa;
        border-bottom: 1px solid #f0f0f0;
        color: #999;
        text-align: left;
    }
    .pw-table tbody tr {
        border-bottom: 1px solid #f5f5f5;
        transition: 0.12s;
    }
    .pw-table tbody tr:hover { background: #fff8f8; }
    .pw-table td { padding: 11px 14px; }

    .shift-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }
    .shift-morning { background: #fff4e5; color: #b26a00; }
    .shift-evening { background: #e7f1ff; color: #185FA5; }

    .status-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }
    .status-open       { background: #e7f1ff; color: #185FA5; }
    .status-closed     { background: #fff4e5; color: #b26a00; }
    .status-dispatched { background: #e6f9f0; color: #198754; }
    .status-cancelled  { background: #fdecea; color: #a32d2d; }

    .pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-top: 1px solid #f0f0f0;
        background: #fff;
    }

    .pagination-info {
        font-size: 13px;
        color: #888;
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .pg-btn {
        width: 32px;
        height: 32px;
        border: 1px solid #e5e5e5;
        background: #fff;
        border-radius: 8px;
        font-size: 13px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #555;
        transition: all 0.15s;
    }

        .pg-btn:hover:not(:disabled) {
            border-color: #185FA5;
            color: #185FA5;
        }

        .pg-btn.active {
            background: #185FA5;
            color: #fff;
            border-color: #185FA5;
            font-weight: 600;
        }

        .pg-btn:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }
</style>

<div class="container-fluid py-3">

    <!-- SUMMARY CARDS -->
    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-label">Total Batches</div>
            <div class="summary-value text-blue">@Model.Count</div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Total Milk</div>
            <div class="summary-value text-green">
                @Model.Sum(x => x.TotalMilkCollected).ToString("F2") L
            </div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Total Amount</div>
            <div class="summary-value text-orange">
                <i class="ti ti-currency-rupee"></i>@Model.Sum(x => x.TotalAmount).ToString("F2")
            </div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Avg FAT</div>
            <div class="summary-value text-red">
                @(Model.Count > 0 ? Model.Average(x => x.AvgFat).ToString("F2") : "0")
            </div>
        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="pw-card">

        <div class="pw-card-head">
            <span class="pw-card-title">Batch Records</span>
            <div class="pw-filters">
                <input type="text" id="searchBox" placeholder="Search batch / center">
                <input type="date" id="dateFilter">
                <select id="shiftFilter">
                    <option value="">All Shift</option>
                    <option value="Morning">Morning</option>
                    <option value="Evening">Evening</option>
                </select>
                <select id="statusFilter">
                    <option value="">All Status</option>
                    <option value="Open">Open</option>
                    <option value="Closed">Closed</option>
                    <option value="Dispatched">Dispatched</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="pw-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Batch ID</th>
                        <th>Date</th>
                        <th>Shift</th>
                        <th>Center</th>
                        <th>Milk Quantity</th>
                        <th>FAT</th>
                        <th>CLR</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        var shiftClass = item.Shift == "Morning"
                        ? "shift-morning" : "shift-evening";

                        var statusClass = item.Status switch
                        {
                            "Open" => "status-open",
                            "Closed" => "status-closed",
                            "Dispatched" => "status-dispatched",
                            "Cancelled" => "status-cancelled",
                            _ => "status-open"
                        };

                        <tr class="data-row"
                            data-search="@item.BatchId @item.CenterName"
                            data-shift="@item.Shift"
                            data-date="@item.BatchDate.ToString("yyyy-MM-dd")"
                            data-status="@item.Status">

                            <td>@i</td>
                            <td>@item.BatchId</td>
                            <td>@item.BatchDate.ToString("dd-MM-yyyy")</td>
                            <td>
                                <span class="shift-badge @shiftClass">@item.Shift</span>
                            </td>
                            <td>@item.CenterName</td>
                            <td>
                                @item.TotalMilkCollected.ToString("F2") L
                            </td>
                            <td>@item.AvgFat</td>
                            <td>@item.AvgCLR</td>
                            <td>
                                <i class="ti ti-currency-rupee"></i>@item.TotalAmount.ToString("F2")
                            </td>
                            <td>
                                <span class="status-badge @statusClass">@item.Status</span>
                            </td>
                            <td>
                                <a asp-action="BatchDetail"  asp-route-id="@item.BatchId"
                                   class="btn btn-sm"
                                   style="font-size:11px; padding:4px 12px; border-radius:20px; border:1px solid #185FA5; color:#185FA5; text-decoration:none;">
                                    <i class="ti ti-eye" style="font-size:12px;"></i> View
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-bar">
            <span class="pagination-info" id="paginationInfo"></span>
            <div class="pagination-controls" id="pagination"></div>
        </div>
    </div>
</div>

<script>
    const rowsPerPage  = 8;
    let currentPage    = 1;

    const rows         = Array.from(document.querySelectorAll(".data-row"));
    const searchBox    = document.getElementById("searchBox");
    const shiftFilter  = document.getElementById("shiftFilter");
    const dateFilter   = document.getElementById("dateFilter");
    const statusFilter = document.getElementById("statusFilter");

    function filterRows() {
        const search = searchBox.value.toLowerCase();
        const shift  = shiftFilter.value;
        const date   = dateFilter.value;
        const status = statusFilter.value;

        return rows.filter(r => {
            const matchSearch = r.dataset.search.toLowerCase().includes(search);
            const matchShift  = !shift  || r.dataset.shift  === shift;
            const matchDate   = !date   || r.dataset.date   === date;
            const matchStatus = !status || r.dataset.status === status;
            return matchSearch && matchShift && matchDate && matchStatus;
        });
    }

    function renderTable() {
        const filtered = filterRows();
        const start    = (currentPage - 1) * rowsPerPage;
        const end      = start + rowsPerPage;
        rows.forEach(r => r.style.display = "none");
        filtered.slice(start, end).forEach(r => r.style.display = "");
        renderPagination(filtered.length);
    }

        function renderPagination(totalRows) {
        const totalPages = Math.ceil(totalRows / rowsPerPage);
        const pagination = document.getElementById("pagination");
        const info = document.getElementById("paginationInfo");

        const start = totalRows === 0 ? 0 : (currentPage - 1) * rowsPerPage + 1;
        const end = Math.min(currentPage * rowsPerPage, totalRows);
        info.textContent = `Showing ${start}–${end} of ${totalRows} entries`;

        pagination.innerHTML = "";

        const prev = document.createElement("button");
        prev.className = "pg-btn";
        prev.innerHTML = `<i class="ti ti-chevron-left"></i>`;
        prev.disabled = currentPage === 1;
        prev.onclick = () => { currentPage--; renderTable(); };
        pagination.appendChild(prev);

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement("button");
            btn.textContent = i;
            btn.className = "pg-btn" + (i === currentPage ? " active" : "");
            btn.onclick = () => { currentPage = i; renderTable(); };
            pagination.appendChild(btn);
        }

        const next = document.createElement("button");
        next.className = "pg-btn";
        next.innerHTML = `<i class="ti ti-chevron-right"></i>`;
        next.disabled = currentPage === totalPages || totalPages === 0;
        next.onclick = () => { currentPage++; renderTable(); };
        pagination.appendChild(next);
    }

    function resetPage() { currentPage = 1; renderTable(); }

    searchBox.addEventListener("input",    resetPage);
    shiftFilter.addEventListener("change", resetPage);
    dateFilter.addEventListener("change",  resetPage);
    statusFilter.addEventListener("change",resetPage);

    renderTable();
</script>