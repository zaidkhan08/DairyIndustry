@model List<DairyIndustry.Models.Collection.DispatchHistoryViewModel>

@{
    ViewData["Title"] = "Dispatch History";
    Layout = "_CollectionCenterLayout";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-gradient text-white rounded-3 shadow-sm d-flex align-items-center justify-content-center"
                 style="width:65px;height:65px;">
                <i class="bi bi-truck fs-3"></i>
            </div>

            <div>
                <h2 class="fw-bold mb-1">Dispatch History</h2>
                <p class="text-muted mb-0">
                    Track all milk transfers dispatched from this collection center
                </p>
            </div>
        </div>

        <a href="@Url.Action("Dispatch")"
           class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-plus-circle me-2"></i>New Dispatch
        </a>

    </div>

    <!-- Alerts -->
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show shadow-sm border-0">
            <i class="bi bi-info-circle-fill me-2"></i>
            @TempData["Info"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-clock-history me-2 text-primary"></i>
                    Dispatch Records
                </h5>

                <span class="badge bg-primary">
                    Total : @Model.Count
                </span>
            </div>
        </div>

        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center py-5">

                    <div class="mb-3">
                        <i class="bi bi-inbox display-1 text-secondary opacity-50"></i>
                    </div>

                    <h4 class="fw-bold text-dark">
                        No Dispatch Records Found
                    </h4>

                    <p class="text-muted mb-4">
                        Close a batch and dispatch milk to a dairy plant.
                    </p>

                    <a href="@Url.Action("Dispatch")"
                       class="btn btn-primary px-4">
                        <i class="bi bi-truck me-2"></i>
                        Create Dispatch
                    </a>

                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr class="text-uppercase small text-muted">

                                <th class="ps-4 py-3">Transfer ID</th>
                                <th class="py-3">Batch Info</th>
                                <th class="py-3">Dispatch Date</th>
                                <th class="py-3">Milk Type</th>
                                <th class="py-3">Logistics</th>
                                <th class="py-3">Destination</th>
                                <th class="py-3">Qty Sent</th>
                                <th class="py-3">Qty Received</th>
                                <th class="py-3">Loss Qty</th>
                                <th class="py-3">Received Date</th>
                                <th class="py-3">Inventory</th>
                                <th class="py-3 pe-4">Status</th>

                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var row in Model)
                            {
                                <tr>

                                    <!-- Transfer ID -->
                                    <td class="ps-4">
                                        <span class="fw-semibold text-primary">
                                            #@row.TransferId
                                        </span>
                                    </td>

                                    <!-- Batch -->
                                    <td>
                                        <div class="fw-semibold text-dark">
                                            @row.BatchDate.ToString("dd MMM yyyy")
                                        </div>

                                        <small class="text-muted">
                                            @row.Shift Shift
                                        </small>
                                    </td>

                                    <!-- Dispatch Date -->
                                    <td class="text-nowrap">
                                        @row.DispatchDate.ToString("dd MMM yyyy")
                                    </td>

                                    <!-- Milk Type -->
                                    <td>
                                        <span class="badge bg-light text-dark border px-3 py-2">
                                            @row.MilkTypeName
                                        </span>
                                    </td>

                                    <!-- Logistics -->
                                    <td>

                                        <div class="fw-semibold text-dark">
                                            <i class="bi bi-truck me-1 text-primary"></i>
                                            @row.VehicleNumber
                                        </div>

                                        <small class="text-muted">
                                            <i class="bi bi-person me-1"></i>
                                            @(string.IsNullOrEmpty(row.DriverName)
                                                                                ? "No Driver"
                                                                                : row.DriverName)
                                </small>

                                    </td>

                                    <!-- Plant -->
                                    <td>
                                        <div class="fw-semibold">
                                            <i class="bi bi-buildings me-1 text-secondary"></i>
                                            @row.PlantName
                                        </div>
                                    </td>

                                    <!-- Sent Qty -->
                                    <td>
                                        <span class="fw-bold text-primary">
                                            @row.DispatchQty.ToString("F2") L
                                        </span>
                                    </td>

                                    <!-- Received Qty -->
                                    <td>

                                @if (row.IsReceived && row.ReceivedQty.HasValue)
                                        {
                                            <span class="fw-bold text-success">
                                                @row.ReceivedQty.Value.ToString("F2") L
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }

                                    </td>

                                    <!-- Loss Qty -->
                                    <td>

                                        @if (row.IsReceived && row.LossQty.HasValue && row.LossQty > 0)
                                        {
                                            <span class="badge bg-danger">
                                                @row.LossQty.Value.ToString("F2") L
                                            </span>
                                        }
                                        else if (row.IsReceived)
                                        {
                                            <span class="badge bg-success">
                                                0.00 L
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }

                                    </td>

                                    <!-- Received Date -->
                                    <td class="text-nowrap">

                                        @if (row.IsReceived && row.ReceivedDate.HasValue)
                                        {
                                            <span class="text-dark">
                                                @row.ReceivedDate.Value.ToString("dd MMM yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Pending
                                            </span>
                                        }

                                    </td>

                                    <!-- Inventory -->
                                    <td>

                                        @if (row.BatchRemainingQty == 0)
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Complete
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">
                                                @row.BatchRemainingQty.ToString("F2") L Left
                                            </span>
                                        }

                                    </td>

                                    <!-- Status -->
                                    <td class="pe-4">

                                        @if (row.IsReceived)
                                        {
                                            <span class="badge rounded-pill bg-success px-3 py-2">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Received
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-info px-3 py-2">
                                                <i class="bi bi-truck me-1"></i>
                                                In Transit
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>