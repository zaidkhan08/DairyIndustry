@model DairyIndustry.Models.FarmerModel.RejectFarmerViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Reject Farmer Registration";
}

<style>
    .rj-wrap {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .rj-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        width: 100%;
        max-width: 460px;
        padding: 32px 28px;
    }

    .rj-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px;
    }

    .rj-subtitle {
        font-size: 13px;
        color: #6b7280;
        margin: 0 0 22px;
    }

    .rj-farmer-box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 22px;
    }

    .rj-farmer-name {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 2px;
    }

    .rj-farmer-phone {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
    }

    .rj-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

        .rj-label span {
            font-size: 11px;
            font-weight: 400;
            color: #9ca3af;
            margin-left: 4px;
        }

    .rj-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
    }

    .rj-chip {
        padding: 4px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 99px;
        font-size: 11px;
        color: #374151;
        background: #f9fafb;
        cursor: pointer;
        transition: all .12s;
    }

        .rj-chip:hover {
            background: #fee2e2;
            border-color: #fca5a5;
            color: #dc2626;
        }

    .rj-textarea {
        width: 100%;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #111827;
        resize: vertical;
        min-height: 100px;
        font-family: system-ui;
        outline: none;
        box-sizing: border-box;
        transition: border-color .15s;
    }

        .rj-textarea:focus {
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220,38,38,.08);
        }

    .rj-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-confirm-reject {
        flex: 1;
        padding: 10px 20px;
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: background .12s;
    }

        .btn-confirm-reject:hover {
            background: #b91c1c;
        }

    .btn-cancel-reject {
        padding: 10px 20px;
        background: #fff;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: background .12s;
        white-space: nowrap;
    }

        .btn-cancel-reject:hover {
            background: #f3f4f6;
            color: #111827;
        }
</style>

<div class="rj-wrap">
    <div class="rj-card">

        <h1 class="rj-title">Reject Registration</h1>
        <p class="rj-subtitle">Provide a reason — this will be shown to the farmer.</p>

        <div class="rj-farmer-box">
            <p class="rj-farmer-name">@Model.FarmerName</p>
            <p class="rj-farmer-phone">@Model.Phone</p>
        </div>

        <form method="post"
              asp-controller="CollectionCenter"
              asp-action="RejectFarmer">
            @Html.AntiForgeryToken()
            <input type="hidden" name="FarmerId" value="@Model.FarmerId" />
            <input type="hidden" name="FarmerName" value="@Model.FarmerName" />
            <input type="hidden" name="Phone" value="@Model.Phone" />

            <label class="rj-label">
                Rejection Reason <span>(required)</span>
            </label>

            <div class="rj-chips">
                <span class="rj-chip" onclick="setReason('Aadhaar card details are not matching')">Aadhaar mismatch</span>
                <span class="rj-chip" onclick="setReason('Documents are not matching')">Documents mismatch</span>
                <span class="rj-chip" onclick="setReason('Duplicate registration detected')">Duplicate registration</span>
                <span class="rj-chip" onclick="setReason('Invalid or incorrect phone number')">Invalid phone</span>
                <span class="rj-chip" onclick="setReason('Bank account details could not be verified')">Bank unverified</span>
            </div>

            <textarea name="ApprovalRemark"
                      id="remarkArea"
                      class="rj-textarea"
                      rows="4"
                      placeholder="e.g. Aadhaar number does not match the submitted document..."
                      required>@Model.ApprovalRemark</textarea>

            <div class="rj-actions">
                <button type="submit" class="btn-confirm-reject">Confirm Rejection</button>
                <a asp-controller="CollectionCenter"
                   asp-action="PendingApprovals"
                   class="btn-cancel-reject">Cancel</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        function setReason(text) {
            document.getElementById('remarkArea').value = text;
            document.getElementById('remarkArea').focus();
        }
    </script>
}