@model DairyIndustry.Models.Collection.MilkCollectionViewModel

@{
    ViewData["Title"] = "Farmers";
    Layout = "_CollectionCenterLayout";
}


<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-dark">Rate Chart</h5>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr class="small text-uppercase">
                    <th class="ps-3">Milk Type</th>
                    <th>Fat Range</th>
                    <th>CLR Range</th>
                    <th>Rate</th>
                    <th>Effective From</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.RateCharts != null)
                {
                    foreach (var item in ViewBag.RateCharts)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-secondary">@item.MilkTypeName</td>
                            <td>
                                <span class="badge rounded-pill bg-light text-dark border fw-normal">
                                    @item.FatFrom - @item.FatTo
                                </span>
                            </td>
                            <td>@item.CLRFrom - @item.CLRTo</td>
                            <td>
                                <span class="fw-bold text-primary">@item.RatePerLiter.ToString("C2")</span>
                            </td>
                            <td class="text-muted small">
                                @item.EffectiveFrom.ToString("dd-MM-yyyy")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No records found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>