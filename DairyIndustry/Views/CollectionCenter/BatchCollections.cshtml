@model List<DairyIndustry.Models.Collection.BatchCollectionView>
@{
    ViewData["Title"] = "Batch Collections";
    Layout = "_CollectionCenterLayout"; // Using the sidebar layout we created
}

<div class="container mt-4">
    <div class="card shadow p-4">

        <h4 class="mb-4 text-center">Batch Collections</h4>

        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-warning text-center">
                No data found
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover text-center">
                <thead class="table-light">
                    <tr>
                        <th>Farmer</th>
                        <th>Quantity</th>
                        <th>Amount</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FarmerName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Amount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>
</div>