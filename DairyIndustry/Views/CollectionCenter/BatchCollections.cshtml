@model List<DairyIndustry.Models.Collection.BatchCollectionView>

@{
    ViewData["Title"] = "Batch Collections";
    Layout = "_CollectionCenterLayout";
    int batchId = ViewBag.BatchId ?? 0;

    var totalQty = Model?.Sum(x => x.Quantity) ?? 0;
    var totalAmount = Model?.Sum(x => x.Amount) ?? 0;
    var avgFat = Model != null && Model.Any() ? Model.Average(x => x.AppliedFat) : 0;
    var avgCLR = Model != null && Model.Any() ? Model.Average(x => x.AppliedCLR) : 0;
}

<div class="container mt-4">

    <!-- Alerts -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4>Batch #@batchId</h4>
            <p class="text-muted mb-0">All milk collection entries</p>
        </div>

        <a asp-action="BatchStatus" class="btn btn-outline-primary">
            Back to Batches
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Summary -->
        <div class="row mb-4">

            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6>Total Quantity</h6>
                        <h5>@totalQty.ToString("F2") L</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6>Total Amount</h6>
                        <h5>₹@totalAmount.ToString("F2")</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6>Avg Fat</h6>
                        <h5>@avgFat.ToString("F2") %</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6>Avg CLR</h6>
                        <h5>@avgCLR.ToString("F2")</h5>
                    </div>
                </div>
            </div>

        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-header">
                Collection Entries (@Model.Count)
            </div>

            <div class="card-body">

                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Shift</th>
                            <th>Farmer</th>
                            <th>Milk Type</th>
                            <th>Qty</th>
                            <th>Fat %</th>
                            <th>CLR</th>
                            <th>Rate</th>
                            <th>Amount</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int i = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@i++</td>
                                <td>#@item.CollectionId</td>
                                <td>@item.CollectionDate.ToString("dd MMM")</td>

                                <td>
                                    @if (item.Shift == "Morning")
                                    {
                                        <span class="badge bg-info text-dark">Morning</span>
                                    }
                                    else if (item.Shift == "Evening")
                                    {
                                        <span class="badge bg-warning text-dark">Evening</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Night</span>
                                    }
                                </td>

                                <td>@item.FarmerName</td>
                                <td>@item.MilkTypeName</td>
                                <td>@item.Quantity.ToString("F2")</td>
                                <td>@item.AppliedFat.ToString("F2")</td>
                                <td>@item.AppliedCLR.ToString("F2")</td>
                                <td>₹@item.RatePerLiter.ToString("F2")</td>
                                <td>₹@item.Amount.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <th colspan="6">Totals</th>
                            <th>@totalQty.ToString("F2")</th>
                            <th>@avgFat.ToString("F2")</th>
                            <th>@avgCLR.ToString("F2")</th>
                            <th></th>
                            <th>₹@totalAmount.ToString("F2")</th>
                        </tr>
                    </tfoot>

                </table>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No entries found for this batch.
        </div>
    }

</div>