@using DairyIndustry.Models.Collection
@model List<DairyIndustry.Models.Collection.AllMilkEntriesModel>

@{
    ViewData["Title"] = "All Milk Entries Page";
    // Layout = "_CollectionCenterLayout";
    Layout = "_AdminLayout";
}

<style>

    .pw-page {
        padding: 24px;
        font-family: inherit;
    }

    /* TOP INFO */
    .pw-topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pw-title {
        font-size: 16px;
        font-weight: 600;
        color: #111;
    }

    .pw-subtitle {
        font-size: 12px;
        color: #888;
        margin-top: 4px;
    }

    /* CARD */
    .pw-card {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 18px;
    }

    .pw-card-head {
        padding: 14px 16px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    /* FILTERS */
    .pw-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

        .pw-filters input,
        .pw-filters select {
            padding: 7px 10px;
            font-size: 12px;
            border: 1px solid #e8e8e8;
            border-radius: 7px;
            background: #fafafa;
            outline: none;
        }

            .pw-filters input:focus,
            .pw-filters select:focus {
                border-color: #2563eb;
                background: #fff;
            }

    /* STATUS */
    .pw-status-bar {
        padding: 12px 16px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .status-pill {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        cursor: pointer;
        user-select: none;
        border: 1px solid transparent;
    }

        .status-pill.active {
            box-shadow: 0 0 0 2px rgba(0,0,0,0.06);
            transform: translateY(-1px);
        }

    /* TABLE */
    .pw-table-wrap {
        overflow-x: auto;
    }

    .pw-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .pw-table thead th {
            background: #fafafa;
            padding: 10px 14px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: #999;
            border-bottom: 1px solid #eee;
            white-space: nowrap;
        }

        .pw-table tbody tr {
            border-bottom: 1px solid #f5f5f5;
        }

            .pw-table tbody tr:hover {
                background: #f9fafb;
            }

        .pw-table td {
            padding: 11px 14px;
            vertical-align: middle;
            color: #222;
        }

    .badge {
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-success {
        background: #EAF3DE;
        color: #2f6b10;
    }

    .badge-danger {
        background: #FCEBEB;
        color: #a32d2d;
    }

    .badge-warning {
        background: #FFF4E5;
        color: #8a5a00;
    }

    .badge-info {
        background: #E6F2FF;
        color: #185FA5;
    }

    /* PAGINATION */
    .pagination-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 14px;
        font-size: 12px;
        color: #666;
        flex-wrap: wrap;
        gap: 10px;
    }

    .page-btn {
        padding: 5px 10px;
        border: 1px solid #ddd;
        background: #fff;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
    }

        .page-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

</style>

<div class="pw-page">

    <!-- TOP -->
    <div class="pw-topbar">
        <div>
            <div class="pw-title">Milk Entries</div>
            <div class="pw-subtitle">Collection Center › All Records</div>
        </div>
    </div>

    <!-- FILTER CARD -->
    <div class="pw-card">

        <div class="pw-card-head">
            <div class="pw-filters">
                <input type="text" id="searchInput" placeholder="Search farmer / code..." />
                <select id="shiftFilter">
                    <option value="all">All Shifts</option>
                    <option value="Morning">Morning</option>
                    <option value="Evening">Evening</option>
                </select>
                <input type="date" id="dateFilter" />
                <button id="resetFilters" class="btn btn-light">Reset</button>
            </div>
        </div>

        <!-- STATUS -->
        <div class="pw-status-bar">
            <span class="status-pill bg-dark text-white filter-btn active" data-status="all">All</span>
            <span class="status-pill bg-success text-white filter-btn" data-status="Accepted">Accepted</span>
            <span class="status-pill bg-danger text-white filter-btn" data-status="Rejected">Rejected</span>
        </div>

    </div>

    <!-- TABLE -->
    <div class="pw-card">

        <div class="pw-table-wrap">
            <table class="pw-table">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Farmer Name</th>
                        <th>Farmer Code</th>
                        <th>Collection Date</th>
                        <th>Shift</th>
                        <th>MilkType</th>
                        <th>Qty</th>
                        <th>Fat</th>
                        <th>CLR</th>
                        <th>Rate</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Reason</th>
                        <th>Remarks</th>
                        <th>Receipt</th>
                        <th>Download</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        var shiftClass = item.Shift == "Morning" ? "badge-warning" : "badge-info";
                        var statusClass = item.Status == "Accepted" ? "badge-success" : "badge-danger";
                        

                        <tr data-status="@item.Status"
                            data-shift="@item.Shift"
                            data-date="@item.CollectionDate.ToString("yyyy-MM-dd")">

                            <td class="row-no"></td>

                            <td class="farmer-name ">@item.FarmerName</td>
                            <td class="farmer-code">@item.FarmerCode</td>

                            <td>@item.CollectionDate.ToString("dd-MM-yyyy")</td>

                            <td><span class="badge @shiftClass">@item.Shift</span></td>
                            <td>
                                <span class="badge @(item.MilkType == "Cow" ? "badge-info" : "badge-warning")">
                                    @item.MilkType
                                </span>
                            </td>

                            <td>@item.Quantity</td>
                            <td>@item.AppliedFat</td>
                            <td>@item.AppliedCLR</td>

                            <td>
                                @(item.Status == "Accepted" ? $"{item.RatePerLiter}" : "-")
                            </td>

                            <td>
                                @(item.Status == "Accepted" ? $"{item.Amount}" : "-")
                            </td>

                            <td><span class="badge @statusClass">@item.Status</span></td>

                            <td>@(string.IsNullOrEmpty(item.RejectionReason) ? "-" : item.RejectionReason)</td>

                            <td>@(string.IsNullOrEmpty(item.Remarks) ? "-" : item.Remarks)</td>

                            <td>
                                @if (item.Status == "Accepted")
                                {
                                    <a asp-action="MilkReceipt" asp-route-id="@item.CollectionId">View</a>
                                }
                                else
                                {

                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @if (item.Status == "Accepted")
                                {
                                    <a asp-action="DownloadReceipt" asp-route-id="@item.CollectionId">PDF</a>
                                }
                                else
                                {

                                    <span>-</span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination-wrap">

            <div>
                Showing <span id="showFrom">0</span> to
                <span id="showTo">0</span> of
                <span id="totalCount">@Model.Count</span> entries
            </div>

            <div id="pagination"></div>

        </div>

    </div>
</div>

<script>

    const rows = Array.from(document.querySelectorAll("tbody tr"));
    const buttons = document.querySelectorAll(".filter-btn");

    const searchInput = document.getElementById("searchInput");
    const shiftFilter = document.getElementById("shiftFilter");
    const dateFilter = document.getElementById("dateFilter");
    const resetBtn = document.getElementById("resetFilters");

    const pagination = document.getElementById("pagination");
    const showFrom = document.getElementById("showFrom");
    const showTo = document.getElementById("showTo");
    const totalCount = document.getElementById("totalCount");

    let currentStatus = "all";
    let currentPage = 1;
    const pageSize = 10;

    function getFilteredRows() {

        const search = searchInput.value.toLowerCase();
        const shift = shiftFilter.value;
        const date = dateFilter.value;

        return rows.filter(row => {

            const name = row.querySelector(".farmer-name")?.innerText.toLowerCase() || "";
            const code = row.querySelector(".farmer-code")?.innerText.toLowerCase() || "";

            const rowStatus = row.dataset.status;
            const rowShift = row.dataset.shift;
            const rowDate = row.dataset.date;

            let ok = true;

            if (currentStatus !== "all" && rowStatus !== currentStatus) ok = false;
            if (!name.includes(search) && !code.includes(search)) ok = false;
            if (shift !== "all" && rowShift !== shift) ok = false;
            if (date && rowDate !== date) ok = false;

            return ok;
        });
    }

    function renderTable() {

        const filtered = getFilteredRows();
        const total = filtered.length;

        const pages = Math.ceil(total / pageSize);
        if (currentPage > pages) currentPage = 1;

        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;

        rows.forEach(r => r.style.display = "none");

        const pageRows = filtered.slice(start, end);

        pageRows.forEach((row, i) => {
            row.style.display = "";
            row.querySelector(".row-no").innerText = start + i + 1;
        });

        showFrom.innerText = total ? start + 1 : 0;
        showTo.innerText = Math.min(end, total);
        totalCount.innerText = total;

        renderPagination(pages);
    }

    function renderPagination(pages) {

        pagination.innerHTML = "";

        if (pages <= 1) return;

        for (let i = 1; i <= pages; i++) {

            const btn = document.createElement("button");
            btn.className = "page-btn";
            btn.innerText = i;

            if (i === currentPage) btn.classList.add("active");

            btn.onclick = () => {
                currentPage = i;
                renderTable();
            };

            pagination.appendChild(btn);
        }
    }

    // EVENTS
    buttons.forEach(b => {
        b.addEventListener("click", function () {
            buttons.forEach(x => x.classList.remove("active"));
            this.classList.add("active");
            currentStatus = this.dataset.status;
            currentPage = 1;
            renderTable();
        });
    });

    searchInput.addEventListener("keyup", () => { currentPage = 1; renderTable(); });
    shiftFilter.addEventListener("change", () => { currentPage = 1; renderTable(); });
    dateFilter.addEventListener("change", () => { currentPage = 1; renderTable(); });

    resetBtn.addEventListener("click", () => {
        searchInput.value = "";
        shiftFilter.value = "all";
        dateFilter.value = "";
        currentStatus = "all";
        currentPage = 1;

        buttons.forEach(b => b.classList.remove("active"));
        document.querySelector('[data-status="all"]').classList.add("active");

        renderTable();
    });

    renderTable();

</script>