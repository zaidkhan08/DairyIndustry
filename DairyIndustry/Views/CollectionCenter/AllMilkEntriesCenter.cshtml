@using DairyIndustry.Models.Collection
@model List<DairyIndustry.Models.Collection.AllMilkEntriesModel>

@{
    ViewData["Title"] = "All Milk Entries Page";
    // Layout = "_CollectionCenterLayout";
    Layout = "_AdminLayout";
}

<style>

    .pw-page {
        padding: 24px;
        font-family: inherit;
    }

    /* TOP INFO */
    .pw-topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pw-title {
        font-size: 16px;
        font-weight: 600;
        color: #111;
    }

    .pw-subtitle {
        font-size: 12px;
        color: #888;
        margin-top: 4px;
    }

    /* CARD */
    .pw-card {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 18px;
    }

    .pw-card-head {
        padding: 14px 16px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    /* FILTERS */
    .pw-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

        .pw-filters input,
        .pw-filters select {
            padding: 7px 10px;
            font-size: 12px;
            border: 1px solid #e8e8e8;
            border-radius: 7px;
            background: #fafafa;
            outline: none;
        }

            .pw-filters input:focus,
            .pw-filters select:focus {
                border-color: #2563eb;
                background: #fff;
            }

    /* STATUS */
    .pw-status-bar {
        padding: 12px 16px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .status-pill {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        cursor: pointer;
        user-select: none;
        border: 1px solid transparent;
    }

        .status-pill.active {
            box-shadow: 0 0 0 2px rgba(0,0,0,0.06);
            transform: translateY(-1px);
        }

    /* TABLE */
    .pw-table-wrap {
        overflow-x: auto;
    }

    .pw-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .pw-table thead th {
            background: #fafafa;
            padding: 10px 14px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: #999;
            border-bottom: 1px solid #eee;
            white-space: nowrap;
        }

        .pw-table tbody tr {
            border-bottom: 1px solid #f5f5f5;
        }

            .pw-table tbody tr:hover {
                background: #f9fafb;
            }

        .pw-table td {
            padding: 11px 14px;
            vertical-align: middle;
            color: #222;
        }

    .badge {
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-success {
        background: #EAF3DE;
        color: #2f6b10;
    }

    .badge-danger {
        background: #FCEBEB;
        color: #a32d2d;
    }

    .badge-warning {
        background: #FFF4E5;
        color: #8a5a00;
    }

    .badge-info {
        background: #E6F2FF;
        color: #185FA5;
    }

    /* PAGINATION */
    /* PAGINATION */
    .pagination-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        font-size: 12.5px;
        color: #6c757d;
        border-top: 1px solid #e9ecef;
        flex-wrap: wrap;
        gap: 8px;
    }

    .page-btns {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .pg-btn {
        min-width: 30px;
        height: 30px;
        padding: 0 6px;
        border-radius: 6px;
        border: 1px solid #dee2e6;
        background: #fff;
        font-size: 12.5px;
        color: #495057;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background .12s;
    }

        .pg-btn:hover {
            background: #f8f9fa;
        }

        .pg-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

        .pg-btn.disabled {
            opacity: .4;
            pointer-events: none;
            cursor: default;
        }
    

        .page-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

</style>

<div class="pw-page">

    <!-- TOP -->
    <div class="pw-topbar">
        <div>
            <div class="pw-title">Milk Entries</div>
            <div class="pw-subtitle">Collection Center › All Records</div>
        </div>
    </div>

    <!-- FILTER CARD -->
    <div class="pw-card">

        <div class="pw-card-head">
            <div class="pw-filters">
                <input type="text" id="searchInput" placeholder="Search farmer / code..." />
                <select id="shiftFilter">
                    <option value="all">All Shifts</option>
                    <option value="Morning">Morning</option>
                    <option value="Evening">Evening</option>
                </select>
                <input type="date" id="dateFilter" />
                <button id="resetFilters" class="btn btn-light">Reset</button>
            </div>
        </div>

        <!-- STATUS -->
        <div class="pw-status-bar">
            <span class="status-pill bg-dark text-white filter-btn active" data-status="all">All</span>
            <span class="status-pill bg-success text-white filter-btn" data-status="Accepted">Accepted</span>
            <span class="status-pill bg-danger text-white filter-btn" data-status="Rejected">Rejected</span>
        </div>

    </div>

    <!-- TABLE -->
    <div class="pw-card">

        <div class="pw-table-wrap">
            <table class="pw-table">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Farmer Name</th>
                        <th>Farmer Code</th>
                        <th>Collection Date</th>
                        <th>Shift</th>
                        <th>MilkType</th>
                        <th>Qty</th>
                        <th>Fat</th>
                        <th>CLR</th>
                        <th>Rate</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Reason</th>
                        <th>Remarks</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        var shiftClass = item.Shift == "Morning" ? "badge-warning" : "badge-info";
                        var statusClass = item.Status == "Accepted" ? "badge-success" : "badge-danger";
                        

                        <tr data-status="@item.Status"
                            data-shift="@item.Shift"
                            data-date="@item.CollectionDate.ToString("yyyy-MM-dd")">

                            <td class="row-no"></td>

                            <td class="farmer-name ">@item.FarmerName</td>
                            <td class="farmer-code">@item.FarmerCode</td>

                            <td>@item.CollectionDate.ToString("dd-MM-yyyy")</td>

                            <td><span class="badge @shiftClass">@item.Shift</span></td>
                            <td>
                                <span class="badge @(item.MilkType == "Cow" ? "badge-info" : "badge-warning")">
                                    @item.MilkType
                                </span>
                            </td>

                            <td>@item.Quantity</td>
                            <td>@item.AppliedFat</td>
                            <td>@item.AppliedCLR</td>

                            <td>
                                @(item.Status == "Accepted" ? $"{item.RatePerLiter}" : "-")
                            </td>

                            <td>
                                @(item.Status == "Accepted" ? $"{item.Amount}" : "-")
                            </td>

                            <td><span class="badge @statusClass">@item.Status</span></td>

                            <td>@(string.IsNullOrEmpty(item.RejectionReason) ? "-" : item.RejectionReason)</td>

                            <td>@(string.IsNullOrEmpty(item.Remarks) ? "-" : item.Remarks)</td>

                            <td>
                                @if (item.Status == "Accepted")
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light px-2 py-1"
                                                type="button"
                                                data-bs-toggle="dropdown">
                                            ⋯
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:13px; min-width:150px;">
                                            <li>
                                                <a class="dropdown-item" asp-action="MilkReceipt" asp-route-id="@item.CollectionId" target="_blank">
                                                    View Receipt
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-action="DownloadReceipt" asp-route-id="@item.CollectionId">
                                                    Download PDF
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        </div>

        <!-- PAGINATION -->
        <!-- PAGINATION -->
        <div class="pagination-wrap">
            <span id="paginationInfo">Showing 0–0 of 0 entries</span>
            <div class="page-btns" id="paginationBtns"></div>
        </div>

    </div>
</div>
<script>
    const rows = Array.from(document.querySelectorAll("tbody tr"));
    const filterBtns = document.querySelectorAll(".filter-btn");

    const searchInput  = document.getElementById("searchInput");
    const shiftFilter  = document.getElementById("shiftFilter");
    const dateFilter   = document.getElementById("dateFilter");
    const resetBtn     = document.getElementById("resetFilters");
    const paginationInfo = document.getElementById("paginationInfo");
    const paginationBtns = document.getElementById("paginationBtns");

    let currentStatus = "all";
    let currentPage   = 1;
    const PAGE_SIZE   = 10;

    function getFilteredRows() {
        const search = searchInput.value.toLowerCase();
        const shift  = shiftFilter.value;
        const date   = dateFilter.value;

        return rows.filter(row => {
            const name    = row.querySelector(".farmer-name")?.innerText.toLowerCase() || "";
            const code    = row.querySelector(".farmer-code")?.innerText.toLowerCase() || "";
            const rowStatus = row.dataset.status;
            const rowShift  = row.dataset.shift;
            const rowDate   = row.dataset.date;

            if (currentStatus !== "all" && rowStatus !== currentStatus) return false;
            if (!name.includes(search) && !code.includes(search))       return false;
            if (shift !== "all" && rowShift !== shift)                   return false;
            if (date && rowDate !== date)                                 return false;
            return true;
        });
    }

    function renderTable() {
        const filtered   = getFilteredRows();
        const total      = filtered.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage      = Math.min(currentPage, totalPages);

        const start = (currentPage - 1) * PAGE_SIZE;
        const end   = Math.min(start + PAGE_SIZE, total);

        rows.forEach(r => r.style.display = "none");
        filtered.slice(start, end).forEach((row, i) => {
            row.style.display = "";
            row.querySelector(".row-no").innerText = start + i + 1;
        });

        const from = total === 0 ? 0 : start + 1;
        paginationInfo.textContent =
            `Showing ${from}–${end} of ${total} entr${total !== 1 ? "ies" : "y"}`;

        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        paginationBtns.innerHTML = "";

        function addBtn(label, page, cls) {
            const el = document.createElement("button");
            el.className = "pg-btn" + (cls ? " " + cls : "");
            el.innerHTML = label;
            if (cls !== "disabled") {
                el.onclick = () => { currentPage = page; renderTable(); };
            }
            paginationBtns.appendChild(el);
        }

        addBtn('<i class="bi bi-chevron-left" style="font-size:11px"></i>',
            currentPage - 1, currentPage === 1 ? "disabled" : "");

        buildPageList(currentPage, totalPages).forEach(p => {
            if (p === "…") {
                const el = document.createElement("span");
                el.className = "pg-btn disabled";
                el.textContent = "…";
                paginationBtns.appendChild(el);
            } else {
                addBtn(p, p, p === currentPage ? "active" : "");
            }
        });

        addBtn('<i class="bi bi-chevron-right" style="font-size:11px"></i>',
            currentPage + 1, currentPage === totalPages ? "disabled" : "");
    }

    function buildPageList(cur, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages = [];
        if (cur <= 4) {
            for (let i = 1; i <= 5; i++) pages.push(i);
            pages.push("…"); pages.push(total);
        } else if (cur >= total - 3) {
            pages.push(1); pages.push("…");
            for (let i = total - 4; i <= total; i++) pages.push(i);
        } else {
            pages.push(1); pages.push("…");
            pages.push(cur - 1); pages.push(cur); pages.push(cur + 1);
            pages.push("…"); pages.push(total);
        }
        return pages;
    }

    // ── Events ──
    filterBtns.forEach(b => {
        b.addEventListener("click", function () {
            filterBtns.forEach(x => x.classList.remove("active"));
            this.classList.add("active");
            currentStatus = this.dataset.status;
            currentPage = 1;
            renderTable();
        });
    });

    searchInput.addEventListener("input",  () => { currentPage = 1; renderTable(); });
    shiftFilter.addEventListener("change", () => { currentPage = 1; renderTable(); });
    dateFilter.addEventListener("change",  () => { currentPage = 1; renderTable(); });

    resetBtn.addEventListener("click", () => {
        searchInput.value = "";
        shiftFilter.value = "all";
        dateFilter.value  = "";
        currentStatus     = "all";
        currentPage       = 1;
        filterBtns.forEach(b => b.classList.remove("active"));
        document.querySelector('[data-status="all"]').classList.add("active");
        renderTable();
    });

    renderTable();
</script>